        "downloaded_at": "",
    }
    data["updated"] = now_iso()
    write_json_atomic(PROFILE_DELIVERY_FILE, data)
    return {
        "token": token,
        "delivery_id": delivery_id,
        "token_hint": token[:8],
        "ip": ip,
        "client": name,
        "adapter": adapter,
        "mode": mode,
