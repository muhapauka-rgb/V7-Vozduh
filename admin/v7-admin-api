    </div></section>

    <section id="tab-identity" class="tab-page"><div class="module-page">
      <div class="stat-grid span-12" id="identityStats"></div>
      <div class="workspace-tabs">
        <button class="workspace-tab active" data-identity-nav="overview" onclick="showIdentityWorkspace('overview')">Обзор</button>
        <button class="workspace-tab" data-identity-nav="issue" onclick="showIssueProfilePanel('identity')">Выдать профиль</button>
        <button class="workspace-tab" data-identity-nav="people" onclick="showIdentityWorkspace('people')">Люди и телефоны</button>
        <button class="workspace-tab" data-identity-nav="access" onclick="showIdentityWorkspace('access')">Доступ</button>
        <button class="workspace-tab" data-identity-nav="lifecycle" onclick="showIdentityWorkspace('lifecycle')">Жизненный цикл</button>
      </div>
      <article class="panel span-12 workspace-panel active" data-identity-workspace="overview"><div class="toolbar"><div><h2>Доступ</h2></div><div class="toolbar-actions"><button class="ghost" onclick="showLogsPreset('identity')">Логи</button><button class="ghost" onclick="showIdentityWorkspace('access')">Телефоны</button><button class="primary" onclick="showIssueProfilePanel('identity')">Добавить телефон</button></div></div><div class="cards-grid" id="identityProfileFlow"></div></article>
