def identity_id(prefix):
    return f"{prefix}_{secrets.token_hex(8)}"


def clean_identity_text(value, max_len=160):
    value = str(value or "").strip()
    value = re.sub(r"[\x00-\x1f\x7f]", " ", value)
    value = re.sub(r"\s+", " ", value).strip()
    return value[:max_len]


def normalize_phone(value):
    digits = re.sub(r"\D+", "", str(value or ""))
    if len(digits) == 10:
        digits = "7" + digits
    elif len(digits) == 11 and digits.startswith("8"):
        digits = "7" + digits[1:]
    if not re.match(r"^[0-9]{10,15}$", digits):
        return ""
    return digits


def safe_identity_id(value):
    value = str(value or "").strip()
    return value if SAFE_IDENTITY_ID_RE.match(value) else ""


def identity_conn():
    IDENTITY_DB_FILE.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(IDENTITY_DB_FILE))
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    conn.execute("PRAGMA journal_mode = WAL")
    return conn


def identity_init_db():
    now = now_iso()
    with identity_conn() as conn:
        conn.executescript(IDENTITY_SCHEMA)
        conn.execute(
            """
            INSERT OR IGNORE INTO access_settings
              (id, current_password_hash, password_updated_at, default_max_devices, created_at, updated_at)
            VALUES (1, '', '', 3, ?, ?)
            """,
            (now, now),
        )
        conn.commit()
    try:
        os.chmod(IDENTITY_DB_FILE, 0o600)
    except OSError:
        pass
    return identity_state()


def identity_rows(conn, sql, params=()):
    return [dict(row) for row in conn.execute(sql, params).fetchall()]


def identity_enriched_users(conn):
    rows = identity_rows(conn, "SELECT * FROM identity_users ORDER BY updated_at DESC LIMIT 200")
    for row in rows:
        row["active_devices"] = int(conn.execute(
            "SELECT count(*) FROM devices WHERE user_id=? AND status='active'",
            (row["id"],),
        ).fetchone()[0])
        org = conn.execute("SELECT name FROM organizations WHERE id=?", (row.get("organization_id", ""),)).fetchone()
        group = conn.execute("SELECT name FROM groups WHERE id=?", (row.get("group_id", ""),)).fetchone()
        row["organization_name"] = org["name"] if org else ""
        row["group_name"] = group["name"] if group else ""
    return rows


def identity_enriched_devices(conn):
    rows = identity_rows(conn, "SELECT * FROM devices ORDER BY updated_at DESC LIMIT 200")
    for row in rows:
        user = conn.execute(
            "SELECT display_name, phone_normalized, max_devices FROM identity_users WHERE id=?",
            (row.get("user_id", ""),),
        ).fetchone()
        if user:
            row["user_display_name"] = user["display_name"]
            row["phone_normalized"] = user["phone_normalized"]
            row["user_max_devices"] = user["max_devices"]
    return rows


def identity_state():
    if not IDENTITY_DB_FILE.exists():
        return {
            "configured": False,
            "db_path": str(IDENTITY_DB_FILE),
            "summary": {},
            "groups": [],
            "organizations": [],
            "allowed_users": [],
            "users": [],
            "devices": [],
            "onboarding_attempts": [],
            "access_settings": {"connection_password_configured": False, "default_max_devices": 3},
        }
    with identity_conn() as conn:
        conn.executescript(IDENTITY_SCHEMA)
        access = conn.execute("SELECT * FROM access_settings WHERE id=1").fetchone()
        if not access:
            now = now_iso()
            conn.execute(
                """
                INSERT OR IGNORE INTO access_settings
                  (id, current_password_hash, password_updated_at, default_max_devices, created_at, updated_at)
                VALUES (1, '', '', 3, ?, ?)
                """,
                (now, now),
            )
            conn.commit()
            access = conn.execute("SELECT * FROM access_settings WHERE id=1").fetchone()
        allowed = identity_rows(conn, "SELECT * FROM allowed_users ORDER BY updated_at DESC LIMIT 200")
        users = identity_enriched_users(conn)
        devices = identity_enriched_devices(conn)
        groups = identity_rows(conn, "SELECT * FROM groups ORDER BY name LIMIT 200")
        orgs = identity_rows(conn, "SELECT * FROM organizations ORDER BY name LIMIT 200")
        attempts = identity_rows(conn, "SELECT * FROM onboarding_attempts ORDER BY created_at DESC LIMIT 100")
        summary = {
