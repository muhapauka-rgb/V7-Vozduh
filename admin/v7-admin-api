def clamp_int(value, default, min_value, max_value):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        parsed = default
    return max(min_value, min(max_value, parsed))


def clamp_float(value, default, min_value, max_value):
    try:
        parsed = float(value)
    except (TypeError, ValueError):
        parsed = default
    return max(min_value, min(max_value, parsed))


def update_policy(actor, patch):
    before = policy_state()
    policy = deep_merge_defaults(before, DEFAULT_POLICY)
    incoming = patch if isinstance(patch, dict) else {}

    switch = incoming.get("switch") or {}
    quality = incoming.get("quality") or {}
    load = incoming.get("load") or {}
    intervals = incoming.get("intervals") or {}

    policy["switch"]["cooldown_seconds"] = clamp_int(switch.get("cooldown_seconds", policy["switch"]["cooldown_seconds"]), 180, 180, 86400)
    policy["switch"]["autoswitch_max_planned_per_run"] = clamp_int(switch.get("autoswitch_max_planned_per_run", policy["switch"]["autoswitch_max_planned_per_run"]), 1, 1, 50)
    policy["switch"]["autoswitch_max_failover_per_run"] = clamp_int(switch.get("autoswitch_max_failover_per_run", policy["switch"]["autoswitch_max_failover_per_run"]), 25, 1, 500)
    policy["quality"]["min_avg_mbps"] = clamp_float(quality.get("min_avg_mbps", policy["quality"]["min_avg_mbps"]), 15.0, 0.1, 10000.0)
    policy["quality"]["min_floor_mbps"] = clamp_float(quality.get("min_floor_mbps", policy["quality"]["min_floor_mbps"]), 10.0, 0.1, 10000.0)
    policy["quality"]["min_stability"] = clamp_float(quality.get("min_stability", policy["quality"]["min_stability"]), 0.45, 0.0, 1.0)
    policy["load"]["soft_limit"] = clamp_int(load.get("soft_limit", policy["load"]["soft_limit"]), 1, 1, 100000)
    policy["load"]["hard_limit"] = clamp_int(load.get("hard_limit", policy["load"]["hard_limit"]), 2, 1, 100000)
    if policy["load"]["hard_limit"] < policy["load"]["soft_limit"]:
        policy["load"]["hard_limit"] = policy["load"]["soft_limit"]
    policy["load"]["rebalance_max_moves_per_run"] = clamp_int(load.get("rebalance_max_moves_per_run", policy["load"]["rebalance_max_moves_per_run"]), 1, 1, 1000)
    policy["intervals"]["health_seconds"] = clamp_int(intervals.get("health_seconds", policy["intervals"]["health_seconds"]), 30, 10, 3600)
    policy["intervals"]["benchmark_seconds"] = clamp_int(intervals.get("benchmark_seconds", policy["intervals"]["benchmark_seconds"]), 300, 60, 86400)
    policy["schema_version"] = 1
    policy["updated"] = now_iso()
    policy["updated_by"] = actor or "admin"

    POLICY_FILE.parent.mkdir(parents=True, exist_ok=True)
    backup = None
    if POLICY_FILE.exists():
        backup = POLICY_FILE.with_name(f"{POLICY_FILE.name}.backup.v7-policy.{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}")
        backup.write_text(POLICY_FILE.read_text(encoding="utf-8", errors="replace"), encoding="utf-8")
        os.chmod(backup, 0o600)
    write_json_atomic(POLICY_FILE, policy)
    os.chmod(POLICY_FILE, 0o600)
    return redact({"before": before, "policy": policy, "backup": str(backup) if backup else None})


def service_recommendations(active_users, matrix_data, prefs):
    items = matrix_data.get("items") or {}
    enabled = bool(prefs.get("enabled"))
    user_prefs = prefs.get("users") or {}
    service_ids = sorted({
        service_id
        for egress_item in items.values()
        for service_id in ((egress_item.get("services") or {}).keys())
    })
    best_by_service = {}
    for service_id in service_ids:
        candidates = []
        for egress_id, egress_item in items.items():
            row = (egress_item.get("services") or {}).get(service_id)
            if not row:
                continue
            candidates.append({
                "egress": egress_id,
                "ok": bool(row.get("ok")),
                "severity": row.get("severity"),
                "http_code": row.get("http_code"),
                "first_byte_sec": row.get("first_byte_sec"),
                "total_sec": row.get("total_sec"),
                "reason": row.get("reason"),
                "tested_at": row.get("tested_at"),
            })
        candidates.sort(key=lambda c: (
            0 if c["ok"] else 1,
            float(c.get("first_byte_sec") or 999),
            float(c.get("total_sec") or 999),
            c["egress"],
        ))
        best = candidates[0] if candidates else None
        best_by_service[service_id] = {
            "service": service_id,
            "best_egress": best.get("egress") if best else None,
            "status": "OK" if best and best.get("ok") else "NO_GOOD_EGRESS",
            "candidates": candidates,
        }

    user_warnings = []
    for user in active_users:
        ip = user.get("ip", "")
        current = user.get("current", "")
        important = normalize_services((user_prefs.get(ip) or {}).get("services") or [])
        if not enabled or not important:
            continue
        current_services = ((items.get(current) or {}).get("services") or {})
        for service_id, recommendation in best_by_service.items():
            if service_id not in important:
                continue
            current_row = current_services.get(service_id)
            best = recommendation.get("best_egress")
            current_ok = bool(current_row and current_row.get("ok"))
            if best and best != current and not current_ok:
                best_candidate = next((c for c in recommendation.get("candidates", []) if c.get("egress") == best), {})
                user_warnings.append({
                    "ip": ip,
                    "current_egress": current,
                    "service": service_id,
                    "current_status": "FAIL" if current_row else "UNKNOWN",
                    "current_reason": (current_row or {}).get("reason"),
                    "recommended_egress": best,
                    "recommended_first_byte_sec": best_candidate.get("first_byte_sec"),
                    "action": "manual_switch_available",
                })
    return {"enabled": enabled, "known_services": list(KNOWN_SERVICES), "user_preferences": user_prefs, "best_by_service": best_by_service, "user_warnings": user_warnings}


def egress_candidate_score(egress_id, registry, route_class, state_row, matrix_row, speed_row):
    if str(registry.get("enabled", "1")) != "1":
        return None
    role = safe_egress_role(registry.get("role", ""), "GLOBAL_FAST")
    excluded = set(safe_csv_tokens(registry.get("exclude_route_classes", ""), uppercase=True, max_items=32))
    if route_class in excluded:
        return None
    manual_only = str(registry.get("manual_only", "0")) == "1"
    reserve_only = str(registry.get("reserve_only", "0")) == "1"
    strict_sensitive = route_class == "TRUSTED_RU_SENSITIVE" and role != "TRUSTED_RU_SENSITIVE"
    if manual_only or strict_sensitive:
        return None

    fitness = ((matrix_row or {}).get("route_class_fitness") or {}).get(route_class, {})
    fitness_status = fitness.get("status", "UNKNOWN")
    service_tags = set(safe_csv_tokens(registry.get("service_tags", ""), max_items=32))
    class_services = set(ROUTE_CLASS_SERVICE_MAP.get(route_class, ()))
    state_row = state_row or {}
    speed_row = speed_row or {}
    try:
        priority = int(str(registry.get("priority", "50")))
    except ValueError:
        priority = 50
    try:
        weight = int(str(registry.get("weight", "100")))
    except ValueError:
        weight = 100
    try:
        mbps = float(speed_row.get("server_v7_mbps") or 0)
    except (TypeError, ValueError):
        mbps = 0.0

    score = 0.0
    reasons = []
    if str(state_row.get("code", "")) == "200":
        score += 50
        reasons.append("health_code_200")
    severity = str(state_row.get("diagnose_severity", "")).upper()
    if severity in ("OK", ""):
        score += 15
    elif severity in ("WARN", "WARNING"):
        score -= 10
        reasons.append("health_warning")
    else:
        score -= 40
        reasons.append(f"health_{severity.lower() or 'unknown'}")

    if role == route_class:
        score += 120
        reasons.append("role_exact_match")
    elif class_services & service_tags:
        score += 35
        reasons.append("service_tag_match")

    if fitness_status == "OK":
        score += 90
        reasons.append("matrix_ok")
    elif fitness_status == "WARN":
        score += 25
        reasons.append("matrix_warn")
    elif fitness_status == "FAIL":
        score -= 100
        reasons.append("matrix_fail")
    else:
        score -= 10
        reasons.append("matrix_unknown")

    score += max(0, 100 - priority) * 0.6
    score += max(0, weight) * 0.12
    score += min(max(mbps, 0), 200) * 0.08
    if reserve_only:
        score -= 35
        reasons.append("reserve_penalty")

    return {
        "egress": egress_id,
        "role": role,
        "score": round(score, 2),
        "status": "CANDIDATE",
        "fitness": fitness_status,
        "priority": priority,
        "weight": weight,
        "server_v7_mbps": mbps or None,
        "reserve_only": reserve_only,
        "manual_only": manual_only,
        "interface": registry.get("interface", ""),
        "test": registry.get("test", ""),
        "reasons": reasons,
    }


def service_aware_route_dry_run(user_ip=""):
    state = read_json(STATE_DIR / "v7-state.json", {})
    users = state.get("users") or parse_registry(STATE_DIR / "users.registry")
    active_users = [row for row in users if str(row.get("enabled", "1")) == "1"]
    user_ip = safe_user_ip(user_ip) or default_active_user_ip(active_users)
    egress_rows = egress_registry_rows(enabled_only=False)
    egress_by_id = {row.get("id"): row for row in egress_rows if row.get("id")}
    enabled_egress = {k: v for k, v in egress_by_id.items() if str(v.get("enabled", "1")) == "1"}
    matrix_items = (service_matrix_state().get("items") or {})
    speed_items = (speed_state().get("items") or {})
    state_egress = state.get("egress") or {}
    routes = {}

    for route_class in ("DIRECT_RU", "TRUSTED_RU_SENSITIVE", "VIDEO_OPTIMIZED", "GLOBAL_FAST", "GLOBAL_STABLE", "LOW_LATENCY"):
        domains = policy_domain_items(route_class)
        service_ids = ROUTE_CLASS_SERVICE_MAP.get(route_class, ())
        if route_class == "DIRECT_RU":
            routes[route_class] = {
                "status": "READY",
                "mode": "direct",
                "selected_path": "V7_DIRECT_RU",
                "selected_egress": "",
                "interface": "ens3",
                "reason": "ordinary RU is allowed to exit directly from the V7 Moscow server",
                "domains_count": len(domains),
                "services": list(service_ids),
                "candidates": [],
                "would_change": [],
            }
            continue

        candidates = []
        for egress_id, registry in enabled_egress.items():
            candidate = egress_candidate_score(
                egress_id,
                registry,
                route_class,
                state_egress.get(egress_id, {}),
                matrix_items.get(egress_id, {}),
                speed_items.get(egress_id, {}),
            )
            if candidate:
                candidates.append(candidate)
        candidates.sort(key=lambda row: (-float(row.get("score") or 0), row.get("priority", 999), row.get("egress", "")))
        selected = candidates[0] if candidates else None

        if route_class == "TRUSTED_RU_SENSITIVE" and not selected:
            status = "BLOCKED_REQUIRED_TRUSTED_PATH"
            reason = "no enabled egress with role TRUSTED_RU_SENSITIVE passed dry-run eligibility"
        elif selected:
            status = "READY" if selected.get("fitness") in ("OK", "WARN") else "NEEDS_MORE_TESTS"
            reason = "selected by role, health, service matrix, priority, weight, and speed"
        else:
            status = "FALLBACK_USER_DEFAULT"
            reason = "no specific route-class egress selected; keep existing per-user sticky routing"

        routes[route_class] = {
            "status": status,
            "mode": "egress" if selected else "user_default",
            "selected_path": selected.get("egress") if selected else "user_default",
            "selected_egress": selected.get("egress") if selected else "",
            "interface": selected.get("interface") if selected else "",
            "reason": reason,
            "domains_count": len(domains),
            "services": list(service_ids),
            "candidates": candidates[:6],
            "would_change": [],
        }

    sample_domains = []
    for route_class in ("TRUSTED_RU_SENSITIVE", "DIRECT_RU", "VIDEO_OPTIMIZED", "GLOBAL_FAST", "GLOBAL_STABLE"):
        for domain in policy_domain_items(route_class)[:4]:
            sample_domains.append(domain)
    for fallback in ("www.gosuslugi.ru", "esia.gosuslugi.ru", "alfabank.ru", "vk.com", "youtube.com", "telegram.org"):
        if fallback not in sample_domains:
            sample_domains.append(fallback)
    domain_rows = []
    for domain in sample_domains[:32]:
        test = run_readonly(["v7-policy-test-domain", domain, user_ip], timeout=5)
        parsed = parse_command_kv(test.get("output", ""))
        route_class = parsed.get("route_class", "DEFAULT_USER_EGRESS")
        plan = routes.get(route_class, {})
        domain_rows.append({
            "domain": domain,
            "route_class": route_class,
            "current_desired_path": parsed.get("desired_path", ""),
            "dry_run_path": plan.get("selected_path", "user_default") if plan else "user_default",
            "status": plan.get("status", "FALLBACK_USER_DEFAULT") if plan else "FALLBACK_USER_DEFAULT",
            "rc": test.get("rc"),
        })

    blockers = []
    if routes.get("TRUSTED_RU_SENSITIVE", {}).get("status") == "BLOCKED_REQUIRED_TRUSTED_PATH":
        blockers.append("trusted_ru_sensitive_has_no_dedicated_enabled_egress")
    warnings = []
    for class_id, row in routes.items():
        if row.get("status") in ("NEEDS_MORE_TESTS", "FALLBACK_USER_DEFAULT"):
            warnings.append(f"{class_id}:{row.get('status')}")

    return redact({
        "updated": now_iso(),
        "mode": "dry_run_read_only",
        "user_ip": user_ip,
        "safety": {
            "routing_changed": False,
            "users_moved": False,
            "kill_switch_changed": False,
            "registry_changed": False,
            "systemd_changed": False,
        },
        "summary": {
            "enabled_egress": len(enabled_egress),
            "route_classes": len(routes),
            "ready": sum(1 for row in routes.values() if row.get("status") == "READY"),
            "blocked": len(blockers),
            "warnings": len(warnings),
        },
        "blockers": blockers,
        "warnings": warnings,
        "routes": routes,
        "domain_samples": domain_rows,
        "next_step": "review_then_generate_apply_preview",
    })


def route_class_registry_rows_with_lines():
    rows = []
    for raw in read_text(ROUTE_CLASSES_REG_FILE, "").splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        row = parse_kv_line(line)
        if row.get("id"):
            row["_line"] = line
            rows.append(row)
    return rows


def route_class_registry_line(row):
    order = ("id", "priority", "mark", "table", "mode", "active_egress", "temporary", "local_direct", "enabled")
    keys = [key for key in order if key in row]
    keys.extend(sorted(key for key in row if key not in set(order) and not key.startswith("_")))
    return " ".join(f"{key}={row.get(key, '')}" for key in keys if str(row.get(key, "")) != "")


def service_aware_apply_preview(user_ip=""):
    dry_run = service_aware_route_dry_run(user_ip=user_ip)
    registry_rows = route_class_registry_rows_with_lines()
    registry_by_id = {row.get("id"): row for row in registry_rows}
    changes = []
    blocked = list(dry_run.get("blockers", []))
    warnings = list(dry_run.get("warnings", []))

    for class_id, route in (dry_run.get("routes") or {}).items():
        current = registry_by_id.get(class_id)
        if not current:
            warnings.append(f"{class_id}:missing_route_class_registry_row")
            continue
        if class_id in ("DIRECT_RU", "DEFAULT_USER_EGRESS"):
            continue
        status = route.get("status", "")
        if status == "BLOCKED_REQUIRED_TRUSTED_PATH":
            blocked.append(f"{class_id}:blocked_no_trusted_path")
            continue
        proposed = dict(current)
        selected = route.get("selected_egress") or ""
        if selected:
            proposed["mode"] = "egress"
            proposed["active_egress"] = selected
            proposed["temporary"] = "0"
        else:
            proposed["mode"] = "egress" if class_id != "DEFAULT_USER_EGRESS" else "default"
            proposed["active_egress"] = "user_default"
        proposed_line = route_class_registry_line(proposed)
        current_line = current.get("_line", "")
        if proposed_line != current_line:
            changes.append({
                "class": class_id,
                "status": status,
                "current_line": current_line,
                "proposed_line": proposed_line,
                "selected_path": route.get("selected_path", ""),
                "reason": route.get("reason", ""),
            })

    validation = "BLOCKED" if blocked else ("WARN" if warnings or not changes else "OK")
    return redact({
        "updated": now_iso(),
        "mode": "apply_preview_read_only",
        "validation": validation,
        "user_ip": dry_run.get("user_ip"),
        "safety": {
            "routing_changed": False,
            "users_moved": False,
            "kill_switch_changed": False,
            "registry_changed": False,
            "systemd_changed": False,
        },
        "registry": str(ROUTE_CLASSES_REG_FILE),
        "would_backup": [str(ROUTE_CLASSES_REG_FILE)],
        "would_change": [str(ROUTE_CLASSES_REG_FILE)] if changes else [],
        "blocked": blocked,
        "warnings": warnings,
        "changes": changes,
        "dry_run_summary": dry_run.get("summary", {}),
        "domain_samples": dry_run.get("domain_samples", []),
        "next_step": "fix_blockers" if blocked else ("guarded_apply_after_backup" if changes else "no_change_needed"),
    })


def service_aware_apply_guarded(user_ip="", confirm=""):
    preview = service_aware_apply_preview(user_ip=user_ip)
    if str(confirm or "") != "APPLY_SERVICE_AWARE_ROUTES":
        return redact({
            "status": "CONFIRM_REQUIRED",
            "required_confirm": "APPLY_SERVICE_AWARE_ROUTES",
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    if preview.get("blocked"):
        return redact({
            "status": "BLOCKED",
            "reason": "apply_preview_has_blockers",
            "blocked": preview.get("blocked", []),
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    changes = preview.get("changes") or []
    if not changes:
        return redact({
            "status": "NO_CHANGE",
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    current_text = read_text(ROUTE_CLASSES_REG_FILE, "")
    if current_text.startswith("ERROR:"):
        return redact({
            "status": "BLOCKED",
            "reason": "route_class_registry_read_failed",
            "error": current_text,
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    replacements = {row.get("class"): row.get("proposed_line", "") for row in changes if row.get("class") and row.get("proposed_line")}
    changed_classes = set()
    next_lines = []
    for raw in current_text.splitlines():
        line = raw.strip()
        row = parse_kv_line(line) if line and not line.startswith("#") else {}
        class_id = row.get("id")
        if class_id in replacements:
            next_lines.append(replacements[class_id])
            changed_classes.add(class_id)
        else:
            next_lines.append(raw)

    missing = sorted(set(replacements) - changed_classes)
    if missing:
        return redact({
            "status": "BLOCKED",
            "reason": "route_class_registry_rows_missing_during_apply",
            "missing": missing,
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    next_text = "\n".join(next_lines) + ("\n" if current_text.endswith("\n") or next_lines else "")
    if next_text == current_text:
        return redact({
            "status": "NO_CHANGE",
            "preview": preview,
            "safety": {
                "routing_changed": False,
                "users_moved": False,
                "kill_switch_changed": False,
                "registry_changed": False,
                "systemd_changed": False,
            },
        })

    ROUTE_CLASSES_REG_FILE.parent.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
    backup = ROUTE_CLASSES_REG_FILE.with_name(f"{ROUTE_CLASSES_REG_FILE.name}.backup.v7-service-aware-apply.{stamp}")
    backup_created = False
    if ROUTE_CLASSES_REG_FILE.exists():
        shutil.copy2(ROUTE_CLASSES_REG_FILE, backup)
        os.chmod(backup, 0o600)
        backup_created = True
    registry_mode = ROUTE_CLASSES_REG_FILE.stat().st_mode & 0o777 if ROUTE_CLASSES_REG_FILE.exists() else 0o600
    write_text_atomic(ROUTE_CLASSES_REG_FILE, next_text, mode=registry_mode or 0o600)
    os.chmod(ROUTE_CLASSES_REG_FILE, registry_mode or 0o600)

    return redact({
        "status": "OK",
        "validation": preview.get("validation"),
        "changed_classes": sorted(changed_classes),
        "backup": str(backup) if backup_created else "",
        "registry": str(ROUTE_CLASSES_REG_FILE),
        "preview": preview,
        "safety": {
            "routing_changed": False,
            "users_moved": False,
            "kill_switch_changed": False,
            "registry_changed": True,
            "systemd_changed": False,
        },
        "next_step": "live_policy_rollout_preview",
    })


def service_aware_live_rollout_preview(user_ip=""):
    apply_preview = service_aware_apply_preview(user_ip=user_ip)
    registry_rows = route_class_registry_rows_with_lines()
    egress_rows = egress_registry_rows(enabled_only=False)
    egress_by_id = {row.get("id"): row for row in egress_rows if row.get("id")}
    blockers = []
    warnings = []
    nft_sets = []
    nft_rules = []
    ip_rules = []
    route_tables = []
    kill_switch_allow = set()
    direct_public_classes = []

    for row in registry_rows:
        class_id = row.get("id", "")
        enabled = str(row.get("enabled", "1")) == "1"
        if not class_id or not enabled:
            continue
        mode = row.get("mode", "")
        mark = row.get("mark", "")
        table = row.get("table", "")
        active_egress = row.get("active_egress", "")
        domains = policy_domain_items(class_id)
        set_name = f"v7_{class_id.lower()}"

        if not mark or not table:
            blockers.append(f"{class_id}:missing_mark_or_table")
            continue

        nft_sets.append({
            "class": class_id,
            "set": set_name,
            "domains_count": len(domains),
            "mark": mark,
            "services": list(ROUTE_CLASS_SERVICE_MAP.get(class_id, ())),
        })
        nft_rules.append({
            "class": class_id,
            "rule": f"ip saddr 10.0.0.0/24 ip daddr @{set_name} meta mark set {mark}",
        })
        ip_rules.append({
            "class": class_id,
            "rule": f"fwmark {mark} lookup {table} priority 10{str(table).zfill(3)}",
        })

        if mode == "direct":
            if class_id != "DIRECT_RU":
                blockers.append(f"{class_id}:direct_mode_not_allowed_for_this_class")
            direct_public_classes.append(class_id)
            route_tables.append({
                "class": class_id,
                "table": table,
                "route": f"default dev {PUBLIC_IF}",
                "mode": "direct",
                "interface": PUBLIC_IF,
            })
            continue

        if mode == "egress":
            if not active_egress or active_egress == "user_default":
                warnings.append(f"{class_id}:uses_user_default_no_dedicated_route")
                route_tables.append({
                    "class": class_id,
                    "table": table,
                    "route": "keep existing per-user sticky route",
                    "mode": "user_default",
                    "interface": "",
                })
                continue

            egress = egress_by_id.get(active_egress)
            if not egress:
                blockers.append(f"{class_id}:active_egress_not_found:{active_egress}")
                continue
            if str(egress.get("enabled", "1")) != "1":
                blockers.append(f"{class_id}:active_egress_disabled:{active_egress}")
                continue

            egress_role = egress.get("role", "")
            if class_id == "TRUSTED_RU_SENSITIVE":
                if str(row.get("temporary", "0")) == "1":
                    blockers.append(f"{class_id}:temporary_route_must_not_go_live")
                if egress_role != "TRUSTED_RU_SENSITIVE":
                    blockers.append(f"{class_id}:active_egress_role_is_not_trusted_ru_sensitive:{active_egress}")

            interface = egress.get("interface", "")
            if not interface:
                blockers.append(f"{class_id}:active_egress_has_no_interface:{active_egress}")
                continue
            kill_switch_allow.add(interface)
            route_tables.append({
                "class": class_id,
                "table": table,
                "route": f"default dev {interface}",
                "mode": "egress",
                "interface": interface,
                "egress": active_egress,
            })
            continue

        warnings.append(f"{class_id}:unsupported_or_default_mode:{mode or 'empty'}")

    if apply_preview.get("blocked"):
        blockers.extend(f"apply_preview:{item}" for item in apply_preview.get("blocked", []))

    validation = "BLOCKED" if blockers else ("WARN" if warnings else "OK")
    return redact({
        "updated": now_iso(),
        "mode": "live_rollout_preview_read_only",
        "validation": validation,
        "user_ip": apply_preview.get("user_ip"),
        "public_interface": PUBLIC_IF,
        "registry": str(ROUTE_CLASSES_REG_FILE),
        "safety": {
            "routing_changed": False,
            "users_moved": False,
            "kill_switch_changed": False,
            "registry_changed": False,
            "systemd_changed": False,
            "nftables_changed": False,
        },
        "blockers": blockers,
        "warnings": warnings,
        "nft": {
            "table": "inet v7_policy",
            "sets": nft_sets,
            "rules": nft_rules,
        },
        "ip_rules": ip_rules,
        "route_tables": route_tables,
        "kill_switch_preview": {
            "allow_user_to_egress_interfaces": sorted(kill_switch_allow),
            "allow_user_to_public_interface_for_classes": direct_public_classes,
            "deny_user_to_public_interface_by_default": True,
            "ssh_lockout_guard_required": True,
        },
        "apply_preview": apply_preview,
        "next_step": "fix_blockers" if blockers else "guarded_live_rollout_apply_design",
    })


