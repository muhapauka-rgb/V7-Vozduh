def client_profile_capabilities(ip=""):
    ip = safe_user_ip(ip)
    conf = wg_conf_for_user_ip(ip) if ip else None
    name = smart_client_name_for_ip(ip, "happ") if ip else ""
    artifacts = client_artifacts_for_ip(ip) if ip else []
    artifact_ready = any(row.get("config_ready") for row in artifacts)
    qr_ready = any(row.get("qr_ready") for row in artifacts)
    rows = []
    for client_id, meta in CONNECT_CLIENTS.items():
        adapter = safe_smart_adapter(meta.get("adapter", ""))
        can_generate = bool(meta.get("can_generate")) and bool(adapter) and (bool(conf) or adapter == "happ")
        generated_modes = []
        if can_generate and name:
            for mode in sorted(SUPPORTED_SMART_MODES):
                path_obj = smart_client_profile_path(name, adapter, mode)
                validation = smart_profile_validation(path_obj, adapter, mode) if path_obj and path_obj.exists() else {"status": "MISSING"}
                generated_modes.append({
                    "mode": mode,
                    "ready": bool(path_obj and path_obj.exists()),
                    "validation": validation,
                    "download_url": f"/api/smart-client-profile?ip={ip}&adapter={adapter}&mode={mode}" if ip and path_obj and path_obj.exists() else None,
                })
        if client_id == "wireguard":
            ready = artifact_ready
            reason = "wireguard_artifact_ready" if ready else "wireguard_artifact_missing"
        elif can_generate:
            ready = any(row.get("ready") for row in generated_modes)
            reason = "smart_profile_ready" if ready else "generate_profile_first"
        else:
            ready = False
            reason = "adapter_not_implemented"
        rows.append({
            "client": client_id,
            "label": meta.get("label", client_id),
            "status": meta.get("status", "planned"),
            "ready": ready,
            "reason": reason,
            "note": meta.get("note", ""),
            "profile_format": meta.get("profile_format", ""),
            "delivery": meta.get("delivery", ""),
            "adapter": adapter,
            "can_generate": can_generate,
            "can_select": bool(meta.get("can_select")) and can_generate,
            "one_time_link": bool(can_generate),
            "admin_artifact": client_id == "wireguard",
            "config_ready": artifact_ready if client_id == "wireguard" else ready,
            "qr_ready": qr_ready if client_id == "wireguard" else False,
            "instructions": meta.get("instructions", ""),
            "blocker": meta.get("blocker", ""),
            "required_v7_inbound": meta.get("required_v7_inbound", ""),
            "supported_imports": meta.get("supported_imports", []),
            "generated_modes": generated_modes,
        })
    return {
        "ip": ip,
        "client": name,
        "wireguard_artifacts": artifacts,
        "items": rows,
    }


def smart_client_profiles_for_ip(ip):
    conf = wg_conf_for_user_ip(ip)
    has_happ_name = bool(smart_client_name_for_ip(ip, "happ"))
    if not conf and not has_happ_name:
        return {
            "available": False,
            "reason": "wireguard_client_config_not_found",
            "supported_adapters": sorted(SUPPORTED_SMART_ADAPTERS),
            "client_capabilities": client_profile_capabilities(ip),
            "supported_modes": SMART_MODE_META,
            "items": [],
        }
    name = safe_client_name(conf.stem) if conf else smart_client_name_for_ip(ip, "happ")
    items = []
    for adapter in sorted(SUPPORTED_SMART_ADAPTERS):
        for mode in sorted(SUPPORTED_SMART_MODES):
            path_obj = smart_client_profile_path(name, adapter, mode)
            if not path_obj:
                continue
            meta_path = path_obj.with_suffix(path_obj.suffix + ".meta")
            exists = path_obj.exists()
            row = {
                "client": name,
                "adapter": adapter,
                "mode": mode,
                "mode_meta": SMART_MODE_META.get(mode, {}),
                "mode_routes": SMART_MODE_ROUTES.get(mode, {}),
                "ready": exists,
                "validation": smart_profile_validation(path_obj, adapter, mode) if exists else {"status": "MISSING", "plain": "Сгенерируйте этот профиль перед проверкой."},
                "download_url": f"/api/smart-client-profile?ip={ip}&adapter={adapter}&mode={mode}" if exists else None,
                "mtime": datetime.fromtimestamp(path_obj.stat().st_mtime, timezone.utc).isoformat() if exists else None,
            }
            if meta_path.exists():
                row["metadata"] = read_json(meta_path, {})
            items.append(row)
    return {
        "available": True,
        "client": name,
        "selected": smart_client_preference_for_ip(ip),
        "supported_adapters": sorted(SUPPORTED_SMART_ADAPTERS),
        "client_capabilities": client_profile_capabilities(ip),
        "supported_modes": SMART_MODE_META,
        "items": items,
    }


def user_detail(ip):
    users = parse_registry(STATE_DIR / "users.registry")
    user = next((row for row in users if row.get("ip") == ip), None)
    if not user:
        return None
    active_users = [u for u in users if str(u.get("enabled", "1")) == "1"]
    client_speed = client_speed_state()
    agents = client_agents_state()
    matrix = service_matrix_state()
    prefs = service_preferences_state()
    recommendations = service_recommendations(active_users, matrix, prefs)
    route = next((row for row in route_status([user]) if row.get("ip") == ip), None)
    speed_rows = client_speed_user_rows([user], client_speed, agents)
    speed_row = speed_rows.get(ip, {})
    agent_row = (agents.get("agents") or {}).get(ip)
    artifacts = client_artifacts_for_ip(ip)
    readiness = user_readiness(ip, user, route, artifacts, speed_row, agent_row)
    delivery_summary = profile_delivery_summary_for_ip(ip)
    history = run_readonly(["v7-safe-run", "v7-user-history", ip, "20"], timeout=8)
    state_user = next((row for row in (read_json(STATE_DIR / "v7-state.json", {}).get("users") or []) if row.get("ip") == ip), {})
    warnings = [row for row in recommendations.get("user_warnings", []) if row.get("ip") == ip]
    commands = [
        row for row in (client_commands_state(80).get("commands") or [])
        if row.get("ip") == ip
    ][-20:]
    related_events = [
        event for event in normalized_events(source="all", limit=160, component="", action="", severity="", user_ip=ip).get("events", [])
        if event.get("user_ip") == ip or event.get("object_id") == ip or ip in str(event.get("message", ""))
    ][:30]
    return {
        "ip": ip,
        "registry": user,
        "state": state_user,
        "route": route,
        "readiness": readiness,
        "onboarding": user_onboarding_stage(ip, user, readiness, delivery_summary),
        "client_speed": speed_row,
        "agent": agent_row,
        "preferences": (prefs.get("users") or {}).get(ip, {"services": []}),
        "recommendations_enabled": bool(prefs.get("enabled")),
        "warnings": warnings,
        "artifacts": artifacts,
        "client_profile_capabilities": client_profile_capabilities(ip),
        "smart_profiles": smart_client_profiles_for_ip(ip),
        "smart_profile_preference": smart_client_preference_for_ip(ip),
        "profile_delivery": delivery_summary,
        "switch_history": history,
        "commands": commands,
        "events": related_events,
    }


def egress_config_payload(egress_id):
    egress_id = safe_egress_id(egress_id)
    if not egress_id:
        return None, {"error": "invalid_egress"}
    path = egress_config_path(egress_id)
    if not path:
        return None, {"error": "unknown_config_path", "egress": egress_id}
    if not path.exists():
        return None, {"error": "config_not_found", "egress": egress_id, "path": str(path)}
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except OSError as exc:
        return None, {"error": "config_read_failed", "detail": str(exc)}
    return {
        "egress": egress_id,
        "path": str(path),
        "size_bytes": path.stat().st_size,
        "mtime": datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat(),
        "redacted": True,
        "content": redact(raw),
    }, None


def egress_detail(egress_id):
    egress_id = safe_egress_id(egress_id)
    if not egress_id:
        return None

    state = read_json(STATE_DIR / "v7-state.json", {})
    state_egress = (state.get("egress") or {}).get(egress_id) or {}
    registry_rows = parse_registry(STATE_DIR / "egress.registry")
    registry = next((row for row in registry_rows if row.get("id") == egress_id), None)
    if not registry and not state_egress:
        return None

    users = parse_registry(STATE_DIR / "users.registry")
    assigned_users = [
        {
            "ip": row.get("ip"),
            "table": row.get("table"),
            "enabled": row.get("enabled", "1"),
        }
        for row in users
        if row.get("current") == egress_id
    ]

    config, config_error = egress_config_payload(egress_id)
    config_json = None
    if config and config.get("content") and str(config.get("path", "")).endswith(".json"):
        try:
            config_json = redact(json.loads(config["content"]))
        except Exception:
            config_json = None

    speed_items = (speed_state().get("items") or {})
    server_speed = speed_items.get(egress_id) or {}
    matrix_items = (service_matrix_state().get("items") or {})
    matrix = matrix_items.get(egress_id) or {}
    flags = read_state_kv(STATE_DIR / "egress-flags.state")
    client_data = client_speed_state()
    user_speed_rows = []
    v7_values = []
    direct_values = []

    for ip, user_data in (client_data.get("users") or {}).items():
        latest = user_data.get("latest") or {}
        latest_v7 = latest.get("v7") or {}
        latest_direct = (latest.get("direct") or {}).get(egress_id) or {}
        if latest_v7.get("egress") == egress_id and isinstance(latest_v7.get("mbps"), (int, float)):
            v7_values.append(float(latest_v7["mbps"]))
        if isinstance(latest_direct.get("mbps"), (int, float)):
            direct_values.append(float(latest_direct["mbps"]))
        history = [
            item for item in (user_data.get("history") or [])
            if item.get("egress") == egress_id
        ][-20:]
        if latest_v7.get("egress") == egress_id or latest_direct or history:
            degradation = None
            if isinstance(latest_v7.get("mbps"), (int, float)) and isinstance(latest_direct.get("mbps"), (int, float)) and float(latest_direct["mbps"]) > 0:
                degradation = round(max(0.0, (float(latest_direct["mbps"]) - float(latest_v7["mbps"])) / float(latest_direct["mbps"]) * 100), 1)
            user_speed_rows.append({
                "ip": ip,
                "latest_v7": latest_v7 if latest_v7.get("egress") == egress_id else {},
                "latest_direct": latest_direct,
                "degradation_pct": degradation,
                "history": history,
            })

    client_v7_avg = round(sum(v7_values) / len(v7_values), 2) if v7_values else None
    client_direct_avg = round(sum(direct_values) / len(direct_values), 2) if direct_values else None
    aggregate_degradation = None
    if client_v7_avg is not None and client_direct_avg and client_direct_avg > 0:
        aggregate_degradation = round(max(0.0, (client_direct_avg - client_v7_avg) / client_direct_avg * 100), 1)

    related_events = [
        event for event in normalized_events(source="all", limit=120, component="", action="", severity="", user_ip="").get("events", [])
        if event.get("object_id") == egress_id or f"egress={egress_id}" in str(event.get("message", "")) or f"id={egress_id}" in str(event.get("message", ""))
    ][:30]
    related_drafts = [
        row for row in egress_drafts_state().get("drafts", [])
        if row.get("pool_egress_id") == egress_id or row.get("id") == egress_id
    ][:8]

    return redact({
        "egress": egress_id,
        "pool_state": flags.get(f"{egress_id}_state") or ("disabled" if registry and registry.get("enabled") == "0" else "enabled"),
        "runtime_readiness": egress_runtime_readiness(egress_id, registry or {}),
        "registry": registry or {},
        "state": state_egress,
        "assigned_users": assigned_users,
        "config": config,
        "config_error": config_error,
        "config_json": config_json,
        "server_speed": server_speed,
        "client_speed": {
            "fresh_seconds": CLIENT_SPEED_FRESH_SECONDS,
            "client_v7_avg_mbps": client_v7_avg,
            "client_direct_avg_mbps": client_direct_avg,
            "degradation_pct": aggregate_degradation,
            "users": user_speed_rows,
            "note": "Client samples are kept visible while fresh; current freshness window is 86400 seconds.",
        },
        "service_matrix": matrix,
        "events": related_events,
        "draft_lifecycle": related_drafts,
    })


