        <span id="topSystem">загрузка</span>
        <span id="topUsers"></span>
        <span id="topAlerts"></span>
        <button class="ghost" onclick="toggleV7Theme()" id="themeBtn" data-no-i18n="1" title="Тёмная / светлая тема">Тема</button>
        <button class="ghost" onclick="toggleV7Language()" id="langBtn" data-no-i18n="1" title="Язык интерфейса">RU</button>
        <button class="ghost" onclick="toggleLayoutEditing()" id="layoutBtn" data-no-i18n="1" title="Настроить вид">Макет</button>
        <button class="ghost" onclick="load()" id="refreshBtn" data-no-i18n="1" title="Обновить данные">Обновить</button>
      </div>
    </div>
  </header>
  <main class="shell">
    <section id="tab-overview" class="tab-page active">
      <div class="grid-metrics" id="metrics"></div>
      <div class="overview-actions"><button class="ghost" onclick="openV2WorkflowPlaybook()">Что дальше</button><button class="ghost" onclick="openV2OperatorGuide()">Сценарии</button></div>
      <div class="overview-grid">
        <article class="panel topology-panel">
          <h2><span>Маршруты</span><button class="ghost" onclick="showTab('routing')">Открыть маршруты</button></h2>
          <div class="topology" id="topology"></div>
        </article>
        <article class="panel overview-alert-panel">
          <h2><span>Важные события</span><button class="ghost" onclick="showTab('logs')">Все логи</button></h2>
          <div class="alert-list" id="alerts"></div>
        </article>
      </div>
      <div class="overview-stack">
        <article class="panel"><div class="toolbar"><div><h2>Активные пользователи</h2></div><button class="ghost" onclick="showTab('users')">Все пользователи</button></div><div class="table-shell" id="overviewUsers"></div></article>
        <article class="panel"><div class="toolbar"><div><h2>Каналы</h2></div><button class="ghost" onclick="showTab('channels')">Все каналы</button></div><div class="table-shell" id="overviewChannels"></div></article>
      </div>
    </section>

    <section id="tab-users" class="tab-page"><div class="module-page">
      <div class="stat-grid span-12" id="userStats"></div>
      <article class="panel span-12"><div class="toolbar"><div><h2>Пользователи</h2></div><div class="toolbar-actions"><button class="ghost" onclick="showTab('identity')">Доступ</button><button class="ghost" onclick="showV2UserColumns()">Столбцы</button><button class="ghost" onclick="toggleLayoutEditing()">Макет</button><button class="primary" onclick="showIssueProfilePanel('new')">Добавить пользователя</button></div></div><div class="filterbar" id="userFilterBar"></div><div class="searchbar"><input id="userSearchV2" placeholder="Поиск: имя, IP, канал..."></div><div class="table-shell" id="usersTableV2"></div></article>
    </div></section>

    <section id="tab-channels" class="tab-page"><div class="module-page">
      <div class="stat-grid span-12" id="channelStats"></div>
      <div class="workspace-tabs">
        <button class="workspace-tab active" data-channel-nav="overview" onclick="showChannelWorkspace('overview')">Обзор</button>
        <button class="workspace-tab" data-channel-nav="onboarding" onclick="showAddChannelWizard()">Добавить канал</button>
        <button class="workspace-tab" data-channel-nav="matrix" onclick="showChannelWorkspace('matrix')">Сервисная матрица</button>
        <button class="workspace-tab" data-channel-nav="readiness" onclick="showChannelWorkspace('readiness')">Готовность и скорость</button>
      </div>
      <article class="panel span-12 workspace-panel" data-channel-workspace="onboarding" id="channelWizard">
        <div class="toolbar"><div><h2>Добавление канала</h2></div><div class="toolbar-actions"><button class="ghost" onclick="openInfoPanel('channelOnboarding')">Инф</button><button class="ghost" onclick="loadV2EgressDrafts()">Обновить черновики</button></div></div>
        <div class="wizard-grid">
          <div class="wizard-card">
            <h3>1. Источник</h3>
            <label class="field">Название<input id="v2EgressDraftLabel" placeholder="netherlands-vless-1"></label>
            <label class="field">Файл конфига<input id="v2EgressDraftFile" type="file" accept=".conf,.json,.ovpn,.yaml,.yml,.txt" onchange="loadV2EgressDraftFile()"></label>
            <label class="field">QR-код<input id="v2EgressDraftQr" type="file" accept="image/*" onchange="loadV2EgressDraftQr()"></label>
            <label class="field">Конфиг / ссылка / ручной ввод<textarea id="v2EgressDraftConfig" placeholder="Вставьте VPN-конфиг или ссылку"></textarea></label>
            <div class="wizard-actions"><button class="ghost" onclick="previewV2EgressDraft()">Распознать</button><button class="primary" onclick="saveV2EgressDraft()">Сохранить черновик</button></div>
          </div>
          <div class="wizard-card">
            <h3>2. Роль и лимиты</h3>
            <label class="field">Роль маршрута<select id="v2EgressDraftRole"></select></label>
            <div class="inline-fields"><label class="field">Приоритет<input id="v2EgressDraftPriority" type="number" min="1" max="999" placeholder="20"></label><label class="field">Вес<input id="v2EgressDraftWeight" type="number" min="0" max="1000" placeholder="100"></label></div>
            <div class="inline-fields"><label class="field">Мягкий лимит<input id="v2EgressDraftSoft" type="number" min="0" placeholder="1"></label><label class="field">Жёсткий лимит<input id="v2EgressDraftHard" type="number" min="0" placeholder="2"></label></div>
            <label class="field">Теги сервисов<input id="v2EgressDraftServiceTags" placeholder="youtube,telegram,global"></label>
            <label class="field">Не использовать для<input id="v2EgressDraftExclude" placeholder="Госуслуги и банки, обычные RU"></label>
            <label class="field"><input id="v2EgressDraftReserveOnly" type="checkbox" style="width:auto;height:auto"> Только резерв</label>
            <label class="field"><input id="v2EgressDraftManualOnly" type="checkbox" style="width:auto;height:auto"> Только вручную</label>
          </div>
          <div class="wizard-card">
            <h3>3. Безопасный путь</h3>
            <div id="v2EgressDraftSteps"></div>
          </div>
        </div>
        <div class="wizard-result">
          <div id="v2EgressDraftResult" class="wizard-card is-empty"></div>
          <h2 style="padding-left:0">Сохранённые черновики</h2>
          <div class="table-shell" id="v2EgressDrafts"></div>
        </div>
      </article>
      <article class="panel span-12 workspace-panel active" data-channel-workspace="overview"><div class="toolbar"><div><h2>Каналы</h2></div><div class="toolbar-actions"><button class="ghost" onclick="toggleLayoutEditing()">Столбцы</button><button class="ghost" onclick="showChannelWorkspace('readiness')">Готовность</button><button class="ghost" onclick="showChannelWorkspace('matrix')">Матрица сервисов</button><button class="primary" onclick="showAddChannelWizard()">Добавить канал</button></div></div><div class="table-shell" id="channelsTableV2"></div></article>
      <article class="panel span-12 workspace-panel" data-channel-workspace="matrix"><div class="toolbar"><div><h2>Сервисная матрица</h2></div><div class="toolbar-actions"><button class="ghost" onclick="openDrawer('Сервисная матрица','channel', serviceMatrixText())">Сводка</button></div></div><div class="table-shell" id="channelsMatrixTable"></div></article>
      <article class="panel span-12 workspace-panel" data-channel-workspace="readiness"><div class="toolbar"><div><h2>Готовность и скорость</h2></div><div class="toolbar-actions"><button class="ghost" onclick="renderChannelReadinessWorkspace()">Обновить</button></div></div><div class="table-shell" id="channelsReadinessTable"></div></article>
    </div></section>

    <section id="tab-routing" class="tab-page"><div class="module-page">
      <div class="stat-grid span-12" id="routingStats"></div>
      <div class="workspace-tabs">
        <button class="workspace-tab active" data-routing-nav="overview" onclick="showRoutingWorkspace('overview')">Обзор</button>
        <button class="workspace-tab" data-routing-nav="domains" onclick="showPolicyDomainPanel()">Группы доменов</button>
        <button class="workspace-tab" data-routing-nav="checks" onclick="showRoutingActionPanel()">Проверка</button>
        <button class="workspace-tab" data-routing-nav="modes" onclick="showRoutingWorkspace('modes')">Режимы клиентов</button>
        <button class="workspace-tab" data-routing-nav="readiness" onclick="showRoutingWorkspace('readiness')">Готовность RU</button>
        <button class="workspace-tab" data-routing-nav="reality" onclick="showRoutingWorkspace('reality')">Факт маршрутов</button>
      </div>
      <article class="panel span-12 workspace-panel" data-routing-workspace="domains" id="policyDomainPanel">
        <div class="toolbar"><div><h2>Группы доменов</h2></div><div class="toolbar-actions"><button class="ghost" onclick="openInfoPanel('routingDomains')">Инф</button><button class="ghost" onclick="renderPolicyDomainPanel()">Обновить</button></div></div>
        <div class="policy-domain-layout">
          <div class="policy-domain-table table-shell" id="v2PolicyDomainTable"></div>
          <div class="policy-domain-tools">
            <div class="filterbar">
              <label class="field compact-field" style="margin:0;min-width:220px"><span>Класс маршрута</span><select id="v2PolicyClass" aria-label="Группа доменов"></select></label>
              <label class="field compact-field" style="margin:0;min-width:240px"><span>Домен</span><input id="v2PolicyDomain" aria-label="Домен" placeholder="alfabank.ru или vk.com"></label>
              <label class="field compact-field" style="margin:0;min-width:160px"><span>Тестовый IP</span><input id="v2PolicyUserIp" aria-label="Тестовый IP" value="10.0.0.3"></label>
              <button class="ghost" onclick="testV2PolicyDomain()">Проверить</button>
              <button class="primary" onclick="addV2PolicyDomain()">Добавить домен</button>
              <button class="ghost" onclick="showV2PolicyBackups()">Бэкапы</button>
            </div>
            <div class="wizard-result is-empty" id="v2PolicyDomainResultWrap"><div id="v2PolicyDomainResult" class="wizard-card"></div></div>
          </div>
        </div>
      </article>
      <article class="panel span-12 workspace-panel" data-routing-workspace="checks" id="routingActionPanel">
        <div class="toolbar"><div><h2>Проверка маршрута</h2></div><div class="toolbar-actions"><button class="ghost" onclick="openInfoPanel('routingChecks')">Инф</button></div></div>
        <div class="filterbar">
          <label class="field" style="margin:0;min-width:220px">Домен<input id="v2RoutingDomain" placeholder="gosuslugi.ru или alfabank.ru"></label>
          <label class="field" style="margin:0;min-width:160px">Тестовый IP<input id="v2RoutingUserIp" value="10.0.0.3"></label>
          <button class="ghost" onclick="testV2RoutingDomain()">Проверить домен</button>
          <button class="ghost" onclick="runV2RoutingMatrix()">Матрица</button>
          <button class="ghost" onclick="runV2ServiceAwareDryRun()">Без изменений</button>
          <button class="ghost" onclick="runV2ServiceAwareApplyPreview()">Что изменится</button>
          <button class="ghost" onclick="runV2ServiceAwareLivePreview()">Живая проверка</button>
          <button class="primary" onclick="runV2ServiceAwareGuardedApply()">Применить</button>
        </div>
        <div class="wizard-result is-empty"><div id="v2RoutingActionResult" class="wizard-card"></div></div>
      </article>
      <article class="panel workspace-panel active routing-overview-main" data-routing-workspace="overview"><div class="toolbar"><div><h2>Маршруты</h2></div><div class="toolbar-actions"><button class="ghost" onclick="showPolicyDomainPanel()">Политика</button><button class="primary" onclick="showRoutingActionPanel()">Матрица</button></div></div><div class="table-shell" id="routeClassesTable"></div></article>
