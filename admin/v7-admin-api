    function openV2OperatorGuide() {
      const rows = v2OperatorScenarios().map(row => `<tr><td><strong>${esc(row.title)}</strong><em>${esc(row.id)}</em></td><td>${esc(row.detail)}</td><td>${esc(row.safety)}</td><td><button class="mini-action" onclick="${esc(row.action)}">${esc(row.action_label)}</button></td></tr>`);
      openDrawer('Сценарии оператора', 'operator', [
