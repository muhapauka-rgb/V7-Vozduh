def smart_client_profile_path(client_name, adapter, mode):
    name = safe_client_name(client_name)
    adapter = safe_smart_adapter(adapter)
    mode = safe_smart_mode(mode)
    if not name or not adapter or not mode:
        return None
    suffix = "txt" if adapter == "happ" else "json"
    path_obj = (SMART_CLIENT_ROOT / name / f"{adapter}-{mode.lower()}.{suffix}").resolve()
    root_resolved = SMART_CLIENT_ROOT.resolve()
    if root_resolved not in path_obj.parents:
        return None
    return path_obj


def domain_matches_suffix(domain, suffixes):
    domain = str(domain or "").lower().strip(".")
    for suffix in suffixes or []:
        suffix = str(suffix or "").lower().strip(".")
        if suffix and (domain == suffix or domain.endswith("." + suffix)):
            return True
    return False


def smart_profile_rule_suffixes(profile, outbound):
    suffixes = []
    for rule in (((profile or {}).get("route") or {}).get("rules") or []):
        if not isinstance(rule, dict) or rule.get("outbound") != outbound:
            continue
        for key in ("domain_suffix", "domain"):
            value = rule.get(key)
            if isinstance(value, str):
                suffixes.append(value.lower().strip("."))
            elif isinstance(value, list):
                suffixes.extend(str(item).lower().strip(".") for item in value if item)
    return sorted(set(item for item in suffixes if item))


def smart_profile_domains_match(profile, outbound, domains):
    suffixes = smart_profile_rule_suffixes(profile, outbound)
    domains = [str(item or "").lower().strip(".") for item in domains if item]
    matched = [domain for domain in domains if domain_matches_suffix(domain, suffixes)]
    missing = [domain for domain in domains if domain not in matched]
    return {
        "outbound": outbound,
        "suffixes_count": len(suffixes),
        "samples": domains[:8],
        "matched": matched[:8],
        "missing": missing[:8],
        "ok": bool(domains) and not missing,
    }


def smart_profile_validation(path_obj, adapter, mode):
    adapter = safe_smart_adapter(adapter)
    mode = safe_smart_mode(mode)
    if not path_obj or not Path(path_obj).exists():
        return {
            "status": "MISSING",
            "plain": "Generate the profile before validating client-side routing.",
            "checks": [],
        }
    if adapter == "happ":
        return {
            "status": "PROXY_ONLY",
            "plain": "happ subscription is a proxy profile. Domain selectors must be handled by the client or a future happ adapter layer.",
            "checks": [{"id": "profile_format", "status": "WARN", "detail": "VLESS subscription text has no embedded domain rules"}],
        }
    profile = read_json(path_obj, {})
    rules = (((profile or {}).get("route") or {}).get("rules") or [])
    outbounds = {(item or {}).get("tag") for item in ((profile or {}).get("outbounds") or []) if isinstance(item, dict)}
    endpoints = {(item or {}).get("tag") for item in ((profile or {}).get("endpoints") or []) if isinstance(item, dict)}
    direct_domains = policy_domain_items("DIRECT_RU") or [".ru", ".xn--p1ai", "yandex.ru", "vk.com", "ozon.ru", "lamoda.ru"]
    sensitive_domains = policy_domain_items("TRUSTED_RU_SENSITIVE") or ["gosuslugi.ru", "esia.gosuslugi.ru", "nalog.gov.ru", "alfabank.ru"]
    video_domains = policy_domain_items("VIDEO_OPTIMIZED") or ["youtube.com", "googlevideo.com"]
    direct_samples = [item.lstrip(".") for item in direct_domains if item][:8]
    sensitive_samples = [item.lstrip(".") for item in sensitive_domains if item][:8]
    video_samples = [item.lstrip(".") for item in video_domains if item][:6]
    direct_match = smart_profile_domains_match(profile, "direct", direct_samples)
    sensitive_direct_match = smart_profile_domains_match(profile, "direct", sensitive_samples)
    video_v7_match = smart_profile_domains_match(profile, "v7-wg", video_samples)
    final_route = (((profile or {}).get("route") or {}).get("final") or "")
    dns_final = (((profile or {}).get("dns") or {}).get("final") or "")
    checks = [
        {"id": "json_profile", "status": "OK" if isinstance(profile, dict) and bool(profile) else "BLOCKED", "detail": "sing-box JSON loaded"},
        {"id": "v7_endpoint", "status": "OK" if "v7-wg" in endpoints else "BLOCKED", "detail": "WireGuard endpoint tag v7-wg"},
        {"id": "direct_outbound", "status": "OK" if "direct" in outbounds else "BLOCKED", "detail": "client direct outbound exists"},
        {"id": "final_global_route", "status": "OK" if final_route == "v7-wg" else "BLOCKED", "detail": f"route.final={final_route or 'missing'}"},
        {"id": "rule_count", "status": "OK" if len(rules) >= 4 else "WARN", "detail": f"{len(rules)} route rules"},
    ]
    if mode == "RU_LOCAL":
        checks.extend([
            {"id": "ordinary_ru_client_direct", "status": "OK" if direct_match.get("ok") else "BLOCKED", "detail": ", ".join(direct_match.get("missing") or []) or "ordinary RU samples route to direct"},
            {"id": "sensitive_ru_client_direct", "status": "OK" if sensitive_direct_match.get("ok") else "BLOCKED", "detail": ", ".join(sensitive_direct_match.get("missing") or []) or "Gosuslugi/banks samples route to direct"},
            {"id": "video_global_v7", "status": "OK" if video_v7_match.get("ok") else "WARN", "detail": ", ".join(video_v7_match.get("missing") or []) or "video samples route to V7"},
            {"id": "dns_local_first", "status": "OK" if dns_final == "local" else "WARN", "detail": f"dns.final={dns_final or 'missing'}"},
        ])
    elif mode in ("ABROAD_RU_VIA_V7", "STRICT_V7"):
        checks.append({"id": "ru_sent_to_v7", "status": "WARN" if final_route == "v7-wg" else "BLOCKED", "detail": "ordinary RU can go through V7, but sensitive RU still needs separate trusted validation for abroad/strict modes"})
    elif mode == "AUTO_TRAVEL":
        selector_tags = {item.get("tag") for item in ((profile or {}).get("outbounds") or []) if isinstance(item, dict) and item.get("type") == "selector"}
        checks.append({"id": "travel_selectors", "status": "OK" if {"ru-mode", "ru-sensitive-mode"}.issubset(selector_tags) else "BLOCKED", "detail": "client selector tags for RU public and sensitive RU"})
    blocked = [row for row in checks if row.get("status") == "BLOCKED"]
    warn = [row for row in checks if row.get("status") == "WARN"]
    status = "BLOCKED" if blocked else ("WARN" if warn else "OK")
    if status == "OK" and mode == "RU_LOCAL":
        plain = "RU_LOCAL profile sends RU/Gosuslugi/banks directly on the client and keeps global/video on V7."
    elif mode in ("ABROAD_RU_VIA_V7", "STRICT_V7") and status != "BLOCKED":
        plain = "Abroad/strict profile routes through V7, but sensitive RU is not production-ready until a trusted server path exists."
    else:
        plain = "Profile needs review before treating client-side routing as solved."
    return {
        "status": status,
        "plain": plain,
        "mode": mode,
        "adapter": adapter,
        "path": str(path_obj),
        "checks": checks,
        "matches": {
            "ordinary_ru_direct": direct_match,
            "sensitive_ru_direct": sensitive_direct_match,
            "video_v7": video_v7_match,
        },
    }


