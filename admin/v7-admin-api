    runtime_mode = str(runtime_mode or "")
    egress_id = safe_egress_id(egress_id)
    if not egress_id:
        return None
    if runtime_mode == "interface" and protocol == "wireguard":
        ifname = ifname or egress_managed_interface_name(egress_id)
        return WIREGUARD_DIR / f"{ifname}.conf"
    if runtime_mode == "interface" and protocol == "amneziawg":
        ifname = ifname or egress_managed_interface_name(egress_id)
        return AMNEZIAWG_DIR / f"{ifname}.conf"
    if runtime_mode in ("proxy_or_tun", "sing_box"):
        return EGRESS_RUNTIME_DIR / egress_id / "config.json"
    return None


def egress_runtime_readiness(egress_id, registry=None):
    egress_id = safe_egress_id(egress_id)
    registry = registry or egress_registry_map().get(egress_id, {})
    if not egress_id or not registry:
        return {"status": "UNKNOWN", "enable_ready": False, "reason": "egress_not_in_registry", "checks": []}

    typ = registry.get("type", "")
    protocol = registry.get("protocol", "")
    enabled = str(registry.get("enabled", "1")) == "1"
    ifname = registry.get("interface", "")
    candidates = egress_runtime_profile_candidates(egress_id, registry)
    existing_profiles = [str(path) for path in candidates if path.exists()]
    checks = [
        {"id": "registry_present", "status": "OK", "detail": "egress is listed in egress.registry"},
        {"id": "pool_enabled_flag", "status": "OK" if enabled else "INFO", "detail": "enabled=1" if enabled else "enabled=0"},
        {"id": "protocol", "status": "OK" if protocol else "WARN", "detail": protocol or "missing"},
        {"id": "type", "status": "OK" if typ else "WARN", "detail": typ or "missing"},
    ]

    if typ == "interface":
        checks.append({"id": "interface_name", "status": "OK" if ifname else "BLOCKED", "detail": ifname or "missing"})
        checks.append({
            "id": "runtime_profile",
            "status": "OK" if existing_profiles else "BLOCKED",
            "detail": existing_profiles[0] if existing_profiles else "no config found in expected interface profile paths",
        })
        live_path = Path("/sys/class/net") / ifname if ifname else None
        interface_live = bool(live_path and live_path.exists())
        checks.append({
            "id": "interface_live_now",
            "status": "OK" if interface_live else ("INFO" if not enabled else "WARN"),
            "detail": "interface exists" if interface_live else "interface is not currently up",
        })
        enable_ready = bool(ifname and existing_profiles)
    elif typ in ("proxy", "tun", "container"):
        checks.append({
            "id": "runtime_profile",
            "status": "OK" if existing_profiles else "WARN",
            "detail": existing_profiles[0] if existing_profiles else "no explicit config path found",
        })
        enable_ready = bool(existing_profiles or egress_id in EGRESS_CONFIG_PATHS)
    else:
        checks.append({"id": "known_type", "status": "BLOCKED", "detail": typ or "missing"})
        enable_ready = False

    blocking = [row for row in checks if row.get("status") == "BLOCKED"]
    warning = [row for row in checks if row.get("status") == "WARN"]
    if blocking:
        status = "BLOCKED"
        reason = blocking[0].get("detail", "")
    elif warning:
        status = "WARN"
        reason = warning[0].get("detail", "")
    else:
        status = "READY" if enable_ready else "UNKNOWN"
        reason = "ready for explicit enable" if enable_ready else "not enough runtime information"

    return {
        "status": status,
        "enable_ready": enable_ready and not blocking,
        "reason": reason,
        "profile_paths_checked": [str(path) for path in candidates],
        "profile_path": existing_profiles[0] if existing_profiles else "",
        "interface": ifname,
        "checks": checks,
    }


