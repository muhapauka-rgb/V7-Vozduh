        <h3>Client Speed Samples</h3>${userSpeed.length ? table(['ip','phone V7','phone direct','drop','v7 ts','direct ts'], userSpeed) : '<div class="muted">No phone samples for this egress yet.</div>'}
        <h3>Recent Speed History</h3>${historyRows.length ? table(['ip','mode','speed','duration ms','time'], historyRows) : '<div class="muted">No recent speed history.</div>'}
