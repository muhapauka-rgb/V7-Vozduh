def security_audit_csv(data):
    def cell(value):
        text = str(value if value is not None else "")
        text = text.replace('"', '""')
        return f'"{text}"'
    headers = ["ts", "severity", "actor", "action", "object_type", "object_id", "result", "request_id", "message"]
    lines = [",".join(headers)]
    for row in data.get("events", []):
        lines.append(",".join(cell(row.get(header, "")) for header in headers))
    return "\n".join(lines) + "\n"


def backups():
    rows = []
    if not BACKUP_DIR.exists():
        return rows
    for path in sorted(BACKUP_DIR.glob("v7-backup-*.tar.gz"), key=lambda p: p.stat().st_mtime, reverse=True):
        sha = path.with_suffix(path.suffix + ".sha256")
        rows.append({
            "name": path.name,
            "path": str(path),
            "size_bytes": path.stat().st_size,
            "mtime": datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat(),
            "sha256_file": sha.exists(),
        })
    return rows


def disk_usage_state(path="/"):
    try:
        usage = shutil.disk_usage(path)
    except OSError as exc:
        return {"error": str(exc)}
    return {
        "path": path,
        "total_bytes": usage.total,
        "used_bytes": usage.used,
        "free_bytes": usage.free,
        "used_pct": round((usage.used / usage.total) * 100, 1) if usage.total else None,
    }


def backup_summary_state(rows=None):
    rows = rows if rows is not None else backups()
    total = sum(int(row.get("size_bytes") or 0) for row in rows)
    return {
        "count": len(rows),
        "total_bytes": total,
        "total_mb": round(total / 1024 / 1024, 2),
        "dir": str(BACKUP_DIR),
    }


