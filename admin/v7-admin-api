def connect_error_view(error):
    code = str((error or {}).get("error") or "")
    message = str((error or {}).get("message") or "Не удалось подключить устройство.")
    hints = {
        "missing_required_fields": "Проверьте, что заполнены все поля. Телефон можно вводить в формате +7.",
        "rate_limited": "Подождите несколько минут и попробуйте снова. Если срочно, напишите оператору.",
        "phone_not_allowed": "Этот телефон ещё не добавлен оператором в список разрешённых.",
        "invalid_connection_password": "Проверьте общий пароль подключения. Это не пароль от приложения и не пароль от телефона.",
        "organization_not_found": "Введите название организации так, как его дал оператор. Если не уверены, уточните у оператора.",
        "organization_mismatch": "Этот телефон привязан к другой организации. Напишите оператору, чтобы он проверил карточку пользователя.",
        "user_blocked": "Пользователь заблокирован. Напишите оператору.",
        "user_disabled": "Пользователь отключён. Напишите оператору.",
        "device_limit_reached": "Лимит устройств исчерпан. Нужно удалить старое устройство или попросить оператора увеличить лимит.",
        "safe_mode_enabled": "Оператор временно включил безопасный режим. Подключение новых устройств остановлено.",
        "provisioning_preflight_failed": "Система не смогла подготовить VPN-профиль. Оператор уже сможет увидеть эту ошибку в админке.",
        "device_create_failed": "Система не смогла создать VPN-пользователя. Оператор уже сможет увидеть эту ошибку в админке.",
        "smart_profile_failed": "VPN-пользователь создан, но профиль приложения не собрался. Оператор уже сможет увидеть эту ошибку в админке.",
        "delivery_create_failed": "Профиль создан, но ссылка выдачи не сформировалась. Оператор уже сможет увидеть эту ошибку в админке.",
    }
    hint = str((error or {}).get("hint") or hints.get(code) or "Попробуйте ещё раз. Если ошибка повторится, напишите оператору.")
    detail = ""
    if code == "device_limit_reached":
        active = html.escape(str((error or {}).get("active_devices", "")))
        maximum = html.escape(str((error or {}).get("max_devices", "")))
        if active and maximum:
            detail = f"<small>Активных устройств: {active} из {maximum}.</small>"
    return {
        "code": code,
        "message": message,
        "hint": hint,
        "detail_html": detail,
    }


def connect_page(result=None, error=None, form_data=None):
    form_data = form_data if isinstance(form_data, dict) else {}
    error_html = ""
    if error:
        ev = connect_error_view(error)
        error_html = f"""
        <div class="notice bad">
          <strong>{html.escape(ev["message"])}</strong>
          <p>{html.escape(ev["hint"])}</p>
          {ev["detail_html"]}
          <small>Код: {html.escape(ev["code"] or "connect_error")}</small>
        </div>
        """
    result_html = ""
    if result:
        profile = result.get("profile", {})
        device = result.get("device", {})
        delivery_url = profile.get("delivery_url", "")
        result_html = f"""
        <div class="notice ok">
          <strong>Готово.</strong><br>
          Устройство создано: {html.escape(device.get("assigned_vpn_ip", ""))}. Ссылка работает один раз и ограничена по времени.
