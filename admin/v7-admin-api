    is_active = 1 if data.get("is_active", True) not in (False, "false", "0", 0) else 0
    with identity_conn() as conn:
        existing = conn.execute("SELECT * FROM allowed_users WHERE phone_normalized=?", (phone,)).fetchone()
        if existing:
            existing = dict(existing)
            allowed_id = existing["id"]
            if "expected_name" not in data and "name" not in data:
                expected_name = existing.get("expected_name", "")
            if "organization_id" not in data:
                org_id = existing.get("organization_id", "")
            if "group_id" not in data:
                group_id = existing.get("group_id", "")
            if "note" not in data:
                note = existing.get("note", "")
            if "is_active" not in data:
                is_active = int(existing.get("is_active") or 0)
        if org_id and not conn.execute("SELECT 1 FROM organizations WHERE id=?", (org_id,)).fetchone():
