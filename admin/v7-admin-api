        "local_ok": sum(1 for row in rows if row["status"] in ("LOCAL_DIRECT_OK", "BROWSER_LIKE_DIRECT_OK")),
        "temporary_ok": sum(1 for row in rows if row["status"] == "TEMP_VLESS_OK"),
        "blocked": sum(1 for row in rows if row["status"] in ("TCP_OR_TLS_BLOCKED", "NO_SERVER_PATH", "DIRECT_BLOCKED")),
        "no_server_path": sum(1 for row in rows if row["status"] == "NO_SERVER_PATH"),
        "total": len(rows),
        "decision": decision,
        "flow_trace": flow,
        "items": rows,
    }


def trusted_ru_readiness_state():
    rows = route_class_registry_rows_with_lines()
    route = next((row for row in rows if row.get("id") == "TRUSTED_RU_SENSITIVE"), {})
    egress_rows = egress_registry_rows(enabled_only=False)
    egress_by_id = {row.get("id"): row for row in egress_rows if row.get("id")}
    active_egress = route.get("active_egress", "")
    egress = egress_by_id.get(active_egress, {}) if active_egress else {}
    matrix = service_matrix_state().get("items", {}).get(active_egress, {}) if active_egress else {}
    services = matrix.get("services") or {}
    diagnostic = trusted_ru_diagnostic_state()
    checks = []

    def add_check(key, label, status, detail=""):
        checks.append({"key": key, "label": label, "status": status, "detail": detail})

    if route:
        add_check("route_class_exists", "Route class exists", "OK", route.get("_line", ""))
    else:
        add_check("route_class_exists", "Route class exists", "BLOCKED", "TRUSTED_RU_SENSITIVE is missing from route-classes.registry")

    add_check("route_class_enabled", "Route class enabled", "OK" if str(route.get("enabled", "0")) == "1" else "BLOCKED", f"enabled={route.get('enabled', '')}")
    add_check("not_temporary", "Route is not temporary", "OK" if str(route.get("temporary", "0")) != "1" else "BLOCKED", f"temporary={route.get('temporary', '')}")
    add_check("active_egress_present", "Dedicated active egress selected", "OK" if active_egress and active_egress != "user_default" else "BLOCKED", active_egress or "empty")
    add_check("active_egress_exists", "Active egress exists in pool", "OK" if egress else "BLOCKED", active_egress or "empty")
    add_check("active_egress_enabled", "Active egress enabled", "OK" if egress and str(egress.get("enabled", "0")) == "1" else "BLOCKED", f"enabled={egress.get('enabled', '')}" if egress else "missing")
    add_check("active_egress_role", "Active egress has trusted RU role", "OK" if egress.get("role") == "TRUSTED_RU_SENSITIVE" else "BLOCKED", f"role={egress.get('role', '') or 'missing'}")
    add_check("active_egress_interface", "Active egress has interface", "OK" if egress.get("interface") else "BLOCKED", egress.get("interface", "missing"))

    service_rows = []
    for service_id in ROUTE_CLASS_SERVICE_MAP.get("TRUSTED_RU_SENSITIVE", ()):
        row = services.get(service_id) or {}
        if not row:
            status = "WARN"
            detail = "not tested"
        else:
            status = "OK" if row.get("ok") else "BLOCKED"
            detail = f"http={row.get('http_code', 'n/a')} first_byte={row.get('first_byte_sec', row.get('total_sec', 'n/a'))}"
        service_rows.append({"service": service_id, "status": status, "detail": detail})

    if not service_rows:
        add_check("service_matrix", "Sensitive RU service matrix", "WARN", "no service matrix samples")
    elif all(row["status"] == "OK" for row in service_rows):
        add_check("service_matrix", "Sensitive RU service matrix", "OK", "all required services passed")
    elif any(row["status"] == "BLOCKED" for row in service_rows):
        add_check("service_matrix", "Sensitive RU service matrix", "BLOCKED", "one or more required services failed")
    else:
        add_check("service_matrix", "Sensitive RU service matrix", "WARN", "one or more services were not tested")

    if int(diagnostic.get("temporary_ok", 0) or 0) > 0:
        add_check("temporary_vless_observed", "Temporary VLESS observed", "WARN", "works for diagnosis, but cannot be the production trusted route")
    if int(diagnostic.get("blocked", 0) or 0) > 0:
        add_check("server_direct_blocked", "Server direct path", "WARN", "some sensitive domains block direct VPS path")

    blocked = [row for row in checks if row.get("status") == "BLOCKED"]
    warnings = [row for row in checks if row.get("status") == "WARN"]
    validation = "BLOCKED" if blocked else ("WARN" if warnings else "READY")
    return redact({
        "updated": now_iso(),
        "validation": validation,
        "route_class": route,
        "active_egress": active_egress,
        "egress": egress,
        "checks": checks,
        "services": service_rows,
        "blockers": blocked,
        "warnings": warnings,
        "diagnostic_summary": {
            "local_direct_ok": diagnostic.get("local_ok", 0),
            "temporary_vless_ok": diagnostic.get("temporary_ok", 0),
            "blocked": diagnostic.get("blocked", 0),
            "total": diagnostic.get("total", 0),
        },
        "next_step": "add_dedicated_trusted_ru_route" if blocked else "run_live_rollout_preview",
    })


def policy_domain_config_state():
    classes = {}
    for class_id, filename in POLICY_DOMAIN_CLASSES.items():
        path = POLICY_DIR / filename
        rows = []
        for line in read_text(path).splitlines():
            value = line.strip()
            if not value or value.startswith("#"):
                continue
            value = value.split("#", 1)[0].strip().lower()
            if value:
                rows.append(value)
        classes[class_id] = {
            "file": str(path),
            "items": rows,
            "count": len(rows),
            "label": POLICY_DOMAIN_CLASS_META.get(class_id, {}).get("label", class_id),
            "plain": POLICY_DOMAIN_CLASS_META.get(class_id, {}).get("plain", ""),
            "permission": POLICY_DOMAIN_CLASS_META.get(class_id, {}).get("permission", ""),
        }
    return {
        "policy_dir": str(POLICY_DIR),
        "classes": classes,
    }


def direct_routing_full(domains=None, user_ip=""):
    users = parse_registry(STATE_DIR / "users.registry")
    user_ip = safe_user_ip(user_ip) or default_active_user_ip(users)
    cleaned = []
    for domain in domains or DIRECT_ROUTING_DOMAINS:
        domain = safe_domain(domain)
        if domain and domain not in cleaned:
            cleaned.append(domain)
    if not cleaned:
        cleaned = list(DIRECT_ROUTING_DOMAINS)

    items = []
    for domain in cleaned[:12]:
        result = run_readonly(["v7-safe-run", "v7-direct-diagnose-domain", domain, user_ip], timeout=14)
        parsed = parse_command_kv(result.get("output", ""))
        route_ok = parsed.get("DIRECT_ROUTE") == "OK"
        https = parsed.get("SERVER_HTTPS", "")
        outcome = parsed.get("V7_DIRECT_DOMAIN_RESULT", "")
        if outcome == "OK":
            level = "ok"
        elif route_ok and https in ("TIMEOUT", "FAIL"):
            level = "warning"
        else:
            level = "bad"
        items.append({
            "domain": domain,
            "level": level,
            "route_ok": route_ok,
            "server_https": https,
            "result": outcome,
            "parsed": parsed,
            "check": result,
        })
    return {
        "updated": now_iso(),
        "user_ip": user_ip,
        "domains": cleaned,
        "items": items,
        "ok_count": sum(1 for item in items if item["level"] == "ok"),
        "warning_count": sum(1 for item in items if item["level"] == "warning"),
        "bad_count": sum(1 for item in items if item["level"] == "bad"),
    }


