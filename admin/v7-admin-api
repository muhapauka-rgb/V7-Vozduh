  <script>
    let csrf = '';
    let overview = {};
    let v2UserFilter = 'all';
    const esc = v => String((v && typeof v === 'object') ? 'служебная запись скрыта' : (v ?? '')).replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
    const jsArg = v => JSON.stringify(String(v ?? '')).replace(/</g, '\\u003c');
    const tone = ok => ok ? 'ok' : 'bad';
    const pill = (text, cls='muted') => `<span class="pill ${cls}">${esc(text)}</span>`;
    const table = (cols, rows) => {
      const body = Array.isArray(rows) ? rows.join('') : String(rows || '');
      return `<table><thead><tr>${cols.map(c=>`<th>${esc(c)}</th>`).join('')}</tr></thead><tbody>${body}</tbody></table>`;
    };
    const kvRows = obj => `<div class="drawer-section"><h3>Сводка</h3>${Object.entries(obj).map(([k,v])=>`<p><span class="muted">${esc(k)}:</span> <strong>${esc(v)}</strong></p>`).join('')}</div>`;
    const drawerSection = (title, body='') => `<div class="drawer-section"><h3>${esc(title)}</h3>${body || '<div class="muted">Нет данных.</div>'}</div>`;
    const revealResult = el => {
      if (!el) return;
      el.classList.remove('is-empty');
      const wrap = el.closest('.wizard-result');
      if (wrap) wrap.classList.remove('is-empty');
    };
    const jsonSection = (title, data) => {
      const keys = data && typeof data === 'object' ? Object.keys(data).length : 0;
      return drawerSection('Служебная информация', `<p>Подробная системная запись скрыта из рабочего интерфейса. Здесь важны статус, причина и следующий шаг.</p><p class="muted">${esc(keys ? `Служебных полей: ${keys}` : 'Служебная запись пуста.')}</p>`);
    };
    const emptyNote = text => `<div class="muted">${esc(text || 'Нет данных.')}</div>`;
    const statusTone = value => {
      const v = String(value || '').toUpperCase();
      if (['OK','READY','PASS','PASSED','ACTIVE','ENABLED','ISSUED','WORKS','GOOD','RU_LOCAL_READY','CLIENT_DIRECT_DEFAULT'].includes(v)) return 'ok';
      if (['FAIL','FAILED','BAD','BLOCKED','DOWN','ERROR','LEAK_RISK'].includes(v)) return 'bad';
      return 'warn';
    };
    const listTable = (cols, rows, empty='Нет данных.') => rows && rows.length ? table(cols, rows) : emptyNote(empty);
    const UI_PREFS_KEY = 'v7.admin.ui.prefs.phase133';
    const ACTIVE_TAB_KEY = 'v7.admin.active.tab.phase134';
    const VALID_TABS = ['overview','users','channels','routing','identity','checks','security','settings','logs'];
    let v7UiPrefs = {};
    function loadUiPrefs() {
      try { v7UiPrefs = JSON.parse(localStorage.getItem(UI_PREFS_KEY) || '{}') || {}; }
      catch { v7UiPrefs = {}; }
      if (!v7UiPrefs.theme) v7UiPrefs.theme = 'dark';
      if (!v7UiPrefs.lang) v7UiPrefs.lang = 'ru';
      if (v7UiPrefs.helperText === undefined) v7UiPrefs.helperText = false;
      if (v7UiPrefs.density === undefined) v7UiPrefs.density = 'comfortable';
    }
    function saveUiPrefs() { localStorage.setItem(UI_PREFS_KEY, JSON.stringify(v7UiPrefs)); }
    function applyUiPrefs() {
      document.body.classList.toggle('light', v7UiPrefs.theme === 'light');
      document.body.classList.toggle('hide-helper-text', v7UiPrefs.helperText !== true);
      document.body.classList.toggle('compact-ui', v7UiPrefs.density === 'compact');
      document.body.classList.toggle('layout-editing', v7UiPrefs.layoutEditing === true);
      document.documentElement.lang = v7UiPrefs.lang || 'ru';
      const themeBtn = document.getElementById('themeBtn');
      const langBtn = document.getElementById('langBtn');
      const layoutBtn = document.getElementById('layoutBtn');
