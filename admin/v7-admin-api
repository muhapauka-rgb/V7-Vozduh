def write_auth_config(data):
    AUTH_FILE.parent.mkdir(parents=True, exist_ok=True)
    if AUTH_FILE.exists():
        backup = AUTH_FILE.with_name(f"{AUTH_FILE.name}.backup.v7-admin-accounts.{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}")
        backup.write_text(AUTH_FILE.read_text(encoding="utf-8", errors="replace"), encoding="utf-8")
        os.chmod(backup, 0o600)
    write_json_atomic(AUTH_FILE, data)
    os.chmod(AUTH_FILE, 0o600)


def auth_config_with_users():
    data = auth_config()
    if not isinstance(data, dict):
        data = {}
    data.setdefault("session_secret", secrets.token_urlsafe(48))
    users = auth_accounts(data)
    data["users"] = users
    data["schema_version"] = max(int(data.get("schema_version", 1) or 1), 2)
    return data


def create_admin_account(actor, username, role, notes=""):
    username = safe_admin_username(username)
    role = normalize_role(role, "")
    if not username:
        return None, {"error": "invalid_admin_username"}
    if role not in ROLE_LEVELS:
        return None, {"error": "invalid_admin_role"}
    data = auth_config_with_users()
    if username in (data.get("users") or {}):
        return None, {"error": "admin_account_exists", "username": username}
    credential = generate_admin_credential()
    now = now_iso()
    data["users"][username] = {
        "username": username,
        "password_hash": hash_password(credential),
        "role": role,
        "enabled": True,
        "created_at": now,
        "updated_at": now,
        "created_by": actor or "admin",
        "notes": str(notes or "")[:240],
    }
    write_auth_config(data)

    return {
        "username": username,
        "role": role,
        "enabled": True,
        "credential_once": credential,
    }, None


def update_admin_account(actor, username, role=None, enabled=None, notes=None, reset=False):
    username = safe_admin_username(username)
    if not username:
        return None, {"error": "invalid_admin_username"}
    data = auth_config_with_users()
    users = data.setdefault("users", {})
    if username not in users:
        return None, {"error": "admin_account_not_found", "username": username}
    account = users[username]
    if role is not None:
        role = normalize_role(role, "")
        if role not in ROLE_LEVELS:
            return None, {"error": "invalid_admin_role"}
        account["role"] = role
    if enabled is not None:
        if username == data.get("username") and enabled is False:
            return None, {"error": "cannot_disable_legacy_owner"}
        account["enabled"] = bool(enabled)
    if notes is not None:
        account["notes"] = str(notes or "")[:240]
    credential = None
    if reset:
        credential = generate_admin_credential()
        account["password_hash"] = hash_password(credential)
    account["updated_at"] = now_iso()
    account["updated_by"] = actor or "admin"
    users[username] = account
    enabled_owner_count = sum(
        1 for row in users.values()
        if row.get("enabled", True) and normalize_role(row.get("role"), "viewer") == "owner"
    )
    if enabled_owner_count < 1:
        return None, {"error": "cannot_leave_system_without_enabled_owner"}
    write_auth_config(data)
    result = {
        "username": username,
        "role": normalize_role(account.get("role"), "viewer"),
        "enabled": bool(account.get("enabled", True)),
    }
    if credential:
        result["credential_once"] = credential
    return result, None


def set_admin_account_password(actor, username, password):
    username = safe_admin_username(username)
    password = str(password or "")
    if not username:
        return None, {"error": "invalid_admin_username"}
    if len(password) < ADMIN_PASSWORD_MIN_LENGTH:
        return None, {"error": "admin_password_too_short", "min_length": ADMIN_PASSWORD_MIN_LENGTH}
    data = auth_config_with_users()
    users = data.setdefault("users", {})
    if username not in users:
        return None, {"error": "admin_account_not_found", "username": username}
    account = users[username]
    account["password_hash"] = hash_password(password)
    account["updated_at"] = now_iso()
    account["updated_by"] = actor or "admin"
    users[username] = account
    if safe_admin_username(data.get("username", "")) == username:
        data["password_hash"] = account["password_hash"]
        data["updated_at"] = account["updated_at"]
    write_auth_config(data)
    return {
        "username": username,
        "role": normalize_role(account.get("role"), "viewer"),
        "enabled": bool(account.get("enabled", True)),
        "password_updated": True,
    }, None


def sync_legacy_account_after_password_rotate(actor):
    data = auth_config()
    username = safe_admin_username(data.get("username", ""))
    password_hash = data.get("password_hash", "")
    if not username or not password_hash:
        return {"synced": False, "reason": "missing_legacy_username_or_hash"}
