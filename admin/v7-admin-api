          <button type="button" data-tab="channels">Каналы</button>
          <button type="button" data-tab="routing">Маршруты</button>
          <button type="button" data-tab="checks">Проверки</button>
          <button type="button" data-tab="security">Безопасность</button>
          <button type="button" data-tab="settings">Настройки</button>
          <button type="button" data-tab="logs">Логи</button>
