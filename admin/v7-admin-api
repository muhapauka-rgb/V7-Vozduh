def client_speed_summary(active_users, client_data):
    by_egress = {}
    for user in active_users:
        ip = user.get("ip", "")
        egress = user.get("current", "")
        if not egress:
            continue
        row = by_egress.setdefault(egress, {"client_v7_values": [], "client_direct_values": [], "users": []})
        row["users"].append(ip)
        latest = ((client_data.get("users") or {}).get(ip) or {}).get("latest") or {}
        v7 = latest.get("v7") or {}
        if v7.get("egress") == egress and isinstance(v7.get("mbps"), (int, float)):
            row["client_v7_values"].append(float(v7["mbps"]))
        direct_items = latest.get("direct") or {}
        direct = direct_items.get(egress) or direct_items.get("_default") or {}
        if isinstance(direct.get("mbps"), (int, float)):
            row["client_direct_values"].append(float(direct["mbps"]))

    for egress, row in by_egress.items():
        v7_values = row.pop("client_v7_values")
        direct_values = row.pop("client_direct_values")
        client_v7 = round(sum(v7_values) / len(v7_values), 2) if v7_values else None
        client_direct = round(sum(direct_values) / len(direct_values), 2) if direct_values else None
        degradation = None
        if client_v7 is not None and client_direct and client_direct > 0:
            degradation = round(max(0.0, (client_direct - client_v7) / client_direct * 100), 1)
        row.update({
            "client_v7_mbps": client_v7,
            "client_direct_mbps": client_direct,
            "degradation_pct": degradation,
            "client_v7_samples": len(v7_values),
            "client_direct_samples": len(direct_values),
        })
    return by_egress


def client_speed_user_rows(active_users, client_data, agents_data):
    rows = {}
    users_data = client_data.get("users") or {}
    agents = agents_data.get("agents") or {}
    for user in active_users:
        ip = user.get("ip", "")
        current = user.get("current", "")
        latest = (users_data.get(ip) or {}).get("latest") or {}
        v7 = latest.get("v7") or {}
        direct = ((latest.get("direct") or {}).get(current) or (latest.get("direct") or {}).get("_default") or {})
        v7_age = age_sec(v7.get("ts"))
        direct_age = age_sec(direct.get("ts"))
        agent = agents.get(ip) or {}
        rows[ip] = {
            "ip": ip,
            "current_egress": current,
            "agent_online": bool(agent.get("online")),
            "agent_last_seen": agent.get("last_seen"),
            "agent_last_seen_age_sec": agent.get("last_seen_age_sec"),
            "v7_mbps": v7.get("mbps"),
            "v7_age_sec": v7_age,
            "v7_fresh": v7_age is not None and v7_age <= CLIENT_SPEED_FRESH_SECONDS,
            "direct_mbps": direct.get("mbps"),
            "direct_age_sec": direct_age,
            "direct_fresh": direct_age is not None and direct_age <= CLIENT_SPEED_FRESH_SECONDS,
        }
    return rows


def create_client_speed_command(ip, actor):
    data = read_json(CLIENT_COMMANDS_FILE, {"updated": now_iso(), "commands": []})
    if not isinstance(data, dict):
        data = {"updated": now_iso(), "commands": []}
    commands = data.setdefault("commands", [])
    command = {
        "id": secrets.token_hex(8),
        "ip": ip,
        "type": "speedtest",
        "mode": "v7",
        "status": "pending",
        "created_at": now_iso(),
        "created_by": actor or "admin",
    }
    commands.append(command)
    data["commands"] = commands[-300:]
    data["updated"] = now_iso()
    write_json_atomic(CLIENT_COMMANDS_FILE, data)
    return command


def client_artifacts_for_ip(ip):
    rows = []
    if not CLIENT_ROOT.exists():
        return rows
    for conf in CLIENT_ROOT.glob("*/*.conf"):
        try:
            text = conf.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        if f"Address = {ip}/32" not in text and f"Address={ip}/32" not in text:
            continue
        name = conf.stem
        qr = conf.with_suffix(".png")
        rows.append({
            "name": name,
            "config_ready": True,
            "qr_ready": qr.exists(),
            "config_url": f"/api/client-artifact?name={name}&type=conf",
            "qr_url": f"/api/client-artifact?name={name}&type=qr" if qr.exists() else None,
            "mtime": datetime.fromtimestamp(conf.stat().st_mtime, timezone.utc).isoformat(),
        })
    return rows


def user_detail(ip):
    users = parse_registry(STATE_DIR / "users.registry")
    user = next((row for row in users if row.get("ip") == ip), None)
    if not user:
        return None
    active_users = [u for u in users if str(u.get("enabled", "1")) == "1"]
    client_speed = client_speed_state()
    agents = client_agents_state()
    matrix = service_matrix_state()
    prefs = service_preferences_state()
    recommendations = service_recommendations(active_users, matrix, prefs)
    route = next((row for row in route_status([user]) if row.get("ip") == ip), None)
