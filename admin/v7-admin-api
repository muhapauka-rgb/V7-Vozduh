def identity_rate_limited(phone, handler=None, window_seconds=900, max_failures=10):
    if not IDENTITY_DB_FILE.exists():
        return False
    cutoff = datetime.fromtimestamp(time.time() - window_seconds, timezone.utc).isoformat()
    phone = normalize_phone(phone)
    ip_address = identity_request_ip(handler)
    with identity_conn() as conn:
        phone_count = 0
        ip_count = 0
        if phone:
            phone_count = int(conn.execute(
                "SELECT count(*) FROM onboarding_attempts WHERE phone_normalized=? AND result='FAIL' AND created_at>=?",
                (phone, cutoff),
            ).fetchone()[0])
        if ip_address:
            ip_count = int(conn.execute(
                "SELECT count(*) FROM onboarding_attempts WHERE ip_address=? AND result='FAIL' AND created_at>=?",
                (ip_address, cutoff),
            ).fetchone()[0])
    return phone_count >= max_failures or ip_count >= max_failures


