    function translateDynamicText(root=document.body) {
      if (!root) return;
      const lang = v7UiPrefs.lang || 'ru';
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
        acceptNode(node) {
          if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          const tag = node.parentElement?.tagName;
          if (node.parentElement?.closest('[data-no-i18n]')) return NodeFilter.FILTER_REJECT;
          if (['SCRIPT','STYLE','TEXTAREA','INPUT','CODE','PRE'].includes(tag)) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      });
      const nodes = [];
      while (walker.nextNode()) nodes.push(walker.currentNode);
      nodes.forEach(node => {
        if (!TEXT_RU_CACHE.has(node)) TEXT_RU_CACHE.set(node, node.nodeValue);
        const ru = TEXT_RU_CACHE.get(node);
        node.nodeValue = lang === 'en' ? translateTextValue(ru) : ru;
      });
      document.querySelectorAll('input[placeholder]').forEach(input => {
        if (input.closest('[data-no-i18n]')) return;
        if (!input.dataset.ruPlaceholder) input.dataset.ruPlaceholder = input.placeholder || '';
        input.placeholder = lang === 'en' ? translateTextValue(input.dataset.ruPlaceholder) : input.dataset.ruPlaceholder;
      });
      document.querySelectorAll('[title]').forEach(el => {
        if (el.closest('[data-no-i18n]')) return;
        if (!el.dataset.ruTitle) el.dataset.ruTitle = el.title || '';
        el.title = lang === 'en' ? translateTextValue(el.dataset.ruTitle) : el.dataset.ruTitle;
      });
    }
