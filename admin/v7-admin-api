def identity_update_access_settings(data, actor):
    identity_init_db()
    updates = {}
    if "default_max_devices" in data:
        try:
            default_max_devices = int(data.get("default_max_devices"))
        except (TypeError, ValueError):
            return None, {"error": "invalid_default_max_devices"}
        if default_max_devices < 1 or default_max_devices > 1000:
            return None, {"error": "invalid_default_max_devices_range", "min": 1, "max": 1000}
        updates["default_max_devices"] = default_max_devices
    if not updates:
        return identity_state()["access_settings"], None
    updates["updated_at"] = now_iso()
    assignments = ", ".join(f"{key}=?" for key in updates)
    with identity_conn() as conn:
        conn.execute(f"UPDATE access_settings SET {assignments} WHERE id=1", tuple(updates.values()))
        conn.commit()
    audit_admin(actor, "identity_access_settings_update", f"fields={','.join(updates.keys())}", object_type="identity_access", object_id="settings", result="OK")
    return identity_state()["access_settings"], None


