      if (v === 'downloaded') return 'Пользователь открыл ссылку выдачи или скачал профиль.';
      if (v === 'no_device') return 'Пользователь есть, но VPN-устройство ещё не выдано.';
      if (v === 'needs_action') return 'Оператору нужно открыть карточку пользователя и выполнить следующий шаг.';
