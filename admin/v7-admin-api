          <div class="wizard-card">
            <h3>Группа и организация</h3>
            <label class="field">Название группы<input id="v2IdentityGroupName" placeholder="default"></label>
            <label class="field">Политика маршрутов<input id="v2IdentityGroupPolicy" placeholder="RU напрямую на устройстве"></label>
            <div class="wizard-actions"><button class="ghost" onclick="v2UpsertIdentityGroup()">Сохранить группу</button></div>
            <label class="field">Организация<input id="v2IdentityOrgName" placeholder="ООО Ромашка"></label>
            <label class="field">Короткое имя<input id="v2IdentityOrgShort" placeholder="Ромашка"></label>
            <label class="field">Группа<select id="v2IdentityOrgGroup"></select></label>
            <div class="wizard-actions"><button class="primary" onclick="v2UpsertIdentityOrganization()">Сохранить организацию</button></div>
          </div>
          <div class="wizard-card">
            <h3>Разрешённый телефон</h3>
            <label class="field">Телефон<input id="v2IdentityAllowedPhone" placeholder="+7 999 123-45-67"></label>
            <label class="field">Имя пользователя<input id="v2IdentityAllowedName" placeholder="Иван"></label>
            <label class="field">Организация<select id="v2IdentityAllowedOrg"></select></label>
            <label class="field">Группа<select id="v2IdentityAllowedGroup"></select></label>
            <label class="field">Заметка оператора<input id="v2IdentityAllowedNote" placeholder="почему телефон разрешён"></label>
            <div class="wizard-actions"><button class="primary" onclick="v2UpsertIdentityAllowedPhone()">Добавить / обновить</button></div>
          </div>
        </div>
        <div class="wizard-result">
          <div class="wizard-card">
            <h3>Массовый импорт телефонов</h3>
            <div class="inline-fields"><label class="field">Организация по умолчанию<select id="v2IdentityImportOrg"></select></label><label class="field">Группа по умолчанию<select id="v2IdentityImportGroup"></select></label></div>
            <label class="field">CSV / lines<textarea id="v2IdentityAllowedImport" placeholder="phone,name,note&#10;+7 999 123-45-67,Ivan,test group"></textarea></label>
            <div class="wizard-actions"><button class="ghost" onclick="v2PreviewAllowedPhones()">Проверить импорт</button><button class="primary" onclick="v2ImportAllowedPhones()">Применить импорт</button></div>
          </div>
          <div id="v2IdentityAccessResult" class="wizard-card is-empty" style="margin-top:12px"></div>
