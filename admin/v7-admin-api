def service_matrix_route_fitness(matrix):
    services = (matrix or {}).get("services") or {}
    fitness = {}
    for route_class, service_ids in ROUTE_CLASS_SERVICE_MAP.items():
        tested = []
        missing = []
        for service_id in service_ids:
            row = services.get(service_id)
            if row:
                tested.append(row)
            else:
                missing.append(service_id)
        ok_count = sum(1 for row in tested if bool(row.get("ok")))
        fail_count = len(tested) - ok_count
        latencies = []
        for row in tested:
            value = row.get("first_byte_sec", row.get("total_sec", 0))
            try:
                latencies.append(float(value))
            except (TypeError, ValueError):
                pass
        if not tested:
            status = "UNKNOWN"
            reason = "not tested yet"
        elif ok_count == len(tested) and not missing:
            status = "OK"
            reason = "all required services passed"
        elif ok_count and fail_count == 0:
            status = "WARN"
            reason = "tested services passed, but some services are not tested"
        elif ok_count:
            status = "WARN"
            reason = "some services passed and some failed"
        else:
            status = "FAIL"
            reason = "tested services failed"
        fitness[route_class] = {
            "status": status,
            "reason": reason,
            "ok_count": ok_count,
            "tested_count": len(tested),
            "missing_count": len(missing),
            "total": len(service_ids),
            "avg_first_byte_sec": round(sum(latencies) / len(latencies), 3) if latencies else None,
            "services": list(service_ids),
            "missing": missing,
        }
    return fitness


def egress_draft_enrich_runtime_result(result, metadata=None):
    if not isinstance(result, dict):
        return result
    matrix = result.get("service_matrix") or {}
    if isinstance(matrix, dict) and matrix.get("services"):
        matrix.setdefault("route_class_fitness", service_matrix_route_fitness(matrix))
        result["service_matrix"] = matrix
        result["route_class_fitness"] = matrix["route_class_fitness"]
        role = safe_egress_role(((metadata or {}).get("usage_policy") or metadata or {}).get("role") or result.get("role") or "GLOBAL_FAST")
        role_fit = matrix["route_class_fitness"].get(role, {})
        result["role_fit"] = {
            "role": role,
            "status": role_fit.get("status", "UNKNOWN"),
            "reason": role_fit.get("reason", "route role was not tested"),
        }
        if role_fit.get("status") == "FAIL":
            result["role_recommendation"] = "Do not use this channel for the selected role unless operator explicitly accepts the risk."
        elif role_fit.get("status") == "WARN":
            result["role_recommendation"] = "Keep as draft/reserve or run a broader service matrix before enabling."
        elif role_fit.get("status") == "OK":
            result["role_recommendation"] = "The tested service matrix fits the selected role."
    return result


