                "user_ip": item.get("user_ip") or extract_user_ip(message),
                "message": message,
                "details": item,
            }
            rows.append(row)
    if source in ("all", "switch"):
        for item in tail_jsonl(EVENT_DIR / "switch-history.jsonl", 400):
