def now_iso():
    return datetime.now(timezone.utc).isoformat()


def b64e(raw):
    return base64.urlsafe_b64encode(raw).decode("ascii").rstrip("=")


def b64d(value):
    padding = "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode(value + padding)


def redact(value):
    if value is None:
        return value
    if isinstance(value, dict):
        return {k: ("[REDACTED]" if SECRET_RE.search(str(k)) else redact(v)) for k, v in value.items()}
    if isinstance(value, list):
        return [redact(v) for v in value]
    if not isinstance(value, str):
        return value
    value = re.sub(r"(PrivateKey|PresharedKey|private_key|preshared_key|password|token|short_id)\s*=\s*\S+", r"\1=[REDACTED]", value, flags=re.I)
    value = re.sub(r'("(?:private_key|preshared_key|password|token|short_id)"\s*:\s*")[^"]+(")', r"\1[REDACTED]\2", value, flags=re.I)
    value = re.sub(r"(?is)<(key|tls-auth|tls-crypt|auth-user-pass)>\s*.*?\s*</\1>", r"<\1>[REDACTED]</\1>", value)
    return value


def read_text(path, default=""):
    try:
        return Path(path).read_text(encoding="utf-8")
    except FileNotFoundError:
        return default
    except OSError as exc:
        return f"ERROR: {exc}"


def read_json(path, default=None):
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return default if default is not None else {}


def write_json_atomic(path, data):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{secrets.token_hex(4)}")
    tmp.write_text(json.dumps(data, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def write_text_atomic(path, text, mode=0o600):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{secrets.token_hex(4)}")
    tmp.write_text(text, encoding="utf-8")
    os.chmod(tmp, mode)
    os.replace(tmp, path)


def deep_merge_defaults(data, defaults):
    merged = json.loads(json.dumps(defaults))
    if not isinstance(data, dict):
        return merged
    for section, value in data.items():
        if isinstance(value, dict) and isinstance(merged.get(section), dict):
            merged[section].update(value)
        else:
            merged[section] = value
    return merged


def parse_ts(value):
    if not value:
        return None
    try:
        text = str(value).replace("Z", "+00:00")
        dt = datetime.fromisoformat(text)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt.timestamp()
    except Exception:
        return None


def age_sec(value):
    ts = parse_ts(value)
    if ts is None:
        return None
    return max(0, int(time.time() - ts))


def auth_config():
    return read_json(AUTH_FILE, {})


def safe_admin_username(value):
    value = str(value or "").strip()
    if not SAFE_ADMIN_USER_RE.match(value):
        return ""
    return value


def hash_password(password, iterations=240000):
    salt = secrets.token_bytes(18)
    digest = hashlib.pbkdf2_hmac("sha256", str(password).encode("utf-8"), salt, iterations)
    return f"pbkdf2_sha256${iterations}${b64e(salt)}${b64e(digest)}"


def generate_admin_credential():
    return secrets.token_urlsafe(18)


def auth_accounts(data=None):
    data = data if isinstance(data, dict) else auth_config()
    users = {}
    raw_users = data.get("users") if isinstance(data.get("users"), dict) else {}
    for username, account in raw_users.items():
        username = safe_admin_username(username)
        if not username or not isinstance(account, dict):
            continue
        users[username] = {
            "username": username,
            "password_hash": account.get("password_hash", ""),
            "role": normalize_role(account.get("role"), "viewer"),
            "enabled": bool(account.get("enabled", True)),
            "created_at": account.get("created_at"),
            "updated_at": account.get("updated_at"),
            "last_login_at": account.get("last_login_at"),
            "notes": str(account.get("notes", ""))[:240],
        }
    legacy_user = safe_admin_username(data.get("username", ""))
    if legacy_user and data.get("password_hash") and legacy_user not in users:
        users[legacy_user] = {
            "username": legacy_user,
            "password_hash": data.get("password_hash", ""),
            "role": normalize_role((data.get("roles") or {}).get(legacy_user) if isinstance(data.get("roles"), dict) else data.get("role"), "owner"),
            "enabled": True,
            "created_at": data.get("created_at"),
            "updated_at": data.get("updated_at"),
            "last_login_at": data.get("last_login_at"),
            "notes": "legacy owner account",
        }
    return users


def auth_configured():
    data = auth_config()
    if not data.get("session_secret"):
        return False
    return any(account.get("enabled") and account.get("password_hash") for account in auth_accounts(data).values())


def role_value(role):
    return ROLE_LEVELS.get(str(role or "").lower(), 0)


def normalize_role(role, default="viewer"):
    role = str(role or default).lower()
    return role if role in ROLE_LEVELS else default


def auth_role(username):
    account = auth_accounts().get(str(username or ""))
    if account:
        return normalize_role(account.get("role"), "viewer")
    return "viewer"


def auth_account(username):
    return auth_accounts().get(str(username or ""))


def admin_accounts_state():
    rows = []
    for username, account in sorted(auth_accounts().items()):
        rows.append({
            "username": username,
            "role": normalize_role(account.get("role"), "viewer"),
            "enabled": bool(account.get("enabled", True)),
            "created_at": account.get("created_at"),
            "updated_at": account.get("updated_at"),
            "last_login_at": account.get("last_login_at"),
            "notes": account.get("notes", ""),
        })
    return {"accounts": rows, "roles": ROLE_DESCRIPTIONS}


def write_auth_config(data):
    AUTH_FILE.parent.mkdir(parents=True, exist_ok=True)
    if AUTH_FILE.exists():
        backup = AUTH_FILE.with_name(f"{AUTH_FILE.name}.backup.v7-admin-accounts.{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}")
        backup.write_text(AUTH_FILE.read_text(encoding="utf-8", errors="replace"), encoding="utf-8")
        os.chmod(backup, 0o600)
    write_json_atomic(AUTH_FILE, data)
    os.chmod(AUTH_FILE, 0o600)


def auth_config_with_users():
    data = auth_config()
    if not isinstance(data, dict):
        data = {}
    data.setdefault("session_secret", secrets.token_urlsafe(48))
    users = auth_accounts(data)
    data["users"] = users
    data["schema_version"] = max(int(data.get("schema_version", 1) or 1), 2)
    return data


def create_admin_account(actor, username, role, notes=""):
    username = safe_admin_username(username)
    role = normalize_role(role, "")
    if not username:
        return None, {"error": "invalid_admin_username"}
    if role not in ROLE_LEVELS:
        return None, {"error": "invalid_admin_role"}
    data = auth_config_with_users()
    if username in (data.get("users") or {}):
        return None, {"error": "admin_account_exists", "username": username}
    credential = generate_admin_credential()
    now = now_iso()
    data["users"][username] = {
        "username": username,
        "password_hash": hash_password(credential),
        "role": role,
        "enabled": True,
        "created_at": now,
        "updated_at": now,
        "created_by": actor or "admin",
        "notes": str(notes or "")[:240],
    }
    write_auth_config(data)

    return {
        "username": username,
        "role": role,
        "enabled": True,
        "credential_once": credential,
    }, None


def update_admin_account(actor, username, role=None, enabled=None, notes=None, reset=False):
    username = safe_admin_username(username)
    if not username:
        return None, {"error": "invalid_admin_username"}
    data = auth_config_with_users()
    users = data.setdefault("users", {})
    if username not in users:
        return None, {"error": "admin_account_not_found", "username": username}
    account = users[username]
    if role is not None:
        role = normalize_role(role, "")
        if role not in ROLE_LEVELS:
            return None, {"error": "invalid_admin_role"}
        account["role"] = role
    if enabled is not None:
        if username == data.get("username") and enabled is False:
            return None, {"error": "cannot_disable_legacy_owner"}
        account["enabled"] = bool(enabled)
    if notes is not None:
        account["notes"] = str(notes or "")[:240]
    credential = None
    if reset:
        credential = generate_admin_credential()
        account["password_hash"] = hash_password(credential)
    account["updated_at"] = now_iso()
    account["updated_by"] = actor or "admin"
    users[username] = account
    enabled_owner_count = sum(
        1 for row in users.values()
        if row.get("enabled", True) and normalize_role(row.get("role"), "viewer") == "owner"
    )
    if enabled_owner_count < 1:
        return None, {"error": "cannot_leave_system_without_enabled_owner"}
    write_auth_config(data)
    result = {
        "username": username,
        "role": normalize_role(account.get("role"), "viewer"),
        "enabled": bool(account.get("enabled", True)),
    }
    if credential:
        result["credential_once"] = credential
    return result, None


def set_admin_account_password(actor, username, password):
    username = safe_admin_username(username)
    password = str(password or "")
    if not username:
        return None, {"error": "invalid_admin_username"}
    if len(password) < ADMIN_PASSWORD_MIN_LENGTH:
        return None, {"error": "admin_password_too_short", "min_length": ADMIN_PASSWORD_MIN_LENGTH}
    data = auth_config_with_users()
    users = data.setdefault("users", {})
    if username not in users:
        return None, {"error": "admin_account_not_found", "username": username}
    account = users[username]
    account["password_hash"] = hash_password(password)
    account["updated_at"] = now_iso()
    account["updated_by"] = actor or "admin"
    users[username] = account
    if safe_admin_username(data.get("username", "")) == username:
        data["password_hash"] = account["password_hash"]
        data["updated_at"] = account["updated_at"]
    write_auth_config(data)
    return {
        "username": username,
        "role": normalize_role(account.get("role"), "viewer"),
        "enabled": bool(account.get("enabled", True)),
        "password_updated": True,
    }, None


def sync_legacy_account_after_password_rotate(actor):
    data = auth_config()
    username = safe_admin_username(data.get("username", ""))
    password_hash = data.get("password_hash", "")
    if not username or not password_hash:
        return {"synced": False, "reason": "missing_legacy_username_or_hash"}
    users = auth_accounts(data)
    account = users.get(username, {
        "username": username,
        "role": "owner",
        "enabled": True,
        "created_at": now_iso(),
        "notes": "legacy owner account",
    })
    account["password_hash"] = password_hash
    account["enabled"] = True
    account["role"] = normalize_role(account.get("role"), "owner")
    account["updated_at"] = now_iso()
    account["updated_by"] = actor or "admin"
    users[username] = account
    data["users"] = users
    data["schema_version"] = max(int(data.get("schema_version", 1) or 1), 2)
    write_auth_config(data)
    return {"synced": True, "username": username, "role": account["role"]}


def role_allows(role, required):
    return role_value(role) >= role_value(required)


def role_state_for_session(session=None):
    username = (session or {}).get("sub") or ""
    role = auth_role(username) if username else "viewer"
    return {
        "user": username,
        "role": role,
        "level": role_value(role),
        "roles": ROLE_DESCRIPTIONS,
        "action_min_role": ACTION_MIN_ROLE,
        "get_min_role": GET_MIN_ROLE,
    }


def verify_password(password, stored):
    try:
        algo, iterations, salt, expected = stored.split("$", 3)
        if algo != "pbkdf2_sha256":
            return False
        digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), b64d(salt), int(iterations))
        return hmac.compare_digest(b64e(digest), expected)
    except Exception:
        return False


def sign_payload(payload_b64, secret):
    return b64e(hmac.new(secret.encode("utf-8"), payload_b64.encode("ascii"), hashlib.sha256).digest())


def make_session(username):
    data = auth_config()
    role = auth_role(username)
    payload = {
        "sub": username,
        "role": role,
        "iat": int(time.time()),
        "exp": int(time.time()) + SESSION_TTL,
        "csrf": secrets.token_urlsafe(24),
    }
    payload_b64 = b64e(json.dumps(payload, separators=(",", ":"), ensure_ascii=True).encode("utf-8"))
    sig = sign_payload(payload_b64, data.get("session_secret", ""))
    return f"{payload_b64}.{sig}", payload


def is_https_request(handler):
    return str(handler.headers.get("X-Forwarded-Proto", "")).lower() == "https"


def cookie_attrs(handler, max_age):
    attrs = ["HttpOnly", "SameSite=Strict", "Path=/", f"Max-Age={max_age}"]
    if is_https_request(handler):
        attrs.insert(0, "Secure")
    return "; ".join(attrs)


def request_client_ip(handler):
    forwarded = str(handler.headers.get("X-Forwarded-For", "")).split(",", 1)[0].strip()
    real_ip = str(handler.headers.get("X-Real-IP", "")).strip()
    return forwarded or real_ip or handler.client_address[0]


def login_failure_key(username, client_ip):
    return f"{client_ip}:{safe_admin_username(username) or 'unknown'}"


def login_throttle_state(username, client_ip):
    now = time.time()
    key = login_failure_key(username, client_ip)
    state = LOGIN_FAILURES.get(key) or {"attempts": [], "locked_until": 0}
    attempts = [item for item in state.get("attempts", []) if now - item <= LOGIN_FAILURE_WINDOW_SECONDS]
    locked_until = float(state.get("locked_until") or 0)
    state = {"attempts": attempts, "locked_until": locked_until}
    LOGIN_FAILURES[key] = state
    if locked_until > now:
        return True, int(locked_until - now)
    return False, 0


def record_login_failure(username, client_ip):
    now = time.time()
    key = login_failure_key(username, client_ip)
    state = LOGIN_FAILURES.get(key) or {"attempts": [], "locked_until": 0}
    attempts = [item for item in state.get("attempts", []) if now - item <= LOGIN_FAILURE_WINDOW_SECONDS]
    attempts.append(now)
    locked_until = float(state.get("locked_until") or 0)
    if len(attempts) >= LOGIN_FAILURE_LIMIT:
        locked_until = now + LOGIN_LOCK_SECONDS
    LOGIN_FAILURES[key] = {"attempts": attempts, "locked_until": locked_until}
    return int(max(0, locked_until - now))


def clear_login_failures(username, client_ip):
