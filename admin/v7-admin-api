    }
    function metric(label, value, detail, ok) {
      return `<article class="metric panel"><span>${esc(label)}</span><strong class="${ok ? 'ok' : 'warn'}">${esc(value)}</strong><em>${esc(detail)}</em></article>`;
    }
    function users() { return overview.registries?.users || []; }
    function activeUsers() { return users().filter(u => String(u.enabled ?? '1') === '1'); }
    function egressRows() {
      const registry = overview.registries?.egress || [];
      const state = overview.state?.egress || {};
      const ids = Array.from(new Set([...registry.map(r=>r.id).filter(Boolean), ...Object.keys(state)]));
      return ids.map(id => ({id, registry: registry.find(r=>r.id===id) || {}, state: state[id] || {}}));
    }
    function egressUserCount(id) { return users().filter(u => u.current === id).length; }
    function formatAge(sec) {
      if (sec === null || sec === undefined || sec === '' || Number(sec) < 0) return 'never';
      const n = Number(sec);
      if (!Number.isFinite(n)) return 'неизвестно';
      if (n < 60) return `${Math.round(n)} сек назад`;
      if (n < 3600) return `${Math.round(n / 60)} мин назад`;
      if (n < 86400) return `${Math.round(n / 3600)} ч назад`;
      return `${Math.round(n / 86400)} дн назад`;
    }
    function humanBytes(value) {
      const n = Number(value || 0);
      if (!Number.isFinite(n) || n <= 0) return value ? String(value) : '';
      const units = ['B','KB','MB','GB','TB'];
      let size = n;
      let unit = 0;
      while (size >= 1024 && unit < units.length - 1) { size /= 1024; unit += 1; }
      return `${size.toFixed(unit ? 1 : 0)} ${units[unit]}`;
    }
    function userReadiness(ip) { return (overview.user_readiness || {})[ip] || {}; }
    function userOnboarding(ip) { return (overview.user_onboarding || {})[ip] || {}; }
    function userSpeed(ip) { return (overview.client_speed_users || {})[ip] || {}; }
    function userRoute(ip) { return (overview.route_reality || []).find(r => r.ip === ip) || {}; }
