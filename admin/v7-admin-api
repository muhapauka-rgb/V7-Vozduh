def safe_admin_username(value):
    value = str(value or "").strip()
    if not SAFE_ADMIN_USER_RE.match(value):
        return ""
    return value


def hash_password(password, iterations=240000):
    salt = secrets.token_bytes(18)
    digest = hashlib.pbkdf2_hmac("sha256", str(password).encode("utf-8"), salt, iterations)
    return f"pbkdf2_sha256${iterations}${b64e(salt)}${b64e(digest)}"


def generate_admin_credential():
    return secrets.token_urlsafe(18)


def auth_accounts(data=None):
    data = data if isinstance(data, dict) else auth_config()
    users = {}
    raw_users = data.get("users") if isinstance(data.get("users"), dict) else {}
    for username, account in raw_users.items():
        username = safe_admin_username(username)
        if not username or not isinstance(account, dict):
            continue
        users[username] = {
            "username": username,
            "password_hash": account.get("password_hash", ""),
            "role": normalize_role(account.get("role"), "viewer"),
            "enabled": bool(account.get("enabled", True)),
            "created_at": account.get("created_at"),
            "updated_at": account.get("updated_at"),
            "last_login_at": account.get("last_login_at"),
            "notes": str(account.get("notes", ""))[:240],
        }
    legacy_user = safe_admin_username(data.get("username", ""))
    if legacy_user and data.get("password_hash") and legacy_user not in users:
        users[legacy_user] = {
            "username": legacy_user,
            "password_hash": data.get("password_hash", ""),
            "role": normalize_role((data.get("roles") or {}).get(legacy_user) if isinstance(data.get("roles"), dict) else data.get("role"), "owner"),
            "enabled": True,
            "created_at": data.get("created_at"),
            "updated_at": data.get("updated_at"),
            "last_login_at": data.get("last_login_at"),
            "notes": "legacy owner account",
        }
    return users


def auth_configured():
