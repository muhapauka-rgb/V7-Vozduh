    .kv span:first-child { color:var(--muted); }
    .detail-actions { display:flex; flex-wrap:wrap; gap:8px; margin:8px 0 10px; }
    section { margin-top:14px; }
    @media (max-width: 900px) { .top, .cols { grid-template-columns:1fr 1fr; } }
    @media (max-width: 900px) { .detail-grid { grid-template-columns:1fr; } }
    @media (max-width: 900px) { .filters { grid-template-columns:1fr 1fr 1fr; } }
    @media (max-width: 620px) { header { align-items:flex-start; gap:8px; flex-direction:column; } main { padding:12px; } .top, .cols, .filters { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <header>
    <div><h1>V7 Admin</h1><div class="muted" id="sub">loading</div></div>
    <div><span id="safeModeBar"></span> <button onclick="load()">Refresh</button> <button onclick="logout()">Sign out</button></div>
  </header>
  <main>
    <div class="grid top" id="metrics"></div>
    <section class="grid cols">
      <div class="card"><h2>Egress</h2><div id="egress"></div></div>
      <div class="card"><h2>Users</h2><div id="users"></div></div>
    </section>
    <section class="grid cols">
      <div class="card"><h2>Route Reality</h2><div id="routes"></div></div>
      <div class="card"><h2>Backups</h2><div id="backups"></div></div>
    </section>
    <section class="card"><h2>Direct / RU Routing</h2><div id="directRu"></div><pre id="directRuFull" style="display:none"></pre></section>
    <section class="card"><h2>Service-aware Policy</h2><div id="routeClasses"></div><pre id="policyRoutePreview"></pre></section>
    <section class="card"><h2>Settings / Policy</h2><div class="filters"><label><span class="label">Cooldown sec</span><input id="policyCooldown" type="number" min="180"></label><label><span class="label">Planned / run</span><input id="policyPlanned" type="number" min="1"></label><label><span class="label">Failover / run</span><input id="policyFailover" type="number" min="1"></label><label><span class="label">Avg Mbps</span><input id="policyAvg" type="number" step="0.1" min="0.1"></label><label><span class="label">Floor Mbps</span><input id="policyFloor" type="number" step="0.1" min="0.1"></label><label><span class="label">Stability</span><input id="policyStability" type="number" step="0.01" min="0" max="1"></label><label><span class="label">Soft limit</span><input id="policySoft" type="number" min="1"></label><label><span class="label">Hard limit</span><input id="policyHard" type="number" min="1"></label><label><span class="label">Rebalance moves</span><input id="policyMoves" type="number" min="1"></label><label><span class="label">Health sec</span><input id="policyHealth" type="number" min="10"></label><label><span class="label">Benchmark sec</span><input id="policyBenchmark" type="number" min="60"></label><label><span class="label">Policy</span><button onclick="savePolicy()">Save Policy</button></label></div><p><button onclick="previewSystemdPolicy()">Systemd Preview</button> <button onclick="applySystemdPolicy()">Apply Systemd Intervals</button></p><div id="policyStatus" class="muted"></div></section>
    <section class="card"><h2>Admin Accounts</h2><div id="adminAccounts" class="muted">loading</div><div class="action-form"><label><span class="label">Username</span><input id="adminAccountName" placeholder="operator-1"></label><label><span class="label">Role</span><select id="adminAccountRole"><option value="viewer">viewer</option><option value="operator">operator</option><option value="admin">admin</option><option value="owner">owner</option></select></label><button onclick="createAdminAccount()">Create Account</button></div></section>
    <section class="card"><h2>Recommendations</h2><div id="recommendations"></div></section>
    <section class="card"><h2>Actions</h2><div class="muted">Safe authenticated actions. Passwords are written to root-only files and never shown here.</div><p><button onclick="action('/api/actions/backup-create')">Create Backup</button> <button onclick="rollbackPreview()">Rollback Preview</button> <button onclick="rollbackApply()">Apply Last Rollback</button> <button onclick="action('/api/actions/password-rotate')">Rotate Password</button></p><div class="action-form"><label><span class="label">Client name</span><input id="newUserName" placeholder="ivan-iphone"></label><label><span class="label">Egress</span><select id="newUserEgress"></select></label><button onclick="createUser()">Create User</button></div><pre id="actions"></pre></section>
    <section class="card"><h2>Diagnostics</h2><pre id="diag"></pre></section>
    <section class="card"><h2>Security Audit</h2><div class="filters"><label><span class="label">Actor</span><input id="securityActor" placeholder="admin"></label><label><span class="label">Action</span><input id="securityAction" placeholder="safe_mode"></label><label><span class="label">Result</span><select id="securityResult"><option value="">any</option><option value="OK">OK</option><option value="FAIL">FAIL</option><option value="DENIED">DENIED</option><option value="BLOCKED">BLOCKED</option></select></label><label><span class="label">Severity</span><select id="securitySeverity"><option value="">any</option><option value="error">error</option><option value="warning">warning</option><option value="info">info</option></select></label><label><span class="label">Object type</span><input id="securityObjectType" placeholder="admin_account"></label><label><span class="label">Limit</span><select id="securityLimit"><option value="50">50</option><option value="120" selected>120</option><option value="300">300</option></select></label></div><p><button onclick="loadSecurityAudit()">Apply Filters</button> <button onclick="clearSecurityAudit()">Clear</button> <button onclick="exportSecurityAudit('json')">Export JSON</button> <button onclick="exportSecurityAudit('csv')">Export CSV</button></p><div id="securitySummary" class="muted"></div><div id="securityAudit"></div></section>
    <section class="card"><h2>Events</h2><div class="filters"><label><span class="label">Source</span><select id="eventSource"><option value="all">all</option><option value="audit">audit</option><option value="switch">switch</option></select></label><label><span class="label">Severity</span><select id="eventSeverity"><option value="">any</option><option value="error">error</option><option value="warning">warning</option><option value="info">info</option></select></label><label><span class="label">Component</span><input id="eventComponent" placeholder="admin"></label><label><span class="label">Action</span><input id="eventAction" placeholder="user_switch"></label><label><span class="label">User IP</span><input id="eventUser" placeholder="10.0.0.3"></label><label><span class="label">Limit</span><select id="eventLimit"><option value="50">50</option><option value="100">100</option><option value="200">200</option></select></label></div><p><button onclick="loadEvents()">Apply Filters</button> <button onclick="clearEventFilters()">Clear</button></p><div id="eventSummary" class="muted"></div><div id="events"></div></section>
  </main>
  <script>
    let csrf = '';
    const chip = (ok, text) => `<span class="chip ${ok ? 'ok' : 'bad'}">${text}</span>`;
    const esc = (v) => String(v ?? '').replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
    const table = (cols, rows) => `<table><thead><tr>${cols.map(c=>`<th>${esc(c)}</th>`).join('')}</tr></thead><tbody>${rows.join('')}</tbody></table>`;
    const enabledEgressRows = (rows) => (rows || []).filter(row => String(row.enabled ?? '1') === '1' && row.id);
    const firstAlternativeEgress = (current, rows) => {
      const candidates = enabledEgressRows(rows).map(row => row.id).filter(id => id !== current);
      return candidates[0] || '';
    };
    const renderEgressSelect = (selectId, rows, selected='') => {
      const select = document.getElementById(selectId);
      if (!select) return;
      const active = enabledEgressRows(rows);
      select.innerHTML = active.map(row => `<option value="${esc(row.id)}" ${row.id === selected ? 'selected' : ''}>${esc(row.id)}</option>`).join('');
      select.disabled = active.length === 0;
    };
    async function load() {
      const sr = await fetch('/api/session', {cache:'no-store'});
      if (sr.status === 401) { location.href = '/login'; return; }
      const sd = await sr.json();
      csrf = sd.csrf || '';
      const r = await fetch('/api/overview', {cache:'no-store'});
      if (r.status === 401) { location.href = '/login'; return; }
      const d = await r.json();
      window.lastOverview = d;
      document.getElementById('sub').textContent = `${d.host} · ${d.bind.host}:${d.bind.port} · ${new Date(d.updated).toLocaleString()} · ${d.access?.user || 'user'}:${d.access?.role || 'viewer'}`;
      renderSafeMode(d.admin_safe_mode || {});
      const s = d.summary;
      const metrics = [
        ['Users', `${s.users_total} / ${s.client_agents_online || 0} online`, true],
        ['Healthy egress', `${s.egress_healthy}/${s.egress_total}`, s.egress_healthy > 0],
        ['Routes OK', `${s.route_ok}/${s.users_total}`, s.route_ok === s.users_total],
        ['Kill switch', s.killswitch_ok ? 'OK' : 'Problem', s.killswitch_ok],
        ['Capacity', s.capacity_ok ? 'OK' : 'Needs /23', s.capacity_ok],
        ['Direct RU', s.direct_ru_route_ok ? 'Route OK' : 'Check', s.direct_ru_route_ok],
        ['State', s.stale_ok ? 'Fresh' : 'Stale', s.stale_ok],
        ['Leak risk', s.route_leak_risk ? 'Yes' : 'No', !s.route_leak_risk],
      ];
      document.getElementById('metrics').innerHTML = metrics.map(m => `<div class="card"><div class="label">${esc(m[0])}</div><div class="metric">${esc(m[1])}</div>${chip(m[2], m[2] ? 'OK' : 'Action')}</div>`).join('');
      const speedItems = (d.speed_tests && d.speed_tests.items) || {};
      const clientSpeed = d.client_speed_summary || {};
      const matrixItems = (d.service_matrix && d.service_matrix.items) || {};
      const egressRegistry = {};
      const egressRows = d.registries?.egress || [];
      egressRows.forEach(row => { if (row.id) egressRegistry[row.id] = row; });
      renderEgressSelect('newUserEgress', egressRows);
      const egressFlags = d.registries?.egress_flags_map || {};
      const eg = Object.entries(d.state.egress || {}).flatMap(([id,e]) => {
        const sp = speedItems[id] || {};
        const cp = clientSpeed[id] || {};
        const mx = matrixItems[id] || {};
        const reg = egressRegistry[id] || {};
        const poolState = egressFlags[`${id}_state`] || (reg.enabled === '0' ? 'disabled' : 'enabled');
        const serverSpeed = sp.server_v7_mbps ? `${sp.server_v7_mbps} Mbps` : 'not measured';
        const phoneV7 = cp.client_v7_mbps ? `${cp.client_v7_mbps} Mbps` : 'client test needed';
        const phoneDirect = cp.client_direct_mbps ? `${cp.client_direct_mbps} Mbps` : 'direct test needed';
        const drop = cp.degradation_pct === null || cp.degradation_pct === undefined ? 'n/a' : `${cp.degradation_pct}%`;
        const matrix = mx.total ? `${mx.ok_count}/${mx.total}` : 'not tested';
        return [
          `<tr><td><button title="Show redacted config, speed history and service matrix" onclick="toggleEgress('${esc(id)}')">Details</button></td><td>${esc(id)}</td><td>${chip(e.code === '200', e.diagnose_severity || e.code)}</td><td>${chip(poolState === 'enabled', poolState)}</td><td>${esc(e.users)}</td><td>${esc(serverSpeed)}</td><td>${esc(phoneV7)}</td><td>${esc(phoneDirect)}</td><td>${esc(drop)}</td><td>${chip(mx.status === 'OK', matrix)}</td><td>${esc(e.load_status)}</td><td><button title="Run manual server speed test" onclick="speedEgress('${esc(id)}')">Speed</button> <button title="Run service matrix" onclick="serviceMatrix('${esc(id)}')">Matrix</button> <button onclick="previewEgressState('${esc(id)}','enabled')">Enable</button> <button onclick="previewEgressState('${esc(id)}','maintenance')">Maintenance</button> <button onclick="previewEgressState('${esc(id)}','disabled')">Disable</button></td></tr>`,
          `<tr id="egress-detail-${esc(id)}" style="display:none"><td colspan="12"><div id="egress-detail-body-${esc(id)}" class="muted">loading...</div></td></tr>`
        ];
      });
      document.getElementById('egress').innerHTML = table(['','id','status','pool','users','server V7','phone V7','phone direct','drop','services','load','test'], eg);
      const users = (d.state.users || []).map(u => {
        const other = firstAlternativeEgress(u.current, egressRows);
        const speed = (d.client_speed_users || {})[u.ip] || {};
        const v7 = speed.v7_mbps ? `${speed.v7_mbps} Mbps` : 'none';
        const freshness = speed.v7_mbps ? (speed.v7_fresh ? 'fresh' : 'stale') : 'no sample';
        const online = speed.agent_online ? 'online' : 'offline';
        const stateAction = u.enabled === '1'
          ? `<button onclick="disableUser('${esc(u.ip)}')">Disable</button>`
          : `<button onclick="enableUser('${esc(u.ip)}')">Enable</button>`;
        const switchAction = other ? `<button onclick="switchUser('${esc(u.ip)}','${esc(other)}')">Switch to ${esc(other)}</button>` : '<span class="muted">no alternate egress</span>';
        return `<tr><td><button onclick="toggleUserDetail('${esc(u.ip)}')">Details</button></td><td>${esc(u.ip)}</td><td>${esc(u.current)}</td><td>${esc(u.table)}</td><td>${chip(u.enabled === '1', u.enabled === '1' ? 'enabled' : 'disabled')}</td><td>${chip(speed.agent_online, online)}</td><td>${esc(v7)} ${chip(speed.v7_fresh, freshness)}</td><td><button onclick="requestClientSpeed('${esc(u.ip)}')">Request Speed</button> <button onclick="userHistory('${esc(u.ip)}')">History</button> ${switchAction} ${stateAction} <button onclick="reissueUserConfig('${esc(u.ip)}')">Reissue Config</button> <button onclick="rotateUserKey('${esc(u.ip)}')">Rotate Key</button></td></tr><tr id="user-detail-${esc(u.ip).replaceAll('.','-')}" style="display:none"><td colspan="8"><pre id="user-detail-pre-${esc(u.ip).replaceAll('.','-')}">loading...</pre></td></tr>`;
      });
      document.getElementById('users').innerHTML = table(['','ip','egress','table','state','agent','phone V7','actions'], users);
      const routes = d.route_reality.map(x => `<tr><td>${esc(x.ip)}</td><td>${esc(x.expected_dev)}</td><td>${chip(x.ok && !x.leak_risk, x.leak_risk ? 'leak risk' : x.ok ? 'OK' : 'check')}</td></tr>`);
      document.getElementById('routes').innerHTML = table(['ip','expected','route'], routes);
      const direct = d.direct_routing || {};
      const directDomains = (direct.domains?.items || []).map(domain => `<tr><td>${esc(domain)}</td><td><button onclick="removeDirectDomain('${esc(domain)}')">Remove</button></td></tr>`);
      document.getElementById('directRu').innerHTML = `${kv({'status': direct.summary || 'unknown', 'test user': direct.user_ip || '', 'quick domain': direct.quick_domain || '', 'route': direct.route_ok ? 'direct via VPS public interface' : 'needs check'})}<div class="action-form"><label><span class="label">Domain / suffix</span><input id="directDomainInput" placeholder=".ru or gosuslugi.ru"></label><label><span class="label">Action</span><button onclick="addDirectDomain()">Add Direct</button></label><button onclick="loadDirectRuFull()">Run Full Direct Check</button></div><h3>Whitelist</h3>${directDomains.length ? table(['domain','action'], directDomains) : '<div class="muted">No direct domains configured.</div>'}<pre>${esc(direct.quick_test?.output || '')}</pre>`;
      renderRouteClasses(d.state?.route_classes || {}, d.state?.policy_apply_preview || {});
      const backups = d.backups.map(b => `<tr><td>${esc(b.name)}</td><td>${Math.round(b.size_bytes/1024)}K</td><td>${chip(b.sha256_file, b.sha256_file ? 'sha' : 'missing')}</td><td><button onclick="verifyBackup('${esc(b.name)}')">Verify</button> <button onclick="previewRestore('${esc(b.name)}')">Restore Preview</button> <button onclick="downloadBackup('${esc(b.name)}')">Download</button></td></tr>`);
      document.getElementById('backups').innerHTML = table(['backup','size','sha','actions'], backups);
      renderPolicy(d.policy || {});
      await loadAdminAccounts();
      const rec = d.service_recommendations || {};
      const prefs = d.service_preferences || {};
      const bestRows = Object.values(rec.best_by_service || {}).map(x => `<tr><td>${esc(x.service)}</td><td>${chip(x.status === 'OK', x.best_egress || 'none')}</td><td>${esc((x.candidates || []).map(c => `${c.egress}:${c.ok ? 'OK' : 'FAIL'}:${c.first_byte_sec ?? 'n/a'}s`).join(' · '))}</td></tr>`);
      const warnRows = (rec.user_warnings || []).map(w => `<tr><td>${esc(w.ip)}</td><td>${esc(w.service)}</td><td>${esc(w.current_egress)}</td><td>${chip(false, w.current_status)}</td><td>${esc(w.recommended_egress)}</td><td><button onclick="switchUser('${esc(w.ip)}','${esc(w.recommended_egress)}')">Switch</button></td></tr>`);
      const prefRows = (d.state.users || []).map(u => {
        const selected = ((prefs.users || {})[u.ip] || {}).services || [];
        const checks = (rec.known_services || []).map(svc => `<label style="display:inline-flex;gap:5px;align-items:center;margin-right:10px"><input type="checkbox" data-pref-ip="${esc(u.ip)}" value="${esc(svc)}" ${selected.includes(svc) ? 'checked' : ''}>${esc(svc)}</label>`).join('');
        return `<tr><td>${esc(u.ip)}</td><td>${checks}</td><td><button onclick="saveUserPrefs('${esc(u.ip)}')">Save</button></td></tr>`;
      });
      document.getElementById('recommendations').innerHTML = `<p>${chip(!!rec.enabled, rec.enabled ? 'recommendations on' : 'recommendations off')} <button onclick="toggleRecommendations(${rec.enabled ? 'false' : 'true'})">${rec.enabled ? 'Disable' : 'Enable'}</button></p><h3>User Service Preferences</h3>${table(['ip','important services','action'], prefRows)}<h3>Best Egress By Service</h3>${table(['service','best','candidates'], bestRows)}<h3>User Warnings</h3>${rec.enabled ? (warnRows.length ? table(['ip','service','current','status','recommended','action'], warnRows) : '<div class="muted">No service mismatches detected for enabled preferences.</div>') : '<div class="muted">Recommendations are disabled.</div>'}`;
      document.getElementById('diag').textContent = ['--- stale ---', d.checks.stale.output, '--- killswitch ---', d.checks.killswitch.output, '--- capacity ---', d.checks.capacity.output, '--- direct routing ---', d.checks.direct_routing.output, '--- rebalance preview ---', d.checks.rebalance_preview.output].join('\\n');
      await loadSecurityAudit();
      await loadEvents();
    }
    function renderRouteClasses(classes, preview) {
      const rows = Object.entries(classes || {}).sort((a, b) => Number(a[1].priority || 999) - Number(b[1].priority || 999)).map(([id, row]) => {
        const temporary = String(row.temporary || '0') === '1';
        const localDirect = row.local_direct || '';
        const mode = row.mode || 'unknown';
        const active = row.active_egress || 'unknown';
        const status = temporary ? '<span class="chip warn">temporary</span>' : chip(String(row.enabled || '1') === '1', String(row.enabled || '1') === '1' ? 'enabled' : 'disabled');
        const note = id === 'TRUSTED_RU_SENSITIVE'
          ? `Sensitive RU. Local direct=${localDirect || 'unknown'}. Active path=${active}.`
          : mode === 'direct'
            ? 'Ordinary direct route through V7 public interface.'
            : active === 'user_default'
              ? 'Falls back to existing per-user sticky egress.'
              : '';
        return `<tr><td>${esc(id)}</td><td>${esc(mode)}</td><td>${esc(active)}</td><td>${esc(row.mark || '')} / ${esc(row.table || '')}</td><td>${esc(row.domains || '0')}</td><td>${status}</td><td>${esc(note)}</td></tr>`;
      });
      const previewBox = {
        validation: preview.validation || 'unknown',
        live_marks: preview.live_marks || 'disabled',
        user_routes_changed: preview.user_routes_changed || '0',
        updated: preview.updated || 'never',
        messages: preview.messages || 'none',
      };
      document.getElementById('routeClasses').innerHTML = `${kv(previewBox)}<div class="action-form"><label><span class="label">Domain</span><input id="policyDomainInput" placeholder="www.gosuslugi.ru" value="www.gosuslugi.ru"></label><label><span class="label">User IP</span><input id="policyDomainUser" placeholder="10.0.0.3" value="10.0.0.3"></label><button onclick="testPolicyDomain()">Test Domain</button></div><p><button onclick="runPolicyRoutePreview()">Refresh Apply Preview</button></p>${rows.length ? table(['class','mode','active path','mark/table','domains','state','note'], rows) : '<div class="muted">No route classes in state.</div>'}`;
      document.getElementById('policyRoutePreview').textContent = 'Live service-aware marks are disabled. This panel is preview/status only.';
    }
    async function testPolicyDomain() {
      const domain = document.getElementById('policyDomainInput').value.trim();
      const userIp = document.getElementById('policyDomainUser').value.trim();
      const el = document.getElementById('policyRoutePreview');
      el.textContent = 'testing service-aware domain policy...';
      const d = await postJson('/api/actions/policy-domain-test', {domain, user_ip: userIp});
      el.textContent = JSON.stringify(d.result || d, null, 2);
    }
    async function runPolicyRoutePreview() {
      const el = document.getElementById('policyRoutePreview');
      el.textContent = 'refreshing service-aware policy preview...';
      const d = await postJson('/api/actions/policy-route-preview', {});
      el.textContent = JSON.stringify(d.result || d, null, 2);
      await load();
    }
    function renderSafeMode(mode) {
      const enabled = !!mode.enabled;
      const label = enabled ? 'Safe Mode ON' : 'Live Mode';
      const cls = enabled ? 'warn' : 'ok';
      const title = enabled ? 'Mutation actions are blocked by the backend' : 'Mutation actions are allowed';
      document.getElementById('safeModeBar').innerHTML = `<span title="${esc(title)}" class="chip ${cls}">${esc(label)}</span> <button onclick="toggleSafeMode()">${enabled ? 'Disable Safe Mode' : 'Enable Safe Mode'}</button>`;
    }
    async function toggleSafeMode() {
      const current = !!(window.lastOverview?.admin_safe_mode?.enabled);
      const confirmation = current
        ? prompt('Disable Safe Mode and allow admin mutations again? Type DISABLE_SAFE_MODE to continue.')
        : prompt('Enable Safe Mode? Mutating admin actions will be blocked. Type SAFE_MODE to continue.');
      const expected = current ? 'DISABLE_SAFE_MODE' : 'SAFE_MODE';
      if (confirmation !== expected) return;
      const el = document.getElementById('actions');
      el.textContent = current ? 'disabling safe mode...' : 'enabling safe mode...';
      const d = await postJson('/api/actions/safe-mode-set', {enabled: !current, confirm: confirmation});
      el.textContent = JSON.stringify(d, null, 2);
      await load();
    }
    function renderPolicy(policy) {
      const sw = policy.switch || {};
      const q = policy.quality || {};
      const l = policy.load || {};
      const it = policy.intervals || {};
      document.getElementById('policyCooldown').value = sw.cooldown_seconds ?? 180;
      document.getElementById('policyPlanned').value = sw.autoswitch_max_planned_per_run ?? 1;
      document.getElementById('policyFailover').value = sw.autoswitch_max_failover_per_run ?? 25;
      document.getElementById('policyAvg').value = q.min_avg_mbps ?? 15;
      document.getElementById('policyFloor').value = q.min_floor_mbps ?? 10;
      document.getElementById('policyStability').value = q.min_stability ?? 0.45;
      document.getElementById('policySoft').value = l.soft_limit ?? 1;
      document.getElementById('policyHard').value = l.hard_limit ?? 2;
      document.getElementById('policyMoves').value = l.rebalance_max_moves_per_run ?? 1;
      document.getElementById('policyHealth').value = it.health_seconds ?? 30;
      document.getElementById('policyBenchmark').value = it.benchmark_seconds ?? 300;
      document.getElementById('policyStatus').textContent = `updated=${policy.updated || 'default'} by=${policy.updated_by || 'system'}; service intervals are stored now and will be applied to systemd loops in a separate safe step`;
    }
    async function savePolicy() {
      const payload = {
        switch: {
          cooldown_seconds: Number(document.getElementById('policyCooldown').value),
          autoswitch_max_planned_per_run: Number(document.getElementById('policyPlanned').value),
          autoswitch_max_failover_per_run: Number(document.getElementById('policyFailover').value),
        },
        quality: {
          min_avg_mbps: Number(document.getElementById('policyAvg').value),
          min_floor_mbps: Number(document.getElementById('policyFloor').value),
          min_stability: Number(document.getElementById('policyStability').value),
        },
        load: {
          soft_limit: Number(document.getElementById('policySoft').value),
          hard_limit: Number(document.getElementById('policyHard').value),
          rebalance_max_moves_per_run: Number(document.getElementById('policyMoves').value),
        },
        intervals: {
          health_seconds: Number(document.getElementById('policyHealth').value),
          benchmark_seconds: Number(document.getElementById('policyBenchmark').value),
        },
      };
