def identity_import_allowed_phones(data, actor):
    text = str(data.get("text") or data.get("csv") or "")
    if not text.strip():
        return None, {"error": "allowed_phones_import_empty"}
    preview, error = identity_preview_allowed_phones(data)
    if error:
        return None, error
    valid_rows = [row for row in preview.get("rows", []) if row.get("valid")]
    if preview.get("error_count"):
        return None, {"error": "allowed_phones_import_has_errors", "preview": preview}
    if not valid_rows:
        return None, {"error": "allowed_phones_import_no_valid_rows", "preview": preview}
    rows = []
    errors = []
    for item in valid_rows:
        row_data, row_error = identity_upsert_allowed_phone(item.get("payload", {}))
        if row_error:
            errors.append({"line": item.get("line"), "phone": item.get("phone_raw"), "error": row_error})
            continue
        rows.append(row_data)
    audit_admin(actor, "admin_action_identity_allowed_phones_import", f"imported={len(rows)} errors={len(errors)}", object_type="identity_allowed_phone", object_id="bulk", result="OK" if not errors else "PARTIAL")
    return {"imported": len(rows), "errors": errors[:50], "allowed_users": rows, "preview": preview}, None


def identity_preview_allowed_phones(data):
    identity_init_db()
    text = str(data.get("text") or data.get("csv") or "")
    if not text.strip():
        return None, {"error": "allowed_phones_import_empty"}
    default_org_id = safe_identity_id(data.get("organization_id", ""))
    default_group_id = safe_identity_id(data.get("group_id", ""))
    default_note = clean_identity_text(data.get("note", ""), 500)
    with identity_conn() as conn:
        if default_org_id and not conn.execute("SELECT 1 FROM organizations WHERE id=?", (default_org_id,)).fetchone():
            return None, {"error": "organization_not_found", "organization_id": default_org_id}
        if default_group_id and not conn.execute("SELECT 1 FROM groups WHERE id=?", (default_group_id,)).fetchone():
            return None, {"error": "group_not_found", "group_id": default_group_id}
        existing_phones = {row["phone_normalized"] for row in conn.execute("SELECT phone_normalized FROM allowed_users").fetchall()}
    reader = csv.reader(io.StringIO(text.replace("\r\n", "\n").replace("\r", "\n")))
    raw_rows = [row for row in reader if any(str(cell).strip() for cell in row)]
    if not raw_rows:
        return None, {"error": "allowed_phones_import_empty"}
    header = [str(cell or "").strip().lower() for cell in raw_rows[0]]
    has_header = "phone" in header or "телефон" in header
    data_rows = raw_rows[1:] if has_header else raw_rows
    rows = []
    seen = set()
    for index, row in enumerate(data_rows, start=2 if has_header else 1):
        mapped = {}
        if has_header:
            for key, value in zip(header, row):
                mapped[key] = str(value or "").strip()
            phone = mapped.get("phone") or mapped.get("телефон") or ""
            expected_name = mapped.get("name") or mapped.get("expected_name") or mapped.get("имя") or ""
            org_id = safe_identity_id(mapped.get("organization_id") or mapped.get("org_id") or "") or default_org_id
            group_id = safe_identity_id(mapped.get("group_id") or "") or default_group_id
            note = mapped.get("note") or mapped.get("заметка") or default_note
        else:
            phone = str(row[0] if len(row) > 0 else "").strip()
            expected_name = str(row[1] if len(row) > 1 else "").strip()
            note = str(row[2] if len(row) > 2 else default_note).strip()
            org_id = default_org_id
            group_id = default_group_id
        phone_normalized = normalize_phone(phone)
        row_errors = []
        if not phone_normalized:
            row_errors.append("invalid_phone")
        if phone_normalized and phone_normalized in seen:
            row_errors.append("duplicate_in_import")
        seen.add(phone_normalized)
        if org_id or group_id:
            with identity_conn() as conn:
                if org_id and not conn.execute("SELECT 1 FROM organizations WHERE id=?", (org_id,)).fetchone():
                    row_errors.append("organization_not_found")
                if group_id and not conn.execute("SELECT 1 FROM groups WHERE id=?", (group_id,)).fetchone():
                    row_errors.append("group_not_found")
        payload = {
            "phone": phone,
            "expected_name": expected_name,
            "organization_id": org_id,
            "group_id": group_id,
            "note": clean_identity_text(note, 500),
            "is_active": True,
        }
        rows.append({
            "line": index,
            "phone_raw": phone,
            "phone_normalized": phone_normalized,
            "expected_name": clean_identity_text(expected_name, 160),
            "organization_id": org_id,
            "group_id": group_id,
            "note": clean_identity_text(note, 500),
            "existing": phone_normalized in existing_phones if phone_normalized else False,
            "valid": not row_errors,
            "errors": row_errors,
            "payload": payload,
        })
    return {
        "row_count": len(rows),
        "valid_count": len([row for row in rows if row.get("valid")]),
        "error_count": len([row for row in rows if not row.get("valid")]),
        "existing_count": len([row for row in rows if row.get("existing")]),
        "has_header": has_header,
        "rows": rows[:300],
    }, None


