def killswitch_summary(check_result, status_result=None):
    output = (check_result or {}).get("output", "")
    kv_data = parse_command_kv(output)
    result = kv_data.get("V7_KILLSWITCH_CHECK", "UNKNOWN")
    warnings = [line for line in str(output).splitlines() if line.startswith("WARN:")]
    essential_rules = {
        "table": kv_data.get("table", ""),
        "client_source_set": kv_data.get("client_source_set", ""),
        "direct_leak_drop_rule": kv_data.get("direct_leak_drop_rule", ""),
        "direct_whitelist_rule": kv_data.get("direct_whitelist_rule", ""),
        "direct_fwmark_rule": kv_data.get("direct_fwmark_rule", ""),
        "direct_fwmark_precedes_user_rules": kv_data.get("direct_fwmark_precedes_user_rules", ""),
        "direct_route_table": kv_data.get("direct_route_table", ""),
        "direct_mark_rule": kv_data.get("direct_mark_rule", ""),
        "dns_capture_udp": kv_data.get("dns_capture_udp", ""),
        "dns_capture_tcp": kv_data.get("dns_capture_tcp", ""),
    }
    rule_values = [value for value in essential_rules.values() if value]
    rules_present = bool(rule_values) and all(value in ("present", "OK") for value in rule_values)
    check_rc = (check_result or {}).get("rc")
    normalized = result
    if result in ("OK", "REBUILDING"):
        normalized = result
    elif check_rc == 0 and rules_present and not warnings:
        normalized = "OK"
    elif check_rc == 124:
        normalized = "TIMEOUT"
    elif check_rc == 127:
        normalized = "COMMAND_ERROR"
    elif result == "UNKNOWN":
        normalized = "CHECK"
    ok = normalized in ("OK", "REBUILDING")
    summary = {
        "result": result,
        "normalized_status": normalized,
        "ok": ok,
        "vpn_subnet": kv_data.get("vpn_subnet", ""),
        "public_if": kv_data.get("public_if", ""),
        **essential_rules,
        "warnings": len(warnings),
        "rules_present": rules_present,
        "ssh_lockout_guard": "status_only_no_rule_changes",
        "admin_ssh_scope": "server_ssh_is_not_filtered_by_v7_forward_chain",
        "status_rc": (status_result or {}).get("rc"),
        "check_rc": check_rc,
    }
    if not ok:
        summary["reason"] = " / ".join(warnings[:3]) or f"result={result} rc={check_rc}"
    return summary


def ip_in_cidr(ip_value, cidr_value):
    try:
        return ipaddress.ip_address(str(ip_value)) in ipaddress.ip_network(str(cidr_value), strict=False)
    except ValueError:
        return False


def capacity_pool_row(label, cidr, capacity, users, mode):
    rows = [row for row in users if row.get("ip") and ip_in_cidr(row.get("ip"), cidr)]
    active = [row for row in rows if str(row.get("enabled", "1")) == "1"]
    used = len(rows)
    free = max(int(capacity) - used, 0)
    pct = round((used / int(capacity)) * 100, 1) if int(capacity) > 0 else 0
    return {
        "label": label,
        "cidr": cidr,
        "mode": mode,
        "capacity": int(capacity),
        "registered": used,
        "active": len(active),
        "free": free,
        "used_pct": pct,
        "sample_ips": [row.get("ip") for row in rows[:5]],
    }


def capacity_state(capacity_result, readiness_result, ipam_preview_result, users):
    capacity_kv = parse_command_kv((capacity_result or {}).get("output", ""))
    readiness_kv = parse_command_kv((readiness_result or {}).get("output", ""))
    ipam_kv = parse_command_kv((ipam_preview_result or {}).get("output", ""))
    readiness = readiness_kv.get("V7_CAPACITY_READINESS", "UNKNOWN")
    legacy_capacity = int(readiness_kv.get("legacy_capacity") or ipam_kv.get("current_limit_10_0_0_0_24") or 253)
    ipam_capacity = int(readiness_kv.get("planned_ipam_capacity") or ipam_kv.get("target_limit_10_7_0_0_22") or 1022)
    ipam_cidr = readiness_kv.get("planned_ipam_pool") or ipam_kv.get("target_cidr") or "10.7.0.0/22"
    target_users = int(readiness_kv.get("target_users") or capacity_kv.get("target_users") or 500)
    active_users = len([row for row in users if str(row.get("enabled", "1")) == "1"])
    total_capacity = legacy_capacity + ipam_capacity
    total_registered = len(users)
    pools = [
        capacity_pool_row("Current users", "10.0.0.0/24", legacy_capacity, users, "existing clients stay here"),
        capacity_pool_row("New users IPAM", ipam_cidr, ipam_capacity, users, "new clients are allocated here"),
    ]
    warnings = []
    if readiness == "WARN":
        warnings.append("legacy /24 alone is intentionally too small for 500 users; staged IPAM pool is required")
    elif readiness not in ("OK", "WARN"):
        warnings.append("capacity readiness check needs attention")
    if active_users > total_capacity:
        warnings.append("registered active users exceed planned capacity")
    next_allocation = {
        "ip": readiness_kv.get("next_ip") or ipam_kv.get("sample_01_ip", "").split(" ")[0],
        "table": readiness_kv.get("next_table") or "",
    }
    return {
        "status": readiness,
        "target_users": target_users,
        "active_users": active_users,
        "registered_users": total_registered,
        "total_capacity": total_capacity,
        "free_capacity": max(total_capacity - total_registered, 0),
        "pools": pools,
        "next_allocation": next_allocation,
        "capacity_result": capacity_kv.get("V7_CAPACITY_RESULT", "UNKNOWN"),
        "readiness_result": readiness,
        "plain": "Existing users remain in 10.0.0.0/24. New users should be issued from the IPAM pool 10.7.0.0/22 after preview.",
        "warnings": warnings,
    }


def run_readonly(cmd, timeout=12):
    try:
        proc = subprocess.run(
            cmd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            check=False,
        )
        return {
            "cmd": cmd,
            "rc": proc.returncode,
            "output": redact(proc.stdout[-12000:]),
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "cmd": cmd,
            "rc": 124,
            "output": redact((exc.stdout or "") + "\nTIMEOUT"),
        }
    except OSError as exc:
        return {
            "cmd": cmd,
            "rc": 127,
            "output": f"ERROR: {exc}",
        }


def run_action(cmd, actor, timeout=40, extra_env=None):
    env = os.environ.copy()
    env["V7_ACTOR"] = actor or "admin"
    if extra_env:
        env.update(extra_env)
    try:
        proc = subprocess.run(
            cmd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            check=False,
            env=env,
        )
        return {
            "cmd": cmd,
            "rc": proc.returncode,
            "output": redact(proc.stdout[-12000:]),
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "cmd": cmd,
            "rc": 124,
            "output": redact((exc.stdout or "") + "\nTIMEOUT"),
        }
    except OSError as exc:
        return {
            "cmd": cmd,
            "rc": 127,
            "output": f"ERROR: {exc}",
        }


def audit_admin(actor, action, message, **fields):
    merged = infer_admin_audit_fields(action, message)
    merged.update({k: v for k, v in fields.items() if v is not None and str(v) != ""})
    extra = [f"{k}={v}" for k, v in merged.items()]
    try:
        subprocess.run(
            ["v7-audit-log", action, "admin", message, *extra],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
            env={**os.environ, "V7_ACTOR": actor or "admin"},
        )
    except OSError:
        return


def file_age(path):
    try:
        return int(time.time() - Path(path).stat().st_mtime)
    except OSError:
        return None


def tail_jsonl(path, limit=30):
    path = Path(path)
    if not path.exists():
        return []
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()[-limit:]
    out = []
    for line in lines:
        try:
            out.append(redact(json.loads(line)))
        except json.JSONDecodeError:
            out.append({"raw": redact(line)})
    return out


def infer_event_severity(event):
    explicit = str(event.get("severity", "")).lower()
    if explicit in ("error", "warning", "info"):
        return explicit
    text = " ".join(str(event.get(k, "")) for k in ("severity", "action", "component", "message", "reason")).lower()
    if any(word in text for word in ("fail", "failed", "error", "down", "leak", "blocked")):
        return "error"
    if any(word in text for word in ("warn", "stale", "quarantine", "rollback", "disable", "rotate")):
        return "warning"
    if any(word in text for word in ("ok", "create", "verify", "preview", "switch", "enable", "reissue")):
        return "info"
    return "info"


def extract_user_ip(text):
    match = re.search(r"\b10\.0\.0\.[0-9]{1,3}\b", str(text or ""))
    return match.group(0) if match else ""


def infer_admin_audit_fields(action, message):
    text = f"{action} {message}".lower()
    result = "OK"
    if any(word in text for word in ("failed", "invalid", "blocked", "error")):
        result = "FAIL"
    if "dry_run=true" in text:
        result = "DRY_RUN"
    object_type = "admin"
    if "user" in action:
        object_type = "user"
    elif "egress" in action or "service_matrix" in action or "service_preferences" in action:
        object_type = "egress"
    elif "backup" in action:
        object_type = "backup"
    elif "rollback" in action:
        object_type = "rollback"
    elif "password" in action or "login" in action or "auth" in action:
        object_type = "admin_auth"
    object_id = ""
    for key in ("ip", "egress", "backup", "name", "username"):
        match = re.search(rf"\b{key}=([^ ]+)", message)
        if match:
            object_id = match.group(1)
            break
    severity = "info"
    if result == "FAIL":
        severity = "error"
    elif any(word in text for word in ("rotate", "disable", "rollback")):
        severity = "warning"
    return {
        "severity": severity,
        "object_type": object_type,
        "object_id": object_id,
        "result": result,
        "request_id": secrets.token_hex(8),
    }


def normalized_events(source="all", limit=80, component="", action="", severity="", user_ip=""):
    limit = max(1, min(int(limit or 80), 300))
    rows = []
    if source in ("all", "audit"):
        for item in tail_jsonl(AUDIT_FILE, 400):
            if not isinstance(item, dict):
                continue
            message = str(item.get("message", ""))
            row = {
                "source": "audit",
                "ts": item.get("ts"),
                "severity": infer_event_severity(item),
                "host": item.get("host"),
                "actor": item.get("actor", "unknown"),
                "component": item.get("component", "core"),
                "action": item.get("action", "event"),
                "object_type": item.get("object_type", ""),
                "object_id": item.get("object_id", ""),
                "result": item.get("result", ""),
                "request_id": item.get("request_id", ""),
                "user_ip": item.get("user_ip") or extract_user_ip(message),
                "message": message,
                "details": item,
            }
            rows.append(row)
    if source in ("all", "switch"):
        for item in tail_jsonl(EVENT_DIR / "switch-history.jsonl", 400):
            if not isinstance(item, dict):
                continue
            from_egress = item.get("from", "unknown")
            to_egress = item.get("to", "unknown")
            reason = item.get("reason", "unknown")
            user = item.get("user_ip", "")
            row = {
                "source": "switch",
                "ts": item.get("ts"),
                "severity": infer_event_severity(item),
                "host": item.get("host"),
                "actor": "system",
                "component": "routing",
                "action": "user_switch",
                "object_type": "user",
                "object_id": user,
                "result": "OK",
                "request_id": "",
                "user_ip": user,
                "message": f"{user}: {from_egress} -> {to_egress} reason={reason}",
                "details": item,
            }
            rows.append(row)

    if component:
        rows = [row for row in rows if str(row.get("component", "")).lower() == component.lower()]
    if action:
        rows = [row for row in rows if str(row.get("action", "")).lower() == action.lower()]
    if severity:
        rows = [row for row in rows if str(row.get("severity", "")).lower() == severity.lower()]
    if user_ip:
        rows = [row for row in rows if row.get("user_ip") == user_ip]

    rows.sort(key=lambda row: parse_ts(row.get("ts")) or 0, reverse=True)
    rows = rows[:limit]

    return redact({
        "updated": now_iso(),
        "source": source,
        "limit": limit,
        "filters": {
            "component": component,
            "action": action,
            "severity": severity,
            "user_ip": user_ip,
        },
        "events": rows,
        "summary": {
            "total": len(rows),
            "error": sum(1 for row in rows if row.get("severity") == "error"),
            "warning": sum(1 for row in rows if row.get("severity") == "warning"),
            "info": sum(1 for row in rows if row.get("severity") == "info"),
        },
    })


def security_audit(actor="", action="", result="", severity="", object_type="", limit=120):
    limit = max(1, min(int(limit or 120), 1000))
    rows = []
    security_prefixes = ("admin_", "admin", "backup", "rollback", "policy", "egress_set_state", "user_")
    for item in tail_jsonl(AUDIT_FILE, 2000):
        if not isinstance(item, dict):
            continue
        row_action = str(item.get("action", ""))
        row_object_type = str(item.get("object_type", ""))
        row_actor = str(item.get("actor", "unknown"))
        row_result = str(item.get("result", ""))
        row_severity = infer_event_severity(item)
        message = str(item.get("message", ""))
        action_lower = row_action.lower()
        if not (
            row_object_type.startswith("admin")
            or action_lower.startswith(security_prefixes)
            or "blocked" in action_lower
            or "denied" in action_lower
            or "login" in action_lower
            or "auth" in action_lower
        ):
            continue
        row = {
            "ts": item.get("ts"),
            "severity": row_severity,
            "actor": row_actor,
            "action": row_action,
            "component": item.get("component", ""),
            "object_type": row_object_type,
            "object_id": item.get("object_id", ""),
            "result": row_result,
            "request_id": item.get("request_id", ""),
            "message": message,
            "details": item,
        }
        rows.append(row)

    if actor:
        rows = [row for row in rows if row.get("actor", "").lower() == actor.lower()]
    if action:
        rows = [row for row in rows if action.lower() in row.get("action", "").lower()]
    if result:
        rows = [row for row in rows if str(row.get("result", "")).lower() == result.lower()]
    if severity:
        rows = [row for row in rows if str(row.get("severity", "")).lower() == severity.lower()]
    if object_type:
        rows = [row for row in rows if str(row.get("object_type", "")).lower() == object_type.lower()]

    rows.sort(key=lambda row: parse_ts(row.get("ts")) or 0, reverse=True)
    rows = rows[:limit]
    summary = {
        "total": len(rows),
        "error": sum(1 for row in rows if row.get("severity") == "error"),
        "warning": sum(1 for row in rows if row.get("severity") == "warning"),
        "info": sum(1 for row in rows if row.get("severity") == "info"),
        "blocked_or_denied": sum(
            1 for row in rows
            if str(row.get("result", "")).upper() in ("BLOCKED", "DENIED", "FAIL")
            or "blocked" in str(row.get("action", "")).lower()
            or "denied" in str(row.get("action", "")).lower()
        ),
        "unique_actors": sorted({row.get("actor", "unknown") for row in rows}),
    }
    return redact({
        "updated": now_iso(),
        "filters": {"actor": actor, "action": action, "result": result, "severity": severity, "object_type": object_type, "limit": limit},
        "summary": summary,
        "events": rows,
    })


