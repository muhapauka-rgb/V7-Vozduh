    .field textarea { min-height:154px; resize:vertical; font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    .inline-fields { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .wizard-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
    .wizard-result { border-top:1px solid var(--line); padding:14px 18px 18px; }
    .flow-steps { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px; margin-top:12px; }
    .flow-step { border:1px solid var(--line); background:var(--panel2); border-radius:8px; padding:10px; min-height:72px; }
    .flow-step strong { display:block; margin-bottom:6px; font-size:12px; }
    .detail-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
    code { font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; white-space:normal; overflow-wrap:anywhere; color:var(--blue); }
    .alert-list { padding:0 14px 14px; display:grid; gap:8px; max-height:314px; overflow:auto; }
    .alert-row { display:flex; justify-content:space-between; gap:12px; align-items:flex-start; }
    .alert-row strong, .check-card strong, .route-card strong { display:block; }
    .alert-row em, .check-card em, .route-card em { display:block; margin-top:4px; color:var(--muted); font-style:normal; font-size:12px; }
    .drawer { position:fixed; inset:0; z-index:60; background:rgba(0,0,0,.42); display:none; justify-content:flex-end; }
    .drawer.open { display:flex; }
    .drawer aside { width:min(560px,100%); height:100%; overflow:auto; background:var(--panel2); border-left:1px solid var(--line); }
    .drawer-head { position:sticky; top:0; z-index:2; background:var(--panel2); border-bottom:1px solid var(--line); padding:18px 20px; display:flex; justify-content:space-between; gap:12px; align-items:center; }
    .drawer h2 { margin:4px 0 0; font-size:22px; max-width:380px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .drawer-body { padding:16px 20px 92px; }
    .drawer-section { border:1px solid var(--line); background:var(--panel); border-radius:8px; padding:14px; margin-top:12px; }
    .drawer-section h3 { margin:0 0 10px; font-size:13px; }
    .drawer pre { white-space:pre-wrap; overflow:auto; max-height:320px; color:var(--muted); }
    .drawer-actionbar { position:sticky; bottom:0; background:var(--panel2); border-top:1px solid var(--line); padding:12px 20px; display:flex; gap:8px; justify-content:flex-end; }
    @media(max-width:1450px){ .top-status span:nth-child(2), .top-status a.ghost{display:none} }
    @media(max-width:1200px){ .grid-metrics{grid-template-columns:repeat(2,minmax(0,1fr));}.overview-grid,.split,.wizard-grid{grid-template-columns:1fr}.span-8,.span-6,.span-4{grid-column:span 12}.cards-grid,.stat-grid,.flow-steps{grid-template-columns:repeat(2,minmax(0,1fr))}.top-status span:nth-child(n+3){display:none} }
    @media(max-width:720px){
      .app-top{height:auto;min-height:56px}
      .top-inner{height:auto;min-height:56px;padding:8px 12px 10px;align-items:flex-start;flex-wrap:wrap;gap:8px;position:relative}
      .left{width:100%;align-items:flex-start;flex-wrap:wrap;gap:8px;padding-right:108px}
      .brand{height:32px;display:flex;align-items:center}
      .nav{order:2;width:100%;height:38px;gap:4px;padding-bottom:2px;scroll-snap-type:x proximity;scrollbar-width:none}
      .nav::-webkit-scrollbar{display:none}
      .nav-group-label{display:none}
      .nav-divider{height:20px;margin:0 2px}
      .nav button{height:34px;padding:0 10px;flex:0 0 auto;border:1px solid transparent;border-radius:999px;scroll-snap-align:start}
      .nav button.active{color:var(--green);border-color:rgba(52,211,153,.26);background:rgba(52,211,153,.10)}
      .nav button.active:after{display:none}
      .top-status{position:absolute;right:12px;top:8px;gap:6px}
      .top-status span,.top-status a.ghost{display:none}
      .top-status .ghost{min-height:32px;padding:4px 9px}
      .shell{padding:12px}
      .grid-metrics,.cards-grid,.stat-grid,.flow-steps{grid-template-columns:1fr}
      .module-hero{align-items:flex-start;flex-direction:column;padding:16px}
      .module-hero h1{font-size:22px}
      .module-hero p{font-size:13px}
      .module-hero > button,.module-hero .primary{width:100%}
      .topology{grid-template-columns:1fr}
      .arrow{display:none}
      .toolbar{padding:14px 14px 10px}
      .toolbar-actions{width:100%}
      .toolbar-actions .ghost,.toolbar-actions .primary{flex:1 1 auto}
      .workspace-tabs{padding:8px;overflow:auto;flex-wrap:nowrap;scrollbar-width:none}
      .workspace-tabs::-webkit-scrollbar{display:none}
      .workspace-tab{flex:0 0 auto}
      .stat-card,.metric{padding:14px}
      .table-shell{max-height:360px}
      th,td{padding:9px 12px}
      .drawer-head{padding:14px 16px}
      .drawer-body{padding:12px 16px 88px}
      .drawer-actionbar{padding:10px 16px}
    }
  </style>
</head>
<body>
  <header class="app-top">
    <div class="top-inner">
      <div class="left">
        <div class="brand">V7</div>
        <nav class="nav" id="tabs">
          <span class="nav-group-label">Статус</span>
          <button type="button" data-tab="overview" class="active">Главная</button>
          <span class="nav-divider"></span>
          <span class="nav-group-label">Работа</span>
          <button type="button" data-tab="users">Пользователи</button>
          <button type="button" data-tab="channels">Каналы</button>
          <button type="button" data-tab="routing">Маршруты</button>
          <span class="nav-divider"></span>
          <span class="nav-group-label">Контроль</span>
          <button type="button" data-tab="checks">Проверки</button>
          <button type="button" data-tab="security">Безопасность</button>
          <span class="nav-divider"></span>
          <span class="nav-group-label">Система</span>
          <button type="button" data-tab="settings">Настройки</button>
          <button type="button" data-tab="logs">Логи</button>
        </nav>
      </div>
      <div class="top-status">
        <span id="topSystem">загрузка</span>
        <span id="topUsers"></span>
        <span id="topAlerts"></span>
        <button class="ghost" onclick="openV2OperatorGuide()">Сценарии</button>
        <button class="ghost" onclick="openV2NavigationMap()">Карта</button>
        <button class="ghost" onclick="load()">Обновить</button>
        <a class="ghost" href="/" style="text-decoration:none">Старая админка</a>
      </div>
    </div>
  </header>
  <main class="shell">
    <section id="tab-overview" class="tab-page active">
      <div class="grid-metrics" id="metrics"></div>
      <article class="panel" style="margin-bottom:16px"><div class="toolbar"><div><h2>Сценарии оператора</h2><p>Самые частые действия без поиска по разделам. Тяжёлые операции всё равно идут через preview и подтверждение.</p></div><button class="ghost" onclick="openV2OperatorGuide()">Карта сценариев</button></div><div class="cards-grid" id="operatorScenarioCards" style="padding:0 16px 16px"></div></article>
      <div class="overview-grid">
        <article class="panel">
          <h2><span>Карта трафика <span class="pill ok">live</span><div class="panel-sub">Пользователи -> V7 aggregator -> каналы -> сервисы</div></span><button class="ghost" onclick="showTab('routing')">Открыть маршруты</button></h2>
          <div class="topology" id="topology"></div>
        </article>
        <article class="panel">
          <h2><span>Важные события<div class="panel-sub">Только то, где может понадобиться действие оператора.</div></span><button class="ghost" onclick="showTab('logs')">Все логи</button></h2>
          <div class="alert-list" id="alerts"></div>
        </article>
      </div>
      <div class="split">
        <article class="panel"><div class="toolbar"><div><h2>Активные пользователи</h2><p>Короткие строки, детали открываются в боковой панели.</p></div><button class="ghost" onclick="showTab('users')">Все пользователи</button></div><div class="table-shell" id="overviewUsers"></div></article>
        <article class="panel"><div class="toolbar"><div><h2>Каналы</h2><p>Здоровье, роль, скорость и покрытие сервисов.</p></div><button class="ghost" onclick="showTab('channels')">Все каналы</button></div><div class="table-shell" id="overviewChannels"></div></article>
      </div>
    </section>

    <section id="tab-users" class="tab-page"><div class="module-page">
      <article class="panel module-hero"><div><h1>Пользователи</h1><p>Люди, устройства, профили, доступ и подключение в одном рабочем пространстве.</p></div><button class="primary" onclick="showIssueProfilePanel('new')">Добавить пользователя</button></article>
      <div class="stat-grid span-12" id="userStats"></div>
      <article class="panel span-12">
        <div class="toolbar"><div><h2>Рабочие зоны</h2><p>Основной экран остаётся коротким. Глубокие действия открываются отдельными зонами и drawer.</p></div><div class="toolbar-actions"><button class="ghost" onclick="showTab('identity')">Доступ и выдача</button></div></div>
        <div class="cards-grid">
          <button class="check-card" onclick="showTab('users')"><strong>VPN-пользователи</strong><em>IP, канал, готовность, маршрут, скорость и следующий шаг.</em><span class="pill ok">основной список</span></button>
          <button class="check-card" onclick="showIssueProfilePanel('identity')"><strong>Выдать профиль</strong><em>Выбор человека, приложения, RU_LOCAL режима и одноразовой ссылки.</em><span class="pill info">мастер</span></button>
          <button class="check-card" onclick="showIdentityWorkspace('people')"><strong>Доступ и телефоны</strong><em>Кто может подключаться: телефоны, группы, организации, лимиты устройств.</em><span class="pill info">внутри пользователей</span></button>
          <button class="check-card" onclick="showIdentityWorkspace('access')"><strong>Настройки входа</strong><em>Пароль подключения, импорт телефонов и правила допуска.</em><span class="pill warn">редко</span></button>
        </div>
      </article>
      <article class="panel span-12"><div class="toolbar"><div><h2>Таблица пользователей</h2><p>Одна компактная строка на человека. Маршрут, скорость и выдача профиля открываются в drawer.</p></div><div class="toolbar-actions"><button class="ghost" onclick="showV2UserColumns()">Столбцы</button></div></div><div class="filterbar" id="userFilterBar"></div><div class="searchbar"><input id="userSearchV2" placeholder="Поиск: имя, IP, канал..."></div><div class="table-shell" id="usersTableV2"></div></article>
    </div></section>

    <section id="tab-channels" class="tab-page"><div class="module-page">
      <article class="panel module-hero"><div><h1>Каналы</h1><p>Внешние VPN/egress-каналы: здоровье, роль, сервисы, скорость и готовность.</p></div><div class="toolbar-actions"><button class="ghost" onclick="openV2SectionGuide('channels')">Карта раздела</button><button class="primary" onclick="showAddChannelWizard()">Добавить канал</button></div></article>
      <div class="stat-grid span-12" id="channelStats"></div>
      <div class="workspace-tabs">
        <button class="workspace-tab active" data-channel-nav="overview" onclick="showChannelWorkspace('overview')">Обзор</button>
        <button class="workspace-tab" data-channel-nav="onboarding" onclick="showAddChannelWizard()">Добавить канал</button>
        <button class="workspace-tab" data-channel-nav="matrix" onclick="showChannelWorkspace('matrix')">Сервисная матрица</button>
        <button class="workspace-tab" data-channel-nav="readiness" onclick="showChannelWorkspace('readiness')">Готовность и скорость</button>
      </div>
      <article class="panel span-12 workspace-panel" data-channel-workspace="onboarding" id="channelWizard">
        <div class="toolbar"><div><h2>Добавление канала</h2><p>Безопасный путь: распознать, сохранить черновик, preflight, изолированный runtime-тест, quarantine, добавить выключенным, подготовить runtime.</p></div><div class="toolbar-actions"><button class="ghost" onclick="hideAddChannelWizard()">Закрыть</button><button class="ghost" onclick="loadV2EgressDrafts()">Обновить черновики</button></div></div>
        <div class="wizard-grid">
          <div class="wizard-card">
            <h3>1. Источник</h3>
            <label class="field">Название<input id="v2EgressDraftLabel" placeholder="netherlands-vless-1"></label>
            <label class="field">Файл конфига<input id="v2EgressDraftFile" type="file" accept=".conf,.json,.ovpn,.yaml,.yml,.txt" onchange="loadV2EgressDraftFile()"></label>
            <label class="field">QR-код<input id="v2EgressDraftQr" type="file" accept="image/*" onchange="loadV2EgressDraftQr()"></label>
            <label class="field">Конфиг / ссылка / ручной ввод<textarea id="v2EgressDraftConfig" placeholder="[Interface]... или vless://... или sing-box JSON"></textarea></label>
            <div class="wizard-actions"><button class="ghost" onclick="previewV2EgressDraft()">Распознать</button><button class="primary" onclick="saveV2EgressDraft()">Сохранить черновик</button></div>
          </div>
          <div class="wizard-card">
            <h3>2. Роль и лимиты</h3>
            <label class="field">Роль маршрута<select id="v2EgressDraftRole"></select></label>
            <div class="inline-fields"><label class="field">Приоритет<input id="v2EgressDraftPriority" type="number" min="1" max="999" placeholder="20"></label><label class="field">Вес<input id="v2EgressDraftWeight" type="number" min="0" max="1000" placeholder="100"></label></div>
            <div class="inline-fields"><label class="field">Мягкий лимит<input id="v2EgressDraftSoft" type="number" min="0" placeholder="1"></label><label class="field">Жёсткий лимит<input id="v2EgressDraftHard" type="number" min="0" placeholder="2"></label></div>
            <label class="field">Теги сервисов<input id="v2EgressDraftServiceTags" placeholder="youtube,telegram,global"></label>
            <label class="field">Не использовать для классов<input id="v2EgressDraftExclude" placeholder="TRUSTED_RU_SENSITIVE,DIRECT_RU"></label>
            <label class="field"><input id="v2EgressDraftReserveOnly" type="checkbox" style="width:auto;height:auto"> Только резерв</label>
            <label class="field"><input id="v2EgressDraftManualOnly" type="checkbox" style="width:auto;height:auto"> Только вручную</label>
          </div>
          <div class="wizard-card">
            <h3>3. Безопасный путь</h3>
            <div id="v2EgressDraftSteps"></div>
          </div>
        </div>
        <div class="wizard-result">
          <div id="v2EgressDraftResult" class="wizard-card">Ожидаю конфиг.</div>
          <h2 style="padding-left:0">Сохранённые черновики</h2>
          <div class="table-shell" id="v2EgressDrafts"></div>
        </div>
      </article>
      <article class="panel span-12 workspace-panel active" data-channel-workspace="overview"><div class="toolbar"><div><h2>Список каналов</h2><p>Одна строка на туннель: здоровье, роль, пользователи, сервисы, скорость, нагрузка и готовность. Конфиги и опасные действия открываются в drawer.</p></div><div class="toolbar-actions"><button class="ghost" onclick="showChannelWorkspace('matrix')">Сервисная матрица</button><button class="ghost" onclick="showChannelWorkspace('readiness')">Готовность</button></div></div><div class="table-shell" id="channelsTableV2"></div></article>
      <article class="panel span-12 workspace-panel" data-channel-workspace="matrix"><div class="toolbar"><div><h2>Сервисная матрица</h2><p>Какие сервисы работают на каждом канале. Эти данные не запускают тесты сами по себе, а показывают последние сохранённые измерения.</p></div><div class="toolbar-actions"><button class="ghost" onclick="openDrawer('Service Matrix','channel', serviceMatrixText())">Технический JSON</button></div></div><div class="table-shell" id="channelsMatrixTable"></div></article>
      <article class="panel span-12 workspace-panel" data-channel-workspace="readiness"><div class="toolbar"><div><h2>Готовность и скорость</h2><p>Можно ли включать канал, есть ли runtime-профиль, какая скорость на сервере и у клиентов.</p></div><div class="toolbar-actions"><button class="ghost" onclick="renderChannelReadinessWorkspace()">Обновить вид</button></div></div><div class="table-shell" id="channelsReadinessTable"></div></article>
    </div></section>

    <section id="tab-routing" class="tab-page"><div class="module-page">
      <article class="panel module-hero"><div><h1>Маршруты</h1><p>Куда идёт трафик: RU_LOCAL на клиенте, глобальные сервисы через V7, доменные группы и безопасные preview.</p></div><div class="toolbar-actions"><button class="ghost" onclick="openV2SectionGuide('routing')">Карта раздела</button><button class="ghost" onclick="showRoutingActionPanel()">Preview политики</button><button class="primary" onclick="showPolicyDomainPanel()">Группы доменов</button></div></article>
      <div class="stat-grid span-12" id="routingStats"></div>
      <div class="workspace-tabs">
        <button class="workspace-tab active" data-routing-nav="overview" onclick="showRoutingWorkspace('overview')">Обзор</button>
        <button class="workspace-tab" data-routing-nav="domains" onclick="showPolicyDomainPanel()">Группы доменов</button>
        <button class="workspace-tab" data-routing-nav="checks" onclick="showRoutingActionPanel()">Проверка</button>
        <button class="workspace-tab" data-routing-nav="modes" onclick="showRoutingWorkspace('modes')">Режимы клиентов</button>
        <button class="workspace-tab" data-routing-nav="readiness" onclick="showRoutingWorkspace('readiness')">Готовность RU</button>
        <button class="workspace-tab" data-routing-nav="reality" onclick="showRoutingWorkspace('reality')">Факт маршрутов</button>
      </div>
      <article class="panel span-12 workspace-panel" data-routing-workspace="domains" id="policyDomainPanel">
        <div class="toolbar"><div><h2>Группы доменов</h2><p>Какие домены относятся к DIRECT_RU, TRUSTED_RU_SENSITIVE и другим классам маршрутов.</p></div><div class="toolbar-actions"><button class="ghost" onclick="hidePolicyDomainPanel()">Закрыть</button><button class="ghost" onclick="renderPolicyDomainPanel()">Обновить</button></div></div>
        <div class="filterbar">
          <label class="field" style="margin:0;min-width:220px">Класс маршрута<select id="v2PolicyClass"></select></label>
          <label class="field" style="margin:0;min-width:240px">Домен<input id="v2PolicyDomain" placeholder="alfabank.ru или vk.com"></label>
          <label class="field" style="margin:0;min-width:160px">Тестовый IP<input id="v2PolicyUserIp" value="10.0.0.3"></label>
          <button class="ghost" onclick="testV2PolicyDomain()">Проверить</button>
          <button class="primary" onclick="addV2PolicyDomain()">Добавить домен</button>
          <button class="ghost" onclick="showV2PolicyBackups()">Backup</button>
        </div>
        <div class="wizard-result"><div id="v2PolicyDomainResult" class="wizard-card">Выберите класс и домен.</div></div>
        <div class="table-shell" id="v2PolicyDomainTable"></div>
      </article>
      <article class="panel span-12 workspace-panel" data-routing-workspace="checks" id="routingActionPanel">
        <div class="toolbar"><div><h2>Проверка маршрута</h2><p>Проверки без переноса пользователей. Guarded apply меняет только registry классов после явного подтверждения.</p></div><div class="toolbar-actions"><button class="ghost" onclick="hideRoutingActionPanel()">Закрыть</button></div></div>
        <div class="filterbar">
          <label class="field" style="margin:0;min-width:220px">Домен<input id="v2RoutingDomain" placeholder="gosuslugi.ru или alfabank.ru"></label>
          <label class="field" style="margin:0;min-width:160px">Тестовый IP<input id="v2RoutingUserIp" value="10.0.0.3"></label>
          <button class="ghost" onclick="testV2RoutingDomain()">Проверить домен</button>
          <button class="ghost" onclick="runV2RoutingMatrix()">Матрица</button>
          <button class="ghost" onclick="runV2ServiceAwareDryRun()">Dry Run</button>
          <button class="ghost" onclick="runV2ServiceAwareApplyPreview()">Apply Preview</button>
          <button class="ghost" onclick="runV2ServiceAwareLivePreview()">Live Preview</button>
          <button class="primary" onclick="runV2ServiceAwareGuardedApply()">Guarded Apply</button>
        </div>
        <div class="wizard-result"><div id="v2RoutingActionResult" class="wizard-card">Выберите домен или запустите preview. Ничего не меняется до подтверждения guarded apply.</div></div>
      </article>
      <article class="panel span-8 workspace-panel active" data-routing-workspace="overview"><h2><span>Классы трафика<div class="panel-sub">Задача маршрута, текущий путь и влияние на пользователей.</div></span></h2><div class="table-shell" id="routeClassesTable"></div></article>
      <article class="panel span-4 workspace-panel active" data-routing-workspace="overview"><h2><span>RU состояние<div class="panel-sub">Обычные RU и чувствительные RU.</div></span></h2><div class="cards-grid" id="ruState"></div></article>
      <article class="panel span-12 workspace-panel" data-routing-workspace="modes"><h2><span>Режимы клиентов<div class="panel-sub">Что отфильтровывается на телефоне или ноутбуке до попадания трафика в V7.</div></span></h2><div class="table-shell" id="routeModesTable"></div></article>
      <article class="panel span-12 workspace-panel" data-routing-workspace="readiness"><h2><span>Готовность чувствительных RU<div class="panel-sub">Почему Госуслуги, банки и государственные сервисы готовы, заблокированы или временные.</div></span></h2><div class="table-shell" id="trustedReadinessTable"></div></article>
      <article class="panel span-12 workspace-panel" data-routing-workspace="reality"><h2><span>Факт маршрутов<div class="panel-sub">Ожидаемый маршрут против фактически увиденного маршрута.</div></span></h2><div class="table-shell" id="routeReality"></div></article>
