        count = 0
    for idx in range(1, count + 1):
        domain = raw.get(f"item_{idx}_domain", "")
        if not domain:
            continue
        items.append({
            "domain": domain,
            "decision": raw.get(f"item_{idx}_decision", ""),
            "path": raw.get(f"item_{idx}_path", ""),
            "direct": raw.get(f"item_{idx}_direct", ""),
            "vless": raw.get(f"item_{idx}_vless", ""),
