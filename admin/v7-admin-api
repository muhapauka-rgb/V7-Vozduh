def parse_command_kv(output):
    data = {}
    for line in str(output or "").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if re.match(r"^[A-Za-z0-9_]+$", key):
            data[key] = value
    return data


def _egress_preview_ini_sections(text):
    sections = {}
    current = ""
    for raw in text.splitlines():
        line = raw.split("#", 1)[0].split(";", 1)[0].strip()
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            current = line[1:-1].strip()
            sections.setdefault(current, {})
            continue
        if current and "=" in line:
            key, value = [part.strip() for part in line.split("=", 1)]
            sections.setdefault(current, {})[key] = value
    return sections


def _egress_preview_openvpn_fields(text):
    fields = {
        "client": False,
        "remote": "",
        "proto": "",
        "dev": "",
        "auth": False,
        "cert": False,
        "key": False,
        "auth_user_pass": False,
        "scripts": [],
        "redirect_gateway": False,
        "pull_filter": False,
    }
    script_keys = {"up", "down", "route-up", "route-pre-down", "ipchange", "client-connect", "client-disconnect", "learn-address"}
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith(("#", ";")):
            continue
        parts = line.split()
        key = parts[0].lower()
        value = " ".join(parts[1:]).strip()
        if key == "client":
            fields["client"] = True
        elif key == "remote" and not fields["remote"]:
            fields["remote"] = value
        elif key == "proto" and not fields["proto"]:
            fields["proto"] = value
        elif key == "dev" and not fields["dev"]:
            fields["dev"] = value
        elif key in {"auth", "cipher", "data-ciphers"}:
            fields["auth"] = True
        elif key == "cert" or line.lower().startswith("<cert>"):
            fields["cert"] = True
        elif key == "key" or line.lower().startswith("<key>"):
            fields["key"] = True
        elif key == "auth-user-pass":
            fields["auth_user_pass"] = True
        elif key == "redirect-gateway":
            fields["redirect_gateway"] = True
        elif key == "pull-filter":
            fields["pull_filter"] = True
        elif key == "script-security" or key in script_keys:
            fields["scripts"].append(line[:120])
    return fields


OPENVPN_SCRIPT_DIRECTIVES = {
    "script-security", "up", "down", "route-up", "route-pre-down", "ipchange",
    "client-connect", "client-disconnect", "learn-address", "tls-verify",
}
OPENVPN_ROUTE_DIRECTIVES = {
    "redirect-gateway", "route", "route-ipv6", "pull-filter", "route-nopull",
    "route-delay", "redirect-private",
}
OPENVPN_SAFE_DIRECTIVES = {
    "client", "dev", "proto", "remote", "remote-random", "resolv-retry", "nobind",
    "persist-key", "persist-tun", "remote-cert-tls", "verify-x509-name", "cipher",
    "data-ciphers", "data-ciphers-fallback", "auth", "auth-nocache", "verb",
    "mute", "connect-retry", "connect-retry-max", "connect-timeout", "explicit-exit-notify",
    "tun-mtu", "mssfix", "sndbuf", "rcvbuf", "reneg-sec", "tls-client",
    "tls-version-min", "auth-user-pass", "ca", "cert", "key", "key-direction",
    "tls-auth", "tls-crypt", "tls-crypt-v2", "compress", "allow-compression",
}
OPENVPN_SECRET_BLOCKS = {"key", "tls-auth", "tls-crypt", "tls-crypt-v2", "auth-user-pass"}


def egress_openvpn_normalize_preview_text(text):
    fields = _egress_preview_openvpn_fields(text)
    kept = []
    blocked = []
    review = []
    secret_blocks = []
    in_block = ""
    block_lines = []

    def finish_block(name, lines):
        block_name = str(name or "").lower()
        if block_name in OPENVPN_SECRET_BLOCKS:
            secret_blocks.append(block_name)
            kept.append(f"<{block_name}>[REDACTED]</{block_name}>")
        elif block_name in {"ca", "cert"}:
            kept.append(f"<{block_name}>")
            kept.extend(["  [CERTIFICATE DATA REDACTED]"])
            kept.append(f"</{block_name}>")
        else:
            review.append({"directive": f"<{block_name}>", "reason": "unknown inline block requires manual review"})

    for raw in text.splitlines():
        line = raw.strip()
        if in_block:
            block_lines.append(raw)
            if line.lower() == f"</{in_block}>":
                finish_block(in_block, block_lines)
                in_block = ""
                block_lines = []
            continue
        if not line or line.startswith(("#", ";")):
            continue
        if line.startswith("<") and line.endswith(">") and not line.startswith("</"):
            in_block = line[1:-1].strip().lower()
            block_lines = [raw]
            continue
        parts = line.split()
        key = parts[0].lower()
        if key in OPENVPN_SCRIPT_DIRECTIVES:
            blocked.append({"line": line[:180], "directive": key, "reason": "scripts/hooks are not allowed in managed V7 runtime"})
        elif key in OPENVPN_ROUTE_DIRECTIVES:
            blocked.append({"line": line[:180], "directive": key, "reason": "OpenVPN must not change V7 routing; V7 owns routes and policy tables"})
        elif key in OPENVPN_SAFE_DIRECTIVES:
            kept.append(redact(line))
        else:
            review.append({"line": line[:180], "directive": key, "reason": "directive is not in the safe allowlist yet"})

    if in_block:
        review.append({"directive": f"<{in_block}>", "reason": "inline block was not closed"})

    required = {
        "client": fields["client"],
        "remote": bool(fields["remote"]),
        "dev": bool(fields["dev"]),
        "auth_material": bool(fields["auth_user_pass"] or (fields["cert"] and fields["key"])),
    }
    checks = [
        {"id": "openvpn_detected", "status": "OK", "detail": "OpenVPN client profile detected"},
        {"id": "required_fields", "status": "OK" if all(required.values()) else "FAIL", "detail": ", ".join(k for k, v in required.items() if not v) or "all required fields present"},
        {"id": "scripts_hooks_absent", "status": "OK" if not fields["scripts"] else "FAIL", "detail": "none" if not fields["scripts"] else "; ".join(fields["scripts"][:4])},
        {"id": "v7_route_control", "status": "OK" if not any(row.get("directive") in OPENVPN_ROUTE_DIRECTIVES for row in blocked) else "BLOCKED", "detail": "no route directives" if not any(row.get("directive") in OPENVPN_ROUTE_DIRECTIVES for row in blocked) else "route directives must be removed/normalized"},
        {"id": "openvpn_runtime_adapter", "status": "BLOCKED", "detail": "preview only; runtime adapter is not enabled yet"},
    ]
    status = "BLOCKED" if blocked or review or not all(required.values()) else "READY_FOR_ADAPTER"
    return {
        "status": status,
        "protocol": "openvpn",
        "runtime_mode": "interface",
        "mode": "preview_only_no_files_changed",
        "validation": "openvpn_normalize_preview",
        "detected_fields": {
            "remote": fields["remote"],
            "proto": fields["proto"] or "default",
            "dev": fields["dev"],
            "auth_user_pass": "present" if fields["auth_user_pass"] else "missing",
            "cert_key": "present" if fields["cert"] and fields["key"] else "missing",
            "secret_blocks": sorted(set(secret_blocks)),
        },
        "checks": checks,
        "blocked_directives": blocked,
        "manual_review": review,
        "normalized_preview_redacted": "\n".join(kept[:120]),
        "kept_directive_count": len(kept),
        "blocked_count": len(blocked),
        "manual_review_count": len(review),
        "would_write_files": False,
        "would_start_runtime": False,
        "would_change_routes": False,
        "would_change_killswitch": False,
        "next_step": "fix_openvpn_blockers_then_build_adapter" if status == "BLOCKED" else "openvpn_adapter_runtime_design",
    }


def _clash_scalar(value):
    value = str(value or "").strip().rstrip(",")
    if (value.startswith('"') and value.endswith('"')) or (value.startswith("'") and value.endswith("'")):
        value = value[1:-1]
    return value.strip()


def _parse_clash_inline_map(value):
    value = str(value or "").strip()
    if not (value.startswith("{") and value.endswith("}")):
        return {}
    body = value[1:-1].strip()
    result = {}
    parts = re.split(r",\s*(?=[A-Za-z0-9_-]+\s*:)", body)
    for part in parts:
        if ":" not in part:
            continue
        key, val = part.split(":", 1)
        result[key.strip()] = _clash_scalar(val)
    return result


def _clash_parse_proxies(text):
    proxies = []
    current = None
    in_proxies = False
    for raw in text.splitlines():
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        if re.match(r"^proxies\s*:\s*$", raw):
            in_proxies = True
            continue
        if in_proxies and re.match(r"^[A-Za-z0-9_-]+\s*:", raw) and not raw.startswith((" ", "\t", "-")):
            break
        if not in_proxies:
            continue
        stripped = raw.strip()
        if stripped.startswith("- "):
            if current:
                proxies.append(current)
            current = {}
            item = stripped[2:].strip()
            if item.startswith("{"):
                current.update(_parse_clash_inline_map(item))
            elif ":" in item:
                key, val = item.split(":", 1)
                current[key.strip()] = _clash_scalar(val)
            continue
        if current is not None and ":" in stripped:
            key, val = stripped.split(":", 1)
            current[key.strip()] = _clash_scalar(val)
    if current:
        proxies.append(current)
    return proxies


def _clash_proxy_to_outbound(proxy, index=1, redact_secrets=True):
    supported_types = {"ss": "shadowsocks", "shadowsocks": "shadowsocks", "vless": "vless", "vmess": "vmess", "trojan": "trojan"}
    ptype = str(proxy.get("type") or "").lower()
    target_type = supported_types.get(ptype)
    name = str(proxy.get("name") or f"proxy-{index}")[:64]
    if not target_type:
        return {
            "index": index,
            "name": name,
            "type": ptype or "missing",
            "target": "",
            "status": "UNSUPPORTED",
            "missing": [],
            "reason": "proxy type is not supported by preview converter yet",
        }
    try:
        port = int(str(proxy.get("port") or "0"))
    except ValueError:
        port = 0
    required = {
        "server": bool(proxy.get("server")),
        "port": bool(port),
    }
    outbound = {
        "tag": safe_client_name(re.sub(r"[^A-Za-z0-9_.-]+", "-", name).strip("-").lower()) or f"proxy-{index}",
        "type": target_type,
        "server": str(proxy.get("server") or ""),
        "server_port": port,
    }
    if target_type == "shadowsocks":
        method = proxy.get("cipher") or proxy.get("method")
        required["method"] = bool(method)
        required["password"] = bool(proxy.get("password"))
        outbound["method"] = str(method or "")
        outbound["password"] = "[REDACTED]" if (redact_secrets and proxy.get("password")) else str(proxy.get("password") or "")
    elif target_type in ("vless", "vmess"):
        required["uuid"] = bool(proxy.get("uuid"))
        outbound["uuid"] = "[REDACTED]" if (redact_secrets and proxy.get("uuid")) else str(proxy.get("uuid") or "")
        if str(proxy.get("tls", "")).lower() in {"true", "1", "yes"} or proxy.get("servername") or proxy.get("sni"):
            outbound["tls"] = {"enabled": True}
            sni = proxy.get("servername") or proxy.get("sni")
            if sni:
                outbound["tls"]["server_name"] = str(sni)
        if proxy.get("network"):
            outbound["transport"] = {"type": str(proxy.get("network"))}
    elif target_type == "trojan":
        required["password"] = bool(proxy.get("password"))
        outbound["password"] = "[REDACTED]" if (redact_secrets and proxy.get("password")) else str(proxy.get("password") or "")
        if str(proxy.get("tls", "")).lower() in {"true", "1", "yes"} or proxy.get("servername") or proxy.get("sni"):
            outbound["tls"] = {"enabled": True}
            sni = proxy.get("servername") or proxy.get("sni")
            if sni:
                outbound["tls"]["server_name"] = str(sni)
    missing = [key for key, ok in required.items() if not ok]
    return {
        "index": index,
        "name": name,
        "type": ptype,
        "target": "sing-box",
        "status": "READY" if not missing else "BLOCKED",
        "missing": missing,
        "outbound_preview": outbound,
        "outbound": outbound,
    }


def egress_clash_convert_preview_text(text):
    proxies = _clash_parse_proxies(text)
    converted = []
    unsupported = []
    for index, proxy in enumerate(proxies, 1):
        row = _clash_proxy_to_outbound(proxy, index=index, redact_secrets=True)
        if row.get("status") == "UNSUPPORTED":
            unsupported.append({"index": row.get("index"), "name": row.get("name"), "type": row.get("type"), "reason": row.get("reason")})
            continue
        row.pop("outbound", None)
        converted.append(row)

    ready_count = sum(1 for row in converted if row.get("status") == "READY")
    status = "READY_FOR_ADAPTER" if ready_count else "BLOCKED"
    return {
        "status": status,
        "protocol": "clash_yaml",
        "runtime_mode": "proxy_or_tun",
        "mode": "preview_only_no_files_changed",
        "validation": "clash_convert_preview",
        "detected_fields": {
            "proxies": len(proxies),
            "convertible": ready_count,
            "unsupported": len(unsupported),
        },
        "checks": [
            {"id": "clash_proxies_found", "status": "OK" if proxies else "FAIL", "detail": f"{len(proxies)} proxies"},
            {"id": "convertible_proxies", "status": "OK" if ready_count else "FAIL", "detail": f"{ready_count}/{len(proxies)} ready"},
            {"id": "clash_runtime_adapter", "status": "BLOCKED", "detail": "preview only; converter does not write runtime profile yet"},
        ],
        "converted_outbounds": converted,
        "unsupported_proxies": unsupported,
        "would_write_files": False,
        "would_start_runtime": False,
        "would_change_routes": False,
        "would_change_killswitch": False,
        "secret_redaction": "proxy secrets are shown only as [REDACTED]",
        "next_step": "select_one_proxy_for_draft_runtime_conversion" if ready_count else "fix_clash_proxy_fields_or_use_manual_input",
    }
def _first_query_value(query, *names):
    for name in names:
        values = query.get(name)
        if values:
            return values[0]
    return ""


def _decode_unpadded_base64(value):
    value = str(value or "").strip()
    padding = "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode((value + padding).encode("ascii", errors="ignore")).decode("utf-8", errors="replace")


def egress_parse_proxy_share(raw):
    raw = str(raw or "").strip()
    lowered = raw.lower()
    if lowered.startswith("vless://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        uuid = unquote(parsed.username or "")
        server = parsed.hostname or ""
        port = parsed.port or 0
        outbound = {
            "type": "vless",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "uuid": uuid,
        }
        flow = _first_query_value(query, "flow")
        if flow:
            outbound["flow"] = flow
        security = _first_query_value(query, "security")
        sni = _first_query_value(query, "sni", "servername", "serverName")
        fp = _first_query_value(query, "fp", "fingerprint") or "chrome"
        public_key = _first_query_value(query, "pbk", "publicKey", "public_key")
        short_id = _first_query_value(query, "sid", "shortId", "short_id")
        if security in ("tls", "reality") or sni or public_key:
            tls = {"enabled": True}
            if sni:
                tls["server_name"] = sni
            if fp:
                tls["utls"] = {"enabled": True, "fingerprint": fp}
            if security == "reality" or public_key:
                tls["reality"] = {"enabled": True, "public_key": public_key}
                if short_id:
                    tls["reality"]["short_id"] = short_id
            outbound["tls"] = tls
        network = _first_query_value(query, "type", "network")
        if network in ("ws", "grpc", "http", "httpupgrade"):
            outbound["transport"] = {"type": network}
            if network == "ws":
                path = _first_query_value(query, "path")
                host = _first_query_value(query, "host")
                if path:
                    outbound["transport"]["path"] = path
                if host:
                    outbound["transport"]["headers"] = {"Host": host}
            if network == "grpc":
                service_name = _first_query_value(query, "serviceName", "service_name")
                if service_name:
                    outbound["transport"]["service_name"] = service_name
        required = {
            "server": bool(server),
            "port": bool(port),
            "uuid": bool(uuid),
        }
        if security == "reality" or public_key:
            required["reality_public_key"] = bool(public_key)
            required["sni"] = bool(sni)
        return {"protocol": "vless", "outbound": outbound, "required": required}, None

    if lowered.startswith("trojan://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        password = unquote(parsed.username or "")
        server = parsed.hostname or ""
        port = parsed.port or 0
        sni = _first_query_value(query, "sni", "peer", "servername", "serverName")
        outbound = {
            "type": "trojan",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "password": password,
        }
        if sni or _first_query_value(query, "security") == "tls":
            outbound["tls"] = {"enabled": True}
            if sni:
                outbound["tls"]["server_name"] = sni
        return {
            "protocol": "trojan",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "password": bool(password)},
        }, None

    if lowered.startswith("ss://"):
        parsed = urlparse(raw)
        server = parsed.hostname or ""
        port = parsed.port or 0
        userinfo = unquote(parsed.username or "")
        if not server:
            body = raw[5:].split("#", 1)[0].split("?", 1)[0]
            decoded = _decode_unpadded_base64(body)
            parsed = urlparse("ss://" + decoded)
            server = parsed.hostname or ""
            port = parsed.port or 0
            userinfo = unquote(parsed.username or "")
        if ":" in userinfo:
            method, password = userinfo.split(":", 1)
        else:
            decoded_userinfo = _decode_unpadded_base64(userinfo) if userinfo else ""
            method, password = decoded_userinfo.split(":", 1) if ":" in decoded_userinfo else ("", "")
        outbound = {
            "type": "shadowsocks",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "method": method,
            "password": password,
        }
        return {
            "protocol": "shadowsocks_or_outline",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "method": bool(method), "password": bool(password)},
        }, None

    if lowered.startswith("vmess://"):
        body = raw.split("://", 1)[1].split("#", 1)[0].strip()
        try:
            payload = json.loads(_decode_unpadded_base64(body))
        except Exception as exc:
            return None, {"error": "invalid_vmess_share", "detail": str(exc)}
        server = str(payload.get("add") or "")
        try:
            port = int(payload.get("port") or 0)
        except ValueError:
            port = 0
        uuid = str(payload.get("id") or "")
        outbound = {
            "type": "vmess",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "uuid": uuid,
            "security": str(payload.get("scy") or "auto"),
        }
        if str(payload.get("tls") or ""):
            outbound["tls"] = {"enabled": True}
            sni = str(payload.get("sni") or payload.get("host") or "")
            if sni:
                outbound["tls"]["server_name"] = sni
        return {
            "protocol": "vmess",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "uuid": bool(uuid)},
        }, None

    return None, {"error": "unsupported_proxy_share"}


