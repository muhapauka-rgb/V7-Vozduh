    function eventPlainMeaning(e={}) {
      const action = String(e.action || '').toLowerCase();
      const component = String(e.component || '').toLowerCase();
      const result = String(e.result || '').toLowerCase();
      const message = String(e.message || '');
      if (String(e.severity || '').toLowerCase() === 'error' || result.includes('fail') || result.includes('block')) return 'Нужно проверить: действие не прошло или было заблокировано.';
      if (action.includes('preview') || result.includes('dry')) return 'Это была безопасная проверка без изменения рабочей системы.';
      if (action.includes('profile_delivery')) return 'Создавалась или отзывалась одноразовая ссылка для выдачи профиля.';
      if (action.includes('profile') || component.includes('identity')) return 'Событие связано с пользователем, телефоном, устройством или выдачей профиля.';
      if (action.includes('egress') || component.includes('egress')) return 'Событие связано с каналом: тест, состояние, рабочий профиль или готовность.';
      if (action.includes('policy') || action.includes('route') || component.includes('routing')) return 'Событие связано с маршрутами, доменными группами или правилами для сервисов.';
      if (action.includes('backup') || action.includes('rollback') || component.includes('maintenance')) return 'Событие относится к обслуживанию: бэкап, откат, очистка или лимиты места.';
      return message || 'Информационное событие V7.';
