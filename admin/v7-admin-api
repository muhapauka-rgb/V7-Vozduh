def egress_usage_policy_from_data(data=None, base=None):
    data = data or {}
    base = base or {}
    role = safe_egress_role(data.get("role") or base.get("role") or "GLOBAL_FAST")
    role_meta = EGRESS_ROLES.get(role, EGRESS_ROLES["GLOBAL_FAST"])
    service_tags = safe_csv_tokens(
        data.get("service_tags") or base.get("service_tags") or role_meta.get("service_tags", ""),
        max_items=32,
    )
    exclude_route_classes = safe_csv_tokens(
        data.get("exclude_route_classes") or base.get("exclude_route_classes") or role_meta.get("exclude_route_classes", ""),
        allowed=set(POLICY_DOMAIN_CLASSES) | set(EGRESS_ROLES),
        max_items=32,
        uppercase=True,
    )
    manual_default = "1" if role == "MANUAL_ONLY" else "0"
    reserve_default = "1" if role == "RESERVE" else "0"
    manual_only = bool_flag_value(data.get("manual_only", base.get("manual_only", manual_default)), manual_default)
    reserve_only = bool_flag_value(data.get("reserve_only", base.get("reserve_only", reserve_default)), reserve_default)
    if role == "MANUAL_ONLY":
        manual_only = "1"
    if role == "RESERVE":
        reserve_only = "1"
    return {
        "role": role,
        "priority": str(bounded_int_value(data.get("priority") or base.get("priority"), role_meta.get("default_priority", 50), 1, 999)),
        "weight": str(bounded_int_value(data.get("weight") or base.get("weight"), role_meta.get("default_weight", 100), 0, 1000)),
        "soft_limit": str(bounded_int_value(data.get("soft_limit") or base.get("soft_limit"), 1, 0, 100000)),
        "hard_limit": str(bounded_int_value(data.get("hard_limit") or base.get("hard_limit"), 2, 0, 100000)),
        "manual_only": manual_only,
