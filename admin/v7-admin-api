    def do_POST(self):
        path = urlparse(self.path).path
        if path == "/connect":
            data = read_request_data(self)
            result, error, status = connect_onboard(data, handler=self)
            if "application/json" in self.headers.get("Content-Type", ""):
                self.send_json({"result": result, "error": error}, status=status)
            else:
                self.send_connect(result=result, error=error, status=status, form_data=data)
            return
        if path in SAFE_MODE_BLOCKED_ACTIONS and admin_safe_mode_enabled():
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            actor = session.get("sub", "admin")
            audit_admin(actor, "admin_safe_mode_blocked", f"path={path}", object_type="admin_safe_mode", object_id=path, result="BLOCKED", severity="warning")
            self.send_json({
                "error": "safe_mode_enabled",
                "message": "Admin Safe Mode is enabled. This action is blocked until Safe Mode is disabled.",
                "path": path,
                "safe_mode": admin_safe_mode_state(),
            }, status=423)
            return
        if path in ACTION_MIN_ROLE:
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            if not self.require_action_access(session, path):
                return
        if path == "/login":
            if not auth_configured():
                self.send_login("Auth is not initialized.", status=503)
                return
            length = min(int(self.headers.get("Content-Length", "0") or 0), 8192)
            raw = self.rfile.read(length).decode("utf-8", errors="replace")
            ctype = self.headers.get("Content-Type", "")
            if "application/json" in ctype:
                try:
                    data = json.loads(raw)
                except json.JSONDecodeError:
                    data = {}
            else:
                form = parse_qs(raw)
                data = {k: v[0] for k, v in form.items()}
            username = safe_admin_username(data.get("username", ""))
            password = str(data.get("password", ""))
            account = auth_account(username)
            if account and account.get("enabled", True) and verify_password(password, account.get("password_hash", "")):
                token, session = make_session(username)
                subprocess.run(
                    ["v7-audit-log", "admin_login", "admin", f"username={username}", f"object_type=admin_auth", f"object_id={username}", "result=OK"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    check=False,
                )
                self.send_response(303)
                self.send_header("Location", "/")
                self.send_header("Set-Cookie", f"{SESSION_COOKIE}={token}; HttpOnly; SameSite=Strict; Path=/; Max-Age={SESSION_TTL}")
                self.send_header("Cache-Control", "no-store")
                self.end_headers()
                return
            subprocess.run(
                ["v7-audit-log", "admin_login_failed", "admin", f"username={username}"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )
            self.send_login("Invalid username or password.", status=401)
        elif path == "/logout":
            self.send_response(303)
            self.send_header("Location", "/login")
            self.send_header("Set-Cookie", f"{SESSION_COOKIE}=deleted; HttpOnly; SameSite=Strict; Path=/; Max-Age=0")
            self.send_header("Cache-Control", "no-store")
