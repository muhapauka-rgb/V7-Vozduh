        <p class="muted">Откройте файл в Karing. Если ссылка уже использована или истекла, пройдите подключение заново.</p>
        """
    name_value = html.escape(str(form_data.get("name", "")))
    phone_value = html.escape(str(form_data.get("phone", "")))
    org_value = html.escape(str(form_data.get("organization", "")))
    vpn_client_value = str(form_data.get("vpn_client", "karing"))
    option = lambda value, label: f'<option value="{html.escape(value)}" {"selected" if vpn_client_value == value else ""}>{html.escape(label)}</option>'
    return f"""<!doctype html>
