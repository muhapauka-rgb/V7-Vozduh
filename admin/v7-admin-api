def egress_config_preview(data):
    text = str(data.get("config", "") or "")
    if len(text) > 65536:
        return None, {"error": "config_too_large", "max_bytes": 65536}
    label = clean_identity_text(data.get("label", ""), 80)
    raw = text.strip()
    if not raw:
        return None, {"error": "empty_config"}

    preview = {
        "label": label,
        "protocol": "unknown",
        "runtime_mode": "unknown",
        "detected_fields": {},
        "required": {},
        "missing": [],
        "sensitive_material": "yes",
        "pool_action": "draft_only_not_added",
        "next_step": "create_isolated_profile_then_test_before_pool",
    }

    lowered = raw.lower()
    if lowered.startswith(("vless://", "vmess://", "trojan://", "ss://")):
        parsed_share, share_error = egress_parse_proxy_share(raw)
        if share_error:
            return None, share_error
        outbound = parsed_share.get("outbound", {})
        required = parsed_share.get("required", {})
        preview.update({"protocol": parsed_share.get("protocol", "unknown"), "runtime_mode": "proxy_or_tun"})
        preview["detected_fields"] = {
            "share_uri": "present",
            "server": "present" if outbound.get("server") else "missing",
            "server_port": "present" if outbound.get("server_port") else "missing",
            "tls": "present" if outbound.get("tls") else "not_configured",
            "transport": (outbound.get("transport") or {}).get("type", "default"),
        }
        preview["required"] = {key: "present" if value else "missing" for key, value in required.items()}
        preview["missing"] = [key for key, value in required.items() if not value]
    elif lowered.startswith("ssconf://"):
        preview.update({"protocol": "shadowsocks_or_outline", "runtime_mode": "proxy_or_tun"})
        preview["detected_fields"] = {"access_key": "present"}
    elif raw.startswith("{"):
        try:
            parsed = json.loads(raw)
        except json.JSONDecodeError as exc:
            return None, {"error": "invalid_json_config", "detail": str(exc)}
        outbounds = parsed.get("outbounds", []) if isinstance(parsed, dict) else []
        inbound_count = len(parsed.get("inbounds", [])) if isinstance(parsed, dict) and isinstance(parsed.get("inbounds"), list) else 0
        outbound_types = sorted(set(str(item.get("type", "")) for item in outbounds if isinstance(item, dict) and item.get("type")))
        protocol = "sing-box"
        if "vless" in outbound_types:
            protocol = "vless"
        elif "shadowsocks" in outbound_types:
            protocol = "shadowsocks_or_outline"
        preview.update({"protocol": protocol, "runtime_mode": "sing_box"})
        preview["detected_fields"] = {
            "json": "valid",
            "inbounds": inbound_count,
            "outbound_types": ", ".join(outbound_types) or "none",
        }
        preview["required"] = {"outbounds": "present" if outbound_types else "missing"}
        if not outbound_types:
            preview["missing"].append("outbounds")
    else:
        sections = _egress_preview_ini_sections(raw)
        interface = sections.get("Interface", {})
        peer = sections.get("Peer", {})
        if interface and peer:
            awg_keys = {"Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4", "H1", "H2", "H3", "H4"}
            protocol = "amneziawg" if any(key in interface for key in awg_keys) else "wireguard"
            preview.update({"protocol": protocol, "runtime_mode": "interface"})
            preview["detected_fields"] = {
                "interface": "present",
                "peer": "present",
                "address": "present" if interface.get("Address") else "missing",
                "endpoint_host": (peer.get("Endpoint", "").rsplit(":", 1)[0] if peer.get("Endpoint") else ""),
                "table": interface.get("Table", ""),
            }
            required = {
                "Interface.PrivateMaterial": interface.get("PrivateKey"),
                "Interface.Address": interface.get("Address"),
                "Peer.PublicKey": peer.get("PublicKey"),
                "Peer.Endpoint": peer.get("Endpoint"),
            }
            preview["required"] = {key: "present" if value else "missing" for key, value in required.items()}
            preview["missing"] = [key for key, value in required.items() if not value]
            if protocol == "amneziawg" and interface.get("Table", "").lower() != "off":
                preview["warnings"] = ["AmneziaWG egress should normally use Table = off because V7 owns routing."]
        else:
            preview["missing"].append("known_protocol_signature")

    if not preview.get("missing"):
        preview["validation"] = "detected_required_fields"
    else:
        preview["validation"] = "needs_operator_fix"
    usage_policy = egress_usage_policy_from_data(data)
    preview["role"] = usage_policy["role"]
    preview["usage_policy"] = usage_policy
    return preview, None


def egress_qr_preview(data):
    label = clean_identity_text(data.get("label", ""), 80) or "qr-egress"
    raw = str(data.get("image_b64", "") or "").strip()
    if not raw:
        return None, {"error": "qr_image_missing"}
    if "," in raw and raw.split(",", 1)[0].lower().startswith("data:image/"):
        raw = raw.split(",", 1)[1]
    try:
        blob = base64.b64decode(raw, validate=True)
    except Exception:
        return None, {"error": "invalid_qr_image_base64"}
    if len(blob) > 4 * 1024 * 1024:
        return None, {"error": "qr_image_too_large", "max_bytes": 4 * 1024 * 1024}
    decoder = shutil.which("zbarimg")
    if not decoder:
        return {
            "label": label,
            "status": "DECODER_MISSING",
            "message": "QR upload is ready in the UI, but the server has no local QR decoder installed yet.",
            "required_tool": "zbarimg",
            "pool_action": "preview_only_not_added",
            "next_step": "install_qr_decoder_or_paste_uri_manually",
        }, None
    suffix = ".png"
    fd, tmp_name = tempfile.mkstemp(prefix="v7-egress-qr-", suffix=suffix)
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "wb") as handle:
            handle.write(blob)
        os.chmod(tmp_path, 0o600)
        decoded = run_readonly([decoder, "--quiet", "--raw", str(tmp_path)], timeout=12)
    finally:
        try:
            tmp_path.unlink()
        except OSError:
            pass
    if decoded["rc"] != 0:
        return None, {"error": "qr_decode_failed", "detail": decoded.get("output", "")[-500:]}
    lines = [line.strip() for line in str(decoded.get("output", "")).splitlines() if line.strip()]
    if not lines:
        return None, {"error": "qr_decode_empty"}
    text = lines[0]
    preview, error = egress_config_preview({
        "label": label,
        "config": text,
        "role": data.get("role", "GLOBAL_FAST"),
        "priority": data.get("priority", ""),
        "weight": data.get("weight", ""),
        "soft_limit": data.get("soft_limit", ""),
        "hard_limit": data.get("hard_limit", ""),
        "service_tags": data.get("service_tags", ""),
        "exclude_route_classes": data.get("exclude_route_classes", ""),
        "manual_only": data.get("manual_only", ""),
        "reserve_only": data.get("reserve_only", ""),
    })
    if error:
        return None, error
    preview["source"] = "qr_upload"
    preview["decoded"] = {
        "status": "OK",
        "length": len(text),
        "format_hint": text.split(":", 1)[0].lower() if ":" in text else "config_text",
        "secret_redaction": "decoded QR text is intentionally not returned",
    }
    preview["pool_action"] = "preview_only_not_added"
    return preview, None


def egress_draft_id(label):
    base = safe_client_name(re.sub(r"[^A-Za-z0-9_.-]+", "-", str(label or "").lower()).strip("-")[:36]) or "egress-draft"
    return f"{base}-{int(time.time())}-{secrets.token_hex(3)}"


def egress_draft_path(draft_id):
    draft_id = safe_draft_id(draft_id)
    if not draft_id:
        return None
    path_obj = (EGRESS_DRAFTS_DIR / draft_id).resolve()
    root_resolved = EGRESS_DRAFTS_DIR.resolve()
    if root_resolved not in path_obj.parents:
        return None
    return path_obj


def egress_draft_create(data, actor):
    text = str(data.get("config", "") or "")
    preview, error = egress_config_preview(data)
    if error:
        return None, error
    if preview.get("validation") != "detected_required_fields":
        return None, {"error": "draft_validation_failed", "preview": preview}
    draft_id = egress_draft_id(preview.get("label") or preview.get("protocol") or "egress")
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_path"}
    EGRESS_DRAFTS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(EGRESS_DRAFTS_DIR, 0o700)
    draft_dir.mkdir(parents=True, exist_ok=False)
    os.chmod(draft_dir, 0o700)
    config_path = draft_dir / "config.input"
    metadata_path = draft_dir / "metadata.json"
    config_hash = hashlib.sha256(text.encode("utf-8")).hexdigest()
    usage_policy = egress_usage_policy_from_data(data, preview.get("usage_policy", {}))
    write_text_atomic(config_path, text if text.endswith("\n") else text + "\n", mode=0o600)
    metadata = {
        "id": draft_id,
        "label": preview.get("label") or draft_id,
        "status": "draft",
        "created_at": now_iso(),
        "created_by": actor or "admin",
        "protocol": preview.get("protocol", "unknown"),
        "runtime_mode": preview.get("runtime_mode", "unknown"),
        "validation": preview.get("validation", ""),
        "missing": preview.get("missing", []),
        "warnings": preview.get("warnings", []),
        "detected_fields": preview.get("detected_fields", {}),
        "config_sha256": config_hash,
        "config_path": str(config_path),
        "role": usage_policy["role"],
        "priority": usage_policy["priority"],
        "weight": usage_policy["weight"],
        "soft_limit": usage_policy["soft_limit"],
        "hard_limit": usage_policy["hard_limit"],
        "manual_only": usage_policy["manual_only"],
        "reserve_only": usage_policy["reserve_only"],
        "service_tags": usage_policy["service_tags"],
        "exclude_route_classes": usage_policy["exclude_route_classes"],
        "usage_policy": usage_policy,
        "pool_action": "not_added",
        "next_step": "isolated_test_profile",
    }
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass
    return metadata, None


def egress_drafts_state():
    rows = []
    if not EGRESS_DRAFTS_DIR.exists():
        return {"dir": str(EGRESS_DRAFTS_DIR), "count": 0, "items": []}
    for meta in sorted(EGRESS_DRAFTS_DIR.glob("*/metadata.json"), key=lambda p: p.stat().st_mtime, reverse=True):
        row = read_json(meta, {})
        if isinstance(row, dict) and safe_draft_id(row.get("id", "")):
            row.pop("config_path", None)
            rows.append(row)
    return {"dir": str(EGRESS_DRAFTS_DIR), "count": len(rows), "items": rows[:100]}


def egress_draft_test_preview(draft_id):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    if not metadata:
        return None, {"error": "draft_not_found"}
    protocol = metadata.get("protocol", "unknown")
    runtime_mode = metadata.get("runtime_mode", "unknown")
    steps = [
        "copy draft config into an isolated profile path",
        "validate runtime dependencies before starting anything",
        "start isolated interface/proxy with a temporary name",
        "run external IP and service matrix checks",
        "keep draft quarantined until all checks pass",
    ]
    if protocol in ("wireguard", "amneziawg"):
        steps.insert(2, "force Table = off or reject until operator confirms V7-managed routing")
        steps.append("verify curl --interface <temporary-interface> external IP")
    elif protocol in ("vless", "sing-box", "shadowsocks_or_outline"):
        steps.append("verify local proxy/tun check without touching current sing-box service")
    return {
        "id": metadata.get("id"),
        "label": metadata.get("label"),
        "protocol": protocol,
        "runtime_mode": runtime_mode,
        "mode": "preview_only",
        "pool_action": "still_not_added",
        "steps": steps,
    }, None


def egress_draft_tool_requirements(protocol, runtime_mode):
    if protocol in ("wireguard",):
        return {
            "required": ["ip", "wg", "wg-quick", "curl"],
            "alternatives": [],
            "notes": ["WireGuard egress drafts must be tested with V7-managed routing and Table = off."],
        }
    if protocol in ("amneziawg",):
        return {
            "required": ["ip", "awg", "curl"],
            "alternatives": [["awg-quick", "amneziawg-go"]],
            "notes": ["AmneziaWG needs native x86_64 tooling; V7 must own routing, so Table = off is required."],
        }
    if protocol in ("vless", "sing-box", "shadowsocks_or_outline", "vmess", "trojan"):
        return {
            "required": ["sing-box", "curl"],
            "alternatives": [],
            "notes": ["Proxy/tun drafts must be tested through an isolated sing-box profile before pool activation."],
        }
    return {
        "required": ["curl"],
        "alternatives": [],
        "notes": ["Unknown drafts can only run generic preflight until the protocol adapter is known."],
    }


def egress_draft_check_tools(requirements):
    checks = []
    ok = True
    for tool in requirements.get("required", []):
        path = shutil.which(tool)
        state = "OK" if path else "MISSING"
        ok = ok and bool(path)
        checks.append({"tool": tool, "required": True, "status": state, "path": path or ""})
    for group in requirements.get("alternatives", []):
        found = [(tool, shutil.which(tool)) for tool in group]
        group_ok = any(path for _, path in found)
        ok = ok and group_ok
        checks.append({
            "tool": " or ".join(group),
            "required": True,
            "status": "OK" if group_ok else "MISSING",
            "path": ", ".join(f"{tool}={path}" for tool, path in found if path),
        })
    return checks, ok


def egress_draft_unsafe_interface_options(text):
    sections = _egress_preview_ini_sections(text)
    blocked = []
    for section_name, section in (("Interface", sections.get("Interface", {})), ("Peer", sections.get("Peer", {}))):
        for key in section:
            if key.lower() in {"preup", "postup", "predown", "postdown", "saveconfig", "dns"}:
                blocked.append(f"{section_name}.{key}")
    return blocked


def egress_draft_static_checks(draft_id, preview, text=""):
    checks = []
    protocol = preview.get("protocol", "unknown")
    runtime_mode = preview.get("runtime_mode", "unknown")
    checks.append({
        "id": "detected_required_fields",
        "status": "OK" if preview.get("validation") == "detected_required_fields" else "FAIL",
        "detail": preview.get("validation", "unknown"),
    })
    active_text = read_text(STATE_DIR / "egress.registry", "") + "\n" + read_text(STATE_DIR / "users.registry", "")
    checks.append({
        "id": "not_in_active_registry",
        "status": "OK" if draft_id not in active_text else "FAIL",
        "detail": "draft id is not active" if draft_id not in active_text else "draft id found in active registry",
    })
    if runtime_mode == "interface" and protocol in ("wireguard", "amneziawg"):
        blocked_hooks = egress_draft_unsafe_interface_options(text)
        checks.append({
            "id": "unsafe_hooks_absent",
            "status": "OK" if not blocked_hooks else "FAIL",
            "detail": "no executable hooks/options copied" if not blocked_hooks else ",".join(blocked_hooks),
        })
        table_value = str((preview.get("detected_fields") or {}).get("table", "")).strip().lower()
        checks.append({
            "id": "table_off_required",
            "status": "OK" if table_value == "off" else "FAIL",
            "detail": "Table = off" if table_value == "off" else "egress interface draft must include Table = off before runtime test",
        })
        endpoint = str((preview.get("detected_fields") or {}).get("endpoint_host", "")).strip()
        checks.append({
            "id": "endpoint_present",
            "status": "OK" if endpoint else "FAIL",
            "detail": endpoint or "missing endpoint host",
        })
    if runtime_mode in ("proxy_or_tun", "sing_box"):
        checks.append({
            "id": "proxy_runtime_isolated",
            "status": "OK",
            "detail": "runtime test must use a temporary profile and must not touch current sing-box service",
        })
    return checks


def egress_draft_latest_preflight(metadata):
    run_id = safe_run_id((metadata or {}).get("last_preflight_run_id", ""))
    if not run_id:
        return {}
    result_path = EGRESS_DRAFT_TESTS_DIR / run_id / "result.json"
    return read_json(result_path, {})


def egress_draft_preflight_run(draft_id, actor):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata_path = draft_dir / "metadata.json"
    config_path = draft_dir / "config.input"
    metadata = read_json(metadata_path, {})
    if not metadata or not config_path.exists():
        return None, {"error": "draft_not_found"}
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, {"error": "draft_config_read_failed", "detail": str(exc)}
    preview, error = egress_config_preview({"label": metadata.get("label", draft_id), "config": text})
    if error:
        return None, error
    protocol = preview.get("protocol", "unknown")
    runtime_mode = preview.get("runtime_mode", "unknown")
    requirements = egress_draft_tool_requirements(protocol, runtime_mode)
    tool_checks, tools_ok = egress_draft_check_tools(requirements)
    static_checks = egress_draft_static_checks(draft_id, preview, text)
    static_ok = all(row.get("status") == "OK" for row in static_checks)
    run_id = f"{draft_id}-{int(time.time())}-{secrets.token_hex(3)}"
    EGRESS_DRAFT_TESTS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(EGRESS_DRAFT_TESTS_DIR, 0o700)
    run_dir = EGRESS_DRAFT_TESTS_DIR / run_id
    run_dir.mkdir(mode=0o700, parents=False, exist_ok=False)
    write_text_atomic(run_dir / "config.input", text if text.endswith("\n") else text + "\n", mode=0o600)
    result = {
        "id": run_id,
        "draft_id": draft_id,
        "label": metadata.get("label", draft_id),
        "created_at": now_iso(),
        "created_by": actor or "admin",
        "stage": "preflight",
        "mode": "no_runtime_start",
        "protocol": protocol,
        "runtime_mode": runtime_mode,
        "status": "PASS" if (tools_ok and static_ok) else "BLOCKED",
        "tool_checks": tool_checks,
        "static_checks": static_checks,
        "notes": requirements.get("notes", []),
        "secret_redaction": "raw_config_not_returned",
        "pool_action": "still_not_added",
        "next_step": "isolated_runtime_test" if (tools_ok and static_ok) else "fix_preflight_blockers",
    }
    write_json_atomic(run_dir / "result.json", result)
    try:
        os.chmod(run_dir / "result.json", 0o600)
    except OSError:
        pass
    metadata.update({
        "last_preflight_at": result["created_at"],
        "last_preflight_status": result["status"],
        "last_preflight_run_id": run_id,
        "next_step": result["next_step"],
    })
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass
    response = dict(result)
    response["stored"] = True
    return response, None


def egress_draft_sanitize_interface_config(text, protocol):
    sections = _egress_preview_ini_sections(text)
    interface = sections.get("Interface", {})
    peer = sections.get("Peer", {})
    if not interface or not peer:
        return None, {"error": "runtime_requires_interface_and_peer"}

    errors = []
    private_key = str(interface.get("PrivateKey", "")).strip()
    public_key = str(peer.get("PublicKey", "")).strip()
    preshared_key = str(peer.get("PresharedKey", "")).strip()
    address = str(interface.get("Address", "")).strip()
    endpoint = str(peer.get("Endpoint", "")).strip()
    allowed_ips = str(peer.get("AllowedIPs", "0.0.0.0/0")).strip() or "0.0.0.0/0"
    keepalive = str(peer.get("PersistentKeepalive", "25")).strip() or "25"
    table = str(interface.get("Table", "")).strip().lower()

    if not SAFE_WG_KEY_RE.match(private_key):
        errors.append("Interface.PrivateKey has invalid WireGuard key format")
    if not SAFE_WG_KEY_RE.match(public_key):
        errors.append("Peer.PublicKey has invalid WireGuard key format")
    if preshared_key and not SAFE_WG_KEY_RE.match(preshared_key):
        errors.append("Peer.PresharedKey has invalid WireGuard key format")
    if not address or not re.match(r"^[0-9a-fA-F:./, ]+$", address):
        errors.append("Interface.Address is missing or unsafe")
    if not endpoint or any(ch in endpoint for ch in " \t\n\r;`$()|&<>"):
        errors.append("Peer.Endpoint is missing or unsafe")
    if any(ch in allowed_ips for ch in "\n\r;`$()|&<>"):
        errors.append("Peer.AllowedIPs is unsafe")
    if not re.match(r"^[0-9]{1,5}$", keepalive):
        errors.append("Peer.PersistentKeepalive is unsafe")
    if table != "off":
        errors.append("Interface.Table must be off for isolated V7 runtime tests")

    blocked_hooks = []
    for section_name, section in (("Interface", interface), ("Peer", peer)):
        for key in section:
            if key.lower() in {"preup", "postup", "predown", "postdown", "saveconfig", "dns"}:
                blocked_hooks.append(f"{section_name}.{key}")
    if blocked_hooks:
        errors.append("unsafe hook/options are not copied into isolated runtime test: " + ",".join(blocked_hooks))
    if errors:
        return None, {"error": "runtime_sanitize_failed", "details": errors}

    lines = [
        "[Interface]",
        f"PrivateKey = {private_key}",
        f"Address = {address}",
        "Table = off",
        "",
        "[Peer]",
        f"PublicKey = {public_key}",
    ]
    if preshared_key:
        lines.append(f"PresharedKey = {preshared_key}")
    lines.extend([
        f"Endpoint = {endpoint}",
        f"AllowedIPs = {allowed_ips}",
        f"PersistentKeepalive = {keepalive}",
        "",
    ])
    return "\n".join(lines), None


def egress_runtime_status_from_external_ip(result):
    if result.get("external_ip", {}).get("ok"):
        return "PASS"
    if result.get("interface_up") and result.get("cleanup", {}).get("status") == "OK":
        return "FAIL_EXTERNAL_IP"
    return "FAIL"


def egress_draft_runtime_run(draft_id, actor, duration=8, requested_mode="runtime"):
    duration = max(3, min(int(duration or 8), 20))
    requested_mode = str(requested_mode or "runtime")
    if requested_mode not in {"runtime", "quarantine"}:
        return None, {"error": "invalid_runtime_mode"}
    if not safe_draft_id(draft_id):
        return None, {"error": "invalid_draft_id"}
    helper = shutil.which("v7-egress-draft-runtime-helper")
    runner = shutil.which("systemd-run")
    if helper and runner and os.environ.get("V7_EGRESS_DRAFT_RUNTIME_HELPER", "1") != "0":
        cmd = [
            runner,
            "--quiet",
            "--wait",
            "--pipe",
            "--collect",
            "--property=Type=oneshot",
            "--property=NoNewPrivileges=no",
            "--property=PrivateTmp=yes",
            helper,
            draft_id,
            str(duration),
            actor or "admin",
            requested_mode,
        ]
        helper_timeout = duration + (260 if requested_mode == "quarantine" else 80)
        helper_result = run_action(cmd, actor, timeout=helper_timeout)
        try:
            parsed = json.loads(helper_result.get("output", "{}"))
        except json.JSONDecodeError:
            parsed = None
        if helper_result["rc"] == 0 and isinstance(parsed, dict):
            draft_dir = egress_draft_path(draft_id)
            metadata = read_json(draft_dir / "metadata.json", {}) if draft_dir else {}
            parsed = egress_draft_enrich_runtime_result(parsed, metadata)
            if requested_mode == "quarantine" and draft_dir:
                metadata_path = draft_dir / "metadata.json"
                metadata.update({
                    "last_service_matrix_status": (parsed.get("service_matrix") or {}).get("status", ""),
                    "last_route_class_fitness": parsed.get("route_class_fitness", {}),
                    "last_role_fit": parsed.get("role_fit", {}),
                })
                write_json_atomic(metadata_path, metadata)
                try:
                    os.chmod(metadata_path, 0o600)
                except OSError:
                    pass
            return parsed, None
        if isinstance(parsed, dict) and parsed.get("error"):
            return None, parsed
        return None, {
            "error": "runtime_helper_failed",
            "rc": helper_result["rc"],
            "output": helper_result.get("output", ""),
        }

    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata_path = draft_dir / "metadata.json"
    config_path = draft_dir / "config.input"
    metadata = read_json(metadata_path, {})
    if not metadata or not config_path.exists():
        return None, {"error": "draft_not_found"}
    preflight = egress_draft_latest_preflight(metadata)
    if preflight.get("status") != "PASS":
        return None, {"error": "runtime_requires_passing_preflight", "last_preflight_status": metadata.get("last_preflight_status", "")}
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, {"error": "draft_config_read_failed", "detail": str(exc)}
    preview, error = egress_config_preview({"label": metadata.get("label", draft_id), "config": text})
    if error:
        return None, error
    protocol = preview.get("protocol", "unknown")
    runtime_mode = preview.get("runtime_mode", "unknown")
    if protocol not in ("wireguard", "amneziawg") or runtime_mode != "interface":
        return None, {"error": "runtime_adapter_not_ready", "protocol": protocol, "runtime_mode": runtime_mode}
    sanitized, error = egress_draft_sanitize_interface_config(text, protocol)
    if error:
        return None, error

    run_id = f"{draft_id}-runtime-{int(time.time())}-{secrets.token_hex(3)}"
    ifname = f"v7rt{secrets.token_hex(5)}"
    EGRESS_DRAFT_TESTS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(EGRESS_DRAFT_TESTS_DIR, 0o700)
    run_dir = EGRESS_DRAFT_TESTS_DIR / run_id
    run_dir.mkdir(mode=0o700, parents=False, exist_ok=False)
    archived_config = run_dir / "sanitized-runtime.conf"
    runtime_config = Path("/etc/wireguard") / f"{ifname}.conf"
    write_text_atomic(archived_config, sanitized, mode=0o600)

    result = {
        "id": run_id,
        "draft_id": draft_id,
        "label": metadata.get("label", draft_id),
        "created_at": now_iso(),
        "created_by": actor or "admin",
        "stage": "isolated_runtime",
        "mode": "temporary_interface_auto_cleanup",
        "requested_mode": requested_mode,
        "protocol": protocol,
        "runtime_mode": runtime_mode,
        "interface": ifname,
        "duration_seconds": duration,
        "pool_action": "still_not_added",
        "route_action": "none",
        "secret_redaction": "raw_config_not_returned",
        "checks": [],
    }

    before_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    if before_link["rc"] == 0:
        result["status"] = "BLOCKED"
        result["checks"].append({"id": "interface_name_free", "status": "FAIL", "detail": "temporary interface already exists"})
        write_json_atomic(run_dir / "result.json", result)
        return result, None
    result["checks"].append({"id": "interface_name_free", "status": "OK", "detail": ifname})
    if runtime_config.exists():
        result["status"] = "BLOCKED"
        result["checks"].append({"id": "runtime_config_name_free", "status": "FAIL", "detail": f"{runtime_config.name} already exists"})
        write_json_atomic(run_dir / "result.json", result)
        return result, None
    write_text_atomic(runtime_config, sanitized, mode=0o600)
    result["checks"].append({"id": "runtime_config_created", "status": "OK", "detail": runtime_config.name})

    up_cmd = ["wg-quick", "up", ifname]
    if protocol == "amneziawg" and shutil.which("awg-quick"):
        up_cmd = ["awg-quick", "up", str(runtime_config)]
    up_result = run_action(up_cmd, actor, timeout=25)
    result["up"] = {"rc": up_result["rc"], "output": up_result["output"]}
    result["checks"].append({"id": "runtime_up", "status": "OK" if up_result["rc"] == 0 else "FAIL", "detail": f"rc={up_result['rc']}"})

    if up_result["rc"] == 0:
        link_result = run_readonly(["ip", "-br", "addr", "show", ifname], timeout=5)
        wg_show_cmd = ["wg", "show", ifname] if protocol == "wireguard" else ["awg", "show", ifname]
        wg_result = run_readonly(wg_show_cmd, timeout=5)
        curl_result = run_readonly(["curl", "--interface", ifname, "-4", "--max-time", str(duration), "-fsS", "https://ifconfig.me"], timeout=duration + 4)
        result["interface_up"] = link_result["rc"] == 0
        result["link"] = {"rc": link_result["rc"], "output": link_result["output"]}
        result["wg_show"] = {"rc": wg_result["rc"], "output": wg_result["output"]}
        result["external_ip"] = {
            "ok": curl_result["rc"] == 0 and bool(str(curl_result["output"]).strip()),
            "rc": curl_result["rc"],
            "ip": str(curl_result["output"]).strip() if curl_result["rc"] == 0 else "",
            "detail": curl_result["output"] if curl_result["rc"] != 0 else "",
        }
        result["checks"].append({"id": "interface_visible", "status": "OK" if result["interface_up"] else "FAIL", "detail": ifname})
        result["checks"].append({"id": "external_ip", "status": "OK" if result["external_ip"]["ok"] else "FAIL", "detail": result["external_ip"].get("ip") or result["external_ip"].get("detail", "")})
    else:
        result["interface_up"] = False
        result["external_ip"] = {"ok": False, "rc": up_result["rc"], "ip": "", "detail": "runtime did not start"}

    partial_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    should_cleanup = up_result["rc"] == 0 or partial_link["rc"] == 0
    down_cmd = ["wg-quick", "down", ifname]
    if protocol == "amneziawg" and shutil.which("awg-quick"):
        down_cmd = ["awg-quick", "down", str(runtime_config)]
    down_result = run_action(down_cmd, actor, timeout=25) if should_cleanup else {"rc": 0, "output": "not_started_no_cleanup_needed"}
    try:
        runtime_config.unlink()
        runtime_config_removed = True
    except FileNotFoundError:
        runtime_config_removed = True
    except OSError as exc:
        runtime_config_removed = False
        result["runtime_config_remove_error"] = str(exc)
    after_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    interface_absent = after_link["rc"] != 0
    cleanup_ok = interface_absent and runtime_config_removed
    result["cleanup"] = {
        "status": "OK" if cleanup_ok else "FAIL",
        "down_rc": down_result["rc"],
        "down_output": down_result["output"],
        "interface_absent": interface_absent,
        "runtime_config_removed": runtime_config_removed,
    }
    result["checks"].append({"id": "cleanup", "status": "OK" if cleanup_ok else "FAIL", "detail": f"down_rc={down_result['rc']}"})
    result["status"] = egress_runtime_status_from_external_ip(result)
    if requested_mode == "quarantine":
        result["quarantine_status"] = "BLOCKED"
        result["service_matrix"] = {"status": "UNAVAILABLE_WITHOUT_HELPER", "reason": "helper is required for quarantine service checks"}
    result = egress_draft_enrich_runtime_result(result, metadata)
    result["next_step"] = "add_to_pool_preview" if result.get("quarantine_status") == "PASS" else ("service_matrix_quarantine_test" if result["status"] == "PASS" else "inspect_runtime_failure")

    write_json_atomic(run_dir / "result.json", result)
    try:
        os.chmod(run_dir / "result.json", 0o600)
    except OSError:
        pass
    metadata.update({
        "last_runtime_at": result["created_at"],
        "last_runtime_status": result["status"],
        "last_runtime_run_id": run_id,
        "next_step": result["next_step"],
    })
    if requested_mode == "quarantine":
        metadata.update({
            "last_quarantine_at": result["created_at"],
            "last_quarantine_status": result.get("quarantine_status", "BLOCKED"),
            "last_quarantine_run_id": run_id,
            "last_service_matrix_status": (result.get("service_matrix") or {}).get("status", ""),
            "last_route_class_fitness": result.get("route_class_fitness", {}),
            "last_role_fit": result.get("role_fit", {}),
        })
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass
    return result, None


def egress_draft_pool_preview(draft_id):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    if not metadata:
        return None, {"error": "draft_not_found"}
    label = metadata.get("label") or draft_id
    proposed_id = safe_egress_id(re.sub(r"[^A-Za-z0-9_.-]+", "-", str(label).lower()).strip("-")[:32]) or safe_egress_id(draft_id[:32])
    protocol = metadata.get("protocol", "unknown")
    runtime_mode = metadata.get("runtime_mode", "unknown")
    enabled = "0"
    typ = "interface" if runtime_mode == "interface" else "proxy"
    interface = egress_managed_interface_name(proposed_id) if typ == "interface" else ""
    proxy_port = egress_managed_proxy_port(proposed_id) if typ == "proxy" else 0
    test = "interface" if typ == "interface" else f"socks5://127.0.0.1:{proxy_port}"
    target_path = egress_draft_runtime_target_path(protocol, runtime_mode, proposed_id, interface)
    config_part = f" config={target_path}" if target_path else ""
    usage_policy = egress_usage_policy_from_data({}, metadata.get("usage_policy") or metadata)
    policy_part = egress_usage_policy_registry_part(usage_policy)
    proposed_line = f"id={proposed_id} protocol={protocol} type={typ} interface={interface} test={test} enabled={enabled}{config_part} {policy_part}".strip()
    active_text = read_text(STATE_DIR / "egress.registry", "")
    id_exists = bool(re.search(rf"^id={re.escape(proposed_id)}\s", active_text, flags=re.M))
    blockers = []
    if metadata.get("last_preflight_status") != "PASS":
        blockers.append("preflight_not_passed")
    if metadata.get("last_runtime_status") != "PASS":
        blockers.append("runtime_not_passed")
    if metadata.get("last_quarantine_status") != "PASS":
        blockers.append("quarantine_not_passed")
    if id_exists:
        blockers.append("egress_id_already_exists")
    if protocol not in ("wireguard", "amneziawg", "vless", "sing-box", "shadowsocks_or_outline", "vmess", "trojan"):
        blockers.append("unsupported_protocol")
    return {
        "draft_id": draft_id,
        "human": "Preview only. No files are changed and users are not moved.",
        "terms": {
            "pool": "the active list of egress channels V7 may route users through",
            "registry_line": "one line that would be added to /opt/v7/egress/state/egress.registry",
            "enabled_0": "the channel would start disabled until an operator explicitly enables it",
            "role": "the intended job of this channel, for example GLOBAL_FAST or TRUSTED_RU_SENSITIVE",
        },
        "ready": not blockers,
        "blockers": blockers,
        "proposed": {
            "id": proposed_id,
            "protocol": protocol,
            "type": typ,
            "interface": interface,
            "test": test,
            "enabled": enabled,
            "listen_port": proxy_port,
            "config": str(target_path) if target_path else "",
            "role": usage_policy["role"],
            "priority": usage_policy["priority"],
            "weight": usage_policy["weight"],
            "soft_limit": usage_policy["soft_limit"],
            "hard_limit": usage_policy["hard_limit"],
            "manual_only": usage_policy["manual_only"],
            "reserve_only": usage_policy["reserve_only"],
            "service_tags": usage_policy["service_tags"],
            "exclude_route_classes": usage_policy["exclude_route_classes"],
            "usage_policy": usage_policy,
