      if (severity === 'error' || result.includes('fail')) return 'Открыть служебную запись, проверить причину и не применять изменение без предварительной проверки.';
      if (result.includes('block')) return 'Проверить, что именно мешает действию, затем вернуться к соответствующему разделу.';
      if (action.includes('preview') || result.includes('dry')) return 'Если предварительная проверка выглядит правильно, применить изменение отдельной кнопкой подтверждения.';
      if (action.includes('profile_delivery')) return 'Проверить, скачал ли пользователь профиль. Старые одноразовые ссылки не продлевать вручную.';
      if (action.includes('speed') || action.includes('matrix')) return 'Использовать результат как свежий снимок, постоянную нагрузку не включать.';
