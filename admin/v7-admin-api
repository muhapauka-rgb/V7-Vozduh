  <div id="modalBackdrop" class="modal-backdrop" onclick="closeModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
      <header><h2 id="modalTitle">Details</h2><button onclick="closeModal()">Close</button></header>
      <div id="modalBody" class="modal-body"></div>
    </div>
  </div>
  <script>
    let csrf = '';
    let userFilter = 'all';
    const chip = (ok, text) => `<span class="chip ${ok ? 'ok' : 'bad'}">${text}</span>`;
    const esc = (v) => String(v ?? '').replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
    const table = (cols, rows) => `<table><thead><tr>${cols.map(c=>`<th>${esc(c)}</th>`).join('')}</tr></thead><tbody>${rows.join('')}</tbody></table>`;
    const bytesHuman = (bytes) => {
      const n = Number(bytes || 0);
      if (n >= 1024 * 1024 * 1024) return `${(n / 1024 / 1024 / 1024).toFixed(2)} GB`;
      if (n >= 1024 * 1024) return `${(n / 1024 / 1024).toFixed(2)} MB`;
      if (n >= 1024) return `${(n / 1024).toFixed(1)} KB`;
      return `${n} B`;
    };
    function openModal(title, bodyHtml) {
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalBody').innerHTML = bodyHtml;
      document.getElementById('modalBackdrop').classList.add('open');
    }
    function closeModal(event) {
      if (event && event.target && event.target.id !== 'modalBackdrop') return;
      document.getElementById('modalBackdrop').classList.remove('open');
    }
    const enabledEgressRows = (rows) => (rows || []).filter(row => String(row.enabled ?? '1') === '1' && row.id);
    const firstAlternativeEgress = (current, rows) => {
      const candidates = enabledEgressRows(rows).map(row => row.id).filter(id => id !== current);
      return candidates[0] || '';
    };
    const renderEgressSelect = (selectId, rows, selected='') => {
      const select = document.getElementById(selectId);
      if (!select) return;
      const active = enabledEgressRows(rows);
      select.innerHTML = active.map(row => `<option value="${esc(row.id)}" ${row.id === selected ? 'selected' : ''}>${esc(row.id)}</option>`).join('');
      select.disabled = active.length === 0;
    };
    async function load() {
      const sr = await fetch('/api/session', {cache:'no-store'});
      if (sr.status === 401) { location.href = '/login'; return; }
      const sd = await sr.json();
      csrf = sd.csrf || '';
      const r = await fetch('/api/overview', {cache:'no-store'});
      if (r.status === 401) { location.href = '/login'; return; }
      const d = await r.json();
      window.lastOverview = d;
      document.getElementById('sub').textContent = `${d.host} · ${d.bind.host}:${d.bind.port} · ${new Date(d.updated).toLocaleString()} · ${d.access?.user || 'user'}:${d.access?.role || 'viewer'}`;
      renderSafeMode(d.admin_safe_mode || {});
      const s = d.summary;
      const rebuildActive = String(d.state?.policy_rebuild?.active || '0') === '1';
      const metrics = [
        ['Users', `${s.users_total} / ${s.client_agents_online || 0} online`, true],
        ['Healthy egress', `${s.egress_healthy}/${s.egress_total}`, s.egress_healthy > 0],
        ['User readiness', `${s.users_ready || 0}/${s.users_total}`, (s.users_ready || 0) === s.users_total],
        ['Routes OK', `${s.route_ok}/${s.users_total}`, s.route_ok === s.users_total],
        ['Kill switch', s.killswitch_status || (s.killswitch_ok ? 'OK' : 'Problem'), s.killswitch_ok],
        ['Capacity', s.capacity_status || (s.capacity_ok ? 'OK' : 'Check'), s.capacity_ok],
        ['Direct RU', s.direct_ru_route_ok ? 'Route OK' : 'Check', s.direct_ru_route_ok],
        ['Identity', `${s.identity_users || 0}/${s.identity_allowed_users || 0} allowed`, !!d.identity?.configured],
        ['Policy rebuild', rebuildActive ? 'Rebuilding' : 'Idle', !rebuildActive],
        ['State', s.stale_ok ? 'Fresh' : 'Stale', s.stale_ok],
        ['Leak risk', s.route_leak_risk ? 'Yes' : 'No', !s.route_leak_risk],
      ];
      document.getElementById('metrics').innerHTML = metrics.map(m => `<div class="card"><div class="label">${esc(m[0])}</div><div class="metric">${esc(m[1])}</div>${chip(m[2], m[2] ? 'OK' : 'Action')}</div>`).join('');
      const speedItems = (d.speed_tests && d.speed_tests.items) || {};
      const clientSpeed = d.client_speed_summary || {};
      const matrixItems = (d.service_matrix && d.service_matrix.items) || {};
      const egressRegistry = {};
      const egressRows = d.registries?.egress || [];
      egressRows.forEach(row => { if (row.id) egressRegistry[row.id] = row; });
      renderEgressSelect('newUserEgress', egressRows);
      const egressFlags = d.registries?.egress_flags_map || {};
      const runtimeReadiness = d.egress_runtime_readiness || {};
      const egressIds = Array.from(new Set([...(egressRows || []).map(row => row.id).filter(Boolean), ...Object.keys(d.state.egress || {})]));
      const eg = egressIds.flatMap(id => {
        const e = (d.state.egress || {})[id] || {};
        const sp = speedItems[id] || {};
        const cp = clientSpeed[id] || {};
        const mx = matrixItems[id] || {};
        const reg = egressRegistry[id] || {};
        const poolState = egressFlags[`${id}_state`] || (reg.enabled === '0' ? 'disabled' : 'enabled');
        const ready = runtimeReadiness[id] || {};
        const serverSpeed = sp.server_v7_mbps ? `${sp.server_v7_mbps} Mbps` : 'not measured';
        const phoneV7 = cp.client_v7_mbps ? `${cp.client_v7_mbps} Mbps` : 'client test needed';
        const phoneDirect = cp.client_direct_mbps ? `${cp.client_direct_mbps} Mbps` : 'direct test needed';
        const drop = cp.degradation_pct === null || cp.degradation_pct === undefined ? 'n/a' : `${cp.degradation_pct}%`;
        const matrix = mx.total ? `${mx.ok_count}/${mx.total}` : 'not tested';
        const healthOk = e.code === '200' || poolState === 'disabled';
        const healthLabel = e.diagnose_severity || e.code || (poolState === 'disabled' ? 'disabled' : 'unknown');
        const users = e.users ?? '0';
        const readinessLabel = ready.status ? `${ready.status}${ready.reason ? `: ${ready.reason}` : ''}` : 'unknown';
        const role = reg.role || 'GLOBAL_FAST';
        return [
          `<tr><td><button title="Show redacted config, speed history and service matrix" onclick="toggleEgress('${esc(id)}')">Details</button></td><td>${esc(id)}</td><td>${chip(healthOk, healthLabel)}</td><td>${chip(poolState === 'enabled', poolState)}</td><td>${esc(role)}</td><td>${chip(!!ready.enable_ready, readinessLabel)}</td><td>${esc(users)}</td><td>${esc(serverSpeed)}</td><td>${esc(phoneV7)}</td><td>${esc(phoneDirect)}</td><td>${esc(drop)}</td><td>${chip(mx.status === 'OK', matrix)}</td><td>${esc(e.load_status || '')}</td><td><button title="Run manual server speed test" onclick="speedEgress('${esc(id)}')">Speed</button> <button title="Run service matrix" onclick="serviceMatrix('${esc(id)}')">Matrix</button> <button onclick="showRouteLogs('${esc(id)}')">Logs</button> <button onclick="previewEgressState('${esc(id)}','enabled')">Enable</button> <button onclick="previewEgressState('${esc(id)}','maintenance')">Maintenance</button> <button onclick="previewEgressState('${esc(id)}','disabled')">Disable</button></td></tr>`,
          `<tr id="egress-detail-${esc(id)}" style="display:none"><td colspan="14"><div id="egress-detail-body-${esc(id)}" class="muted">loading...</div></td></tr>`
        ];
      });
      document.getElementById('egress').innerHTML = table(['','id','status','pool','role','enable readiness','users','server V7','phone V7','phone direct','drop','services','load','test'], eg);
      renderUsersTable(d, egressRows);
      const routes = d.route_reality.map(x => `<tr><td>${esc(x.ip)}</td><td>${esc(x.expected_dev)}</td><td>${chip(x.ok && !x.leak_risk, x.leak_risk ? 'leak risk' : x.ok ? 'OK' : 'check')}</td></tr>`);
      document.getElementById('routes').innerHTML = `<p><button onclick="showKillSwitch()">Kill Switch Details</button></p>${table(['ip','expected','route'], routes)}`;
      renderCapacityPlan(d.capacity_plan || {});
      const direct = d.direct_routing || {};
      const directDomains = (direct.domains?.items || []).map(domain => `<tr><td>${esc(domain)}</td><td><button onclick="removeDirectDomain('${esc(domain)}')">Remove</button></td></tr>`);
      document.getElementById('directRu').innerHTML = `${kv({'status': direct.summary || 'unknown', 'test user': direct.user_ip || '', 'quick domain': direct.quick_domain || '', 'route': direct.route_ok ? 'direct via VPS public interface' : 'needs check'})}<div class="action-form"><label><span class="label">Domain / suffix</span><input id="directDomainInput" placeholder=".ru or gosuslugi.ru"></label><label><span class="label">Action</span><button onclick="addDirectDomain()">Add Direct</button></label><button onclick="loadDirectRuFull()">Run Full Direct Check</button></div><h3>Whitelist</h3>${directDomains.length ? table(['domain','action'], directDomains) : '<div class="muted">No direct domains configured.</div>'}<pre>${esc(direct.quick_test?.output || '')}</pre>`;
      renderRouteClasses(d);
      renderPolicyDomains(d.policy_domains || {});
      renderTrustedRu(d.trusted_ru || {}, d.trusted_ru_readiness || {});
      renderIdentity(d.identity || {});
      const backups = d.backups.map(b => `<tr><td>${esc(b.name)}</td><td>${bytesHuman(b.size_bytes)}</td><td>${chip(b.sha256_file, b.sha256_file ? 'sha' : 'missing')}</td><td><button onclick="verifyBackup('${esc(b.name)}')">Verify</button> <button onclick="previewRestore('${esc(b.name)}')">Restore Preview</button> <button onclick="downloadBackup('${esc(b.name)}')">Download</button></td></tr>`);
      document.getElementById('backups').innerHTML = `${kv({'backup dir': d.maintenance?.backups?.dir || '', 'backup count': d.maintenance?.backups?.count || 0, 'backup total': bytesHuman(d.maintenance?.backups?.total_bytes), 'disk used': d.maintenance?.disk?.used_pct !== undefined ? `${d.maintenance.disk.used_pct}%` : 'unknown'})}<p><button onclick="showBackupManager()">Backup Manager</button> <button onclick="showLogMaintenance()">Log / Disk Limits</button></p>${table(['backup','size','sha','actions'], backups)}`;
      renderPolicy(d.policy || {});
      await loadAdminAccounts();
      const rec = d.service_recommendations || {};
      const prefs = d.service_preferences || {};
      const bestRows = Object.values(rec.best_by_service || {}).map(x => `<tr><td>${esc(x.service)}</td><td>${chip(x.status === 'OK', x.best_egress || 'none')}</td><td>${esc((x.candidates || []).map(c => `${c.egress}:${c.ok ? 'OK' : 'FAIL'}:${c.first_byte_sec ?? 'n/a'}s`).join(' · '))}</td></tr>`);
      const warnRows = (rec.user_warnings || []).map(w => `<tr><td>${esc(w.ip)}</td><td>${esc(w.service)}</td><td>${esc(w.current_egress)}</td><td>${chip(false, w.current_status)}</td><td>${esc(w.recommended_egress)}</td><td><button onclick="switchUser('${esc(w.ip)}','${esc(w.recommended_egress)}')">Switch</button></td></tr>`);
      const prefRows = (d.state.users || []).map(u => {
        const selected = ((prefs.users || {})[u.ip] || {}).services || [];
        const checks = (rec.known_services || []).map(svc => `<label style="display:inline-flex;gap:5px;align-items:center;margin-right:10px"><input type="checkbox" data-pref-ip="${esc(u.ip)}" value="${esc(svc)}" ${selected.includes(svc) ? 'checked' : ''}>${esc(svc)}</label>`).join('');
        return `<tr><td>${esc(u.ip)}</td><td>${checks}</td><td><button onclick="saveUserPrefs('${esc(u.ip)}')">Save</button></td></tr>`;
      });
      document.getElementById('recommendations').innerHTML = `<p>${chip(!!rec.enabled, rec.enabled ? 'recommendations on' : 'recommendations off')} <button onclick="toggleRecommendations(${rec.enabled ? 'false' : 'true'})">${rec.enabled ? 'Disable' : 'Enable'}</button></p><h3>User Service Preferences</h3>${table(['ip','important services','action'], prefRows)}<h3>Best Egress By Service</h3>${table(['service','best','candidates'], bestRows)}<h3>User Warnings</h3>${rec.enabled ? (warnRows.length ? table(['ip','service','current','status','recommended','action'], warnRows) : '<div class="muted">No service mismatches detected for enabled preferences.</div>') : '<div class="muted">Recommendations are disabled.</div>'}`;
      document.getElementById('diag').textContent = ['--- stale ---', d.checks.stale.output, '--- killswitch ---', d.checks.killswitch.output, '--- capacity ---', d.checks.capacity.output, '--- capacity readiness ---', d.checks.capacity_readiness.output, '--- ipam preview ---', d.checks.ipam_preview.output, '--- direct routing ---', d.checks.direct_routing.output, '--- sensitive RU ---', d.checks.trusted_ru.output, '--- rebalance preview ---', d.checks.rebalance_preview.output].join('\\n');
      await loadSecurityAudit();
      await loadEvents();
    }
    function renderCapacityPlan(plan) {
      const el = document.getElementById('capacityPlan');
      if (!el) return;
      const pools = (plan.pools || []).map(row => `<tr><td>${esc(row.label)}</td><td><code>${esc(row.cidr)}</code></td><td>${esc(row.mode)}</td><td>${esc(row.capacity)}</td><td>${esc(row.registered)}</td><td>${esc(row.active)}</td><td>${esc(row.free)}</td><td>${esc(row.used_pct)}%</td></tr>`);
      const warnings = (plan.warnings || []).map(w => `<div class="muted">• ${esc(w)}</div>`).join('');
      const next = plan.next_allocation || {};
      el.innerHTML = `${kv({'status': plan.status || 'UNKNOWN', 'target users': plan.target_users || 500, 'registered users': plan.registered_users ?? 0, 'active users': plan.active_users ?? 0, 'total address capacity': plan.total_capacity ?? '', 'free addresses': plan.free_capacity ?? '', 'next IP preview': next.ip || 'unknown', 'next table preview': next.table || 'unknown', 'meaning': plan.plain || ''})}${warnings}${pools.length ? table(['pool','subnet','meaning','capacity','registered','active','free','used'], pools) : '<div class="muted">No pool data yet.</div>'}<div class="muted" style="margin-top:8px">Preview only. This screen does not create users or change routing.</div>`;
    }
    function userFilterMatch(user, readiness, filter) {
      const enabled = String(user.enabled ?? '1') === '1';
      const status = String(readiness.status || 'UNKNOWN').toLowerCase();
      if (filter === 'all') return true;
      if (filter === 'disabled') return !enabled;
      if (!enabled) return false;
      return status === filter;
    }
    function setUserFilter(filter) {
      userFilter = filter || 'all';
      if (window.lastOverview) renderUsersTable(window.lastOverview, window.lastEgressRows || []);
    }
    function userFilterButton(id, label, count) {
      return `<button class="${userFilter === id ? 'active' : ''}" onclick="setUserFilter('${esc(id)}')">${esc(label)} ${esc(count)}</button>`;
    }
    function readinessReason(readiness) {
      const items = (readiness.blockers || []).concat(readiness.warnings || []);
      const value = items[0] || (readiness.status === 'READY' ? 'ready' : 'unknown');
      const labels = {
        user_disabled: 'User disabled',
        client_config_missing: 'Config missing',
        desired_state_needs_check: 'State needs check',
        route_or_leak_check_failed: 'Route/leak check failed',
        waiting_for_first_client_connection: 'Waiting first connection',
        ready: 'Ready',
        unknown: 'Check details',
      };
      return labels[value] || String(value).replaceAll('_', ' ');
    }
    function renderUsersTable(d, egressRows) {
      window.lastOverview = d;
      window.lastEgressRows = egressRows || [];
      const allUsers = d.state.users || [];
      const readiness = d.user_readiness || {};
      const counts = {
        all: allUsers.length,
        ready: allUsers.filter(u => String(u.enabled ?? '1') === '1' && String((readiness[u.ip] || {}).status || '').toUpperCase() === 'READY').length,
        waiting: allUsers.filter(u => String(u.enabled ?? '1') === '1' && String((readiness[u.ip] || {}).status || '').toUpperCase() === 'WAITING').length,
        blocked: allUsers.filter(u => String(u.enabled ?? '1') === '1' && String((readiness[u.ip] || {}).status || '').toUpperCase() === 'BLOCKED').length,
