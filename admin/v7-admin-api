def validate_maintenance_settings(data):
    def bounded_int(name, default, min_value, max_value):
        raw = str(data.get(name, default)).strip()
        if not re.match(r"^[0-9]+$", raw):
            return None, f"{name}_must_be_integer"
        value = int(raw)
        if value < min_value or value > max_value:
            return None, f"{name}_out_of_range_{min_value}_{max_value}"
        return value, None

    backup_keep, error = bounded_int("backup_keep", "10", 1, 365)
    if error:
        return None, error
    backup_keep_days, error = bounded_int("backup_keep_days", "14", 1, 3650)
    if error:
        return None, error
    journal_vacuum_size = str(data.get("journal_vacuum_size", "200M")).strip().upper()
    if not SAFE_SIZE_RE.match(journal_vacuum_size):
        return None, "journal_vacuum_size_invalid"
    journal_vacuum_time = str(data.get("journal_vacuum_time", "14d")).strip().lower()
    if not SAFE_TIME_RE.match(journal_vacuum_time):
        return None, "journal_vacuum_time_invalid"
    return {
        "backup_keep": backup_keep,
        "backup_keep_days": backup_keep_days,
        "journal_vacuum_size": journal_vacuum_size,
        "journal_vacuum_time": journal_vacuum_time,
    }, None


