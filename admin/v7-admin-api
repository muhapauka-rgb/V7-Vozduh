def identity_issue_device(data, actor):
    if admin_safe_mode_enabled():
        return None, {"error": "safe_mode_enabled", "message": "Safe mode allows diagnostics only."}, 423
    identity_init_db()
    user_id = safe_identity_id(data.get("user_id", ""))
    user = identity_user_by_id(user_id)
    if not user:
        return None, {"error": "identity_user_not_found"}, 404
    if user.get("status") in ("blocked", "disabled"):
        return None, {"error": f"user_{user.get('status')}", "message": "Identity user is blocked or disabled."}, 403
    vpn_client = safe_connect_client(data.get("vpn_client", "karing"))
    if not connect_client_supported(vpn_client):
        return None, {"error": "unsupported_vpn_client", "supported": sorted(SUPPORTED_CONNECT_CLIENTS)}, 400
    client_meta = CONNECT_CLIENTS.get(vpn_client, CONNECT_CLIENTS["karing"])
    adapter = safe_smart_adapter(client_meta.get("adapter") or vpn_client)
    mode = safe_smart_mode(data.get("mode", "RU_LOCAL")) or "RU_LOCAL"
    device_type = clean_identity_text(data.get("device_type", "phone"), 60) or "phone"
    egress = safe_egress_id(data.get("egress", "")) or default_egress_id()
    dry_run = bool(data.get("dry_run", True))
    if not adapter:
        return None, {"error": "invalid_smart_adapter", "supported": sorted(SUPPORTED_SMART_ADAPTERS)}, 400
    if not mode:
        return None, {"error": "invalid_smart_mode", "supported": sorted(SUPPORTED_SMART_MODES)}, 400
    if not egress_exists(egress, enabled_only=True):
        return None, {"error": "invalid_egress"}, 400
    active_devices = identity_active_device_count(user["id"])
    max_devices = int(user.get("max_devices") or 3)
    if active_devices >= max_devices:
        return None, {"error": "device_limit_reached", "active_devices": active_devices, "max_devices": max_devices}, 409
    client_name = safe_client_name(data.get("client_name", "")) or onboarding_client_name(user, device_type)
    planned = {
        "user_id": user["id"],
        "display_name": user.get("display_name") or user.get("entered_name") or user.get("phone_normalized"),
        "phone_normalized": user.get("phone_normalized", ""),
        "client_name": client_name,
        "vpn_client": vpn_client,
        "adapter": adapter,
        "mode": mode,
        "device_type": device_type,
        "egress": egress,
        "active_devices": active_devices,
        "max_devices": max_devices,
    }
    preflight = run_action(["v7-user-create-from-ipam", "--name", client_name, "--device", device_type, "--egress", egress], actor, timeout=30)
    if preflight["rc"] != 0:
        audit_admin(actor, "admin_action_identity_device_issue", f"user_id={user['id']} client={vpn_client} mode={mode} dry_run={str(dry_run).lower()} preflight=fail", object_type="identity_user", object_id=user["id"], result="FAIL")
        return {"planned": planned, "preflight": preflight}, {"error": "provisioning_preflight_failed"}, 500
    if dry_run:
        audit_admin(actor, "admin_action_identity_device_issue_preview", f"user_id={user['id']} client={vpn_client} mode={mode}", object_type="identity_user", object_id=user["id"], result="OK")
        return {"action": "identity_device_issue_preview", "planned": planned, "preflight": preflight}, None, 200
    created = run_action([
        "v7-user-create-from-ipam",
        "--name", client_name,
        "--device", device_type,
        "--egress", egress,
        "--apply",
        "--confirm", "CREATE_IPAM_USER",
    ], actor, timeout=70)
    parsed = parse_command_kv(created.get("output", ""))
    if created["rc"] != 0 or not safe_user_ip(parsed.get("ip", "")):
        audit_admin(actor, "admin_action_identity_device_issue", f"user_id={user['id']} client={vpn_client} mode={mode} create=fail", object_type="identity_user", object_id=user["id"], result="FAIL")
        return {"planned": planned, "preflight": preflight, "created": created, "parsed": parsed}, {"error": "device_create_failed"}, 500
    ip = parsed["ip"]
    artifact_name = safe_client_name(parsed.get("name", "")) or client_name
