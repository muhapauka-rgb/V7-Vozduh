          <div class="detail-panel"><h3>Health</h3>${kv({code:d.state?.code || '', severity:d.state?.diagnose_severity || '', reason:d.state?.diagnose_reason || '', load:d.state?.load_status || '', updated:matrix.updated || speed.updated || ''})}</div>
        </div>
