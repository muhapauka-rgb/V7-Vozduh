            data = read_request_data(self)
            try:
                limit = int(data.get("limit", 2))
            except (TypeError, ValueError):
                limit = 2
            limit = max(1, min(6, limit))
            actor = session.get("sub", "admin")
            audit_admin(actor, "admin_action_trusted_ru_refresh_missing", f"limit={limit}", object_type="trusted_ru", object_id="missing", result="OK")
            result = run_action(["v7-trusted-ru-refresh-missing", "--limit", str(limit)], actor, timeout=max(120, limit * 70))
            status = 200 if result["rc"] == 0 else 500
            self.send_json({"action": "trusted_ru_refresh_missing", "limit": limit, "result": result, "trusted_ru": trusted_ru_diagnostic_state(), "overview": overview()}, status=status)
        elif path == "/api/actions/user-flow-trace":
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            data = read_request_data(self)
            user_ip = safe_user_ip(data.get("user_ip", "")) or default_active_user_ip(parse_registry(STATE_DIR / "users.registry"))
            domain = safe_domain(data.get("domain", ""))
            try:
                duration = int(data.get("duration", 25))
            except (TypeError, ValueError):
                duration = 25
            duration = max(5, min(60, duration))
            if not user_ip:
                self.send_json({"error": "invalid_user_ip"}, status=400)
                return
            if not domain:
                self.send_json({"error": "invalid_domain"}, status=400)
                return
            actor = session.get("sub", "admin")
            audit_admin(actor, "admin_action_user_flow_trace", f"user_ip={user_ip} domain={domain} duration={duration}", object_type="user_flow_trace", object_id=f"{user_ip}:{domain}", result="OK")
            result = run_action(["v7-user-flow-trace", user_ip, domain, str(duration)], actor, timeout=duration + 20)
            status = 200 if result["rc"] == 0 else 500
            self.send_json({"action": "user_flow_trace", "user_ip": user_ip, "domain": domain, "duration": duration, "result": result, "trusted_ru": trusted_ru_diagnostic_state(), "overview": overview()}, status=status)
        elif path == "/api/actions/policy-systemd-apply":
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            data = read_request_data(self)
            if str(data.get("confirm", "")) != "APPLY_INTERVALS":
                self.send_json({"error": "policy_systemd_apply_requires_confirm_APPLY_INTERVALS"}, status=400)
                return
            actor = session.get("sub", "admin")
            audit_admin(actor, "admin_action_policy_systemd_apply", "policy systemd interval apply confirmed", object_type="policy", object_id="systemd", result="OK")
            result = run_action(["v7-policy-apply-systemd", "--apply"], actor, timeout=45)
            self.send_json({"action": "policy_systemd_apply", "result": result, "overview": overview()}, status=200 if result["rc"] == 0 else 500)
        elif path == "/api/actions/trusted-ru-diagnostic":
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            data = read_request_data(self)
            raw_domains = data.get("domains", [])
            if isinstance(raw_domains, str):
                raw_domains = re.split(r"[\s,]+", raw_domains)
            domains = []
            domain_source = raw_domains if isinstance(raw_domains, list) else []
            for item in domain_source:
                domain = safe_domain(item)
                if domain and domain not in domains:
                    domains.append(domain)
            if len(domains) > 12:
                self.send_json({"error": "too_many_domains", "max": 12}, status=400)
                return
            actor = session.get("sub", "admin")
            audit_admin(actor, "admin_action_trusted_ru_diagnostic", f"domains={','.join(domains) if domains else 'default'}", object_type="trusted_ru", object_id="diagnostic", result="OK")
            cmd = ["v7-trusted-ru-diagnostic"] + domains
            result = run_action(cmd, actor, timeout=220)
            decision_result = run_action(["v7-trusted-ru-decision", "--write-state"] + domains, actor, timeout=40) if result["rc"] == 0 else {"rc": 1, "output": "diagnostic_failed"}
            status = 200 if result["rc"] == 0 else 500
            self.send_json({"action": "trusted_ru_diagnostic", "domains": domains or "default", "result": result, "decision_result": decision_result, "trusted_ru": trusted_ru_diagnostic_state(), "overview": overview()}, status=status)
        elif path == "/api/actions/service-preferences-update":
            session = self.require_auth(api=True)
            if not session:
                return
            if not self.require_csrf(session):
                return
            data = read_request_data(self)
            enabled = data.get("enabled") if "enabled" in data else None
            ip = safe_user_ip(data.get("ip", "")) if data.get("ip") else ""
            services = data.get("services", [])
            if data.get("ip") and not ip:
                self.send_json({"error": "invalid_user_ip"}, status=400)
                return
            if ip:
                users = parse_registry(STATE_DIR / "users.registry")
                if not any(row.get("ip") == ip and str(row.get("enabled", "1")) == "1" for row in users):
                    self.send_json({"error": "user_not_found_or_disabled", "ip": ip}, status=404)
                    return
            actor = session.get("sub", "admin")
            prefs = update_service_preferences(actor, enabled=enabled, user_ip=ip or None, services=services)
            audit_admin(actor, "admin_action_service_preferences_update", f"enabled={prefs.get('enabled')} ip={ip or 'none'} services={','.join(normalize_services(services)) if ip else 'unchanged'}")
            self.send_json({"action": "service_preferences_update", "preferences": prefs, "overview": overview()})
        else:
            self.send_json({"error": "not_found", "path": html.escape(path)}, status=404)


def main():
    httpd = ThreadingHTTPServer((HOST, PORT), Handler)
    print(f"V7 admin API listening on http://{HOST}:{PORT}", flush=True)
    httpd.serve_forever()


if __name__ == "__main__":
    main()
