      const d = await api(`/api/events?${v2EventParams().toString()}`);
      const events = d.items || d.events || [];
      window.v2Events = events;
      const summary = d.summary || {};
      const latest = events[0] || {};
      const statsHost = document.getElementById('logsStats');
      if (statsHost) statsHost.innerHTML = [
        statCard('Показано событий', summary.total || events.length || 0, 'после текущих фильтров'),
        statCard('Ошибки', summary.error || 0, 'требует внимания', Number(summary.error || 0) ? 'bad' : 'ok'),
        statCard('Предупреждения', summary.warning || 0, 'проверить при случае', Number(summary.warning || 0) ? 'warn' : 'ok'),
        statCard('Последнее', latest.time || latest.ts || latest.created_at || 'нет', latest.action || latest.component || 'лента событий'),
      ].join('');
      const rows = events.map((e, index) => {
        const object = [e.object_type, e.object_id].filter(Boolean).join(':');
        return `<tr data-v2-event-index="${index}"><td>${esc(e.time || e.ts || e.created_at || '')}</td><td>${pill(e.severity || 'info', eventTone(e.severity))}</td><td>${esc(e.source || '')}<br><span class="muted">${esc(e.actor || '')}</span></td><td>${esc(e.component || '')}<br><span class="muted">${esc(e.action || '')}</span></td><td>${esc(object || e.user_ip || '')}</td><td>${pill(e.result || 'event', statusTone(e.result || e.severity))}</td><td>${esc(e.message || e.action || '')}</td></tr>`;
      });
      document.getElementById('v2EventSummary').innerHTML = renderV2EventSummary(summary);
      host.innerHTML = listTable(['Время','Важность','Источник / actor','Компонент / действие','Объект','Результат','Сообщение'], rows, 'Событий по текущим фильтрам нет.');
      host.querySelectorAll('[data-v2-event-index]').forEach(row => row.addEventListener('click', () => openV2Event(row.dataset.v2EventIndex)));
    }
    function bindTableSearch(inputId, tableHostId) {
      const input = document.getElementById(inputId);
      const host = document.getElementById(tableHostId);
      if (!input || !host || input.dataset.bound) return;
      input.dataset.bound = '1';
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase();
        host.querySelectorAll('tbody tr').forEach(tr => tr.style.display = tr.innerText.toLowerCase().includes(q) ? '' : 'none');
      });
    }
    function bindDrawerRows() {
      document.querySelectorAll('[data-v2-drawer]').forEach(row => {
        if (row.dataset.drawerBound) return;
        row.dataset.drawerBound = '1';
        row.addEventListener('click', () => {
          const type = row.dataset.v2Drawer;
          if (type === 'user') {
            const ip = row.dataset.ip || '';
            openUserDrawer(ip);
          } else if (type === 'channel') {
            const id = row.dataset.egress || '';
            openChannelDrawer(id);
          } else if (type === 'identity') {
            const id = row.dataset.userId || '';
            openIdentityDrawer(id);
          } else if (type === 'route') {
            openRouteDrawer(row.dataset.routeClass || '');
          }
        });
      });
    }
    function renderAll() {
      renderOverview();
      renderUsers();
      renderChannels();
      renderRouting();
      renderIdentity();
      renderChecks();
      renderSecurity();
      renderSettings();
      renderLogsGuideCards();
      loadEvents();
      bindDrawerRows();
    }
    async function load() {
      const session = await api('/api/session');
      csrf = session.csrf || '';
      overview = await api('/api/overview');
      renderAll();
    }
    load();
  </script>
</body>
</html>"""


