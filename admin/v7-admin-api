        if group_id and not conn.execute("SELECT 1 FROM groups WHERE id=?", (group_id,)).fetchone():
            return None, {"error": "group_not_found", "group_id": group_id}
        conn.execute(
            """
            INSERT INTO allowed_users
              (id, phone_normalized, expected_name, organization_id, group_id, note, is_active, created_at, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            ON CONFLICT(id) DO UPDATE SET
              phone_normalized=excluded.phone_normalized,
              expected_name=excluded.expected_name,
              organization_id=excluded.organization_id,
              group_id=excluded.group_id,
              note=excluded.note,
