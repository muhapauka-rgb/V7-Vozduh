    return result, None


def egress_draft_clash_create_proxy_draft(data, actor):
    source_draft_id = safe_draft_id(data.get("draft_id", ""))
    draft_dir = egress_draft_path(source_draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    config_path = draft_dir / "config.input"
    if not metadata or not config_path.exists():
        return None, {"error": "draft_not_found"}
    if metadata.get("protocol") != "clash_yaml":
        return None, {"error": "draft_is_not_clash_yaml", "protocol": metadata.get("protocol", "")}
    try:
        proxy_index = int(str(data.get("proxy_index", "0") or "0"))
    except ValueError:
        proxy_index = 0
    if proxy_index <= 0:
        return None, {"error": "invalid_proxy_index"}
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, {"error": "draft_config_read_failed", "detail": str(exc)}
    proxies = _clash_parse_proxies(text)
    if proxy_index > len(proxies):
        return None, {"error": "proxy_index_not_found", "proxy_index": proxy_index, "proxy_count": len(proxies)}
    selected = _clash_proxy_to_outbound(proxies[proxy_index - 1], index=proxy_index, redact_secrets=False)
    if selected.get("status") != "READY":
        return None, {
            "error": "selected_proxy_not_ready",
            "proxy_index": proxy_index,
            "status": selected.get("status"),
            "missing": selected.get("missing", []),
            "type": selected.get("type", ""),
            "reason": selected.get("reason", ""),
        }
    outbound = dict(selected.get("outbound") or {})
    outbound["tag"] = "egress"
    profile = {
        "log": {"level": "warn"},
        "outbounds": [
            outbound,
            {"type": "direct", "tag": "direct"},
            {"type": "block", "tag": "block"},
        ],
        "route": {"final": "egress"},
    }
    label = clean_identity_text(data.get("label", ""), 80) or f"{metadata.get('label', 'clash')}-{selected.get('name', f'proxy-{proxy_index}')}"
    create_data = {
        "label": label,
        "config": json.dumps(profile, ensure_ascii=False, indent=2),
        "role": data.get("role") or metadata.get("role") or (metadata.get("usage_policy") or {}).get("role") or "GLOBAL_FAST",
        "priority": data.get("priority") if str(data.get("priority", "")).strip() else metadata.get("priority", ""),
        "weight": data.get("weight") if str(data.get("weight", "")).strip() else metadata.get("weight", ""),
        "soft_limit": data.get("soft_limit") if str(data.get("soft_limit", "")).strip() else metadata.get("soft_limit", ""),
        "hard_limit": data.get("hard_limit") if str(data.get("hard_limit", "")).strip() else metadata.get("hard_limit", ""),
        "service_tags": data.get("service_tags") if str(data.get("service_tags", "")).strip() else ",".join(metadata.get("service_tags", []) or []),
        "exclude_route_classes": data.get("exclude_route_classes") if str(data.get("exclude_route_classes", "")).strip() else ",".join(metadata.get("exclude_route_classes", []) or []),
        "manual_only": data.get("manual_only") if "manual_only" in data else metadata.get("manual_only", False),
        "reserve_only": data.get("reserve_only") if "reserve_only" in data else metadata.get("reserve_only", False),
    }
    child, error = egress_draft_create(create_data, actor)
    if error:
        return None, error
    child_dir = egress_draft_path(child.get("id", ""))
    if child_dir:
        metadata_path = child_dir / "metadata.json"
        child_meta = read_json(metadata_path, child)
        child_meta.update({
            "source": "clash_yaml_proxy",
            "source_clash_draft_id": source_draft_id,
            "source_proxy_index": proxy_index,
            "source_proxy_name": selected.get("name", ""),
            "converted_from": {
                "protocol": "clash_yaml",
                "proxy_type": selected.get("type", ""),
                "target": "sing-box",
            },
            "next_step": "preflight",
        })
        child_meta["lifecycle"] = egress_draft_lifecycle(child_meta)
        write_json_atomic(metadata_path, child_meta)
        child = dict(child_meta)
    safe_child = dict(child)
    safe_child.pop("config_path", None)
    return {
        "status": "CREATED",
        "source_draft_id": source_draft_id,
        "source_proxy_index": proxy_index,
        "source_proxy_name": selected.get("name", ""),
        "child_draft": safe_child,
        "pool_action": "still_not_added",
        "would_start_runtime": False,
        "would_change_routes": False,
        "would_change_killswitch": False,
        "secret_redaction": "child draft stores real proxy secret root-only; API response redacts it",
        "next_step": "run_preflight_on_child_draft",
    }, None


def egress_draft_sanitize_interface_config(text, protocol):
    sections = _egress_preview_ini_sections(text)
    interface = sections.get("Interface", {})
    peer = sections.get("Peer", {})
    if not interface or not peer:
        return None, {"error": "runtime_requires_interface_and_peer"}

    errors = []
    private_key = str(interface.get("PrivateKey", "")).strip()
    public_key = str(peer.get("PublicKey", "")).strip()
    preshared_key = str(peer.get("PresharedKey", "")).strip()
    address = str(interface.get("Address", "")).strip()
    endpoint = str(peer.get("Endpoint", "")).strip()
    allowed_ips = str(peer.get("AllowedIPs", "0.0.0.0/0")).strip() or "0.0.0.0/0"
    keepalive = str(peer.get("PersistentKeepalive", "25")).strip() or "25"
    table = str(interface.get("Table", "")).strip().lower()

    if not SAFE_WG_KEY_RE.match(private_key):
        errors.append("Interface.PrivateKey has invalid WireGuard key format")
    if not SAFE_WG_KEY_RE.match(public_key):
        errors.append("Peer.PublicKey has invalid WireGuard key format")
    if preshared_key and not SAFE_WG_KEY_RE.match(preshared_key):
        errors.append("Peer.PresharedKey has invalid WireGuard key format")
    if not address or not re.match(r"^[0-9a-fA-F:./, ]+$", address):
        errors.append("Interface.Address is missing or unsafe")
    if not endpoint or any(ch in endpoint for ch in " \t\n\r;`$()|&<>"):
        errors.append("Peer.Endpoint is missing or unsafe")
    if any(ch in allowed_ips for ch in "\n\r;`$()|&<>"):
        errors.append("Peer.AllowedIPs is unsafe")
    if not re.match(r"^[0-9]{1,5}$", keepalive):
        errors.append("Peer.PersistentKeepalive is unsafe")
    if table != "off":
        errors.append("Interface.Table must be off for isolated V7 runtime tests")

    blocked_hooks = []
    for section_name, section in (("Interface", interface), ("Peer", peer)):
        for key in section:
            if key.lower() in {"preup", "postup", "predown", "postdown", "saveconfig", "dns"}:
                blocked_hooks.append(f"{section_name}.{key}")
    if blocked_hooks:
        errors.append("unsafe hook/options are not copied into isolated runtime test: " + ",".join(blocked_hooks))
    if errors:
        return None, {"error": "runtime_sanitize_failed", "details": errors}

    lines = [
        "[Interface]",
        f"PrivateKey = {private_key}",
        f"Address = {address}",
        "Table = off",
        "",
        "[Peer]",
        f"PublicKey = {public_key}",
    ]
    if preshared_key:
        lines.append(f"PresharedKey = {preshared_key}")
    lines.extend([
        f"Endpoint = {endpoint}",
        f"AllowedIPs = {allowed_ips}",
        f"PersistentKeepalive = {keepalive}",
        "",
    ])
    return "\n".join(lines), None


def egress_runtime_status_from_external_ip(result):
    if result.get("external_ip", {}).get("ok"):
        return "PASS"
    if result.get("interface_up") and result.get("cleanup", {}).get("status") == "OK":
        return "FAIL_EXTERNAL_IP"
    return "FAIL"


def egress_draft_runtime_run(draft_id, actor, duration=8, requested_mode="runtime"):
    duration = max(3, min(int(duration or 8), 20))
    requested_mode = str(requested_mode or "runtime")
    if requested_mode not in {"runtime", "quarantine"}:
        return None, {"error": "invalid_runtime_mode"}
    if not safe_draft_id(draft_id):
        return None, {"error": "invalid_draft_id"}
    helper = shutil.which("v7-egress-draft-runtime-helper")
    runner = shutil.which("systemd-run")
    if helper and runner and os.environ.get("V7_EGRESS_DRAFT_RUNTIME_HELPER", "1") != "0":
        cmd = [
            runner,
            "--quiet",
            "--wait",
            "--pipe",
            "--collect",
            "--property=Type=oneshot",
            "--property=NoNewPrivileges=no",
            "--property=PrivateTmp=yes",
            helper,
            draft_id,
            str(duration),
            actor or "admin",
            requested_mode,
        ]
        helper_timeout = duration + (260 if requested_mode == "quarantine" else 80)
        helper_result = run_action(cmd, actor, timeout=helper_timeout)
        try:
            parsed = json.loads(helper_result.get("output", "{}"))
        except json.JSONDecodeError:
            parsed = None
        if helper_result["rc"] == 0 and isinstance(parsed, dict):
            draft_dir = egress_draft_path(draft_id)
            metadata = read_json(draft_dir / "metadata.json", {}) if draft_dir else {}
            parsed = egress_draft_enrich_runtime_result(parsed, metadata)
            if requested_mode == "quarantine" and draft_dir:
                metadata_path = draft_dir / "metadata.json"
                metadata.update({
                    "last_service_matrix_status": (parsed.get("service_matrix") or {}).get("status", ""),
                    "last_route_class_fitness": parsed.get("route_class_fitness", {}),
                    "last_role_fit": parsed.get("role_fit", {}),
                })
                write_json_atomic(metadata_path, metadata)
                try:
                    os.chmod(metadata_path, 0o600)
                except OSError:
                    pass
            if draft_dir:
                parsed["lifecycle"] = egress_draft_lifecycle(read_json(draft_dir / "metadata.json", {}))
            return parsed, None
        if isinstance(parsed, dict) and parsed.get("error"):
            return None, parsed
        return None, {
            "error": "runtime_helper_failed",
            "rc": helper_result["rc"],
            "output": helper_result.get("output", ""),
        }

    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata_path = draft_dir / "metadata.json"
    config_path = draft_dir / "config.input"
    metadata = read_json(metadata_path, {})
    if not metadata or not config_path.exists():
        return None, {"error": "draft_not_found"}
    preflight = egress_draft_latest_preflight(metadata)
    if preflight.get("status") != "PASS":
        return None, {"error": "runtime_requires_passing_preflight", "last_preflight_status": metadata.get("last_preflight_status", "")}
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, {"error": "draft_config_read_failed", "detail": str(exc)}
    preview, error = egress_config_preview({"label": metadata.get("label", draft_id), "config": text})
    if error:
        return None, error
    protocol = preview.get("protocol", "unknown")
    runtime_mode = preview.get("runtime_mode", "unknown")
    if protocol not in ("wireguard", "amneziawg") or runtime_mode != "interface":
        return None, {"error": "runtime_adapter_not_ready", "protocol": protocol, "runtime_mode": runtime_mode}
    sanitized, error = egress_draft_sanitize_interface_config(text, protocol)
    if error:
        return None, error

    run_id = f"{draft_id}-runtime-{int(time.time())}-{secrets.token_hex(3)}"
    ifname = f"v7rt{secrets.token_hex(5)}"
    EGRESS_DRAFT_TESTS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(EGRESS_DRAFT_TESTS_DIR, 0o700)
    run_dir = EGRESS_DRAFT_TESTS_DIR / run_id
    run_dir.mkdir(mode=0o700, parents=False, exist_ok=False)
    archived_config = run_dir / "sanitized-runtime.conf"
    runtime_config = Path("/etc/wireguard") / f"{ifname}.conf"
    write_text_atomic(archived_config, sanitized, mode=0o600)

    result = {
        "id": run_id,
        "draft_id": draft_id,
        "label": metadata.get("label", draft_id),
        "created_at": now_iso(),
        "created_by": actor or "admin",
        "stage": "isolated_runtime",
        "mode": "temporary_interface_auto_cleanup",
        "requested_mode": requested_mode,
        "protocol": protocol,
        "runtime_mode": runtime_mode,
        "interface": ifname,
        "duration_seconds": duration,
        "pool_action": "still_not_added",
        "route_action": "none",
        "secret_redaction": "raw_config_not_returned",
        "checks": [],
    }

    before_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    if before_link["rc"] == 0:
        result["status"] = "BLOCKED"
        result["checks"].append({"id": "interface_name_free", "status": "FAIL", "detail": "temporary interface already exists"})
        write_json_atomic(run_dir / "result.json", result)
        return result, None
    result["checks"].append({"id": "interface_name_free", "status": "OK", "detail": ifname})
    if runtime_config.exists():
        result["status"] = "BLOCKED"
        result["checks"].append({"id": "runtime_config_name_free", "status": "FAIL", "detail": f"{runtime_config.name} already exists"})
        write_json_atomic(run_dir / "result.json", result)
        return result, None
    write_text_atomic(runtime_config, sanitized, mode=0o600)
    result["checks"].append({"id": "runtime_config_created", "status": "OK", "detail": runtime_config.name})

    up_cmd = ["wg-quick", "up", ifname]
    if protocol == "amneziawg" and shutil.which("awg-quick"):
        up_cmd = ["awg-quick", "up", str(runtime_config)]
    up_result = run_action(up_cmd, actor, timeout=25)
    result["up"] = {"rc": up_result["rc"], "output": up_result["output"]}
    result["checks"].append({"id": "runtime_up", "status": "OK" if up_result["rc"] == 0 else "FAIL", "detail": f"rc={up_result['rc']}"})

    if up_result["rc"] == 0:
        link_result = run_readonly(["ip", "-br", "addr", "show", ifname], timeout=5)
        wg_show_cmd = ["wg", "show", ifname] if protocol == "wireguard" else ["awg", "show", ifname]
        wg_result = run_readonly(wg_show_cmd, timeout=5)
        curl_result = run_readonly(["curl", "--interface", ifname, "-4", "--max-time", str(duration), "-fsS", "https://ifconfig.me"], timeout=duration + 4)
        result["interface_up"] = link_result["rc"] == 0
        result["link"] = {"rc": link_result["rc"], "output": link_result["output"]}
        result["wg_show"] = {"rc": wg_result["rc"], "output": wg_result["output"]}
        result["external_ip"] = {
            "ok": curl_result["rc"] == 0 and bool(str(curl_result["output"]).strip()),
            "rc": curl_result["rc"],
            "ip": str(curl_result["output"]).strip() if curl_result["rc"] == 0 else "",
            "detail": curl_result["output"] if curl_result["rc"] != 0 else "",
        }
        result["checks"].append({"id": "interface_visible", "status": "OK" if result["interface_up"] else "FAIL", "detail": ifname})
        result["checks"].append({"id": "external_ip", "status": "OK" if result["external_ip"]["ok"] else "FAIL", "detail": result["external_ip"].get("ip") or result["external_ip"].get("detail", "")})
    else:
        result["interface_up"] = False
        result["external_ip"] = {"ok": False, "rc": up_result["rc"], "ip": "", "detail": "runtime did not start"}

    partial_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    should_cleanup = up_result["rc"] == 0 or partial_link["rc"] == 0
    down_cmd = ["wg-quick", "down", ifname]
    if protocol == "amneziawg" and shutil.which("awg-quick"):
        down_cmd = ["awg-quick", "down", str(runtime_config)]
    down_result = run_action(down_cmd, actor, timeout=25) if should_cleanup else {"rc": 0, "output": "not_started_no_cleanup_needed"}
    try:
        runtime_config.unlink()
        runtime_config_removed = True
    except FileNotFoundError:
        runtime_config_removed = True
    except OSError as exc:
        runtime_config_removed = False
        result["runtime_config_remove_error"] = str(exc)
    after_link = run_readonly(["ip", "link", "show", ifname], timeout=5)
    interface_absent = after_link["rc"] != 0
    cleanup_ok = interface_absent and runtime_config_removed
    result["cleanup"] = {
        "status": "OK" if cleanup_ok else "FAIL",
        "down_rc": down_result["rc"],
        "down_output": down_result["output"],
        "interface_absent": interface_absent,
        "runtime_config_removed": runtime_config_removed,
    }
    result["checks"].append({"id": "cleanup", "status": "OK" if cleanup_ok else "FAIL", "detail": f"down_rc={down_result['rc']}"})
    result["status"] = egress_runtime_status_from_external_ip(result)
    if requested_mode == "quarantine":
        result["quarantine_status"] = "BLOCKED"
        result["service_matrix"] = {"status": "UNAVAILABLE_WITHOUT_HELPER", "reason": "helper is required for quarantine service checks"}
    result = egress_draft_enrich_runtime_result(result, metadata)
    result["next_step"] = "add_to_pool_preview" if result.get("quarantine_status") == "PASS" else ("service_matrix_quarantine_test" if result["status"] == "PASS" else "inspect_runtime_failure")

    write_json_atomic(run_dir / "result.json", result)
    try:
        os.chmod(run_dir / "result.json", 0o600)
    except OSError:
        pass
    metadata.update({
        "last_runtime_at": result["created_at"],
        "last_runtime_status": result["status"],
        "last_runtime_run_id": run_id,
        "next_step": result["next_step"],
    })
    if requested_mode == "quarantine":
        metadata.update({
            "last_quarantine_at": result["created_at"],
            "last_quarantine_status": result.get("quarantine_status", "BLOCKED"),
            "last_quarantine_run_id": run_id,
            "last_service_matrix_status": (result.get("service_matrix") or {}).get("status", ""),
            "last_route_class_fitness": result.get("route_class_fitness", {}),
            "last_role_fit": result.get("role_fit", {}),
        })
    metadata["lifecycle"] = egress_draft_lifecycle(metadata)
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass
    return result, None


def egress_draft_pool_preview(draft_id):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    if not metadata:
        return None, {"error": "draft_not_found"}
    label = metadata.get("label") or draft_id
    proposed_id = safe_egress_id(re.sub(r"[^A-Za-z0-9_.-]+", "-", str(label).lower()).strip("-")[:32]) or safe_egress_id(draft_id[:32])
    protocol = metadata.get("protocol", "unknown")
    runtime_mode = metadata.get("runtime_mode", "unknown")
    enabled = "0"
    typ = "interface" if runtime_mode == "interface" else "proxy"
    interface = egress_managed_interface_name(proposed_id) if typ == "interface" else ""
    proxy_port = egress_managed_proxy_port(proposed_id) if typ == "proxy" else 0
    test = "interface" if typ == "interface" else f"socks5://127.0.0.1:{proxy_port}"
    target_path = egress_draft_runtime_target_path(protocol, runtime_mode, proposed_id, interface)
    config_part = f" config={target_path}" if target_path else ""
    usage_policy = egress_usage_policy_from_data({}, metadata.get("usage_policy") or metadata)
    policy_part = egress_usage_policy_registry_part(usage_policy)
    proposed_line = f"id={proposed_id} protocol={protocol} type={typ} interface={interface} test={test} enabled={enabled}{config_part} {policy_part}".strip()
    active_text = read_text(STATE_DIR / "egress.registry", "")
    id_exists = bool(re.search(rf"^id={re.escape(proposed_id)}\s", active_text, flags=re.M))
    blockers = []
    if metadata.get("last_preflight_status") != "PASS":
        blockers.append("preflight_not_passed")
    if metadata.get("last_runtime_status") != "PASS":
        blockers.append("runtime_not_passed")
    if metadata.get("last_quarantine_status") != "PASS":
        blockers.append("quarantine_not_passed")
    if id_exists:
        blockers.append("egress_id_already_exists")
    if protocol not in ("wireguard", "amneziawg", "vless", "sing-box", "shadowsocks_or_outline", "vmess", "trojan"):
        blockers.append("unsupported_protocol")
    return {
        "draft_id": draft_id,
        "human": "Только предпросмотр. Файлы не меняются, пользователи не переносятся.",
        "terms": {
            "pool": "активный список egress-каналов, через которые V7 может вести пользователей",
            "registry_line": "строка, которая будет добавлена в /opt/v7/egress/state/egress.registry",
            "enabled_0": "канал стартует выключенным, пока оператор явно не включит его",
            "role": "роль канала, например GLOBAL_FAST или TRUSTED_RU_SENSITIVE",
        },
        "ready": not blockers,
        "blockers": blockers,
        "proposed": {
            "id": proposed_id,
            "protocol": protocol,
            "type": typ,
            "interface": interface,
            "test": test,
            "enabled": enabled,
            "listen_port": proxy_port,
            "config": str(target_path) if target_path else "",
            "role": usage_policy["role"],
            "priority": usage_policy["priority"],
            "weight": usage_policy["weight"],
            "soft_limit": usage_policy["soft_limit"],
            "hard_limit": usage_policy["hard_limit"],
            "manual_only": usage_policy["manual_only"],
            "reserve_only": usage_policy["reserve_only"],
            "service_tags": usage_policy["service_tags"],
            "exclude_route_classes": usage_policy["exclude_route_classes"],
            "usage_policy": usage_policy,
            "registry_line": proposed_line,
        },
        "source_checks": {
            "preflight": metadata.get("last_preflight_status", ""),
            "runtime": metadata.get("last_runtime_status", ""),
            "quarantine": metadata.get("last_quarantine_status", ""),
            "next_step": metadata.get("next_step", ""),
        },
        "would_backup": [
            str(STATE_DIR / "egress.registry"),
            str(draft_dir / "metadata.json"),
        ],
        "would_change": [
            str(STATE_DIR / "egress.registry"),
        ],
        "would_not_change": [
            str(STATE_DIR / "users.registry"),
            "current user routes",
            "running V7 services",
        ],
        "pool_action": "preview_only_not_added",
    }, None


def egress_draft_pool_apply(draft_id, actor):
    preview, error = egress_draft_pool_preview(draft_id)
    if error:
        return None, error
    if not preview.get("ready"):
        return None, {
            "error": "egress_draft_not_ready_for_pool",
            "blockers": preview.get("blockers", []),
            "preview": preview,
        }

    draft_dir = egress_draft_path(draft_id)
    metadata_path = draft_dir / "metadata.json"
    registry_path = STATE_DIR / "egress.registry"
    metadata = read_json(metadata_path, {})
    registry_text = read_text(registry_path, "")
    if not registry_text.strip():
        return None, {"error": "egress_registry_missing_or_empty", "path": str(registry_path)}

    proposed = preview.get("proposed") or {}
    proposed_id = safe_egress_id(proposed.get("id", ""))
    proposed_line = str(proposed.get("registry_line", "")).strip()
    usage_policy = egress_usage_policy_from_data({}, proposed.get("usage_policy") or proposed)
    if not proposed_id or not proposed_line.startswith(f"id={proposed_id} "):
        return None, {"error": "invalid_pool_preview_proposal"}
    if re.search(rf"^id={re.escape(proposed_id)}\s", registry_text, flags=re.M):
        return None, {"error": "egress_id_already_exists", "egress": proposed_id}

    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
    registry_backup = registry_path.with_name(f"{registry_path.name}.backup.v7-egress-draft-pool-apply.{stamp}")
    metadata_backup = metadata_path.with_name(f"{metadata_path.name}.backup.v7-egress-draft-pool-apply.{stamp}")
    shutil.copy2(registry_path, registry_backup)
    shutil.copy2(metadata_path, metadata_backup)

    registry_mode = registry_path.stat().st_mode & 0o777
    next_registry = registry_text.rstrip() + "\n" + proposed_line + "\n"
    write_text_atomic(registry_path, next_registry, mode=registry_mode or 0o600)

    metadata.update({
        "status": "pool_added_disabled",
        "pool_action": "added_disabled",
        "pool_added_at": now_iso(),
        "pool_added_by": actor or "admin",
        "pool_egress_id": proposed_id,
        "pool_registry_line": proposed_line,
        "pool_registry_backup": str(registry_backup),
        "pool_metadata_backup": str(metadata_backup),
        "role": usage_policy["role"],
        "priority": usage_policy["priority"],
        "weight": usage_policy["weight"],
        "soft_limit": usage_policy["soft_limit"],
        "hard_limit": usage_policy["hard_limit"],
        "manual_only": usage_policy["manual_only"],
        "reserve_only": usage_policy["reserve_only"],
        "service_tags": usage_policy["service_tags"],
        "exclude_route_classes": usage_policy["exclude_route_classes"],
        "usage_policy": usage_policy,
        "next_step": "explicit_enable_after_operator_review",
    })
    metadata["lifecycle"] = egress_draft_lifecycle(metadata)
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass

    return {
        "draft_id": draft_id,
        "human": "The channel was added to the V7 pool disabled. Users were not moved and the channel will not carry traffic until it is explicitly enabled.",
        "terms": {
            "pool": "the active registry of channels V7 knows about",
            "disabled": "enabled=0 means V7 can see the channel, but must not route users through it yet",
            "backup": "timestamped copies created before changing registry or draft metadata",
        },
        "egress": proposed_id,
        "usage_policy": usage_policy,
        "registry_line": proposed_line,
        "enabled": "0",
        "changed": [str(registry_path), str(metadata_path)],
        "backups": [str(registry_backup), str(metadata_backup)],
        "users_moved": False,
        "routes_changed": False,
        "services_restarted": False,
        "next_step": "enable_explicitly_after_operator_review",
        "pool_action": "added_disabled",
    }, None


def egress_draft_runtime_provision(draft_id, actor):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata_path = draft_dir / "metadata.json"
    config_path = draft_dir / "config.input"
    metadata = read_json(metadata_path, {})
    if not metadata or not config_path.exists():
        return None, {"error": "draft_not_found"}
    if metadata.get("pool_action") != "added_disabled" or not safe_egress_id(metadata.get("pool_egress_id", "")):
        return None, {
            "error": "runtime_provision_requires_added_disabled_pool_entry",
            "current_pool_action": metadata.get("pool_action", "not_added"),
        }

    egress_id = safe_egress_id(metadata.get("pool_egress_id", ""))
    registry = egress_registry_map().get(egress_id, {})
    if not registry:
        return None, {"error": "egress_not_found_in_registry", "egress": egress_id}
    if str(registry.get("enabled", "1")) != "0":
        return None, {"error": "runtime_provision_requires_disabled_egress", "egress": egress_id}

    protocol = metadata.get("protocol", "unknown")
    runtime_mode = metadata.get("runtime_mode", "unknown")
    supported_proxy = protocol in ("vless", "vmess", "trojan", "shadowsocks_or_outline", "sing-box") and runtime_mode in ("proxy_or_tun", "sing_box")
    supported_interface = protocol in ("wireguard", "amneziawg") and runtime_mode == "interface"
    if not supported_interface and not supported_proxy:
        return None, {
            "error": "runtime_provision_adapter_not_ready",
            "protocol": protocol,
            "runtime_mode": runtime_mode,
            "message": "This protocol adapter is not ready for runtime provisioning yet.",
        }

    ifname = registry.get("interface") or (egress_managed_interface_name(egress_id) if supported_interface else "")
    if supported_interface and not re.match(r"^[A-Za-z0-9_.-]{1,15}$", ifname or ""):
        return None, {"error": "invalid_or_too_long_interface_name", "interface": ifname}
    target_path = egress_draft_runtime_target_path(protocol, runtime_mode, egress_id, ifname)
    if not target_path:
        return None, {"error": "runtime_target_path_unavailable", "protocol": protocol, "runtime_mode": runtime_mode}

    try:
        raw = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, {"error": "draft_config_read_failed", "detail": str(exc)}
    if supported_interface:
        runtime_text, error = egress_draft_sanitize_interface_config(raw, protocol)
        if error:
            return None, error
    else:
        listen_port = egress_managed_proxy_port(egress_id)
        test_value = str(registry.get("test", ""))
        match = re.search(r":([0-9]{2,5})$", test_value)
        if match:
            listen_port = int(match.group(1))
        if not 1024 <= int(listen_port) <= 65535:
            return None, {"error": "invalid_proxy_listen_port", "port": listen_port}
        if raw.strip().startswith("{"):
            try:
                parsed_config = json.loads(raw)
            except json.JSONDecodeError as exc:
                return None, {"error": "invalid_json_config", "detail": str(exc)}
            outbounds = parsed_config.get("outbounds", []) if isinstance(parsed_config, dict) else []
            outbound = next((item for item in outbounds if isinstance(item, dict) and item.get("type") not in ("direct", "block", "dns")), None)
            if not outbound:
                return None, {"error": "sing_box_outbound_not_found"}
            outbound = dict(outbound)
            outbound["tag"] = "egress"
        else:
            parsed_share, share_error = egress_parse_proxy_share(raw)
            if share_error:
                return None, share_error
            outbound = parsed_share.get("outbound", {})
        runtime_text = json.dumps(egress_sing_box_profile_from_outbound(outbound, listen_port), ensure_ascii=True, indent=2)

    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
    metadata_backup = metadata_path.with_name(f"{metadata_path.name}.backup.v7-runtime-provision.{stamp}")
    shutil.copy2(metadata_path, metadata_backup)

    target_backup = ""
    target_already_ready = False
    if target_path.exists():
        current = read_text(target_path, "")
        if current.strip() == runtime_text.strip():
            target_already_ready = True
        else:
            return None, {
                "error": "runtime_profile_exists_with_different_content",
                "path": str(target_path),
                "message": "Existing runtime profile differs. Manual review or explicit replace flow is required.",
            }

    if not target_already_ready:
        target_path.parent.mkdir(parents=True, exist_ok=True)
        try:
            os.chmod(target_path.parent, 0o700)
        except OSError:
            pass
        write_text_atomic(target_path, runtime_text if runtime_text.endswith("\n") else runtime_text + "\n", mode=0o600)

    readiness = egress_runtime_readiness(egress_id, registry)
    metadata.update({
        "runtime_profile_status": "READY" if readiness.get("enable_ready") else "BLOCKED",
        "runtime_profile_path": str(target_path),
        "runtime_profile_interface": ifname,
        "runtime_profile_provisioned_at": now_iso(),
        "runtime_profile_provisioned_by": actor or "admin",
        "runtime_profile_metadata_backup": str(metadata_backup),
        "next_step": "explicit_enable_after_operator_review" if readiness.get("enable_ready") else "inspect_runtime_profile_readiness",
    })
    metadata["lifecycle"] = egress_draft_lifecycle(metadata)
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass

    return {
        "draft_id": draft_id,
        "egress": egress_id,
        "human": "Runtime profile is prepared but not started. Users were not moved and the channel remains disabled.",
        "terms": {
            "runtime_profile": "the real root-only config file V7 can use later to start this channel",
            "provisioned": "the profile was written into the managed runtime path",
            "disabled": "the channel still has enabled=0 and cannot carry traffic yet",
        },
        "status": metadata["runtime_profile_status"],
        "protocol": protocol,
        "interface": ifname,
        "listen_port": egress_managed_proxy_port(egress_id) if supported_proxy else 0,
        "path": str(target_path),
        "already_ready": target_already_ready,
        "metadata_backup": str(metadata_backup),
        "target_backup": target_backup,
        "readiness": readiness,
        "users_moved": False,
        "routes_changed": False,
        "services_restarted": False,
        "pool_state": "disabled",
        "next_step": metadata["next_step"],
    }, None


def egress_draft_enable_preview(draft_id, actor="admin"):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    if not metadata:
        return None, {"error": "draft_not_found"}
    egress_id = safe_egress_id(metadata.get("pool_egress_id", ""))
    if not egress_id:
        return None, {"error": "draft_has_no_pool_egress_id"}
    registry = egress_registry_map().get(egress_id, {})
    if not registry:
        return None, {"error": "egress_not_found_in_registry", "egress": egress_id}
    readiness = egress_runtime_readiness(egress_id, registry)
    blockers = []
    if metadata.get("pool_action") not in {"added_disabled", "enabled"}:
        blockers.append("draft_not_added_disabled")
    if str(registry.get("enabled", "1")) != "0":
        if metadata.get("pool_action") == "enabled":
            blockers.append("already_enabled")
        else:
            blockers.append("registry_not_disabled")
    if metadata.get("runtime_profile_status") != "READY":
        blockers.append("runtime_profile_not_ready")
    if not readiness.get("enable_ready"):
        blockers.append("runtime_readiness_blocked")
    dry_run = run_action(["v7-egress-set-state", egress_id, "enabled"], actor, timeout=20)
    if dry_run.get("rc") not in (0,):
        blockers.append("egress_set_state_preview_failed")
    return {
        "draft_id": draft_id,
        "egress": egress_id,
        "ready": not blockers,
        "blockers": blockers,
        "confirm": "ENABLE_DRAFT_EGRESS",
        "human": "Только предпросмотр. Включение сделает канал доступным V7, но само по себе не перенесёт пользователей.",
        "runtime_readiness": readiness,
        "set_state_preview": dry_run,
        "would_change": [str(STATE_DIR / "egress.registry"), str(STATE_DIR / "egress-flags.state")],
        "would_not_change": [
            str(STATE_DIR / "users.registry"),
            "current user assignments",
            "current per-user route tables",
            "running V7 services",
            "kill switch rules",
        ],
        "kill_switch_guard": "enable does not edit firewall rules; route use still depends on separate routing/failover/rebalance decisions",
        "next_step": "apply_enable" if not blockers else "fix_enable_blockers",
    }, None


def egress_draft_enable_apply(draft_id, actor):
    preview, error = egress_draft_enable_preview(draft_id, actor=actor)
    if error:
        return None, error
    if not preview.get("ready"):
        return None, {
            "error": "draft_egress_not_ready_for_enable",
            "blockers": preview.get("blockers", []),
            "preview": preview,
        }
    draft_dir = egress_draft_path(draft_id)
    metadata_path = draft_dir / "metadata.json"
    metadata = read_json(metadata_path, {})
    egress_id = preview["egress"]
    result = run_action(["v7-egress-set-state", egress_id, "enabled", "--apply"], actor, timeout=30)
    if result.get("rc") != 0:
        return None, {"error": "egress_set_state_apply_failed", "result": result}
    metadata.update({
        "pool_action": "enabled",
        "pool_enabled_at": now_iso(),
        "pool_enabled_by": actor or "admin",
        "next_step": "enabled_watch_health",
    })
    metadata["lifecycle"] = egress_draft_lifecycle(metadata)
    write_json_atomic(metadata_path, metadata)
    try:
        os.chmod(metadata_path, 0o600)
    except OSError:
        pass
    validation = egress_draft_post_enable_validation(draft_id, actor=actor)[0]
    return {
        "draft_id": draft_id,
        "egress": egress_id,
        "status": "ENABLED",
        "human": "The channel is now enabled in the V7 pool. Users were not moved by this action.",
        "result": result,
        "users_moved": False,
        "routes_changed": False,
        "services_restarted": False,
        "lifecycle": metadata["lifecycle"],
        "post_enable_validation": validation,
        "next_step": "monitor_health_then_manual_switch_or_rebalance",
    }, None


def egress_draft_post_enable_validation(draft_id, actor="admin"):
    draft_dir = egress_draft_path(draft_id)
    if not draft_dir:
        return None, {"error": "invalid_draft_id"}
    metadata = read_json(draft_dir / "metadata.json", {})
    if not metadata:
        return None, {"error": "draft_not_found"}
    egress_id = safe_egress_id(metadata.get("pool_egress_id", ""))
    if not egress_id:
        return None, {"error": "draft_has_no_pool_egress_id"}
    registry = egress_registry_map().get(egress_id, {})
    if not registry:
        return None, {"error": "egress_not_found_in_registry", "egress": egress_id}
    readiness = egress_runtime_readiness(egress_id, registry)
    runtime_path_raw = str(metadata.get("runtime_profile_path") or readiness.get("profile_path") or "")
    runtime_path = Path(runtime_path_raw) if runtime_path_raw else None
    runtime_exists = bool(runtime_path and runtime_path.exists())
    users_on_egress = [row for row in parse_registry(STATE_DIR / "users.registry") if row.get("current") == egress_id]
    registry_enabled = str(registry.get("enabled", "0")) == "1"
    checks = [
        {"id": "registry_present", "status": "OK", "detail": egress_id},
        {"id": "registry_enabled", "status": "OK" if registry_enabled else "BLOCKED", "detail": f"enabled={registry.get('enabled', '')}"},
        {"id": "runtime_profile_path", "status": "OK" if runtime_exists else "BLOCKED", "detail": runtime_path_raw or "missing"},
        {"id": "runtime_readiness", "status": "OK" if readiness.get("enable_ready") else "WARN", "detail": readiness.get("reason", "")},
        {"id": "users_not_moved_by_enable", "status": "OK", "detail": f"assigned_users={len(users_on_egress)}"},
        {"id": "routes_not_changed_by_enable", "status": "OK", "detail": "enable only changed pool availability"},
    ]
    blockers = [row["id"] for row in checks if row.get("status") == "BLOCKED"]
    warnings = [row["id"] for row in checks if row.get("status") == "WARN"]
    rebalance_preview = run_readonly(["v7-users-rebalance-dry-run"], timeout=10)
    manual_switch_hint = ""
    users = parse_registry(STATE_DIR / "users.registry")
    if users:
        manual_switch_hint = f"manual switch can be tested with one user, for example {users[0].get('ip', '')}"
    return {
        "draft_id": draft_id,
        "egress": egress_id,
        "status": "OK" if not blockers else "BLOCKED",
        "checks": checks,
        "blockers": blockers,
        "warnings": warnings,
        "runtime_readiness": readiness,
        "assigned_users": len(users_on_egress),
        "users_moved_by_enable": False,
        "routes_changed_by_enable": False,
        "kill_switch_changed_by_enable": False,
        "safe_next_actions": [
            "run service matrix for this egress",
            "manual switch one test user if needed",
            "run rebalance dry-run before any broader movement",
        ],
        "manual_switch_hint": manual_switch_hint,
        "rebalance_preview": rebalance_preview,
        "next_step": "manual_switch_one_user_or_rebalance_dry_run" if not blockers else "fix_post_enable_blockers",
    }, None


