def identity_update_user(data, actor):
    identity_init_db()
    user_id = safe_identity_id(data.get("user_id", ""))
    if not user_id:
        return None, {"error": "invalid_identity_user_id"}
    allowed_statuses = {"active", "blocked", "pending", "disabled"}
    with identity_conn() as conn:
        row = conn.execute("SELECT * FROM identity_users WHERE id=?", (user_id,)).fetchone()
        if not row:
            return None, {"error": "identity_user_not_found"}
        user = dict(row)
        active_devices = int(conn.execute(
            "SELECT count(*) FROM devices WHERE user_id=? AND status='active'",
            (user_id,),
        ).fetchone()[0])
        updates = {}
        if "max_devices" in data:
            try:
                max_devices = int(data.get("max_devices"))
            except (TypeError, ValueError):
                return None, {"error": "invalid_max_devices"}
            if max_devices < 0 or max_devices > 1000:
                return None, {"error": "invalid_max_devices_range"}
            if max_devices < active_devices and data.get("confirm") != "LOWER_DEVICE_LIMIT":
                return None, {
                    "error": "lower_device_limit_requires_confirm",
                    "message": "User already has more active devices than the new limit. Existing devices will not be removed automatically.",
                    "active_devices": active_devices,
                    "requested_max_devices": max_devices,
                    "confirm": "LOWER_DEVICE_LIMIT",
                }
            updates["max_devices"] = max_devices
        if "status" in data:
            status = clean_identity_text(data.get("status", ""), 20).lower()
            if status not in allowed_statuses:
                return None, {"error": "invalid_user_status", "allowed": sorted(allowed_statuses)}
            updates["status"] = status
        if "notes" in data:
            updates["notes"] = clean_identity_text(data.get("notes", ""), 800)
        if not updates:
            return user, None
        updates["updated_at"] = now_iso()
        assignments = ", ".join(f"{key}=?" for key in updates)
        conn.execute(
            f"UPDATE identity_users SET {assignments} WHERE id=?",
            (*updates.values(), user_id),
        )
        conn.commit()
        result = dict(conn.execute("SELECT * FROM identity_users WHERE id=?", (user_id,)).fetchone())
    audit_admin(actor, "admin_action_identity_user_update", f"user_id={user_id} fields={','.join(updates.keys())} notes_updated={str('notes' in updates).lower()}", object_type="identity_user", object_id=user_id, result="OK")
    return result, None


