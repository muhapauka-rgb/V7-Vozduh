        "role": role,
        "enabled": True,
        "created_at": now,
        "updated_at": now,
        "created_by": actor or "admin",
        "notes": str(notes or "")[:240],
    }
    write_auth_config(data)
    killswitch_output = killswitch["output"]
    killswitch_status = "REBUILDING" if "V7_KILLSWITCH_CHECK=REBUILDING" in killswitch_output else ("OK" if "V7_KILLSWITCH_CHECK=OK" in killswitch_output else "Problem")

    return {
        "username": username,
        "role": role,
        "enabled": True,
