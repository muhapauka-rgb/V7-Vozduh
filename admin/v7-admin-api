def clamp_int(value, default, min_value, max_value):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        parsed = default
    return max(min_value, min(max_value, parsed))


def clamp_float(value, default, min_value, max_value):
    try:
        parsed = float(value)
    except (TypeError, ValueError):
        parsed = default
    return max(min_value, min(max_value, parsed))


def update_policy(actor, patch):
    before = policy_state()
    policy = deep_merge_defaults(before, DEFAULT_POLICY)
    incoming = patch if isinstance(patch, dict) else {}

    switch = incoming.get("switch") or {}
    quality = incoming.get("quality") or {}
    load = incoming.get("load") or {}
    intervals = incoming.get("intervals") or {}

    policy["switch"]["cooldown_seconds"] = clamp_int(switch.get("cooldown_seconds", policy["switch"]["cooldown_seconds"]), 180, 180, 86400)
    policy["switch"]["autoswitch_max_planned_per_run"] = clamp_int(switch.get("autoswitch_max_planned_per_run", policy["switch"]["autoswitch_max_planned_per_run"]), 1, 1, 50)
    policy["switch"]["autoswitch_max_failover_per_run"] = clamp_int(switch.get("autoswitch_max_failover_per_run", policy["switch"]["autoswitch_max_failover_per_run"]), 25, 1, 500)
    policy["quality"]["min_avg_mbps"] = clamp_float(quality.get("min_avg_mbps", policy["quality"]["min_avg_mbps"]), 15.0, 0.1, 10000.0)
    policy["quality"]["min_floor_mbps"] = clamp_float(quality.get("min_floor_mbps", policy["quality"]["min_floor_mbps"]), 10.0, 0.1, 10000.0)
    policy["quality"]["min_stability"] = clamp_float(quality.get("min_stability", policy["quality"]["min_stability"]), 0.45, 0.0, 1.0)
    policy["load"]["soft_limit"] = clamp_int(load.get("soft_limit", policy["load"]["soft_limit"]), 1, 1, 100000)
    policy["load"]["hard_limit"] = clamp_int(load.get("hard_limit", policy["load"]["hard_limit"]), 2, 1, 100000)
    if policy["load"]["hard_limit"] < policy["load"]["soft_limit"]:
        policy["load"]["hard_limit"] = policy["load"]["soft_limit"]
    policy["load"]["rebalance_max_moves_per_run"] = clamp_int(load.get("rebalance_max_moves_per_run", policy["load"]["rebalance_max_moves_per_run"]), 1, 1, 1000)
    policy["intervals"]["health_seconds"] = clamp_int(intervals.get("health_seconds", policy["intervals"]["health_seconds"]), 30, 10, 3600)
    policy["intervals"]["benchmark_seconds"] = clamp_int(intervals.get("benchmark_seconds", policy["intervals"]["benchmark_seconds"]), 300, 60, 86400)
    policy["schema_version"] = 1
    policy["updated"] = now_iso()
    policy["updated_by"] = actor or "admin"

    POLICY_FILE.parent.mkdir(parents=True, exist_ok=True)
    backup = None
    if POLICY_FILE.exists():
        backup = POLICY_FILE.with_name(f"{POLICY_FILE.name}.backup.v7-policy.{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}")
        backup.write_text(POLICY_FILE.read_text(encoding="utf-8", errors="replace"), encoding="utf-8")
        os.chmod(backup, 0o600)
    write_json_atomic(POLICY_FILE, policy)
    os.chmod(POLICY_FILE, 0o600)
    return redact({"before": before, "policy": policy, "backup": str(backup) if backup else None})


def service_recommendations(active_users, matrix_data, prefs):
    items = matrix_data.get("items") or {}
    enabled = bool(prefs.get("enabled"))
    user_prefs = prefs.get("users") or {}
    service_ids = sorted({
        service_id
        for egress_item in items.values()
        for service_id in ((egress_item.get("services") or {}).keys())
    })
    best_by_service = {}
    for service_id in service_ids:
        candidates = []
        for egress_id, egress_item in items.items():
            row = (egress_item.get("services") or {}).get(service_id)
            if not row:
                continue
            candidates.append({
                "egress": egress_id,
                "ok": bool(row.get("ok")),
                "severity": row.get("severity"),
                "http_code": row.get("http_code"),
                "first_byte_sec": row.get("first_byte_sec"),
                "total_sec": row.get("total_sec"),
                "reason": row.get("reason"),
                "tested_at": row.get("tested_at"),
            })
        candidates.sort(key=lambda c: (
            0 if c["ok"] else 1,
            float(c.get("first_byte_sec") or 999),
            float(c.get("total_sec") or 999),
            c["egress"],
        ))
        best = candidates[0] if candidates else None
        best_by_service[service_id] = {
            "service": service_id,
            "best_egress": best.get("egress") if best else None,
            "status": "OK" if best and best.get("ok") else "NO_GOOD_EGRESS",
            "candidates": candidates,
        }

    user_warnings = []
    for user in active_users:
        ip = user.get("ip", "")
        current = user.get("current", "")
        important = normalize_services((user_prefs.get(ip) or {}).get("services") or [])
        if not enabled or not important:
            continue
        current_services = ((items.get(current) or {}).get("services") or {})
        for service_id, recommendation in best_by_service.items():
            if service_id not in important:
                continue
            current_row = current_services.get(service_id)
            best = recommendation.get("best_egress")
            current_ok = bool(current_row and current_row.get("ok"))
            if best and best != current and not current_ok:
                best_candidate = next((c for c in recommendation.get("candidates", []) if c.get("egress") == best), {})
                user_warnings.append({
                    "ip": ip,
                    "current_egress": current,
                    "service": service_id,
                    "current_status": "FAIL" if current_row else "UNKNOWN",
                    "current_reason": (current_row or {}).get("reason"),
                    "recommended_egress": best,
                    "recommended_first_byte_sec": best_candidate.get("first_byte_sec"),
                    "action": "manual_switch_available",
                })
    return {"enabled": enabled, "known_services": list(KNOWN_SERVICES), "user_preferences": user_prefs, "best_by_service": best_by_service, "user_warnings": user_warnings}


