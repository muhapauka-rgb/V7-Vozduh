def egress_runtime_profile_candidates(egress_id, registry=None):
    registry = registry or egress_registry_map().get(safe_egress_id(egress_id), {})
    candidates = []
    configured = registry.get("config") or registry.get("config_path")
    if configured:
        candidates.append(Path(configured))
    known = EGRESS_CONFIG_PATHS.get(egress_id)
    if known:
        candidates.append(known)
    if registry.get("type") == "interface":
        ifname = registry.get("interface") or egress_id
        if ifname:
            candidates.extend([
                WIREGUARD_DIR / f"{ifname}.conf",
                AMNEZIAWG_DIR / f"{ifname}.conf",
                Path("/etc/amneziawg") / f"{ifname}.conf",
            ])
    unique = []
    seen = set()
    for path in candidates:
        text = str(path)
        if text not in seen:
            unique.append(path)
            seen.add(text)
    return unique


def egress_managed_interface_name(egress_id):
    egress_id = safe_egress_id(egress_id)
    if not egress_id:
        return ""
    return "v7e" + hashlib.sha1(egress_id.encode("utf-8")).hexdigest()[:10]


def egress_managed_proxy_port(egress_id):
