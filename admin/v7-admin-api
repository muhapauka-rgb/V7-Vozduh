        device_create_failed: ['Device create failed', 'Check WireGuard/user registry capacity and v7-user-create logs.'],
        smart_profile_failed: ['Smart profile failed', 'Check smart profile generator, sing-box check, and writable profile directory.'],
        delivery_create_failed: ['Delivery failed', 'Check profile delivery token state and state directory permissions.'],
