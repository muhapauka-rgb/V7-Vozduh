def identity_device_revoke_apply(device_id, actor, confirm):
    if confirm != "REVOKE_DEVICE":
        return None, {"error": "device_revoke_requires_confirm_REVOKE_DEVICE"}
    preview, error = identity_device_revoke_preview(device_id, actor)
    if error:
        return None, error
    device = preview["device"]
    ip = safe_user_ip(device.get("assigned_vpn_ip", ""))
    result = run_action(["v7-user-disable", ip], actor, timeout=35)
    if result["rc"] != 0:
        return {"device": device, "result": result}, {"error": "runtime_device_revoke_failed"}
    now = now_iso()
    with identity_conn() as conn:
        conn.execute(
            "UPDATE devices SET status='revoked', revoked_at=?, updated_at=? WHERE id=?",
            (now, now, device["id"]),
        )
        conn.execute(
            "UPDATE identity_users SET updated_at=? WHERE id=?",
            (now, device["user_id"]),
        )
        conn.commit()
        updated = dict(conn.execute("SELECT * FROM devices WHERE id=?", (device["id"],)).fetchone())
    revoked_deliveries = revoke_profile_deliveries_for_ip(ip, actor)
    audit_admin(actor, "admin_action_identity_device_revoke", f"device_id={device['id']} ip={ip} revoked_deliveries={len(revoked_deliveries)}", object_type="identity_device", object_id=device["id"], result="OK")
    return {"device": updated, "result": result, "revoked_deliveries": revoked_deliveries}, None


