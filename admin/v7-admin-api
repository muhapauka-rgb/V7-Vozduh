    input, select {{ width:100%; height:40px; margin-top:5px; padding:0 11px; border-radius:7px; border:1px solid var(--line); background:#10141a; color:var(--text); }}
    button, .primary {{ display:flex; align-items:center; justify-content:center; width:100%; height:42px; margin-top:16px; border-radius:7px; border:1px solid var(--accent); background:#172033; color:var(--text); text-decoration:none; cursor:pointer; font-weight:650; }}
