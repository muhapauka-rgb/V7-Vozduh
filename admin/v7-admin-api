def identity_find_organization(value):
    needle = clean_identity_text(value, 160).lower()
    if not needle or not IDENTITY_DB_FILE.exists():
        return None
    with identity_conn() as conn:
        for row in conn.execute("SELECT * FROM organizations").fetchall():
            item = dict(row)
            names = [item.get("name", ""), item.get("short_name", "")]
            try:
                aliases = json.loads(item.get("aliases") or "[]")
                if isinstance(aliases, list):
                    names.extend(str(alias) for alias in aliases)
            except json.JSONDecodeError:
                pass
            if any(clean_identity_text(name, 160).lower() == needle for name in names if name):
                return item
    return None


