def direct_routing_full(domains=None, user_ip=""):
    users = parse_registry(STATE_DIR / "users.registry")
    user_ip = safe_user_ip(user_ip) or default_active_user_ip(users)
    cleaned = []
    for domain in domains or DIRECT_ROUTING_DOMAINS:
        domain = safe_domain(domain)
        if domain and domain not in cleaned:
            cleaned.append(domain)
    if not cleaned:
        cleaned = list(DIRECT_ROUTING_DOMAINS)

    items = []
    for domain in cleaned[:12]:
        result = run_readonly(["v7-safe-run", "v7-direct-diagnose-domain", domain, user_ip], timeout=14)
        parsed = parse_command_kv(result.get("output", ""))
        route_ok = parsed.get("DIRECT_ROUTE") == "OK"
        https = parsed.get("SERVER_HTTPS", "")
        outcome = parsed.get("V7_DIRECT_DOMAIN_RESULT", "")
        if outcome == "OK":
            level = "ok"
        elif route_ok and https in ("TIMEOUT", "FAIL"):
            level = "warning"
        else:
            level = "bad"
        items.append({
            "domain": domain,
            "level": level,
            "route_ok": route_ok,
            "server_https": https,
            "result": outcome,
            "parsed": parsed,
            "check": result,
        })
    return {
        "updated": now_iso(),
        "user_ip": user_ip,
        "domains": cleaned,
        "items": items,
        "ok_count": sum(1 for item in items if item["level"] == "ok"),
        "warning_count": sum(1 for item in items if item["level"] == "warning"),
        "bad_count": sum(1 for item in items if item["level"] == "bad"),
    }


