def safe_domain(value):
    value = str(value or "").strip().lower().rstrip(".")
    if not SAFE_DOMAIN_RE.match(value):
        return ""
    if ".." in value or value.startswith("-") or value.endswith("-"):
        return ""
    return value


def safe_direct_domain(value):
    value = str(value or "").strip().lower().replace(" ", "").rstrip(".")
    if SAFE_DIRECT_SUFFIX_RE.match(value):
        return value
    return safe_domain(value)


def backup_path_from_name(name):
    name = safe_backup_name(name)
    if not name:
        return None
    path_obj = (BACKUP_DIR / name).resolve()
    root_resolved = BACKUP_DIR.resolve()
    if root_resolved not in path_obj.parents or not path_obj.exists():
        return None
    return path_obj


def read_request_data(handler, limit=8192):
    length = min(int(handler.headers.get("Content-Length", "0") or 0), limit)
    raw = handler.rfile.read(length).decode("utf-8", errors="replace")
    ctype = handler.headers.get("Content-Type", "")
    if "application/json" in ctype:
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {}
    form = parse_qs(raw)
    return {k: v[0] for k, v in form.items()}


def parse_command_kv(output):
    data = {}
    for line in str(output or "").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if re.match(r"^[A-Za-z0-9_]+$", key):
            data[key] = value
    return data


def run_readonly(cmd, timeout=12):
    try:
        proc = subprocess.run(
            cmd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            check=False,
        )
        return {
            "cmd": cmd,
            "rc": proc.returncode,
            "output": redact(proc.stdout[-12000:]),
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "cmd": cmd,
            "rc": 124,
            "output": redact((exc.stdout or "") + "\nTIMEOUT"),
        }
    except OSError as exc:
        return {
            "cmd": cmd,
            "rc": 127,
            "output": f"ERROR: {exc}",
        }


