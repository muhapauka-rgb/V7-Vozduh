class Handler(BaseHTTPRequestHandler):
    server_version = "V7Admin/0.1"

    def log_message(self, fmt, *args):
        return

    def send_json(self, data, status=200):
        body = json.dumps(redact(data), ensure_ascii=False, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_redirect(self, location):
        self.send_response(303)
        self.send_header("Location", location)
        self.send_header("Cache-Control", "no-store")
        self.end_headers()

    def send_html(self):
        body = html_page().encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_login(self, error="", status=200):
        body = login_page(error).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_connect(self, result=None, error=None, status=200, form_data=None):
        body = connect_page(result=result, error=error, form_data=form_data).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def current_session(self):
        return parse_session(self.headers.get("Cookie"))

    def require_auth(self, api=False):
        if not auth_configured():
            if api:
                self.send_json({"error": "auth_not_initialized", "setup": "run v7-admin-auth-init on the VPS"}, status=503)
            else:
                self.send_login("Auth is not initialized.", status=503)
            return None
        cached = getattr(self, "_v7_session", None)
        if cached:
            return cached
        session = self.current_session()
        if not session:
            if api:
                self.send_json({"error": "unauthorized"}, status=401)
            else:
                self.send_redirect("/login")
            return None
        self._v7_session = session
        return session

    def require_csrf(self, session):
        if getattr(self, "_v7_csrf_checked", False):
            return True
        provided = self.headers.get("X-CSRF-Token", "")
        if not provided:
            length = min(int(self.headers.get("Content-Length", "0") or 0), 8192)
            raw = self.rfile.read(length).decode("utf-8", errors="replace")
            ctype = self.headers.get("Content-Type", "")
            if "application/json" in ctype:
                try:
                    data = json.loads(raw)
                except json.JSONDecodeError:
                    data = {}
            else:
                form = parse_qs(raw)
                data = {k: v[0] for k, v in form.items()}
            provided = str(data.get("csrf", ""))
        if not provided or not hmac.compare_digest(provided, str(session.get("csrf", ""))):
            self.send_json({"error": "csrf_failed"}, status=403)
            return False
        self._v7_csrf_checked = True
        return True

    def require_role(self, session, required):
        role = (session or {}).get("role") or auth_role((session or {}).get("sub", ""))
        required = normalize_role(required, "owner")
        if role_allows(role, required):
            return True
        actor = (session or {}).get("sub", "unknown")
        audit_admin(
            actor,
            "admin_role_denied",
            f"path={urlparse(self.path).path} required={required} role={role}",
            object_type="admin_access",
            object_id=urlparse(self.path).path,
            result="DENIED",
            severity="warning",
        )
        self.send_json({
            "error": "forbidden_role",
            "message": "This action requires a higher admin role.",
            "required_role": required,
            "current_role": role,
            "access": role_state_for_session(session),
        }, status=403)
        return False

    def require_action_access(self, session, path):
        required = ACTION_MIN_ROLE.get(path, "owner")
        return self.require_role(session, required)

    def require_get_access(self, session, path):
        required = GET_MIN_ROLE.get(path, "viewer")
        return self.require_role(session, required)

    def do_HEAD(self):
        path = urlparse(self.path).path
        if path in ("/", "/login", "/connect", "/health"):
            content_type = "application/json; charset=utf-8" if path == "/health" else "text/html; charset=utf-8"
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
        else:
            self.send_response(404)
            self.send_header("Cache-Control", "no-store")
            self.end_headers()

