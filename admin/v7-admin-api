    raw = read_state_kv(TRUSTED_RU_DIAG_FILE)
    decision = trusted_ru_decision_state()
    flow = read_state_kv(USER_FLOW_TRACE_FILE)
    decisions_by_domain = {item.get("domain"): item for item in decision.get("items", [])}
