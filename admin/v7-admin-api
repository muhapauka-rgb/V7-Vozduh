        "safe_mode_enabled": "Оператор временно включил безопасный режим. Подключение новых устройств остановлено.",
        "unsupported_vpn_client": "Выберите Karing/Hiddify или попросите оператора выдать профиль для другого приложения.",
        "provisioning_preflight_failed": "Система не смогла подготовить VPN-профиль. Оператор уже сможет увидеть эту ошибку в админке.",
        "device_create_failed": "Система не смогла создать VPN-пользователя. Оператор уже сможет увидеть эту ошибку в админке.",
        "smart_profile_failed": "VPN-пользователь создан, но профиль приложения не собрался. Оператор уже сможет увидеть эту ошибку в админке.",
        "delivery_create_failed": "Профиль создан, но ссылка выдачи не сформировалась. Оператор уже сможет увидеть эту ошибку в админке.",
    }
    hint = str((error or {}).get("hint") or hints.get(code) or "Попробуйте ещё раз. Если ошибка повторится, напишите оператору.")
    detail = ""
    if code == "device_limit_reached":
        active = html.escape(str((error or {}).get("active_devices", "")))
        maximum = html.escape(str((error or {}).get("max_devices", "")))
        if active and maximum:
            detail = f"<small>Активных устройств: {active} из {maximum}.</small>"
    if code == "unsupported_vpn_client":
        client = html.escape(str((error or {}).get("client", "")))
        if client:
            detail = f"<small>Выбранное приложение: {client}.</small>"
    return {
        "code": code,
        "message": message,
        "hint": hint,
        "detail_html": detail,
    }


def connect_client_steps(vpn_client):
    client = str(vpn_client or "karing").lower()
    if client == "hiddify":
        return [
            "Нажмите «Получить профиль».",
            "Скачайте файл на телефон.",
            "Откройте Hiddify и добавьте профиль из файла.",
            "Включите подключение и подождите 10-20 секунд.",
        ]
    if client == "wireguard":
        return [
            "Нажмите «Получить профиль».",
            "Если приложение не импортирует JSON, попросите оператора выдать WireGuard config/QR.",
            "Импортируйте профиль и включите VPN.",
            "После подключения оператор увидит статус в админке.",
        ]
    return [
        "Нажмите «Получить профиль».",
        "Откройте скачанный файл в Karing.",
        "Импортируйте профиль и включите подключение.",
        "Подождите 10-20 секунд: V7 увидит первое подключение.",
    ]


def connect_success_view(result):
    profile = (result or {}).get("profile", {})
    device = (result or {}).get("device", {})
    user = (result or {}).get("user", {})
    delivery_url = str(profile.get("delivery_url", ""))
    ttl = int(profile.get("ttl_seconds") or 0)
    vpn_client = str(device.get("vpn_client") or "karing")
    steps = "".join(f"<li>{html.escape(step)}</li>" for step in connect_client_steps(vpn_client))
    ttl_text = f"{ttl // 60} мин." if ttl >= 60 else f"{ttl} сек."
    return f"""
    <section class="result">
      <div class="notice ok">
        <strong>Профиль готов</strong>
        <p>Устройство создано. Осталось скачать профиль, импортировать его в приложение и включить VPN.</p>
      </div>
      <div class="summary">
        <div><span>Пользователь</span><strong>{html.escape(str(user.get("display_name") or ""))}</strong></div>
        <div><span>Организация</span><strong>{html.escape(str(user.get("organization") or ""))}</strong></div>
        <div><span>VPN IP</span><strong>{html.escape(str(device.get("assigned_vpn_ip") or ""))}</strong></div>
        <div><span>Приложение</span><strong>{html.escape(vpn_client)}</strong></div>
        <div><span>Профиль</span><strong>{html.escape(str(profile.get("mode") or ""))}</strong></div>
        <div><span>Ссылка</span><strong>одноразовая, {html.escape(ttl_text)}</strong></div>
      </div>
      <a class="primary" href="{html.escape(delivery_url)}">Получить профиль</a>
      <ol class="steps">{steps}</ol>
      <div class="notice wait">
        <strong>После импорта</strong>
        <p>Включите VPN в приложении. В админке V7 сначала будет статус «Waiting first connection», затем после первого подключения оператор увидит актуальный маршрут и отсутствие утечки.</p>
      </div>
    </section>
    """


def connect_client_options(selected):
    selected = safe_connect_client(selected)
    options = []
    for key, meta in CONNECT_CLIENTS.items():
        label = str(meta.get("label") or key)
        note = str(meta.get("note") or "")
        suffix = "" if key in SUPPORTED_CONNECT_CLIENTS else f" — {note}"
        disabled = "" if key in SUPPORTED_CONNECT_CLIENTS else " disabled"
        is_selected = " selected" if selected == key else ""
        options.append(
            f'<option value="{html.escape(key)}"{is_selected}{disabled}>{html.escape(label + suffix)}</option>'
        )
    return "".join(options)


def connect_client_status_view():
    rows = []
    for key, meta in CONNECT_CLIENTS.items():
        label = html.escape(str(meta.get("label") or key))
        if key in SUPPORTED_CONNECT_CLIENTS:
            status_label = "доступно"
        elif meta.get("status") == "blocked":
            status_label = "нужен отдельный вход"
        else:
            status_label = "скоро"
        note = html.escape(str(meta.get("note") or ""))
        rows.append(f"<li><strong>{label}</strong><span>{html.escape(status_label)} · {note}</span></li>")
    return "<ul class=\"client-status\">" + "".join(rows) + "</ul>"


def connect_page(result=None, error=None, form_data=None):
    form_data = form_data if isinstance(form_data, dict) else {}
    error_html = ""
    if error:
        ev = connect_error_view(error)
        error_html = f"""
        <div class="notice bad">
          <strong>{html.escape(ev["message"])}</strong>
          <p>{html.escape(ev["hint"])}</p>
          {ev["detail_html"]}
          <small>Код: {html.escape(ev["code"] or "connect_error")}</small>
        </div>
        """
    result_html = ""
    if result:
        result_html = connect_success_view(result)
    name_value = html.escape(str(form_data.get("name", "")))
    phone_value = html.escape(str(form_data.get("phone", "")))
    org_value = html.escape(str(form_data.get("organization", "")))
    vpn_client_value = safe_connect_client(form_data.get("vpn_client", "karing"))
    client_options = connect_client_options(vpn_client_value)
    client_status = connect_client_status_view()
    return f"""<!doctype html>
