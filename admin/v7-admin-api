    .result {{ margin-top:14px; }}
    .summary {{ display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }}
    .summary div {{ border:1px solid var(--line); border-radius:8px; padding:9px; background:#10141a; }}
