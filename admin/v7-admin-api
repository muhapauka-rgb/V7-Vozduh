    .drawer { position:fixed; inset:0; z-index:60; background:rgba(0,0,0,.54); display:none; justify-content:center; align-items:center; padding:24px; backdrop-filter:blur(10px); }
    .drawer.open { display:flex; }
    .drawer aside { width:min(1120px,calc(100vw - 48px)); max-height:calc(100vh - 48px); overflow:hidden; background:var(--panel2); border:1px solid var(--line); border-radius:18px; box-shadow:0 28px 90px rgba(0,0,0,.38); display:flex; flex-direction:column; }
    .drawer-head { position:sticky; top:0; z-index:2; background:var(--panel2); border-bottom:1px solid var(--line); padding:18px 20px; display:flex; justify-content:space-between; gap:12px; align-items:center; }
    .drawer h2 { margin:4px 0 0; font-size:22px; max-width:380px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .drawer-body { padding:16px 20px 20px; overflow:auto; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px; }
    .drawer-section { border:1px solid var(--line); background:var(--panel); border-radius:14px; padding:14px; margin-top:0; min-width:0; }
    .drawer-section:has(pre), .drawer-section:has(table), details.drawer-section { grid-column:span 2; }
    .drawer-section h3 { margin:0 0 10px; font-size:13px; }
    .drawer pre { white-space:pre-wrap; overflow:auto; max-height:320px; color:var(--muted); }
    .drawer-actionbar { background:var(--panel2); border-top:1px solid var(--line); padding:12px 20px; display:flex; gap:8px; justify-content:flex-end; }
    .layout-tools { position:fixed; right:20px; bottom:20px; z-index:50; display:none; gap:8px; padding:10px; border:1px solid var(--line); border-radius:16px; background:var(--panel2); box-shadow:var(--shadow); }
    body.layout-editing .layout-tools { display:flex; }
    body.layout-editing .panel, body.layout-editing .metric, body.layout-editing .stat-card { outline:1px dashed rgba(96,165,250,.42); outline-offset:-5px; }
    body.layout-editing .panel:hover, body.layout-editing .metric:hover, body.layout-editing .stat-card:hover { outline-color:var(--green); }
    @media(max-width:1450px){ .top-status span:nth-child(2), .top-status a.ghost{display:none} }
    @media(max-width:1200px){ .grid-metrics{grid-template-columns:repeat(2,minmax(0,1fr));}.overview-grid,.split,.wizard-grid{grid-template-columns:1fr}.span-8,.span-6,.span-4,.settings-overview-main,.settings-overview-side{grid-column:span 12}.cards-grid,.stat-grid,.flow-steps{grid-template-columns:repeat(2,minmax(0,1fr))}.top-status span:nth-child(n+3){display:none} }
    @media(max-width:720px){
      .app-top{height:auto;min-height:56px}
      .top-inner{height:auto;min-height:56px;padding:8px 12px 10px;align-items:flex-start;flex-wrap:wrap;gap:8px;position:relative}
      .left{width:100%;align-items:flex-start;flex-wrap:wrap;gap:8px;padding-right:108px}
      .brand{height:32px;display:flex;align-items:center}
      .nav{order:2;width:100%;height:38px;gap:4px;padding-bottom:2px;scroll-snap-type:x proximity;scrollbar-width:none}
      .nav::-webkit-scrollbar{display:none}
      .nav-group-label{display:none}
      .nav-divider{height:20px;margin:0 2px}
      .nav button{height:34px;padding:0 10px;flex:0 0 auto;border:1px solid transparent;border-radius:999px;scroll-snap-align:start}
      .nav button.active{color:var(--green);border-color:rgba(52,211,153,.26);background:rgba(52,211,153,.10)}
      .nav button.active:after{display:none}
      .top-status{position:absolute;right:12px;top:8px;gap:6px}
      .top-status span,.top-status a.ghost{display:none}
      .top-status .ghost{min-height:32px;padding:4px 9px}
      .shell{padding:12px}
      .grid-metrics,.cards-grid,.stat-grid,.flow-steps{grid-template-columns:1fr}
      .module-hero{display:none}
      .module-hero h1{font-size:22px}
      .module-hero p{font-size:13px}
      .module-hero > button,.module-hero .primary{width:100%}
      .topology{height:248px; padding:12px; gap:8px; scroll-snap-type:x proximity}
      .topology-node,.egress-pool{scroll-snap-align:start}
      .egress-pool{flex-basis:340px}
      .arrow{display:block; flex-basis:14px}
      .toolbar{padding:14px 14px 10px}
      .toolbar-actions{width:100%}
      .toolbar-actions .ghost,.toolbar-actions .primary{flex:1 1 auto}
      .workspace-tabs{padding:8px;overflow:auto;flex-wrap:nowrap;scrollbar-width:none}
      .workspace-tabs::-webkit-scrollbar{display:none}
      .workspace-tab{flex:0 0 auto}
      .stat-card,.metric{padding:14px}
      .table-shell{max-height:360px}
      th,td{padding:9px 12px}
      .drawer{padding:10px; align-items:stretch}
      .drawer aside{width:100%; max-height:calc(100vh - 20px); border-radius:14px}
      .drawer-head{padding:14px 16px}
      .drawer-body{padding:12px 16px; grid-template-columns:1fr}
      .drawer-section:has(pre), .drawer-section:has(table), details.drawer-section { grid-column:span 1; }
      .drawer-actionbar{padding:10px 16px}
    }
  </style>
</head>
<body>
  <header class="app-top">
    <div class="top-inner">
      <div class="left">
        <div class="brand">V7</div>
