def verify_password(password, stored):
    try:
        algo, iterations, salt, expected = stored.split("$", 3)
        if algo != "pbkdf2_sha256":
            return False
        digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), b64d(salt), int(iterations))
        return hmac.compare_digest(b64e(digest), expected)
    except Exception:
        return False


def sign_payload(payload_b64, secret):
    return b64e(hmac.new(secret.encode("utf-8"), payload_b64.encode("ascii"), hashlib.sha256).digest())


def make_session(username):
    data = auth_config()
    role = auth_role(username)
    payload = {
        "sub": username,
        "role": role,
        "iat": int(time.time()),
        "exp": int(time.time()) + SESSION_TTL,
        "csrf": secrets.token_urlsafe(24),
    }
    payload_b64 = b64e(json.dumps(payload, separators=(",", ":"), ensure_ascii=True).encode("utf-8"))
    sig = sign_payload(payload_b64, data.get("session_secret", ""))
    return f"{payload_b64}.{sig}", payload


def parse_session(header):
    if not header:
        return None
    jar = cookies.SimpleCookie()
    try:
        jar.load(header)
    except cookies.CookieError:
        return None
    morsel = jar.get(SESSION_COOKIE)
    if not morsel:
        return None
    token = morsel.value
    try:
        payload_b64, sig = token.split(".", 1)
    except ValueError:
        return None
    data = auth_config()
    expected = sign_payload(payload_b64, data.get("session_secret", ""))
    if not hmac.compare_digest(sig, expected):
        return None
    try:
        payload = json.loads(b64d(payload_b64).decode("utf-8"))
    except Exception:
        return None
    if int(payload.get("exp", 0)) < int(time.time()):
        return None
    account = auth_accounts(data).get(str(payload.get("sub") or ""))
    if not account or not account.get("enabled", True):
        return None
    payload["role"] = auth_role(payload.get("sub"))
    return payload


def parse_kv_line(line):
    item = {}
    for part in line.strip().split():
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        item[key] = value
    return item


def parse_registry(path):
    items = []
    for line in read_text(path).splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        items.append(parse_kv_line(line))
    return redact(items)


def egress_registry_rows(enabled_only=False):
    rows = parse_registry(STATE_DIR / "egress.registry")
    if enabled_only:
        rows = [row for row in rows if str(row.get("enabled", "1")) == "1"]
    return rows


def egress_registry_map(enabled_only=False):
    return {
        row.get("id"): row
        for row in egress_registry_rows(enabled_only=enabled_only)
        if row.get("id")
    }


def egress_exists(egress_id, enabled_only=False):
    egress_id = safe_egress_id(egress_id)
    return bool(egress_id and egress_id in egress_registry_map(enabled_only=enabled_only))


def default_egress_id():
    rows = egress_registry_rows(enabled_only=True)
    return rows[0].get("id", "") if rows else ""


def egress_interface(egress_id):
    row = egress_registry_map().get(safe_egress_id(egress_id), {})
    return row.get("interface", "")


def egress_config_path(egress_id):
    row = egress_registry_map().get(safe_egress_id(egress_id), {})
    configured = row.get("config") or row.get("config_path")
    if configured:
        return Path(configured)
    return EGRESS_CONFIG_PATHS.get(egress_id)


def read_state_kv(path):
    data = {}
    for line in read_text(path).splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key] = value
    return redact(data)


