def identity_device_revoke_apply(device_id, actor, confirm):
    if confirm != "REVOKE_DEVICE":
        return None, {"error": "device_revoke_requires_confirm_REVOKE_DEVICE"}
    preview, error = identity_device_revoke_preview(device_id, actor)
    if error:
        return None, error
    device = preview["device"]
    ip = safe_user_ip(device.get("assigned_vpn_ip", ""))
    result = run_action(["v7-user-disable", ip], actor, timeout=35)
    if result["rc"] != 0:
        return {"device": device, "result": result}, {"error": "runtime_device_revoke_failed"}
    now = now_iso()
    with identity_conn() as conn:
        conn.execute(
            "UPDATE devices SET status='revoked', revoked_at=?, updated_at=? WHERE id=?",
            (now, now, device["id"]),
        )
        conn.execute(
            "UPDATE identity_users SET updated_at=? WHERE id=?",
            (now, device["user_id"]),
        )
        conn.commit()
        updated = dict(conn.execute("SELECT * FROM devices WHERE id=?", (device["id"],)).fetchone())
    audit_admin(actor, "admin_action_identity_device_revoke", f"device_id={device['id']} ip={ip}", object_type="identity_device", object_id=device["id"], result="OK")
    return {"device": updated, "result": result}, None


def connect_onboard(data, handler=None):
    if admin_safe_mode_enabled():
        return None, {"error": "safe_mode_enabled", "message": "Подключение временно отключено администратором."}, 423
    identity_init_db()
    entered_name = clean_identity_text(data.get("name", ""), 160)
    phone = normalize_phone(data.get("phone", ""))
    org_input = clean_identity_text(data.get("organization", ""), 160)
    password = str(data.get("password", ""))
    vpn_client = safe_connect_client(data.get("vpn_client", "karing"))
    device_type = clean_identity_text(data.get("device_type", "phone"), 60) or "phone"
    mode = safe_smart_mode(data.get("mode", "RU_LOCAL")) or "RU_LOCAL"
    client_meta = CONNECT_CLIENTS.get(vpn_client, CONNECT_CLIENTS["karing"])
    adapter = safe_smart_adapter(client_meta.get("adapter") or "karing")
    if not entered_name or not phone or not org_input or not password:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "missing_required_fields", handler)
        return None, {"error": "missing_required_fields", "message": "Заполните имя, телефон, организацию и пароль."}, 400
    if identity_rate_limited(phone, handler=handler):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "rate_limited", handler)
        return None, {"error": "rate_limited", "message": "Слишком много неудачных попыток. Попробуйте позже или обратитесь к администратору."}, 429
    if not connect_client_supported(vpn_client):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "unsupported_vpn_client", handler)
        client = CONNECT_CLIENTS.get(vpn_client, CONNECT_CLIENTS["karing"])
        return None, {
            "error": "unsupported_vpn_client",
            "message": "Это приложение ещё не подключено к автоматической выдаче.",
            "client": client.get("label", vpn_client),
            "hint": "Сейчас автоматическая выдача работает для Karing и Hiddify. Для остальных клиентов профиль выдаёт оператор или нужен отдельный адаптер.",
        }, 400
    allowed = identity_find_allowed_phone(phone)
    if not allowed or not int(allowed.get("is_active") or 0):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "phone_not_allowed", handler)
        return None, {"error": "phone_not_allowed", "message": "Телефон не найден в списке разрешенных."}, 403
    if not identity_verify_connection_password(password):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "invalid_connection_password", handler)
        return None, {"error": "invalid_connection_password", "message": "Неверный пароль подключения."}, 403
    organization = identity_find_organization(org_input)
    if not organization:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "organization_not_found", handler)
        return None, {"error": "organization_not_found", "message": "Организация не найдена. Выберите организацию из списка администратора."}, 404
    if allowed.get("organization_id") and allowed.get("organization_id") != organization.get("id"):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "organization_mismatch", handler)
        return None, {"error": "organization_mismatch", "message": "Телефон разрешен для другой организации."}, 403
    mode, mode_context = identity_effective_smart_mode(mode, allowed, organization)
    user, error = identity_get_or_create_user(phone, entered_name, allowed, organization)
    if error:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", error.get("error", "user_error"), handler)
        return None, error, 400
    if user.get("status") in ("blocked", "disabled"):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", f"user_{user.get('status')}", handler)
        return None, {"error": f"user_{user.get('status')}", "message": "Пользователь заблокирован или отключен."}, 403
    active_devices = identity_active_device_count(user["id"])
    max_devices = int(user.get("max_devices") or 3)
    if active_devices >= max_devices:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "device_limit_reached", handler)
        return None, {"error": "device_limit_reached", "message": "Для этого пользователя достигнут лимит устройств.", "active_devices": active_devices, "max_devices": max_devices}, 409
    client_name = onboarding_client_name(user, device_type)
    egress = default_egress_id()
    dry = run_action(["v7-user-create", client_name, "--egress", egress, "--dry-run"], "connect", timeout=20)
    if dry["rc"] != 0:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "provisioning_preflight_failed", handler)
        return None, {"error": "provisioning_preflight_failed", "detail": dry}, 500
    created = run_action(["v7-user-create", client_name, "--egress", egress], "connect", timeout=45)
    parsed = parse_command_kv(created.get("output", ""))
    if created["rc"] != 0 or not safe_user_ip(parsed.get("ip", "")):
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "device_create_failed", handler)
        return None, {"error": "device_create_failed", "detail": created}, 500
    conf = wg_conf_for_user_ip(parsed["ip"])
    output = smart_client_profile_path(client_name, adapter, mode)
    generated = run_action([
        "v7-smart-client-profile-generate",
        "--adapter", adapter,
        "--mode", mode,
        "--wg-conf", str(conf),
        "--name", client_name,
        "--output", str(output),
    ], "connect", timeout=35)
    check = {"rc": 0, "output": "skipped"} if generated["rc"] != 0 else run_action(["sing-box", "check", "-c", str(output)], "connect", timeout=20)
    if generated["rc"] != 0 or check["rc"] != 0:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "smart_profile_failed", handler)
        return None, {"error": "smart_profile_failed", "generate": generated, "check": check}, 500
    delivery, delivery_error = create_profile_delivery(parsed["ip"], adapter, mode, "connect")
    if delivery_error:
        identity_log_attempt(phone, entered_name, org_input, "FAIL", "delivery_create_failed", handler)
        return None, delivery_error, 500
    device = identity_record_device(user["id"], client_name, vpn_client, device_type, parsed)
    identity_log_attempt(phone, entered_name, org_input, "OK", "device_created", handler)
    audit_admin("connect", "public_connect_onboard", f"phone={phone} user_id={user.get('id')} device_id={device.get('id')} ip={parsed.get('ip')}", object_type="identity_device", object_id=device.get("id", ""), result="OK")
    return {
        "user": {
            "id": user.get("id"),
            "display_name": user.get("display_name"),
            "phone_normalized": phone,
            "organization": organization.get("name"),
            "max_devices": max_devices,
            "active_devices": active_devices + 1,
        },
        "device": {
            "id": device.get("id"),
            "device_name": device.get("device_name"),
            "assigned_vpn_ip": device.get("assigned_vpn_ip"),
            "vpn_client": device.get("vpn_client"),
            "route_table": device.get("route_table"),
        },
        "profile": {
            "adapter": adapter,
            "mode": mode,
            "mode_context": mode_context,
            "delivery_url": delivery.get("url"),
            "ttl_seconds": delivery.get("ttl_seconds"),
            "expires_at_epoch": delivery.get("expires_at_epoch"),
        },
    }, None, 200


def parse_command_kv(output):
    data = {}
    for line in str(output or "").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if re.match(r"^[A-Za-z0-9_]+$", key):
            data[key] = value
    return data


def _egress_preview_ini_sections(text):
    sections = {}
    current = ""
    for raw in text.splitlines():
        line = raw.split("#", 1)[0].split(";", 1)[0].strip()
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            current = line[1:-1].strip()
            sections.setdefault(current, {})
            continue
        if current and "=" in line:
            key, value = [part.strip() for part in line.split("=", 1)]
            sections.setdefault(current, {})[key] = value
    return sections


def _first_query_value(query, *names):
    for name in names:
        values = query.get(name)
        if values:
            return values[0]
    return ""


def _decode_unpadded_base64(value):
    value = str(value or "").strip()
    padding = "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode((value + padding).encode("ascii", errors="ignore")).decode("utf-8", errors="replace")


def egress_parse_proxy_share(raw):
    raw = str(raw or "").strip()
    lowered = raw.lower()
    if lowered.startswith("vless://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        uuid = unquote(parsed.username or "")
        server = parsed.hostname or ""
        port = parsed.port or 0
        outbound = {
            "type": "vless",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "uuid": uuid,
        }
        flow = _first_query_value(query, "flow")
        if flow:
            outbound["flow"] = flow
        security = _first_query_value(query, "security")
        sni = _first_query_value(query, "sni", "servername", "serverName")
        fp = _first_query_value(query, "fp", "fingerprint") or "chrome"
        public_key = _first_query_value(query, "pbk", "publicKey", "public_key")
        short_id = _first_query_value(query, "sid", "shortId", "short_id")
        if security in ("tls", "reality") or sni or public_key:
            tls = {"enabled": True}
            if sni:
                tls["server_name"] = sni
            if fp:
                tls["utls"] = {"enabled": True, "fingerprint": fp}
            if security == "reality" or public_key:
                tls["reality"] = {"enabled": True, "public_key": public_key}
                if short_id:
                    tls["reality"]["short_id"] = short_id
            outbound["tls"] = tls
        network = _first_query_value(query, "type", "network")
        if network in ("ws", "grpc", "http", "httpupgrade"):
            outbound["transport"] = {"type": network}
            if network == "ws":
                path = _first_query_value(query, "path")
                host = _first_query_value(query, "host")
                if path:
                    outbound["transport"]["path"] = path
                if host:
                    outbound["transport"]["headers"] = {"Host": host}
            if network == "grpc":
                service_name = _first_query_value(query, "serviceName", "service_name")
                if service_name:
                    outbound["transport"]["service_name"] = service_name
        required = {
            "server": bool(server),
            "port": bool(port),
            "uuid": bool(uuid),
        }
        if security == "reality" or public_key:
            required["reality_public_key"] = bool(public_key)
            required["sni"] = bool(sni)
        return {"protocol": "vless", "outbound": outbound, "required": required}, None

    if lowered.startswith("trojan://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        password = unquote(parsed.username or "")
        server = parsed.hostname or ""
        port = parsed.port or 0
        sni = _first_query_value(query, "sni", "peer", "servername", "serverName")
        outbound = {
            "type": "trojan",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "password": password,
        }
        if sni or _first_query_value(query, "security") == "tls":
            outbound["tls"] = {"enabled": True}
            if sni:
                outbound["tls"]["server_name"] = sni
        return {
            "protocol": "trojan",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "password": bool(password)},
        }, None

    if lowered.startswith("ss://"):
        parsed = urlparse(raw)
        server = parsed.hostname or ""
        port = parsed.port or 0
        userinfo = unquote(parsed.username or "")
        if not server:
            body = raw[5:].split("#", 1)[0].split("?", 1)[0]
            decoded = _decode_unpadded_base64(body)
            parsed = urlparse("ss://" + decoded)
            server = parsed.hostname or ""
            port = parsed.port or 0
            userinfo = unquote(parsed.username or "")
        if ":" in userinfo:
            method, password = userinfo.split(":", 1)
        else:
            decoded_userinfo = _decode_unpadded_base64(userinfo) if userinfo else ""
            method, password = decoded_userinfo.split(":", 1) if ":" in decoded_userinfo else ("", "")
        outbound = {
            "type": "shadowsocks",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "method": method,
            "password": password,
        }
        return {
            "protocol": "shadowsocks_or_outline",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "method": bool(method), "password": bool(password)},
        }, None

    if lowered.startswith("vmess://"):
        body = raw.split("://", 1)[1].split("#", 1)[0].strip()
        try:
            payload = json.loads(_decode_unpadded_base64(body))
        except Exception as exc:
            return None, {"error": "invalid_vmess_share", "detail": str(exc)}
        server = str(payload.get("add") or "")
        try:
            port = int(payload.get("port") or 0)
        except ValueError:
            port = 0
        uuid = str(payload.get("id") or "")
        outbound = {
            "type": "vmess",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "uuid": uuid,
            "security": str(payload.get("scy") or "auto"),
        }
        if str(payload.get("tls") or ""):
            outbound["tls"] = {"enabled": True}
            sni = str(payload.get("sni") or payload.get("host") or "")
            if sni:
                outbound["tls"]["server_name"] = sni
        return {
            "protocol": "vmess",
            "outbound": outbound,
            "required": {"server": bool(server), "port": bool(port), "uuid": bool(uuid)},
        }, None

    return None, {"error": "unsupported_proxy_share"}


def egress_sing_box_profile_from_outbound(outbound, listen_port):
    return {
        "log": {"level": "warn"},
        "inbounds": [
            {
                "type": "socks",
