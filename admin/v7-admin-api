    candidate_path = root / "public-candidate" / "sing-box.json"
    candidate_meta_path = root / "public-candidate" / "metadata.json"
    unit = f"v7-proxy-inbound-{inbound_id}.service"
    binding_files = sorted(bind_dir.glob("user-*.json")) if bind_dir.exists() else []
    bindings = []
    for path in binding_files:
        data = read_json(path, {})
        bindings.append({
            "file": path.name,
            "user_ip": data.get("user_ip", ""),
            "route_table": data.get("route_table", ""),
            "current_egress": data.get("current_egress", ""),
            "included_in_runtime_config": bool(data.get("included_in_runtime_config")),
        })
    runtime = read_json(runtime_path, {})
    candidate = read_json(candidate_path, {})
    candidate_meta = read_json(candidate_meta_path, {})
    runtime_users = 0
    for inbound in runtime.get("inbounds") or []:
        runtime_users += len(inbound.get("users") or [])
    candidate_rules = (candidate.get("route") or {}).get("rules") or []
    auth_user_rules = [rule for rule in candidate_rules if rule.get("auth_user")]
    legacy_user_rules = [rule for rule in candidate_rules if rule.get("user")]
    inbound_fallback_rules = [rule for rule in candidate_rules if rule.get("inbound") and not rule.get("auth_user") and not rule.get("user")]
    service = run_readonly(["systemctl", "is-active", unit], timeout=4)
    service_active = service.get("output", "").strip().splitlines()[-1:] == ["active"]
    binding_count = len(bindings)
    runtime_fresh = binding_count == runtime_users
    candidate_fresh = binding_count == len(auth_user_rules) and not legacy_user_rules and not inbound_fallback_rules
    needs_refresh = binding_count > 0 and (not runtime_fresh or not candidate_fresh or not service_active)
    status = "REFRESH_REQUIRED" if needs_refresh else ("OK" if binding_count > 0 and service_active else "NOT_READY")
    reasons = []
    if binding_count != runtime_users:
        reasons.append(f"runtime_users_mismatch:bindings={binding_count}:runtime={runtime_users}")
    if binding_count != len(auth_user_rules):
        reasons.append(f"candidate_rules_mismatch:bindings={binding_count}:auth_user_rules={len(auth_user_rules)}")
    if legacy_user_rules:
        reasons.append("candidate_has_legacy_user_rules")
    if inbound_fallback_rules:
        reasons.append("candidate_has_inbound_fallback")
    if not service_active:
        reasons.append("public_proxy_service_inactive")
    return {
        "inbound_id": inbound_id,
        "unit": unit,
        "status": status,
        "needs_refresh": needs_refresh,
        "binding_count": binding_count,
        "runtime_users": runtime_users,
        "candidate_auth_user_rules": len(auth_user_rules),
        "candidate_legacy_user_rules": len(legacy_user_rules),
        "candidate_inbound_fallback_rules": len(inbound_fallback_rules),
        "service_active": service_active,
        "candidate_status": candidate_meta.get("status", ""),
        "candidate_rendered_at": candidate_meta.get("rendered_at", ""),
        "reasons": reasons,
        "bindings": bindings[:100],
    }


def profile_delivery_prune(data=None):
    data = data or profile_delivery_state()
    now = time.time()
    changed = False
    tokens = data.setdefault("tokens", {})
    for token, row in list(tokens.items()):
        if not isinstance(row, dict):
            tokens.pop(token, None)
            changed = True
            continue
        expires_at = float(row.get("expires_at_epoch") or 0)
        if row.get("downloaded_at") or (expires_at and expires_at < now):
            # Keep only a short non-secret tombstone for audit context.
            row["expired"] = True
            row.pop("profile_path", None)
            if len(tokens) > 300:
                tokens.pop(token, None)
            changed = True
    if changed:
        data["updated"] = now_iso()
        write_json_atomic(PROFILE_DELIVERY_FILE, data)
    return data


def profile_delivery_id(token, row=None):
    existing = (row or {}).get("delivery_id") if isinstance(row, dict) else ""
    if isinstance(existing, str) and re.match(r"^[a-f0-9]{16}$", existing):
        return existing
    return hashlib.sha256(token.encode("utf-8")).hexdigest()[:16]


def profile_delivery_status(row, now_epoch=None):
    now_epoch = time.time() if now_epoch is None else now_epoch
    if row.get("revoked_at"):
        return "revoked"
    if row.get("downloaded_at"):
        return "downloaded"
    if row.get("expired"):
        return "expired"
    expires_at = float(row.get("expires_at_epoch") or 0)
    if expires_at and expires_at < now_epoch:
        return "expired"
    return "active"


def profile_delivery_public_row(token, row, now_epoch=None):
    now_epoch = time.time() if now_epoch is None else now_epoch
    status = profile_delivery_status(row, now_epoch)
    expires_at = float(row.get("expires_at_epoch") or 0)
    public = {
        "delivery_id": profile_delivery_id(token, row),
        "token_hint": token[:8],
        "status": status,
        "ip": row.get("ip", ""),
        "client": row.get("client", ""),
        "adapter": row.get("adapter", ""),
        "mode": row.get("mode", ""),
        "created_at": row.get("created_at", ""),
        "created_by": row.get("created_by", ""),
        "downloaded_at": row.get("downloaded_at", ""),
        "revoked_at": row.get("revoked_at", ""),
        "revoked_by": row.get("revoked_by", ""),
        "expires_at_epoch": expires_at,
        "ttl_seconds": int(row.get("ttl_seconds") or PROFILE_DELIVERY_TTL_SECONDS),
        "profile_available": bool(row.get("profile_path")) and status == "active",
    }
    public["expires_in_sec"] = max(0, int(expires_at - now_epoch)) if status == "active" and expires_at else 0
    return public


def profile_delivery_rows(ip="", status="", limit=100):
    data = profile_delivery_prune()
    now_epoch = time.time()
    rows = []
    for token, row in (data.get("tokens") or {}).items():
        if not isinstance(row, dict):
            continue
        public = profile_delivery_public_row(token, row, now_epoch)
        if ip and public.get("ip") != ip:
            continue
        if status and public.get("status") != status:
            continue
        rows.append(public)
    rows.sort(key=lambda item: float(item.get("expires_at_epoch") or 0), reverse=True)
    return rows[:max(1, min(int(limit or 100), 300))]


def profile_delivery_summary_for_ip(ip):
    rows = profile_delivery_rows(ip=ip, limit=80)
    counts = {}
    for row in rows:
        counts[row.get("status", "unknown")] = counts.get(row.get("status", "unknown"), 0) + 1
    return {
        "ip": ip,
        "counts": counts,
        "items": rows,
    }


def profile_delivery_latest(rows):
    rows = [row for row in rows or [] if isinstance(row, dict)]
    if not rows:
        return {}
    for status in ("active", "downloaded"):
        row = next((item for item in rows if item.get("status") == status), None)
        if row:
            return row
    return rows[0]


def profile_delivery_overview():
    rows = profile_delivery_rows(limit=120)
    counts = {}
    for row in rows:
        counts[row.get("status", "unknown")] = counts.get(row.get("status", "unknown"), 0) + 1
    return {
        "counts": counts,
        "items": rows,
        "recent": rows[:20],
    }


def revoke_profile_delivery(delivery_id, actor):
    delivery_id = str(delivery_id or "").strip().lower()
    if not re.match(r"^[a-f0-9]{16}$", delivery_id):
        return None, {"error": "invalid_delivery_id"}
    data = profile_delivery_prune()
    tokens = data.setdefault("tokens", {})
    for token, row in tokens.items():
        if not isinstance(row, dict):
            continue
        if profile_delivery_id(token, row) != delivery_id:
            continue
        if profile_delivery_status(row) != "active":
            return profile_delivery_public_row(token, row), {"error": "delivery_not_active", "status": profile_delivery_status(row)}
        row["delivery_id"] = delivery_id
        row["revoked_at"] = now_iso()
        row["revoked_by"] = actor or "admin"
        row["expired"] = True
        row.pop("profile_path", None)
        data["updated"] = now_iso()
        write_json_atomic(PROFILE_DELIVERY_FILE, data)
        return profile_delivery_public_row(token, row), None
    return None, {"error": "delivery_not_found"}


def revoke_profile_deliveries_for_ip(ip, actor, reason="identity_device_revoked"):
    ip = safe_user_ip(ip)
    if not ip:
        return []
    data = profile_delivery_prune()
    now = now_iso()
    revoked = []
    for token, row in (data.get("tokens") or {}).items():
        if row.get("ip") != ip or profile_delivery_status(row) != "active":
            continue
        row["status"] = "revoked"
        row["revoked_at"] = now
        row["revoked_by"] = actor
        row["revoke_reason"] = clean_identity_text(reason, 120)
        row["delivery_id"] = profile_delivery_id(token, row)
        revoked.append(profile_delivery_public_row(token, row))
    if revoked:
        data["updated"] = now
        write_json_atomic(PROFILE_DELIVERY_FILE, data)
    return revoked


def create_profile_delivery(ip, adapter, mode, actor):
    conf = wg_conf_for_user_ip(ip)
    if not conf and adapter != "happ":
        return None, {"error": "wireguard_client_config_not_found", "ip": ip}
    name = smart_client_name_for_ip(ip, adapter)
    path_obj = smart_client_profile_path(name, adapter, mode)
    if not path_obj or not path_obj.exists():
        return None, {"error": "smart_profile_not_found", "message": "Generate the profile before creating a delivery link."}
    token = b64e(secrets.token_bytes(32))
    created_epoch = time.time()
    expires_epoch = created_epoch + PROFILE_DELIVERY_TTL_SECONDS
    data = profile_delivery_prune()
    delivery_id = profile_delivery_id(token)
    data.setdefault("tokens", {})[token] = {
        "delivery_id": delivery_id,
        "ip": ip,
        "client": name,
        "adapter": adapter,
        "mode": mode,
        "profile_path": str(path_obj),
        "created_at": now_iso(),
        "created_at_epoch": created_epoch,
        "expires_at_epoch": expires_epoch,
        "ttl_seconds": PROFILE_DELIVERY_TTL_SECONDS,
        "created_by": actor or "admin",
        "downloaded_at": "",
    }
    data["updated"] = now_iso()
    write_json_atomic(PROFILE_DELIVERY_FILE, data)
    return {
        "token": token,
        "delivery_id": delivery_id,
        "token_hint": token[:8],
        "ip": ip,
        "client": name,
        "adapter": adapter,
        "mode": mode,
        "ttl_seconds": PROFILE_DELIVERY_TTL_SECONDS,
        "expires_at_epoch": expires_epoch,
        "url": f"/profile-delivery/{token}",
    }, None


def consume_profile_delivery(token):
    token = safe_delivery_token(token)
    if not token:
        return None, {"error": "invalid_delivery_token"}
    data = profile_delivery_prune()
    row = (data.get("tokens") or {}).get(token)
    if not isinstance(row, dict) or row.get("expired"):
        return None, {"error": "delivery_token_not_found_or_expired"}
    if row.get("downloaded_at"):
        return None, {"error": "delivery_token_already_used"}
    if float(row.get("expires_at_epoch") or 0) < time.time():
        row["expired"] = True
        row.pop("profile_path", None)
        data["updated"] = now_iso()
        write_json_atomic(PROFILE_DELIVERY_FILE, data)
        return None, {"error": "delivery_token_expired"}
    path_obj = Path(row.get("profile_path", "")).resolve()
    root_resolved = SMART_CLIENT_ROOT.resolve()
    if root_resolved not in path_obj.parents or not path_obj.exists():
        return None, {"error": "delivery_profile_missing"}
    row["downloaded_at"] = now_iso()
    row["expired"] = True
    row.pop("profile_path", None)
    data["updated"] = now_iso()
    write_json_atomic(PROFILE_DELIVERY_FILE, data)
    return {"row": row, "path": path_obj}, None


def wg_conf_for_user_ip(ip):
    if not CLIENT_ROOT.exists():
        return None
    for conf in CLIENT_ROOT.glob("*/*.conf"):
        try:
            text = conf.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        if f"Address = {ip}/32" not in text and f"Address={ip}/32" not in text:
            continue
        return conf
    return None


def client_artifacts_for_ip(ip):
    rows = []
    conf = wg_conf_for_user_ip(ip)
    if not conf:
        return rows
    try:
        name = conf.stem
        qr = conf.with_suffix(".png")
        rows.append({
            "name": name,
            "config_ready": True,
            "qr_ready": qr.exists(),
            "config_url": f"/api/client-artifact?name={name}&type=conf",
            "qr_url": f"/api/client-artifact?name={name}&type=qr" if qr.exists() else None,
            "mtime": datetime.fromtimestamp(conf.stat().st_mtime, timezone.utc).isoformat(),
        })
    except OSError:
        return rows
    return rows


def client_artifacts_map(users):
    wanted = {row.get("ip") for row in users if row.get("ip")}
    result = {ip: [] for ip in wanted}
    if not CLIENT_ROOT.exists():
        return result
    for conf in CLIENT_ROOT.glob("*/*.conf"):
        try:
            text = conf.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        matches = re.findall(r"(?m)^\s*Address\s*=\s*([0-9.]+)/32\s*$", text)
        for ip in matches:
            if ip not in wanted:
                continue
            try:
                name = conf.stem
                qr = conf.with_suffix(".png")
                result.setdefault(ip, []).append({
                    "name": name,
                    "config_ready": True,
                    "qr_ready": qr.exists(),
                    "config_url": f"/api/client-artifact?name={name}&type=conf",
                    "qr_url": f"/api/client-artifact?name={name}&type=qr" if qr.exists() else None,
                    "mtime": datetime.fromtimestamp(conf.stat().st_mtime, timezone.utc).isoformat(),
                })
            except OSError:
                continue
    return result


def wg_handshake_map():
    result = {}
    wg = run_readonly(["wg", "show", "wg0", "dump"], timeout=5)
    now = int(time.time())
    for line in str(wg.get("output", "")).splitlines()[1:]:
        parts = line.split("\t")
        if len(parts) < 7:
            continue
        for allowed in parts[3].split(","):
            allowed = allowed.strip()
            if not allowed.endswith("/32"):
                continue
            ip = allowed[:-3]
            if not safe_user_ip(ip):
                continue
            try:
                handshake_ts = int(parts[4])
            except ValueError:
                handshake_ts = 0
            age = None if handshake_ts <= 0 else max(0, now - handshake_ts)
            result[ip] = {
                "present": True,
                "latest_handshake_epoch": handshake_ts,
                "latest_handshake_age_sec": age,
                "recent": age is not None and age <= 180,
                "transfer_rx_bytes": int(parts[5]) if parts[5].isdigit() else 0,
                "transfer_tx_bytes": int(parts[6]) if parts[6].isdigit() else 0,
            }
    return result


def wg_handshake_state(ip):
    ip = safe_user_ip(ip)
    if not ip:
        return {}
    row = wg_handshake_map().get(ip)
    if row:
        return row
    return {
        "present": False,
        "latest_handshake_epoch": 0,
        "latest_handshake_age_sec": None,
        "recent": False,
        "transfer_rx_bytes": 0,
        "transfer_tx_bytes": 0,
    }


def desired_state_map():
    result = {}
    check = run_readonly(["v7-user-desired-state"], timeout=8)
    for line in str(check.get("output", "")).splitlines():
        if not line.startswith("user="):
            continue
        row = parse_command_kv(line)
        ip = safe_user_ip(row.get("user", ""))
        if not ip:
            continue
        row["_output"] = line
        result[ip] = row
    return result


def desired_state_row(ip):
    return desired_state_map().get(ip, {})


def empty_handshake():
    return {
        "present": False,
        "latest_handshake_epoch": 0,
        "latest_handshake_age_sec": None,
        "recent": False,
        "transfer_rx_bytes": 0,
        "transfer_tx_bytes": 0,
    }


def user_readiness(ip, user, route, artifacts, speed_row, agent_row, handshake=None, desired=None):
    handshake = handshake if handshake is not None else wg_handshake_state(ip)
    desired = desired if desired is not None else desired_state_row(ip)
    enabled = str(user.get("enabled", "1")) == "1"
    artifacts_ready = any(row.get("config_ready") for row in artifacts)
    smart_profiles = smart_client_profiles_for_ip(ip) if enabled else {"available": False, "items": []}
    ru_local_profile = next(
        (
            row for row in smart_profiles.get("items", [])
            if row.get("adapter") == "karing" and row.get("mode") == "RU_LOCAL"
        ),
        {},
    )
    ru_local_validation = ru_local_profile.get("validation") or {}
    ru_local_ready = bool(ru_local_profile.get("ready")) and ru_local_validation.get("status") == "OK"
    route_ok = bool((route or {}).get("ok")) and not bool((route or {}).get("leak_risk"))
    desired_ok = desired.get("status") == "OK"
    agent_online = bool((agent_row or {}).get("online") or (speed_row or {}).get("agent_online"))
    connected = bool(handshake.get("recent") or agent_online)
    blockers = []
    warnings = []
    if not enabled:
        blockers.append("user_disabled")
    if not artifacts_ready:
        blockers.append("client_config_missing")
    if enabled and artifacts_ready and not ru_local_ready:
        blockers.append("ru_local_smart_profile_missing_or_invalid")
    if not desired_ok:
        warnings.append("desired_state_needs_check")
    if not route_ok:
        blockers.append("route_or_leak_check_failed")
    if not connected:
        warnings.append("waiting_for_first_client_connection")
    if blockers:
        status = "BLOCKED"
    elif warnings:
        status = "WAITING"
    else:
        status = "READY"
    next_action = user_next_action(
        enabled=enabled,
        artifacts_ready=artifacts_ready,
        ru_local_ready=ru_local_ready,
        route_ok=route_ok,
        leak_risk=bool((route or {}).get("leak_risk")),
        desired_ok=desired_ok,
        connected=connected,
    )
    return {
        "status": status,
        "enabled": enabled,
        "artifacts_ready": artifacts_ready,
        "ru_local_profile_ready": ru_local_ready,
        "ru_local_profile": {
            "adapter": "karing",
            "mode": "RU_LOCAL",
            "ready": bool(ru_local_profile.get("ready")),
            "validation": ru_local_validation,
            "download_url": ru_local_profile.get("download_url", ""),
        },
        "connected": connected,
        "handshake": handshake,
        "agent_online": agent_online,
        "route_ok": route_ok,
        "leak_risk": bool((route or {}).get("leak_risk")),
        "desired_state": desired,
        "desired_ok": desired_ok,
        "blockers": blockers,
        "warnings": warnings,
        "next_action": next_action,
        "plain": {
            "READY": "Client is issued, route is correct, and a recent connection was observed.",
            "WAITING": "Client profile and route are prepared. Waiting for the user to connect or refresh.",
            "BLOCKED": "Client is not ready. Fix the blockers before treating this user as connected.",
        }.get(status, "Unknown readiness state."),
    }


def user_next_action(enabled, artifacts_ready, ru_local_ready, route_ok, leak_risk, desired_ok, connected):
    if not enabled:
        return {
            "code": "enable_user_if_expected",
            "label": "Enable user if expected",
            "plain": "The user is disabled, so V7 will not treat this device as active.",
            "primary": "enable_preview",
        }
    if not artifacts_ready:
        return {
            "code": "issue_wireguard_config",
            "label": "Issue / reissue base config",
            "plain": "Create the base client config first. After that generate the RU_LOCAL smart profile.",
            "primary": "issue_profile",
        }
    if not ru_local_ready:
        return {
            "code": "generate_karing_ru_local",
            "label": "Generate Karing RU_LOCAL",
            "plain": "Generate the smart profile that sends RU, Gosuslugi and banks directly on the client while global traffic uses V7.",
            "primary": "generate_karing_ru_local",
        }
    if leak_risk or not route_ok:
        return {
            "code": "check_route_reality",
            "label": "Check route / leak",
            "plain": "The client profile exists, but the observed route needs review before this user is considered ready.",
            "primary": "check_user",
        }
    if not connected:
        return {
            "code": "wait_for_client_connection",
            "label": "Wait for client connection",
            "plain": "Everything is issued. Ask the user to import/connect the profile; readiness becomes OK after handshake or client agent signal.",
            "primary": "delivery_history",
        }
    if not desired_ok:
        return {
            "code": "refresh_desired_state",
            "label": "Refresh desired state",
            "plain": "Route is fine, but desired-state metadata should be refreshed or reconciled.",
            "primary": "check_user",
        }
    return {
        "code": "watch",
        "label": "Ready",
        "plain": "User profile, route and connection look ready.",
        "primary": "none",
    }


def user_onboarding_stage(ip, user, readiness, delivery_summary=None):
    readiness = readiness or {}
    delivery_summary = delivery_summary or profile_delivery_summary_for_ip(ip)
    rows = delivery_summary.get("items") or []
    counts = delivery_summary.get("counts") or {}
    latest = profile_delivery_latest(rows)
    active_delivery = int(counts.get("active") or 0)
    downloaded_delivery = int(counts.get("downloaded") or 0)
    enabled = str((user or {}).get("enabled", "1")) == "1"
    artifacts_ready = bool(readiness.get("artifacts_ready"))
    ru_local_ready = bool(readiness.get("ru_local_profile_ready"))
    connected = bool(readiness.get("connected"))
    route_ok = bool(readiness.get("route_ok")) and not bool(readiness.get("leak_risk"))

    if not enabled:
        stage = ("disabled", "Disabled", "bad", "User is disabled in registry.", "Enable user only if this device should be active.")
    elif not artifacts_ready:
        stage = ("needs_base_config", "Needs base config", "bad", "WireGuard/client base config is missing.", "Issue or reissue the base client profile.")
    elif not ru_local_ready:
        stage = ("needs_ru_local", "Needs RU_LOCAL", "bad", "Smart client profile for RU_LOCAL is missing or invalid.", "Generate Karing RU_LOCAL profile.")
    elif connected and not route_ok:
        stage = ("route_check", "Route check", "bad", "Client is seen, but route or leak check needs review.", "Run user route/leak check.")
    elif readiness.get("status") == "READY":
        stage = ("ready", "Ready", "ok", "Profile, route and recent connection look ready.", "No action needed.")
    elif downloaded_delivery and not connected:
        stage = ("downloaded_waiting_connection", "Downloaded, waiting", "info", "User downloaded the profile but V7 has not seen a recent connection.", "Ask the user to connect the imported profile.")
    elif active_delivery and not connected:
        stage = ("link_sent", "Link sent", "info", "One-time delivery link is active and waiting for the user.", "Wait for download or resend/revoke if needed.")
    elif not connected:
        stage = ("ready_to_deliver", "Ready to deliver", "warn", "Profile is ready but no active/downloaded delivery is recorded.", "Create a one-time delivery link or download the RU_LOCAL profile.")
    else:
        stage = ("connected_watch", "Connected", "ok", "Client is connected; readiness has no blocking action.", "Watch normal health metrics.")

    steps = [
        {"id": "base_config", "label": "Base config", "ok": artifacts_ready},
        {"id": "ru_local", "label": "RU_LOCAL profile", "ok": ru_local_ready},
        {"id": "delivery_link", "label": "Delivery link", "ok": bool(active_delivery or downloaded_delivery)},
        {"id": "downloaded", "label": "Downloaded", "ok": bool(downloaded_delivery)},
        {"id": "connected", "label": "Connected", "ok": connected},
        {"id": "route_ok", "label": "Route OK", "ok": route_ok},
    ]
    return {
        "ip": ip,
        "stage": stage[0],
        "label": stage[1],
        "tone": stage[2],
        "detail": stage[3],
        "next": stage[4],
        "delivery_counts": counts,
        "latest_delivery": latest,
        "steps": steps,
    }


def user_readiness_map(users, route_rows, speed_rows, agents):
    routes = {row.get("ip"): row for row in route_rows or []}
    artifact_rows = client_artifacts_map(users)
    handshakes = wg_handshake_map()
    desired_rows = desired_state_map()
    agent_rows = (agents.get("agents") or {}) if isinstance(agents, dict) else {}
    result = {}
    for user in users:
        ip = user.get("ip", "")
        if not ip:
            continue
        result[ip] = user_readiness(
            ip,
            user,
            routes.get(ip),
            artifact_rows.get(ip, []),
            (speed_rows or {}).get(ip, {}),
            agent_rows.get(ip),
            handshake=handshakes.get(ip, empty_handshake()),
            desired=desired_rows.get(ip, {}),
        )
    return result


