#!/usr/bin/env python3
import argparse
import base64
import hashlib
import json
import os
import secrets
import subprocess
from datetime import datetime, timezone
from pathlib import Path


AUTH_DIR = Path("/etc/v7/admin")
AUTH_FILE = AUTH_DIR / "auth.json"
INITIAL_PASSWORD_FILE = Path("/root/v7-admin-initial-password.txt")
ITERATIONS = 260000


def pbkdf2_hash(password: str) -> str:
    salt = secrets.token_bytes(16)
    digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt, ITERATIONS)
    return "pbkdf2_sha256${}${}${}".format(
        ITERATIONS,
        base64.urlsafe_b64encode(salt).decode("ascii").rstrip("="),
        base64.urlsafe_b64encode(digest).decode("ascii").rstrip("="),
    )


def main():
    parser = argparse.ArgumentParser(description="Initialize V7 admin local auth.")
    parser.add_argument("--username", default="admin")
    parser.add_argument("--force", action="store_true")
    args = parser.parse_args()

    if AUTH_FILE.exists() and not args.force:
        print("V7_ADMIN_AUTH_INIT=already_exists")
        print(f"auth_file={AUTH_FILE}")
        print("Use --force to rotate credentials.")
        return

    password = secrets.token_urlsafe(24)
    session_secret = secrets.token_urlsafe(48)
    AUTH_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(AUTH_DIR, 0o700)

    data = {
        "version": 1,
        "username": args.username,
        "password_hash": pbkdf2_hash(password),
        "session_secret": session_secret,
        "created_at": datetime.now(timezone.utc).isoformat(),
    }

    tmp = AUTH_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.chmod(tmp, 0o600)
    tmp.replace(AUTH_FILE)
    os.chmod(AUTH_FILE, 0o600)

    INITIAL_PASSWORD_FILE.write_text(
        "V7 admin initial login\n"
        f"created_at={data['created_at']}\n"
        f"username={args.username}\n"
        f"password={password}\n",
        encoding="utf-8",
    )
    os.chmod(INITIAL_PASSWORD_FILE, 0o600)

    subprocess.run(
        ["v7-audit-log", "admin_auth_init", "admin", f"username={args.username}"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )

    print("V7_ADMIN_AUTH_INIT=OK")
    print(f"auth_file={AUTH_FILE}")
    print(f"initial_password_file={INITIAL_PASSWORD_FILE}")
    print("password_printed=false")


if __name__ == "__main__":
    main()
