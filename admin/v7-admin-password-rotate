#!/usr/bin/env python3
import argparse
import base64
import hashlib
import json
import os
import secrets
import subprocess
from datetime import datetime, timezone
from pathlib import Path


AUTH_FILE = Path("/etc/v7/admin/auth.json")
INITIAL_PASSWORD_FILE = Path("/root/v7-admin-initial-password.txt")
ROTATED_PASSWORD_FILE = Path("/etc/v7/admin/rotated-password.txt")
ITERATIONS = 260000


def b64e(raw: bytes) -> str:
    return base64.urlsafe_b64encode(raw).decode("ascii").rstrip("=")


def pbkdf2_hash(password: str) -> str:
    salt = secrets.token_bytes(16)
    digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt, ITERATIONS)
    return f"pbkdf2_sha256${ITERATIONS}${b64e(salt)}${b64e(digest)}"


def main():
    parser = argparse.ArgumentParser(description="Rotate V7 admin password.")
    parser.add_argument("--username", default="")
    parser.add_argument("--keep-sessions", action="store_true", help="Do not rotate session secret.")
    args = parser.parse_args()

    if not AUTH_FILE.exists():
        print("FAIL: auth config missing. Run v7-admin-auth-init first.", flush=True)
        raise SystemExit(1)

    data = json.loads(AUTH_FILE.read_text(encoding="utf-8"))
    username = args.username or data.get("username", "admin")
    password = secrets.token_urlsafe(24)
    now = datetime.now(timezone.utc).isoformat()

    backup = AUTH_FILE.with_name(f"auth.json.backup.v7-admin-password-rotate.{datetime.now().strftime('%Y%m%d-%H%M%S')}")
    backup.write_text(json.dumps(data, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.chmod(backup, 0o600)

    data["username"] = username
    data["password_hash"] = pbkdf2_hash(password)
    data["password_rotated_at"] = now
    if not args.keep_sessions:
        data["session_secret"] = secrets.token_urlsafe(48)
        data["sessions_invalidated_at"] = now

    tmp = AUTH_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.chmod(tmp, 0o600)
    tmp.replace(AUTH_FILE)
    os.chmod(AUTH_FILE, 0o600)

    ROTATED_PASSWORD_FILE.write_text(
        "V7 admin rotated login\n"
        f"created_at={now}\n"
        f"username={username}\n"
        f"password={password}\n",
        encoding="utf-8",
    )
    os.chmod(ROTATED_PASSWORD_FILE, 0o600)

    if INITIAL_PASSWORD_FILE.exists():
        INITIAL_PASSWORD_FILE.unlink()

    subprocess.run(
        ["v7-audit-log", "admin_password_rotate", "admin", f"username={username} sessions_invalidated={str(not args.keep_sessions).lower()}"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )

    print("V7_ADMIN_PASSWORD_ROTATE=OK")
    print(f"auth_backup={backup}")
    print(f"rotated_password_file={ROTATED_PASSWORD_FILE}")
    print("password_printed=false")
    print(f"sessions_invalidated={str(not args.keep_sessions).lower()}")


if __name__ == "__main__":
    main()
