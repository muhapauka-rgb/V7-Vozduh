#!/usr/bin/env python3
import html
import json
import os
import re
import socket
import time
import secrets
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import urlparse


HOST = os.environ.get("V7_CLIENT_SPEED_HOST", "10.0.0.1")
PORT = int(os.environ.get("V7_CLIENT_SPEED_PORT", "7090"))
STATE_DIR = Path(os.environ.get("V7_STATE_DIR", "/opt/v7/egress/state"))
OUT = Path(os.environ.get("V7_CLIENT_SPEED_FILE", str(STATE_DIR / "client-speed.json")))
AGENTS = Path(os.environ.get("V7_CLIENT_AGENTS_FILE", str(STATE_DIR / "client-agents.json")))
COMMANDS = Path(os.environ.get("V7_CLIENT_COMMANDS_FILE", str(STATE_DIR / "client-commands.json")))
USERS_REG = STATE_DIR / "users.registry"
EGRESS_REG = STATE_DIR / "egress.registry"
MAX_HISTORY = int(os.environ.get("V7_CLIENT_SPEED_MAX_HISTORY", "80"))
ONLINE_TTL = int(os.environ.get("V7_CLIENT_ONLINE_TTL", "45"))
VPN_IP_RE = re.compile(r"^10\.0\.0\.[0-9]{1,3}$")
SAFE_EGRESS_RE = re.compile(r"^[A-Za-z0-9_.-]{0,64}$")


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def read_text(path, default=""):
    try:
        return Path(path).read_text(encoding="utf-8")
    except OSError:
        return default


def parse_registry():
    users = {}
    for line in read_text(USERS_REG).splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        row = {}
        for part in line.split():
            if "=" in part:
                k, v = part.split("=", 1)
                row[k] = v
        if row.get("ip"):
            users[row["ip"]] = row
    return users


def parse_egress_registry():
    rows = []
    for line in read_text(EGRESS_REG).splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        row = {}
        for part in line.split():
            if "=" in part:
                k, v = part.split("=", 1)
                row[k] = v
        if row.get("id") and str(row.get("enabled", "1")) == "1":
            rows.append(row)
    return rows


def egress_options_html():
    rows = parse_egress_registry()
    return "\n".join(
        f'<option value="{html.escape(row["id"])}">{html.escape(row["id"])}</option>'
        for row in rows
    )


def read_state():
    return read_json_file(OUT, {"updated": now_iso(), "users": {}})


def read_json_file(path, default):
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return default


def write_state(data):
    write_json_file(OUT, data)


def write_json_file(path, data):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{secrets.token_hex(4)}")
    tmp.write_text(json.dumps(data, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def client_ip(handler):
    ip = handler.client_address[0]
    if ip.startswith("::ffff:"):
        ip = ip[7:]
    return ip


def safe_float(value, default=0.0):
    try:
        return float(value)
    except Exception:
        return default


def registered_user(ip):
    users = parse_registry()
    row = users.get(ip)
    if not row or str(row.get("enabled", "1")) != "1":
        return None
    return row


def update_agent(ip, user_row, user_agent):
    data = read_json_file(AGENTS, {"updated": now_iso(), "agents": {}})
    agents = data.setdefault("agents", {})
    now = now_iso()
    agents[ip] = {
        "ip": ip,
        "current_egress": user_row.get("current"),
        "table": user_row.get("table"),
        "last_seen": now,
        "online_until": int(time.time()) + ONLINE_TTL,
        "user_agent": str(user_agent or "")[:180],
    }
    data["updated"] = now
    write_json_file(AGENTS, data)
    return agents[ip]


def commands_for(ip):
    data = read_json_file(COMMANDS, {"updated": now_iso(), "commands": []})
    cmds = data.setdefault("commands", [])
    changed = False
    now = now_iso()
    out = []
    for cmd in cmds:
        if cmd.get("ip") != ip:
            continue
        if cmd.get("status") not in ("pending", "delivered"):
            continue
        cmd["status"] = "delivered"
        cmd["delivered_at"] = now
        changed = True
        out.append(cmd)
    if changed:
        data["updated"] = now
        write_json_file(COMMANDS, data)
    return out


def complete_command(command_id, ip, sample):
    if not command_id:
        return
    data = read_json_file(COMMANDS, {"updated": now_iso(), "commands": []})
    changed = False
    for cmd in data.setdefault("commands", []):
        if cmd.get("id") == command_id and cmd.get("ip") == ip:
            cmd["status"] = "completed"
            cmd["completed_at"] = now_iso()
            cmd["result"] = {
                "mode": sample.get("mode"),
                "egress": sample.get("egress"),
                "mbps": sample.get("mbps"),
                "duration_ms": sample.get("duration_ms"),
            }
            changed = True
            break
    if changed:
        data["updated"] = now_iso()
        write_json_file(COMMANDS, data)


