class Handler(BaseHTTPRequestHandler):
    server_version = "V7ClientSpeed/0.1"

    def log_message(self, fmt, *args):
        return

    def send_json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = urlparse(self.path).path
        ip = client_ip(self)
        if path == "/":
            body = page().encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif path == "/health":
            self.send_json({"status": "OK", "host": HOST, "port": PORT, "updated": now_iso()})
        elif path == "/api/my-speed":
            user = registered_user(ip) or {}
            state = read_state()
            mine = state.get("users", {}).get(ip, {})
            self.send_json({"ip": ip, "current_egress": user.get("current"), "table": user.get("table"), "latest": mine.get("latest", {}), "history": mine.get("history", [])[-10:]})
        elif path == "/api/agent/poll":
            user = registered_user(ip)
            if not user:
                self.send_json({"error": "unregistered_client", "ip": ip}, status=403)
                return
            agent = update_agent(ip, user, self.headers.get("User-Agent", ""))
            self.send_json({"ok": True, "ip": ip, "agent": agent, "commands": commands_for(ip)})
        else:
            self.send_json({"error": "not_found", "path": html.escape(path)}, status=404)

    def do_POST(self):
        path = urlparse(self.path).path
        ip = client_ip(self)
        if path != "/api/sample":
            self.send_json({"error": "not_found"}, status=404)
            return
        if not VPN_IP_RE.match(ip):
            self.send_json({"error": "forbidden_source", "ip": ip}, status=403)
            return
        user_row = registered_user(ip)
        if not user_row:
            self.send_json({"error": "unregistered_client", "ip": ip}, status=403)
            return
        length = min(int(self.headers.get("Content-Length", "0") or 0), 4096)
        try:
            data = json.loads(self.rfile.read(length).decode("utf-8", errors="replace"))
        except Exception:
            data = {}
        mode = str(data.get("mode", "")).lower()
        if mode not in ("v7", "direct"):
            self.send_json({"error": "invalid_mode"}, status=400)
            return
        egress = str(data.get("egress", "")).strip()
        if not SAFE_EGRESS_RE.match(egress):
            self.send_json({"error": "invalid_egress"}, status=400)
            return
        mbps = safe_float(data.get("mbps"))
        duration_ms = int(safe_float(data.get("duration_ms")))
        bytes_count = int(safe_float(data.get("bytes")))
        if mbps <= 0 or duration_ms <= 0 or bytes_count <= 0:
            self.send_json({"error": "invalid_measurement"}, status=400)
            return
        current = user_row.get("current", "")
        sample = {
            "ts": now_iso(),
            "source_ip": ip,
            "mode": mode,
            "egress": egress if mode == "direct" else current,
            "current_egress": current,
            "mbps": round(mbps, 2),
            "bytes": bytes_count,
            "duration_ms": duration_ms,
            "target_url": str(data.get("target_url", ""))[:160],
            "measured_at": str(data.get("measured_at", ""))[:80],
            "command_id": str(data.get("command_id", ""))[:80],
            "user_agent": self.headers.get("User-Agent", "")[:180],
        }
        state = read_state()
        state["updated"] = now_iso()
        user = state.setdefault("users", {}).setdefault(ip, {"latest": {}, "history": []})
        latest = user.setdefault("latest", {})
        if mode == "direct":
            direct = latest.setdefault("direct", {})
            direct[egress or "_default"] = sample
        else:
            latest["v7"] = sample
        history = user.setdefault("history", [])
        history.append(sample)
        user["history"] = history[-MAX_HISTORY:]
        write_state(state)
        complete_command(sample.get("command_id"), ip, sample)
        self.send_json({"ok": True, "saved": sample})


def main():
    httpd = ThreadingHTTPServer((HOST, PORT), Handler)
    print(f"V7 client speed API listening on http://{HOST}:{PORT}", flush=True)
    httpd.serve_forever()


if __name__ == "__main__":
    main()
