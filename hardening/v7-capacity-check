#!/usr/bin/env bash
set -u

TARGET_USERS="${1:-500}"
WG_CONF="${V7_WG_CONF:-/etc/wireguard/wg0.conf}"
USERS_REG="${V7_USERS_REGISTRY:-/opt/v7/egress/state/users.registry}"

FAIL=0
WARN=0

fail() {
  echo "FAIL: $*"
  FAIL=1
}

warn() {
  echo "WARN: $*"
  WARN=1
}

ok() {
  echo "OK: $*"
}

cidr_capacity() {
  local cidr="$1"
  if ! [[ "$cidr" =~ ^[0-9]+$ ]] || [ "$cidr" -lt 1 ] || [ "$cidr" -gt 30 ]; then
    echo 0
    return
  fi
  # Usable IPv4 hosts minus one address reserved for the V7 wg0 gateway.
  echo $(( (1 << (32 - cidr)) - 3 ))
}

recommended_cidr() {
  local target="$1"
  local cidr cap
  for cidr in $(seq 30 -1 16); do
    cap=$(cidr_capacity "$cidr")
    if [ "$cap" -ge "$target" ]; then
      echo "$cidr"
      return
    fi
  done
  echo "16"
}

echo "===== V7 CAPACITY CHECK ====="
date
echo "target_users=$TARGET_USERS"

if ! [[ "$TARGET_USERS" =~ ^[0-9]+$ ]] || [ "$TARGET_USERS" -lt 1 ]; then
  fail "target users must be a positive integer"
fi

if [ ! -r "$WG_CONF" ]; then
  fail "wg config not readable: $WG_CONF"
else
  address=$(awk -F= '/^[[:space:]]*Address[[:space:]]*=/{gsub(/[[:space:]]/, "", $2); print $2; exit}' "$WG_CONF")
  echo "wg_address=$address"
  cidr="${address#*/}"
  capacity=$(cidr_capacity "$cidr")
  echo "current_cidr=$cidr"
  echo "current_client_capacity=$capacity"
  if [ "$capacity" -ge "$TARGET_USERS" ]; then
    ok "current WireGuard subnet capacity covers target"
  else
    rec=$(recommended_cidr "$TARGET_USERS")
    fail "current WireGuard subnet capacity is too small for target"
    echo "recommended_min_cidr=/$rec"
    echo "recommended_client_capacity=$(cidr_capacity "$rec")"
  fi
fi

if [ -r "$USERS_REG" ]; then
  active_users=$(awk '$0 !~ /^[[:space:]]*($|#)/ {enabled="1"; for (i=1;i<=NF;i++) if ($i ~ /^enabled=/) {enabled=$i; sub(/^enabled=/, "", enabled)}; if (enabled == "1") c++} END{print c+0}' "$USERS_REG")
  total_users=$(awk '$0 !~ /^[[:space:]]*($|#)/ {c++} END{print c+0}' "$USERS_REG")
  echo "registered_users=$total_users"
  echo "active_users=$active_users"
else
  warn "users registry not readable: $USERS_REG"
fi

echo
echo "===== /24 REFERENCES ====="
grep -RIn "10\.0\.0\.0/24\|10\.0\.0\.\[0-9\]\|BASE_PREFIX=\"10\.0\.0\"" \
  /usr/local/bin/v7-* /etc/wireguard /etc/v7 2>/dev/null \
  | grep -v '\.bak\|backup' \
  | head -n 120 || true

echo
echo "===== RESULT ====="
if [ "$FAIL" -eq 1 ]; then
  echo "V7_CAPACITY_RESULT=FAIL"
  exit 1
elif [ "$WARN" -eq 1 ]; then
  echo "V7_CAPACITY_RESULT=WARN"
  exit 0
else
  echo "V7_CAPACITY_RESULT=OK"
  exit 0
fi
