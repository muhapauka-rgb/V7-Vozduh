STATE_DIR = Path(os.environ.get("V7_STATE_DIR", "/opt/v7/egress/state"))
EGRESS_DRAFTS_DIR = Path(os.environ.get("V7_EGRESS_DRAFTS_DIR", "/etc/v7/egress-drafts"))
EGRESS_DRAFT_TESTS_DIR = Path(os.environ.get("V7_EGRESS_DRAFT_TESTS_DIR", "/opt/v7/admin/egress-draft-tests"))
SAFE_ID_RE = re.compile(r"^[A-Za-z0-9_.-]{1,64}$")
SAFE_RUN_ID_RE = re.compile(r"^[A-Za-z0-9_.-]{1,180}$")
SAFE_WG_KEY_RE = re.compile(r"^[A-Za-z0-9+/]{43}=$")
SECRET_RE = re.compile(r"(PrivateKey|PresharedKey|private_key|preshared_key|password|token|secret)\s*=\s*\S+", re.I)
