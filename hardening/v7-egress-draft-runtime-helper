def now_iso():
    return datetime.now(timezone.utc).isoformat()


def redact(value):
    if value is None:
        return value
    if isinstance(value, dict):
        return {k: ("[REDACTED]" if "key" in str(k).lower() or "secret" in str(k).lower() else redact(v)) for k, v in value.items()}
    if isinstance(value, list):
        return [redact(v) for v in value]
    if not isinstance(value, str):
        return value
    return SECRET_RE.sub(r"\1=[REDACTED]", value)


def read_json(path, default=None):
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return default if default is not None else {}


def write_json_atomic(path, data, mode=0o600):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{secrets.token_hex(4)}")
    tmp.write_text(json.dumps(redact(data), ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    os.chmod(tmp, mode)
    os.replace(tmp, path)


def write_text_atomic(path, text, mode=0o600):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{secrets.token_hex(4)}")
    tmp.write_text(text, encoding="utf-8")
    os.chmod(tmp, mode)
    os.replace(tmp, path)


def run(cmd, timeout=20):
    try:
        proc = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=timeout, check=False)
        return {"cmd": cmd, "rc": proc.returncode, "output": redact(proc.stdout[-12000:])}
    except subprocess.TimeoutExpired as exc:
        return {"cmd": cmd, "rc": 124, "output": redact((exc.stdout or "") + "\nTIMEOUT")}
    except OSError as exc:
        return {"cmd": cmd, "rc": 127, "output": f"ERROR: {exc}"}


def free_local_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        return int(sock.getsockname()[1])


def wait_tcp(host, port, timeout=8):
    deadline = time.time() + timeout
    last_error = ""
    while time.time() < deadline:
        try:
            with socket.create_connection((host, int(port)), timeout=0.4):
                return True, ""
        except OSError as exc:
            last_error = str(exc)
            time.sleep(0.2)
    return False, last_error


def _first_query_value(query, *names):
    for name in names:
        values = query.get(name)
        if values:
            return values[0]
    return ""


def _decode_unpadded_base64(value):
    import base64
    value = str(value or "").strip()
    padding = "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode((value + padding).encode("ascii", errors="ignore")).decode("utf-8", errors="replace")


def parse_proxy_share(raw):
    from urllib.parse import parse_qs, unquote, urlparse
    raw = str(raw or "").strip()
    lowered = raw.lower()
    if lowered.startswith("vless://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        outbound = {
            "type": "vless",
            "tag": "egress",
            "server": parsed.hostname or "",
            "server_port": parsed.port or 0,
            "uuid": unquote(parsed.username or ""),
        }
        flow = _first_query_value(query, "flow")
        if flow:
            outbound["flow"] = flow
        security = _first_query_value(query, "security")
        sni = _first_query_value(query, "sni", "servername", "serverName")
        fp = _first_query_value(query, "fp", "fingerprint") or "chrome"
        public_key = _first_query_value(query, "pbk", "publicKey", "public_key")
        short_id = _first_query_value(query, "sid", "shortId", "short_id")
        if security in ("tls", "reality") or sni or public_key:
            tls = {"enabled": True}
            if sni:
                tls["server_name"] = sni
            if fp:
                tls["utls"] = {"enabled": True, "fingerprint": fp}
            if security == "reality" or public_key:
                tls["reality"] = {"enabled": True, "public_key": public_key}
                if short_id:
                    tls["reality"]["short_id"] = short_id
            outbound["tls"] = tls
        network = _first_query_value(query, "type", "network")
        if network in ("ws", "grpc", "http", "httpupgrade"):
            outbound["transport"] = {"type": network}
            if network == "ws":
                path = _first_query_value(query, "path")
                host = _first_query_value(query, "host")
                if path:
                    outbound["transport"]["path"] = path
                if host:
                    outbound["transport"]["headers"] = {"Host": host}
            if network == "grpc":
                service_name = _first_query_value(query, "serviceName", "service_name")
                if service_name:
                    outbound["transport"]["service_name"] = service_name
        return outbound, []

    if lowered.startswith("trojan://"):
        parsed = urlparse(raw)
        query = parse_qs(parsed.query)
        sni = _first_query_value(query, "sni", "peer", "servername", "serverName")
        outbound = {
            "type": "trojan",
            "tag": "egress",
            "server": parsed.hostname or "",
            "server_port": parsed.port or 0,
            "password": unquote(parsed.username or ""),
        }
        if sni or _first_query_value(query, "security") == "tls":
            outbound["tls"] = {"enabled": True}
            if sni:
                outbound["tls"]["server_name"] = sni
        return outbound, []

    if lowered.startswith("vmess://"):
        body = raw.split("://", 1)[1].split("#", 1)[0].strip()
        try:
            payload = json.loads(_decode_unpadded_base64(body))
        except Exception as exc:
            return None, [f"invalid vmess share: {exc}"]
        try:
            port = int(payload.get("port") or 0)
        except ValueError:
            port = 0
        outbound = {
            "type": "vmess",
            "tag": "egress",
            "server": str(payload.get("add") or ""),
            "server_port": port,
            "uuid": str(payload.get("id") or ""),
            "security": str(payload.get("scy") or "auto"),
        }
        if str(payload.get("tls") or ""):
            outbound["tls"] = {"enabled": True}
            sni = str(payload.get("sni") or payload.get("host") or "")
            if sni:
                outbound["tls"]["server_name"] = sni
        return outbound, []

    if lowered.startswith("ss://"):
        parsed = urlparse(raw)
        server = parsed.hostname or ""
        port = parsed.port or 0
        userinfo = unquote(parsed.username or "")
        if not server:
            body = raw[5:].split("#", 1)[0].split("?", 1)[0]
            decoded = _decode_unpadded_base64(body)
            parsed = urlparse("ss://" + decoded)
            server = parsed.hostname or ""
            port = parsed.port or 0
            userinfo = unquote(parsed.username or "")
        if ":" in userinfo:
            method, password = userinfo.split(":", 1)
        else:
            decoded_userinfo = _decode_unpadded_base64(userinfo) if userinfo else ""
            method, password = decoded_userinfo.split(":", 1) if ":" in decoded_userinfo else ("", "")
        return {
            "type": "shadowsocks",
            "tag": "egress",
            "server": server,
            "server_port": port,
            "method": method,
            "password": password,
        }, []

    return None, ["unsupported proxy share"]


def proxy_outbound_from_config(text):
    raw = str(text or "").strip()
    if raw.startswith("{"):
        try:
            parsed_config = json.loads(raw)
        except json.JSONDecodeError as exc:
            return None, [f"invalid json config: {exc}"]
        outbounds = parsed_config.get("outbounds", []) if isinstance(parsed_config, dict) else []
        outbound = next((item for item in outbounds if isinstance(item, dict) and item.get("type") not in ("direct", "block", "dns")), None)
        if not outbound:
            return None, ["sing-box outbound not found"]
        outbound = dict(outbound)
        outbound["tag"] = "egress"
        return outbound, []
    return parse_proxy_share(raw)


