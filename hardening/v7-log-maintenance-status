#!/usr/bin/env bash
set -u

CONF_FILE="${V7_MAINTENANCE_CONF:-/etc/v7/maintenance.conf}"
BACKUP_KEEP="${V7_BACKUP_KEEP:-10}"
BACKUP_KEEP_DAYS="${V7_BACKUP_KEEP_DAYS:-14}"
JOURNAL_VACUUM_SIZE="${V7_JOURNAL_VACUUM_SIZE:-200M}"
JOURNAL_VACUUM_TIME="${V7_JOURNAL_VACUUM_TIME:-14d}"

load_config() {
  [ -r "$CONF_FILE" ] || return 0
  while IFS='=' read -r key value; do
    key="${key%%#*}"
    value="${value%%#*}"
    key="$(printf '%s' "$key" | tr -d '[:space:]')"
    value="$(printf '%s' "$value" | tr -d '[:space:]')"
    case "$key" in
      V7_BACKUP_KEEP) BACKUP_KEEP="$value" ;;
      V7_BACKUP_KEEP_DAYS) BACKUP_KEEP_DAYS="$value" ;;
      V7_JOURNAL_VACUUM_SIZE) JOURNAL_VACUUM_SIZE="$value" ;;
      V7_JOURNAL_VACUUM_TIME) JOURNAL_VACUUM_TIME="$value" ;;
    esac
  done < "$CONF_FILE"
}

load_config

echo "===== V7 LOG MAINTENANCE STATUS ====="
date -Is
echo "maintenance_config=$CONF_FILE"
echo "backup_keep=$BACKUP_KEEP"
echo "backup_keep_days=$BACKUP_KEEP_DAYS"
echo "journal_vacuum_size=$JOURNAL_VACUUM_SIZE"
echo "journal_vacuum_time=$JOURNAL_VACUUM_TIME"

echo
echo "===== JOURNAL DISK USAGE ====="
journalctl --disk-usage 2>/dev/null || echo "journalctl unavailable"

echo
echo "===== V7 LOG FILES ====="
find /opt/v7 /var/log -type f \( -name '*v7*.log' -o -name '*v7*.jsonl' -o -name 'egress-history.jsonl' \) -printf '%s %p\n' 2>/dev/null | sort -nr | head -n 30 | awk '{printf "%.2f MB %s\n", $1/1024/1024, $2}'

echo
echo "===== LOGROTATE CONFIG ====="
if [ -s /etc/logrotate.d/v7 ]; then
  echo "OK: /etc/logrotate.d/v7 exists"
else
  echo "WARN: /etc/logrotate.d/v7 missing"
fi

echo
echo "===== JOURNAL LIMIT CONFIG ====="
if [ -s /etc/systemd/journald.conf.d/v7-limits.conf ]; then
  echo "OK: /etc/systemd/journald.conf.d/v7-limits.conf exists"
  cat /etc/systemd/journald.conf.d/v7-limits.conf
else
  echo "WARN: /etc/systemd/journald.conf.d/v7-limits.conf missing"
fi
