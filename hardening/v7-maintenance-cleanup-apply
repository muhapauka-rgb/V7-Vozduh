#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="${V7_BACKUP_DIR:-/root/v7-backups}"
KEEP="${V7_BACKUP_KEEP:-10}"
KEEP_DAYS="${V7_BACKUP_KEEP_DAYS:-14}"
JOURNAL_SIZE="${V7_JOURNAL_VACUUM_SIZE:-200M}"
JOURNAL_TIME="${V7_JOURNAL_VACUUM_TIME:-14d}"
CONFIRM=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --confirm)
      CONFIRM="${2:-}"
      shift 2
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [ "$CONFIRM" != "CLEANUP" ]; then
  echo "ERROR: cleanup requires --confirm CLEANUP" >&2
  exit 2
fi
if ! [[ "$KEEP" =~ ^[0-9]+$ ]] || [ "$KEEP" -lt 1 ]; then
  echo "ERROR: V7_BACKUP_KEEP must be a positive integer" >&2
  exit 2
fi
if ! [[ "$KEEP_DAYS" =~ ^[0-9]+$ ]] || [ "$KEEP_DAYS" -lt 1 ]; then
  echo "ERROR: V7_BACKUP_KEEP_DAYS must be a positive integer" >&2
  exit 2
fi

NOW="$(date +%s)"
deleted_count=0
deleted_bytes=0

echo "V7_MAINTENANCE_CLEANUP_APPLY=START"
echo "backup_dir=$BACKUP_DIR"
echo "backup_keep=$KEEP"
echo "backup_keep_days=$KEEP_DAYS"

if [ -d "$BACKUP_DIR" ]; then
  tmp="$(mktemp)"
  find "$BACKUP_DIR" -maxdepth 1 -type f -name 'v7-backup-*.tar.gz' -printf '%T@ %p\n' 2>/dev/null | sort -nr > "$tmp"
  idx=0
  while read -r _ path; do
    [ -n "${path:-}" ] || continue
    case "$path" in
      "$BACKUP_DIR"/v7-backup-*.tar.gz) ;;
      *)
        echo "SKIP: unsafe backup path: $path"
        continue
        ;;
    esac
    idx=$((idx + 1))
    mtime="$(stat -c %Y "$path")"
    age_days="$(( (NOW - mtime) / 86400 ))"
    size="$(stat -c %s "$path")"
    if [ "$idx" -gt "$KEEP" ] && [ "$age_days" -ge "$KEEP_DAYS" ]; then
      base="$(basename "$path")"
      rm -f -- "$path" "$path.sha256"
      deleted_count=$((deleted_count + 1))
      deleted_bytes=$((deleted_bytes + size))
      echo "deleted_backup=$base size_bytes=$size age_days=$age_days"
    fi
  done < "$tmp"
  rm -f "$tmp"
fi

echo "deleted_count=$deleted_count"
echo "deleted_bytes=$deleted_bytes"

if command -v journalctl >/dev/null 2>&1; then
  echo
  echo "===== JOURNAL VACUUM ====="
  journalctl --vacuum-size="$JOURNAL_SIZE" --vacuum-time="$JOURNAL_TIME" || true
fi

if command -v logrotate >/dev/null 2>&1 && [ -s /etc/logrotate.d/v7 ]; then
  echo
  echo "===== LOGROTATE ====="
  logrotate -f /etc/logrotate.d/v7 || true
fi

if command -v v7-audit-log >/dev/null 2>&1; then
  v7-audit-log "maintenance_cleanup_apply" "maintenance" "deleted_count=$deleted_count deleted_bytes=$deleted_bytes journal_size=$JOURNAL_SIZE journal_time=$JOURNAL_TIME" object_type=maintenance object_id=cleanup result=OK >/dev/null 2>&1 || true
fi

echo "V7_MAINTENANCE_CLEANUP_APPLY=OK"
