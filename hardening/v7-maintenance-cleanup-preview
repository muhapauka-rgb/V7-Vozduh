#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="${V7_BACKUP_DIR:-/root/v7-backups}"
KEEP="${V7_BACKUP_KEEP:-10}"
KEEP_DAYS="${V7_BACKUP_KEEP_DAYS:-14}"
JOURNAL_SIZE="${V7_JOURNAL_VACUUM_SIZE:-200M}"
JOURNAL_TIME="${V7_JOURNAL_VACUUM_TIME:-14d}"
NOW="$(date +%s)"

if ! [[ "$KEEP" =~ ^[0-9]+$ ]] || [ "$KEEP" -lt 1 ]; then
  echo "ERROR: V7_BACKUP_KEEP must be a positive integer" >&2
  exit 2
fi
if ! [[ "$KEEP_DAYS" =~ ^[0-9]+$ ]] || [ "$KEEP_DAYS" -lt 1 ]; then
  echo "ERROR: V7_BACKUP_KEEP_DAYS must be a positive integer" >&2
  exit 2
fi

echo "V7_MAINTENANCE_CLEANUP_PREVIEW=OK"
echo "backup_dir=$BACKUP_DIR"
echo "backup_keep=$KEEP"
echo "backup_keep_days=$KEEP_DAYS"
echo "journal_vacuum_size=$JOURNAL_SIZE"
echo "journal_vacuum_time=$JOURNAL_TIME"

echo
echo "===== DISK ====="
df -h / "$BACKUP_DIR" 2>/dev/null || df -h /

echo
echo "===== JOURNAL CURRENT ====="
journalctl --disk-usage 2>/dev/null || echo "journalctl unavailable"
echo "planned_journal_command=journalctl --vacuum-size=$JOURNAL_SIZE --vacuum-time=$JOURNAL_TIME"

echo
echo "===== LOGROTATE ====="
if [ -s /etc/logrotate.d/v7 ]; then
  echo "logrotate_config=OK"
  echo "planned_logrotate_command=logrotate -f /etc/logrotate.d/v7"
else
  echo "logrotate_config=MISSING"
fi

echo
echo "===== BACKUPS ====="
if [ ! -d "$BACKUP_DIR" ]; then
  echo "backup_dir_missing=1"
  exit 0
fi

tmp="$(mktemp)"
find "$BACKUP_DIR" -maxdepth 1 -type f -name 'v7-backup-*.tar.gz' -printf '%T@ %p\n' 2>/dev/null | sort -nr > "$tmp"
count="$(wc -l < "$tmp" | tr -d ' ')"
total_bytes="$(awk '{sum += $1*0; cmd="stat -c %s \"" $2 "\""; cmd | getline s; close(cmd); sum += s} END {printf "%.0f", sum+0}' "$tmp" 2>/dev/null || echo 0)"
echo "backup_count=$count"
echo "backup_total_bytes=$total_bytes"

idx=0
delete_count=0
delete_bytes=0
while read -r _ path; do
  [ -n "${path:-}" ] || continue
  idx=$((idx + 1))
  mtime="$(stat -c %Y "$path")"
  age_days="$(( (NOW - mtime) / 86400 ))"
  size="$(stat -c %s "$path")"
  base="$(basename "$path")"
  decision="KEEP"
  reason="within_retention"
  if [ "$idx" -gt "$KEEP" ] && [ "$age_days" -ge "$KEEP_DAYS" ]; then
    decision="DELETE"
    reason="older_than_keep_and_age"
    delete_count=$((delete_count + 1))
    delete_bytes=$((delete_bytes + size))
  fi
  printf 'backup=%s size_bytes=%s age_days=%s rank=%s decision=%s reason=%s\n' "$base" "$size" "$age_days" "$idx" "$decision" "$reason"
done < "$tmp"
rm -f "$tmp"

echo
echo "planned_delete_count=$delete_count"
echo "planned_delete_bytes=$delete_bytes"
echo "apply_command=v7-maintenance-cleanup-apply --confirm CLEANUP"
