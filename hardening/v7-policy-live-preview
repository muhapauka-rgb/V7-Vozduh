#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
ROUTE_CLASSES_REG="${V7_ROUTE_CLASSES_REG:-/opt/v7/policy/route-classes.registry}"
EGRESS_REG="${V7_EGRESS_REGISTRY:-$STATE_DIR/egress.registry}"
VPN_SUBNET="${V7_VPN_SUBNET:-10.0.0.0/24}"
PUBLIC_IF="${V7_PUBLIC_IF:-ens3}"
LIB="${V7_EGRESS_LIB:-/usr/local/lib/v7-egress-lib}"
[ -r "$LIB" ] && . "$LIB"
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
  VPN_SUBNET="${V7_VPN_SUBNET:-$VPN_SUBNET}"
  PUBLIC_IF="${V7_PUBLIC_IF:-$PUBLIC_IF}"
fi

result="OK"

echo "===== V7 POLICY LIVE PREVIEW ====="
date -Is
echo "mode=read_only"
echo "vpn_subnet=$VPN_SUBNET"
echo "public_if=$PUBLIC_IF"
echo "route_classes=$ROUTE_CLASSES_REG"
echo

[ -r "$ROUTE_CLASSES_REG" ] || { echo "ERROR: missing route classes registry"; exit 1; }

while IFS= read -r line || [ -n "$line" ]; do
  [ -n "$line" ] || continue
  case "$line" in \#*) continue ;; esac
  class="$(v7_kv_get "$line" id)"
  enabled="$(v7_kv_get "$line" enabled)"
  mark="$(v7_kv_get "$line" mark)"
  table="$(v7_kv_get "$line" table)"
  mode="$(v7_kv_get "$line" mode)"
  active="$(v7_kv_get "$line" active_egress)"
  temporary="$(v7_kv_get "$line" temporary)"
  [ "${enabled:-1}" = "1" ] || continue

  echo "class=$class mode=$mode mark=$mark table=$table active_egress=$active temporary=${temporary:-0}"
  case "$class" in
    TRUSTED_RU_SENSITIVE)
      if [ "${temporary:-0}" = "1" ]; then
        echo "  BLOCKED: trusted RU route is temporary"
        result="BLOCKED"
      fi
      ;;
  esac

  if [ "$mode" = "direct" ]; then
    echo "  nft_allow_public_if_for_class=$class"
    echo "  route_would_add=ip route replace default dev $PUBLIC_IF table $table"
  elif [ "$mode" = "egress" ] && [ -n "$active" ] && [ "$active" != "user_default" ]; then
    iface="$(v7_egress_interface "$active" || true)"
    if [ -z "$iface" ]; then
      echo "  BLOCKED: active egress has no interface"
      result="BLOCKED"
    else
      echo "  nft_allow_egress_if=$iface"
      echo "  route_would_add=ip route replace default dev $iface table $table"
    fi
  else
    echo "  route_would_use=existing_per_user_tables"
  fi
  if [ -n "$mark" ] && [ -n "$table" ]; then
    echo "  ip_rule_would_add=ip rule add fwmark $mark lookup $table"
  fi
done < "$ROUTE_CLASSES_REG"

echo
echo "===== SAFETY ====="
echo "ssh_lockout_guard=required"
echo "nft_backup_required=yes"
echo "rollback_required=yes"
echo "live_apply_available=no"
echo "V7_POLICY_LIVE_PREVIEW=$result"
[ "$result" != "FAIL" ]
