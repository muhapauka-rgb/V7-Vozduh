#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
OUT_STATE="${V7_POLICY_DOMAIN_MATRIX_STATE:-$STATE_DIR/policy-domain-matrix.state}"
USER_IP="${V7_POLICY_MATRIX_USER_IP:-10.0.0.3}"
WRITE_STATE=0

usage() {
  cat <<USAGE
Usage: v7-policy-matrix [--write-state] [--user-ip 10.0.0.3] [domain ...]

Runs a read-only service-aware policy matrix:
domain -> route class -> direct engine -> desired path.
USAGE
}

domains=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --write-state) WRITE_STATE=1; shift ;;
    --user-ip) USER_IP="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) echo "ERROR: unknown argument: $1" >&2; usage; exit 1 ;;
    *) domains+=("$1"); shift ;;
  esac
done
while [ "$#" -gt 0 ]; do
  domains+=("$1")
  shift
done

if [ "${#domains[@]}" -eq 0 ]; then
  domains=(
    "www.gosuslugi.ru"
    "esia.gosuslugi.ru"
    "alfa-mobile.alfabank.ru"
    "groupib-am.alfabank.ru"
    "pushserver.edna.id"
    "yandex.ru"
    "ya.ru"
    "ozon.ru"
    "youtube.com"
    "telegram.org"
  )
fi

safe_domain() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g; s/[.]$//'
}

last_kv() {
  local key="$1"
  awk -F= -v key="$key" '$1 == key { value=$2 } END { print value }'
}

direct_summary_from_output() {
  local text="$1"
  if printf '%s\n' "$text" | grep -q '^decision=VPN_PREFERRED_DIRECT_EXCLUDED$'; then
    echo "vpn_preferred_excluded"
  elif printf '%s\n' "$text" | grep -q '^decision=DIRECT_READY$'; then
    echo "direct_ready"
  elif printf '%s\n' "$text" | grep -q '^decision=DNS_EMPTY$'; then
    echo "dns_empty"
  else
    echo "unknown"
  fi
}

note_for() {
  local class="$1" direct="$2" desired="$3"
  if [ "$class" = "TRUSTED_RU_SENSITIVE" ] && [ "$direct" = "direct_ready" ]; then
    echo "policy_overrides_broad_direct"
  elif [ "$class" = "DIRECT_RU" ] && [ "$direct" = "direct_ready" ]; then
    echo "ordinary_ru_direct"
  elif [ "$desired" = "user_current" ] || [ "$desired" = "user_default" ]; then
    echo "sticky_user_default"
  else
    echo "check"
  fi
}

tmp_state="${OUT_STATE}.tmp.$$"
if [ "$WRITE_STATE" -eq 1 ]; then
  mkdir -p "$(dirname "$OUT_STATE")"
  {
    echo "updated=$(date -Is)"
    echo "user_ip=$USER_IP"
  } > "$tmp_state"
fi

echo "===== V7 POLICY DOMAIN MATRIX ====="
date -Is
echo "user_ip=$USER_IP"
echo
printf '%-32s %-22s %-12s %-22s %-22s %s\n' "DOMAIN" "CLASS" "MODE" "DESIRED_PATH" "DIRECT_ENGINE" "NOTE"

idx=0
for raw_domain in "${domains[@]}"; do
  domain="$(safe_domain "$raw_domain")"
  [ -n "$domain" ] || continue
  idx=$((idx + 1))
  output="$(v7-policy-test-domain "$domain" "$USER_IP" 2>&1 || true)"
  class="$(printf '%s\n' "$output" | last_kv route_class)"
  mode="$(printf '%s\n' "$output" | last_kv mode)"
  desired="$(printf '%s\n' "$output" | last_kv desired_path)"
  direct="$(direct_summary_from_output "$output")"
  note="$(note_for "$class" "$direct" "$desired")"

  printf '%-32s %-22s %-12s %-22s %-22s %s\n' "$domain" "${class:-unknown}" "${mode:-unknown}" "${desired:-unknown}" "$direct" "$note"

  if [ "$WRITE_STATE" -eq 1 ]; then
    {
      echo "item_${idx}_domain=$domain"
      echo "item_${idx}_class=${class:-unknown}"
      echo "item_${idx}_mode=${mode:-unknown}"
      echo "item_${idx}_desired_path=${desired:-unknown}"
      echo "item_${idx}_direct_engine=$direct"
      echo "item_${idx}_note=$note"
    } >> "$tmp_state"
  fi
done

echo
echo "V7_POLICY_MATRIX=OK"

if [ "$WRITE_STATE" -eq 1 ]; then
  echo "count=$idx" >> "$tmp_state"
  mv "$tmp_state" "$OUT_STATE"
  echo "matrix_state=$OUT_STATE"
fi
