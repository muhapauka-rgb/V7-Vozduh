#!/usr/bin/env bash
set -u

ROOT="${V7_PROXY_INBOUND_RUNTIME_ROOT:-/etc/v7/inbound-runtime}"
BACKUP_ROOT="${V7_BACKUP_ROOT:-/root/v7-install-backups}"

INBOUND_ID="happ-test"
APPLY=0
CONFIRM=""

usage() {
  cat <<'USAGE'
Usage:
  v7-proxy-inbound-render-disabled [options]

Options:
  --inbound-id NAME          Inbound draft id. Default: happ-test
  --apply                    Write rendered disabled config. Preview only without it.
  --confirm RENDER_PROXY_INBOUND_DISABLED
                             Required with --apply.

Renders disabled proxy identity bindings into the sing-box inbound users[] list.
The rendered profile stays disabled operationally: route.final remains block,
no service is started, no port is opened, and V7 routing/firewall are unchanged.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --inbound-id) INBOUND_ID="${2:-}"; shift 2 ;;
    --apply) APPLY=1; shift ;;
    --confirm) CONFIRM="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "ERROR: unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

safe_name() {
  printf '%s' "$1" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//'
}

INBOUND_ID="$(safe_name "$INBOUND_ID")"
if [ -z "$INBOUND_ID" ]; then
  echo "ERROR: invalid inbound id" >&2
  exit 2
fi

TARGET_DIR="$ROOT/$INBOUND_ID"
CONFIG_PATH="$TARGET_DIR/sing-box.json"
META_PATH="$TARGET_DIR/metadata.json"
BIND_DIR="$TARGET_DIR/bindings"

if [ ! -r "$META_PATH" ]; then
  echo "ERROR: inbound draft metadata missing: $META_PATH" >&2
  exit 1
fi
if [ ! -d "$BIND_DIR" ]; then
  echo "ERROR: bindings directory missing: $BIND_DIR" >&2
  exit 1
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
CONFIG_TMP="$TMP_DIR/sing-box.json"
META_TMP="$TMP_DIR/metadata.json"
SUMMARY_TMP="$TMP_DIR/summary.env"
UPDATED_BIND_DIR="$TMP_DIR/bindings"
mkdir -p "$UPDATED_BIND_DIR"

python3 - "$INBOUND_ID" "$TARGET_DIR" "$CONFIG_TMP" "$META_TMP" "$SUMMARY_TMP" "$UPDATED_BIND_DIR" <<'PY'
import json
import re
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

inbound_id, target_dir, config_tmp, meta_tmp, summary_tmp, updated_bind_dir = sys.argv[1:]
target = Path(target_dir)
meta_path = target / "metadata.json"
bind_dir = target / "bindings"

def fail(message, code=1):
    print(f"ERROR: {message}", file=sys.stderr)
    raise SystemExit(code)

def safe_user_name(value):
    return re.sub(r"[^A-Za-z0-9_.-]+", "-", value).strip("-")[:64] or "user"

def redact_uuid(value):
    if len(value) <= 12:
        return "redacted"
    return f"{value[:8]}...{value[-4:]}"

try:
    metadata = json.loads(meta_path.read_text())
except Exception as exc:
    fail(f"cannot read metadata json: {exc}")

listen = metadata.get("listen", "127.0.0.1")
port = metadata.get("port")
protocol = metadata.get("protocol", "vless")
runtime = metadata.get("runtime", "sing-box")
status = metadata.get("status", "")

if protocol != "vless":
    fail(f"unsupported proxy inbound protocol: {protocol}")
if runtime != "sing-box":
    fail(f"unsupported runtime: {runtime}")
if status not in ("draft_disabled", "rendered_disabled"):
    fail(f"unsafe inbound status for render: {status}")
if listen not in ("127.0.0.1", "0.0.0.0", "::1"):
    fail(f"unsupported listen address: {listen}")
if not isinstance(port, int) or port < 1 or port > 65535:
    fail(f"invalid listen port: {port}")

users = []
updated_bindings = []
binding_files = sorted(bind_dir.glob("user-*.json"))
for path in binding_files:
    try:
        binding = json.loads(path.read_text())
    except Exception as exc:
        fail(f"cannot read binding {path.name}: {exc}")
    if binding.get("inbound_id") != inbound_id:
        fail(f"binding inbound mismatch: {path.name}")
    if binding.get("status") != "binding_disabled":
        fail(f"binding is not disabled: {path.name}")
    if binding.get("proxy_protocol", "vless") != "vless":
        fail(f"unsupported binding protocol: {path.name}")
    proxy_uuid = str(binding.get("proxy_uuid", ""))
    try:
        uuid.UUID(proxy_uuid)
    except Exception:
        fail(f"invalid proxy uuid in binding: {path.name}")
    user_ip = str(binding.get("user_ip", ""))
    route_table = binding.get("route_table")
    if not re.match(r"^\d{1,3}(\.\d{1,3}){3}$", user_ip):
        fail(f"invalid user ip in binding: {path.name}")
    if not isinstance(route_table, int):
        fail(f"invalid route table in binding: {path.name}")
    client = safe_user_name(str(binding.get("client", "proxy")))
    user_name = safe_user_name(f"v7-{user_ip}-{client}")
    users.append({"uuid": proxy_uuid, "name": user_name})
    binding["included_in_runtime_config"] = True
    binding["rendered_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    binding["runtime_route_final"] = "block"
    updated_path = Path(updated_bind_dir) / path.name
    updated_path.write_text(json.dumps(binding, ensure_ascii=True, indent=2) + "\n")
    updated_bindings.append({
        "file": path.name,
        "user_ip": user_ip,
        "route_table": route_table,
        "client": client,
        "uuid_redacted": redact_uuid(proxy_uuid),
    })

if not users:
    fail("no disabled identity bindings found")

rendered_at = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
config = {
    "log": {
        "level": "info",
        "timestamp": True,
    },
    "inbounds": [
        {
            "type": "vless",
            "tag": f"v7-{inbound_id}-in",
            "listen": listen,
            "listen_port": port,
            "users": users,
        }
    ],
    "outbounds": [
        {
            "type": "block",
            "tag": "block",
        }
    ],
    "route": {
        "final": "block",
    },
}

metadata["schema"] = "v7-proxy-inbound-draft/v1"
metadata["status"] = "rendered_disabled"
metadata["last_rendered_at"] = rendered_at
metadata["rendered_bindings"] = len(users)
metadata["runtime_users_rendered"] = True
metadata["traffic_policy"] = "block_until_route_policy_mapping_is_implemented"
metadata["live_changes"] = False
metadata["starts_service"] = False
metadata["opens_firewall"] = False
metadata["moves_users"] = False
metadata["changes_routing"] = False
metadata["route_final"] = "block"
metadata["required_next_steps"] = [
    "isolated_loopback_runtime_test",
    "policy_route_mapping",
    "kill_switch_leak_test",
    "operator_enable_guard",
]

Path(config_tmp).write_text(json.dumps(config, ensure_ascii=True, indent=2) + "\n")
Path(meta_tmp).write_text(json.dumps(metadata, ensure_ascii=True, indent=2) + "\n")

summary_lines = [
    f"inbound_id={inbound_id}",
    f"listen={listen}",
    f"port={port}",
    f"binding_count={len(users)}",
    "route_final=block",
    "live_changes=no",
    "starts_service=no",
    "opens_firewall=no",
    "changes_routing=no",
]
for item in updated_bindings:
    summary_lines.append(
        "binding="
        + f"{item['file']}:user_ip={item['user_ip']}:table={item['route_table']}:client={item['client']}:uuid={item['uuid_redacted']}"
    )
Path(summary_tmp).write_text("\n".join(summary_lines) + "\n")
PY

echo "===== V7 PROXY INBOUND RENDER DISABLED ====="
date -u +"%Y-%m-%dT%H:%M:%SZ"
cat "$SUMMARY_TMP"
printf 'config_path=%s\n' "$CONFIG_PATH"
printf 'metadata_path=%s\n' "$META_PATH"
printf 'mode=%s\n' "$([ "$APPLY" = "1" ] && echo apply || echo preview)"

echo
echo "===== VALIDATION ====="
if python3 -m json.tool "$CONFIG_TMP" >/dev/null; then
  echo "config_json=OK"
else
  echo "config_json=FAIL"
  exit 1
fi
if python3 -m json.tool "$META_TMP" >/dev/null; then
  echo "metadata_json=OK"
else
  echo "metadata_json=FAIL"
  exit 1
fi
for binding_file in "$UPDATED_BIND_DIR"/*.json; do
  if [ -e "$binding_file" ]; then
    if python3 -m json.tool "$binding_file" >/dev/null; then
      printf 'binding_json=OK:%s\n' "$(basename "$binding_file")"
    else
      printf 'binding_json=FAIL:%s\n' "$(basename "$binding_file")"
      exit 1
    fi
  fi
done

if command -v sing-box >/dev/null 2>&1; then
  check_out="$TMP_DIR/sing-box-check.out"
  if sing-box check -c "$CONFIG_TMP" >"$check_out" 2>&1; then
    echo "sing_box_check=OK"
  else
    echo "sing_box_check=FAIL"
    sed 's/^/sing_box_check_output=/' "$check_out"
    exit 1
  fi
else
  echo "sing_box_check=SKIPPED"
  echo "WARN: sing-box command missing"
fi

port="$(awk -F= '$1=="port" {print $2; exit}' "$SUMMARY_TMP")"
tcp_conflict="$(ss -lntH 2>/dev/null | awk -v p=":$port" '$4 ~ p "$" {print}')"
if [ -n "$tcp_conflict" ]; then
  echo "listener_check=WARN"
  printf '%s\n' "$tcp_conflict" | sed 's/^/tcp_listener=/'
else
  echo "listener_check=OK"
fi

if [ "$APPLY" != "1" ]; then
  echo
  echo "===== RESULT ====="
  echo "V7_PROXY_INBOUND_RENDER_PREVIEW=OK"
  echo "next=run_with_apply_and_confirm_to_write_rendered_disabled_config"
  exit 0
fi

if [ "$CONFIRM" != "RENDER_PROXY_INBOUND_DISABLED" ]; then
  echo "ERROR: --apply requires --confirm RENDER_PROXY_INBOUND_DISABLED" >&2
  exit 2
fi

echo
echo "===== APPLY ====="
umask 077
mkdir -p "$TARGET_DIR" "$BIND_DIR"
stamp="$(date +%Y%m%d-%H%M%S)"
backup_dir="$BACKUP_ROOT/proxy-inbound-render-$INBOUND_ID-$stamp"
mkdir -p "$backup_dir"
if [ -e "$CONFIG_PATH" ]; then
  cp -a "$CONFIG_PATH" "$backup_dir/sing-box.json"
fi
if [ -e "$META_PATH" ]; then
  cp -a "$META_PATH" "$backup_dir/metadata.json"
fi
if [ -d "$BIND_DIR" ]; then
  mkdir -p "$backup_dir/bindings"
  find "$BIND_DIR" -maxdepth 1 -type f -name '*.json' -exec cp -a {} "$backup_dir/bindings/" \;
fi
install -m 600 "$CONFIG_TMP" "$CONFIG_PATH"
install -m 600 "$META_TMP" "$META_PATH"
for binding_file in "$UPDATED_BIND_DIR"/*.json; do
  [ -e "$binding_file" ] || continue
  install -m 600 "$binding_file" "$BIND_DIR/$(basename "$binding_file")"
done
printf 'backup_dir=%s\n' "$backup_dir"
printf 'written_config=%s\n' "$CONFIG_PATH"
printf 'written_metadata=%s\n' "$META_PATH"
printf 'updated_bindings=%s\n' "$(find "$UPDATED_BIND_DIR" -maxdepth 1 -type f -name '*.json' | wc -l | tr -d ' ')"

echo
echo "===== RESULT ====="
echo "V7_PROXY_INBOUND_RENDER_DISABLED=OK"
echo "status=rendered_disabled"
echo "route_final=block"
echo "next=isolated_loopback_runtime_test"
