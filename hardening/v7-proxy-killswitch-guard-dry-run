#!/usr/bin/env bash
set -u

ROOT="${V7_PROXY_INBOUND_RUNTIME_ROOT:-/etc/v7/inbound-runtime}"
STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
EGRESS_REG="${V7_EGRESS_REGISTRY:-$STATE_DIR/egress.registry}"
INBOUND_ID="happ-test"
PUBLIC_IF="${V7_PUBLIC_IF:-ens3}"
RUNTIME_USER="${V7_PROXY_RUNTIME_USER:-v7proxy}"
NFT_TABLE="${V7_KILLSWITCH_NFT_TABLE:-inet v7_killswitch}"

usage() {
  cat <<'USAGE'
Usage:
  v7-proxy-killswitch-guard-dry-run [options]

Options:
  --inbound-id NAME          Inbound id. Default: happ-test
  --runtime-user USER        Future proxy runtime user. Default: v7proxy

Builds a read-only kill-switch guard plan for proxy inbound traffic.

WireGuard users are protected in the nftables forward path. Proxy inbound
traffic is generated by a local sing-box process, so the future guard must
protect the nftables output path too:

  runtime process user -> allow approved egress interfaces -> drop public if

This command does not write files, change nftables, start services, open ports,
change routing, or move users.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --inbound-id) INBOUND_ID="${2:-}"; shift 2 ;;
    --runtime-user) RUNTIME_USER="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "ERROR: unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

safe_name() {
  printf '%s' "$1" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//'
}

INBOUND_ID="$(safe_name "$INBOUND_ID")"
RUNTIME_USER="$(safe_name "$RUNTIME_USER")"
if [ -z "$INBOUND_ID" ] || [ -z "$RUNTIME_USER" ]; then
  echo "ERROR: invalid inbound id or runtime user" >&2
  exit 2
fi

LIB="/usr/local/lib/v7-egress-lib"
if [ -r "$LIB" ]; then
  # shellcheck disable=SC1090
  . "$LIB"
fi
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
  PUBLIC_IF="${V7_PUBLIC_IF:-$PUBLIC_IF}"
fi

TARGET_DIR="$ROOT/$INBOUND_ID"
CONFIG_PATH="$TARGET_DIR/sing-box.json"
META_PATH="$TARGET_DIR/metadata.json"
BIND_DIR="$TARGET_DIR/bindings"

echo "===== V7 PROXY KILL SWITCH GUARD DRY RUN ====="
date -u +"%Y-%m-%dT%H:%M:%SZ"
printf 'inbound_id=%s\n' "$INBOUND_ID"
printf 'runtime_dir=%s\n' "$TARGET_DIR"
printf 'public_if=%s\n' "$PUBLIC_IF"
printf 'runtime_user=%s\n' "$RUNTIME_USER"
printf 'nft_table=%s\n' "$NFT_TABLE"
echo "mode=read_only"
echo "live_changes=no"

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required" >&2
  exit 1
fi
if [ ! -r "$META_PATH" ]; then
  echo "ERROR: metadata missing: $META_PATH" >&2
  exit 1
fi
if [ ! -r "$CONFIG_PATH" ]; then
  echo "ERROR: config missing: $CONFIG_PATH" >&2
  exit 1
fi
if [ ! -d "$BIND_DIR" ]; then
  echo "ERROR: bindings directory missing: $BIND_DIR" >&2
  exit 1
fi
if [ ! -r "$EGRESS_REG" ]; then
  echo "ERROR: egress registry missing: $EGRESS_REG" >&2
  exit 1
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
NFT_TABLE_OUT="$TMP_DIR/nft-table.txt"
LINKS_OUT="$TMP_DIR/ip-links.txt"
LISTENERS_OUT="$TMP_DIR/listeners.txt"
PASSWD_OUT="$TMP_DIR/passwd.txt"
SUMMARY_JSON="$TMP_DIR/summary.json"

nft list table $NFT_TABLE >"$NFT_TABLE_OUT" 2>/dev/null || true
ip -o link show >"$LINKS_OUT" 2>/dev/null || true
ss -lntH >"$LISTENERS_OUT" 2>/dev/null || true
getent passwd "$RUNTIME_USER" >"$PASSWD_OUT" 2>/dev/null || true

python3 - "$INBOUND_ID" "$TARGET_DIR" "$EGRESS_REG" "$PUBLIC_IF" "$RUNTIME_USER" "$NFT_TABLE" "$NFT_TABLE_OUT" "$LINKS_OUT" "$LISTENERS_OUT" "$PASSWD_OUT" "$SUMMARY_JSON" <<'PY'
import json
import re
import sys
import uuid
from pathlib import Path

(
    inbound_id,
    target_dir,
    egress_reg,
    public_if,
    runtime_user,
    nft_table,
    nft_table_out,
    links_out,
    listeners_out,
    passwd_out,
    summary_json,
) = sys.argv[1:]

target = Path(target_dir)
meta_path = target / "metadata.json"
config_path = target / "sing-box.json"
bind_dir = target / "bindings"

def fail(message):
    print(f"ERROR: {message}", file=sys.stderr)
    raise SystemExit(1)

def read_json(path):
    try:
        return json.loads(path.read_text())
    except Exception as exc:
        fail(f"cannot read json {path}: {exc}")

def parse_registry(path):
    rows = []
    for raw in Path(path).read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        item = {"_raw": line}
        for part in line.split():
            if "=" in part:
                key, value = part.split("=", 1)
                item[key] = value
        rows.append(item)
    return rows

def iface_exists(links, iface):
    pattern = re.compile(rf"^\d+:\s+{re.escape(iface)}[@:]")
    return any(pattern.search(row) for row in links)

def listener_on_port(listeners, port):
    suffix = f":{port}"
    return [row for row in listeners if row.split() and row.split()[3].endswith(suffix)]

def safe_rule_text(value):
    return re.sub(r"[^A-Za-z0-9_.:-]+", "_", value)

meta = read_json(meta_path)
config = read_json(config_path)
egresses = parse_registry(egress_reg)
nft_text = Path(nft_table_out).read_text(errors="ignore")
links = Path(links_out).read_text(errors="ignore").splitlines()
listeners = Path(listeners_out).read_text(errors="ignore").splitlines()
runtime_user_passwd = Path(passwd_out).read_text(errors="ignore").strip()

runtime_status = str(meta.get("status", ""))
listen = str(meta.get("listen", ""))
port = meta.get("port")
route_final = (config.get("route") or {}).get("final")
bindings = []
for path in sorted(bind_dir.glob("user-*.json")):
    bindings.append((path.name, read_json(path)))

blockers = []
warnings = []
required_before_live = []

if runtime_status != "rendered_disabled":
    blockers.append(f"runtime_status_not_rendered_disabled:{runtime_status}")
if listen != "127.0.0.1":
    blockers.append(f"listen_not_loopback:{listen}")
if route_final != "block":
    blockers.append(f"route_final_not_block:{route_final}")
if not isinstance(port, int):
    blockers.append("port_invalid")
if not bindings:
    blockers.append("no_bindings")

public_listeners = listener_on_port(listeners, port) if isinstance(port, int) else []
public_listeners = [row for row in public_listeners if not row.split()[3].startswith("127.0.0.1:")]
if public_listeners:
    blockers.append("public_listener_present")

egress_by_id = {row.get("id"): row for row in egresses if row.get("id")}
allowed_ifaces = []
for filename, binding in bindings:
    proxy_uuid = str(binding.get("proxy_uuid", ""))
    try:
        uuid.UUID(proxy_uuid)
    except Exception:
        blockers.append(f"{filename}:invalid_proxy_uuid")
    current_egress = str(binding.get("current_egress", ""))
    egress = egress_by_id.get(current_egress)
    if not egress:
        blockers.append(f"{filename}:egress_missing:{current_egress}")
        continue
    if egress.get("enabled") != "1":
        blockers.append(f"{filename}:egress_disabled:{current_egress}")
    iface = egress.get("interface", "")
    if not iface:
        blockers.append(f"{filename}:egress_interface_missing:{current_egress}")
        continue
    if not iface_exists(links, iface):
        blockers.append(f"{filename}:egress_interface_not_live:{iface}")
    if iface not in allowed_ifaces:
        allowed_ifaces.append(iface)

proxy_allow_guard_present = "V7 proxy allow egress interface" in nft_text
proxy_loopback_allow_present = "V7 proxy allow loopback" in nft_text
proxy_tunnel_endpoint_allow_present = "V7 proxy allow egress tunnel endpoint" in nft_text
proxy_public_drop_present = "V7 proxy block public leak" in nft_text
proxy_default_drop_present = "V7 proxy block non-approved output" in nft_text
proxy_any_skuid_guard_present = (
    f"meta skuid \"{runtime_user}\"" in nft_text
    or f"skuid {runtime_user}" in nft_text
    or (proxy_allow_guard_present and proxy_public_drop_present and proxy_default_drop_present)
)

if not runtime_user_passwd:
    required_before_live.append(f"create_runtime_user:{runtime_user}")
if not proxy_any_skuid_guard_present:
    required_before_live.append("add_nft_output_skuid_guard")
if not proxy_loopback_allow_present:
    required_before_live.append("add_nft_output_allow_loopback_for_proxy_runtime_user")
if not proxy_allow_guard_present:
    required_before_live.append("add_nft_output_allow_rules_for_proxy_runtime_user")
if not proxy_tunnel_endpoint_allow_present:
    required_before_live.append("add_nft_output_allow_egress_tunnel_endpoint_for_proxy_runtime_user")
if not proxy_public_drop_present:
    required_before_live.append("add_nft_output_drop_public_rule_for_proxy_runtime_user")
if public_if in allowed_ifaces:
    blockers.append("public_interface_is_listed_as_allowed_egress")

guard_rules = []
guard_rules.append(
    f'insert rule {nft_table} output meta skuid "{runtime_user}" oifname "lo" counter accept comment "V7 proxy allow loopback"'
)
for iface in allowed_ifaces:
    guard_rules.append(
        f'add rule {nft_table} output meta skuid "{runtime_user}" oifname "{safe_rule_text(iface)}" counter accept comment "V7 proxy allow egress interface"'
    )
guard_rules.append(
    f'add rule {nft_table} output meta skuid "{runtime_user}" oifname "{safe_rule_text(public_if)}" counter drop comment "V7 proxy block public leak"'
)
guard_rules.append(
    f'add rule {nft_table} output meta skuid "{runtime_user}" counter drop comment "V7 proxy block non-approved output"'
)

print()
print("===== CURRENT GUARD STATE =====")
print(f"runtime_status={runtime_status}")
print(f"listen={listen}")
print(f"port={port}")
print(f"route_final={route_final}")
print(f"bindings={len(bindings)}")
print(f"allowed_egress_interfaces={','.join(allowed_ifaces) if allowed_ifaces else 'none'}")
print(f"runtime_user_exists={'yes' if runtime_user_passwd else 'no'}")
print(f"nft_table_present={'yes' if nft_text.strip() else 'no'}")
print(f"proxy_output_guard_present={'yes' if proxy_public_drop_present else 'no'}")
print(f"proxy_output_loopback_allow_present={'yes' if proxy_loopback_allow_present else 'no'}")
print(f"proxy_output_tunnel_endpoint_allow_present={'yes' if proxy_tunnel_endpoint_allow_present else 'no'}")
print(f"proxy_output_allow_present={'yes' if proxy_allow_guard_present else 'no'}")
print(f"proxy_output_default_drop_present={'yes' if proxy_default_drop_present else 'no'}")
print(f"public_listener={'present' if public_listeners else 'none'}")

print()
print("===== REQUIRED BEFORE LIVE =====")
if required_before_live:
    for item in required_before_live:
        print(f"required={item}")
else:
    print("required=none")

print()
print("===== FUTURE NFT PLAN =====")
print("would_change_nft=no")
print("would_start_service=no")
print("would_open_firewall=no")
print("would_change_routing=no")
print("would_move_users=no")
print("would_require_backup=yes")
print("would_require_ssh_lockout_guard=yes")
for rule in guard_rules:
    print(f"nft_would_add={rule}")

summary = {
    "inbound_id": inbound_id,
    "runtime_status": runtime_status,
    "listen": listen,
    "port": port,
    "route_final": route_final,
    "allowed_egress_interfaces": allowed_ifaces,
    "public_interface": public_if,
    "runtime_user": runtime_user,
    "runtime_user_exists": bool(runtime_user_passwd),
    "proxy_output_guard_present": proxy_public_drop_present,
    "proxy_output_loopback_allow_present": proxy_loopback_allow_present,
    "proxy_output_tunnel_endpoint_allow_present": proxy_tunnel_endpoint_allow_present,
    "proxy_output_allow_present": proxy_allow_guard_present,
    "proxy_output_default_drop_present": proxy_default_drop_present,
    "required_before_live": required_before_live,
    "guard_rules": guard_rules,
    "blockers": blockers,
    "warnings": warnings,
    "live_enable": "BLOCKED",
    "next": "proxy_public_enable_guard_dry_run",
}
Path(summary_json).write_text(json.dumps(summary, ensure_ascii=True, indent=2) + "\n")

print()
print("===== RESULT =====")
if blockers:
    print("V7_PROXY_KILLSWITCH_GUARD_DRY_RUN=BLOCKED")
else:
    print("V7_PROXY_KILLSWITCH_GUARD_DRY_RUN=OK")
print(f"blockers={len(blockers)}")
for item in blockers:
    print(f"blocker={item}")
print(f"warnings={len(warnings)}")
for item in warnings:
    print(f"warning={item}")
print(f"required_before_live={len(required_before_live)}")
for item in required_before_live:
    print(f"required_before_live_item={item}")
print("live_enable=BLOCKED")
print("next=proxy_public_enable_guard_dry_run")
print("technical_json=" + json.dumps(summary, ensure_ascii=True, sort_keys=True))
raise SystemExit(0 if not blockers else 1)
PY
