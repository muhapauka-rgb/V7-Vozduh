#!/usr/bin/env bash
set -u

ROOT="${V7_PROXY_INBOUND_RUNTIME_ROOT:-/etc/v7/inbound-runtime}"
STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
USERS_REG="${V7_USERS_REGISTRY:-$STATE_DIR/users.registry}"
EGRESS_REG="${V7_EGRESS_REGISTRY:-$STATE_DIR/egress.registry}"
INBOUND_ID="happ-test"

usage() {
  cat <<'USAGE'
Usage:
  v7-proxy-policy-runtime-adapter-dry-run [options]

Options:
  --inbound-id NAME          Inbound id. Default: happ-test

Builds and validates a temporary sing-box runtime adapter candidate:

  authenticated proxy user name -> sing-box auth_user route rule -> direct outbound bound to V7 egress interface

This is read-only. It does not write runtime files, start services, open ports,
change firewall/kill switch, change routing, or move users.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --inbound-id) INBOUND_ID="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "ERROR: unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

safe_name() {
  printf '%s' "$1" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//'
}

INBOUND_ID="$(safe_name "$INBOUND_ID")"
if [ -z "$INBOUND_ID" ]; then
  echo "ERROR: invalid inbound id" >&2
  exit 2
fi

TARGET_DIR="$ROOT/$INBOUND_ID"
CONFIG_PATH="$TARGET_DIR/sing-box.json"
META_PATH="$TARGET_DIR/metadata.json"
BIND_DIR="$TARGET_DIR/bindings"

echo "===== V7 PROXY POLICY RUNTIME ADAPTER DRY RUN ====="
date -u +"%Y-%m-%dT%H:%M:%SZ"
printf 'inbound_id=%s\n' "$INBOUND_ID"
printf 'runtime_dir=%s\n' "$TARGET_DIR"
printf 'users_registry=%s\n' "$USERS_REG"
printf 'egress_registry=%s\n' "$EGRESS_REG"
echo "mode=read_only"
echo "live_changes=no"

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required" >&2
  exit 1
fi
if ! command -v sing-box >/dev/null 2>&1; then
  echo "ERROR: sing-box is required" >&2
  exit 1
fi
if [ ! -r "$META_PATH" ]; then
  echo "ERROR: metadata missing: $META_PATH" >&2
  exit 1
fi
if [ ! -r "$CONFIG_PATH" ]; then
  echo "ERROR: config missing: $CONFIG_PATH" >&2
  exit 1
fi
if [ ! -d "$BIND_DIR" ]; then
  echo "ERROR: bindings directory missing: $BIND_DIR" >&2
  exit 1
fi
if [ ! -r "$USERS_REG" ]; then
  echo "ERROR: users registry missing: $USERS_REG" >&2
  exit 1
fi
if [ ! -r "$EGRESS_REG" ]; then
  echo "ERROR: egress registry missing: $EGRESS_REG" >&2
  exit 1
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
CANDIDATE_CONFIG="$TMP_DIR/sing-box-policy-adapter-candidate.json"
SUMMARY_JSON="$TMP_DIR/summary.json"
IP_RULES="$TMP_DIR/ip-rules.txt"
LINKS="$TMP_DIR/ip-links.txt"
LISTENERS="$TMP_DIR/listeners.txt"

ip rule >"$IP_RULES" 2>/dev/null || true
ip -o link show >"$LINKS" 2>/dev/null || true
ss -lntH >"$LISTENERS" 2>/dev/null || true

python3 - "$INBOUND_ID" "$TARGET_DIR" "$USERS_REG" "$EGRESS_REG" "$IP_RULES" "$LINKS" "$LISTENERS" "$CANDIDATE_CONFIG" "$SUMMARY_JSON" <<'PY'
import json
import re
import sys
import uuid
from pathlib import Path

(
    inbound_id,
    target_dir,
    users_reg,
    egress_reg,
    ip_rules_path,
    links_path,
    listeners_path,
    candidate_config_path,
    summary_json_path,
) = sys.argv[1:]

target = Path(target_dir)
meta_path = target / "metadata.json"
config_path = target / "sing-box.json"
bind_dir = target / "bindings"

def fail(message):
    print(f"ERROR: {message}", file=sys.stderr)
    raise SystemExit(1)

def read_json(path):
    try:
        return json.loads(path.read_text())
    except Exception as exc:
        fail(f"cannot read json {path}: {exc}")

def parse_registry(path):
    rows = []
    for raw in Path(path).read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        item = {"_raw": line}
        for part in line.split():
            if "=" in part:
                key, value = part.split("=", 1)
                item[key] = value
        rows.append(item)
    return rows

def redact_uuid(value):
    if len(value) <= 12:
        return "redacted"
    return f"{value[:8]}...{value[-4:]}"

def has_ip_rule(rules, user_ip, table):
    needle_a = f"from {user_ip} lookup {table}"
    needle_b = f"from {user_ip} table {table}"
    return any(needle_a in row or needle_b in row for row in rules)

def iface_exists(links, iface):
    pattern = re.compile(rf"^\d+:\s+{re.escape(iface)}[@:]")
    return any(pattern.search(row) for row in links)

def listener_on_port(listeners, port):
    suffix = f":{port}"
    return [row for row in listeners if row.split() and row.split()[3].endswith(suffix)]

def safe_tag(value):
    return re.sub(r"[^A-Za-z0-9_.-]+", "-", value).strip("-")[:80] or "item"

meta = read_json(meta_path)
base_config = read_json(config_path)
users_rows = parse_registry(users_reg)
egress_rows = parse_registry(egress_reg)
rules_text = Path(ip_rules_path).read_text(errors="ignore").splitlines()
links_text = Path(links_path).read_text(errors="ignore").splitlines()
listeners_text = Path(listeners_path).read_text(errors="ignore").splitlines()

runtime_status = str(meta.get("status", ""))
listen = str(meta.get("listen", ""))
port = meta.get("port")
route_final = (base_config.get("route") or {}).get("final")
inbounds = base_config.get("inbounds") or []
rendered_users = (inbounds[0].get("users") if inbounds else []) or []
runtime_user_by_uuid = {str(item.get("uuid", "")): str(item.get("name", "")) for item in rendered_users}

blockers = []
warnings = []
adapter_rules = []
outbounds_by_tag = {}

if runtime_status != "rendered_disabled":
    blockers.append(f"runtime_status_not_rendered_disabled:{runtime_status}")
if route_final != "block":
    blockers.append(f"route_final_not_block:{route_final}")
if listen != "127.0.0.1":
    blockers.append(f"listen_not_loopback:{listen}")
if not isinstance(port, int):
    blockers.append("port_invalid")

port_listeners = listener_on_port(listeners_text, port) if isinstance(port, int) else []
public_listeners = [row for row in port_listeners if not row.split()[3].startswith("127.0.0.1:")]
if public_listeners:
    blockers.append("public_listener_present")

users_by_ip = {row.get("ip"): row for row in users_rows if row.get("ip")}
egress_by_id = {row.get("id"): row for row in egress_rows if row.get("id")}
bindings = []
for path in sorted(bind_dir.glob("user-*.json")):
    bindings.append((path.name, read_json(path)))
if not bindings:
    blockers.append("no_bindings")

for filename, binding in bindings:
    row_blockers = []
    row_warnings = []
    proxy_uuid = str(binding.get("proxy_uuid", ""))
    try:
        uuid.UUID(proxy_uuid)
    except Exception:
        row_blockers.append("invalid_proxy_uuid")
    runtime_user_name = runtime_user_by_uuid.get(proxy_uuid, "")
    if not runtime_user_name:
        row_blockers.append("uuid_not_rendered_in_runtime")
    user_ip = str(binding.get("user_ip", ""))
    table = binding.get("route_table")
    bound_egress = str(binding.get("current_egress", ""))

    user = users_by_ip.get(user_ip)
    registry_egress = bound_egress
    if not user:
        row_blockers.append("user_missing_from_users_registry")
        registry_table = ""
    else:
        registry_table = user.get("table", "")
        if user.get("enabled") != "1":
            row_blockers.append("user_disabled")
        if str(registry_table) != str(table):
            row_blockers.append(f"route_table_mismatch:binding={table}:registry={registry_table}")
        if user.get("current") and user.get("current") != bound_egress:
            row_warnings.append(f"current_egress_changed:binding={bound_egress}:registry={user.get('current')}")
            registry_egress = user.get("current")

    egress = egress_by_id.get(registry_egress)
    if not egress:
        row_blockers.append("egress_missing_from_registry")
        iface = ""
    else:
        iface = egress.get("interface", "")
        if egress.get("enabled") != "1":
            row_blockers.append("egress_disabled")
        if not iface:
            row_blockers.append("egress_interface_missing")
        elif not iface_exists(links_text, iface):
            row_blockers.append(f"egress_interface_not_live:{iface}")

    if not has_ip_rule(rules_text, user_ip, table):
        row_blockers.append("reference_user_ip_rule_missing")

    outbound_tag = f"v7-egress-{safe_tag(registry_egress)}"
    if iface and outbound_tag not in outbounds_by_tag:
        outbounds_by_tag[outbound_tag] = {
            "type": "direct",
            "tag": outbound_tag,
            "bind_interface": iface,
        }

    adapter_rules.append({
        "binding_file": filename,
        "proxy_uuid_redacted": redact_uuid(proxy_uuid),
        "runtime_user": runtime_user_name,
        "user_ip": user_ip,
        "route_table_reference": table,
        "egress": registry_egress,
        "interface": iface,
        "outbound_tag": outbound_tag,
        "rule": {"auth_user": [runtime_user_name], "outbound": outbound_tag} if runtime_user_name and iface else {},
        "kernel_table_used_directly": False,
        "kernel_table_reference": table,
        "strategy": "sing_box_auth_user_rule_bind_interface",
        "blockers": row_blockers,
        "warnings": row_warnings,
    })
    blockers.extend([f"{filename}:{item}" for item in row_blockers])
    warnings.extend([f"{filename}:{item}" for item in row_warnings])

candidate = json.loads(json.dumps(base_config))
candidate["log"] = {"level": "info", "timestamp": True}
candidate["outbounds"] = list(outbounds_by_tag.values()) + [{"type": "block", "tag": "block"}]
candidate["route"] = {
    "rules": [item["rule"] for item in adapter_rules if item["rule"]],
    "final": "block",
}
Path(candidate_config_path).write_text(json.dumps(candidate, ensure_ascii=True, indent=2) + "\n")

summary = {
    "inbound_id": inbound_id,
    "adapter_mode": "sing_box_auth_user_rule_bind_interface",
    "runtime_status": runtime_status,
    "listen": listen,
    "port": port,
    "route_final_before": route_final,
    "route_final_candidate": "block",
    "bindings": len(bindings),
    "adapter_rules": adapter_rules,
    "outbounds": list(outbounds_by_tag.values()),
    "blockers": blockers,
    "warnings": warnings,
    "live_enable": "BLOCKED",
    "next": "kill_switch_proxy_identity_guard_dry_run",
}
Path(summary_json_path).write_text(json.dumps(summary, ensure_ascii=True, indent=2) + "\n")

print()
print("===== ADAPTER CANDIDATE =====")
print("adapter_mode=sing_box_auth_user_rule_bind_interface")
print(f"bindings={len(bindings)}")
print(f"outbounds={len(outbounds_by_tag)}")
print("route_final_candidate=block")
print("would_write_runtime_config=no")
print("would_start_service=no")
print("would_open_firewall=no")
print("would_change_routing=no")
print("would_change_killswitch=no")
print("would_move_users=no")
for item in adapter_rules:
    print(f"adapter_rule={item['runtime_user']} -> {item['outbound_tag']} iface={item['interface']} user_ip={item['user_ip']} table_ref={item['route_table_reference']}")
    if item["warnings"]:
        print(f"  warnings={','.join(item['warnings'])}")
    if item["blockers"]:
        print(f"  blockers={','.join(item['blockers'])}")

print()
print("===== LIMITS =====")
print("kernel_table_used_directly=no")
print("reason=proxy_inbound_traffic_is_not_linux_source_ip_10_0_0_x")
print("preserves_current_user_egress=yes")
print("service_aware_proxy_routing=next_phase")
print("live_enable=BLOCKED")
PY

echo
echo "===== SING-BOX VALIDATION ====="
if sing-box check -c "$CANDIDATE_CONFIG" >/tmp/v7-proxy-policy-adapter-check.$$ 2>&1; then
  echo "candidate_sing_box_check=OK"
else
  echo "candidate_sing_box_check=FAIL"
  sed 's/^/sing_box_check_output=/' /tmp/v7-proxy-policy-adapter-check.$$
  rm -f /tmp/v7-proxy-policy-adapter-check.$$
  exit 1
fi
rm -f /tmp/v7-proxy-policy-adapter-check.$$

echo
echo "===== RESULT ====="
python3 - "$SUMMARY_JSON" <<'PY'
import json
import sys
summary = json.load(open(sys.argv[1]))
blockers = summary.get("blockers") or []
warnings = summary.get("warnings") or []
if blockers:
    print("V7_PROXY_POLICY_RUNTIME_ADAPTER_DRY_RUN=BLOCKED")
else:
    print("V7_PROXY_POLICY_RUNTIME_ADAPTER_DRY_RUN=OK")
print(f"blockers={len(blockers)}")
for item in blockers:
    print(f"blocker={item}")
print(f"warnings={len(warnings)}")
for item in warnings:
    print(f"warning={item}")
print("live_enable=BLOCKED")
print("next=kill_switch_proxy_identity_guard_dry_run")
print("technical_json=" + json.dumps(summary, ensure_ascii=True, sort_keys=True))
raise SystemExit(0 if not blockers else 1)
PY
