#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
USER_REG="${V7_USERS_REGISTRY:-$STATE_DIR/users.registry}"
EGRESS_REG="${V7_EGRESS_REGISTRY:-$STATE_DIR/egress.registry}"
WG_IF="${V7_WG_IF:-wg0}"
LIB="${V7_EGRESS_LIB:-/usr/local/lib/v7-egress-lib}"
[ -r "$LIB" ] && . "$LIB"
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
  WG_IF="${V7_WG_IF:-$WG_IF}"
fi

result="OK"
warnings=0
errors=0

warn() {
  warnings=$((warnings + 1))
  [ "$result" = "OK" ] && result="WARN"
  echo "WARN: $*"
}

err() {
  errors=$((errors + 1))
  result="FAIL"
  echo "ERROR: $*"
}

echo "===== V7 RECONCILE CHECK ====="
date -Is
echo "state_dir=$STATE_DIR"
echo "users_registry=$USER_REG"
echo "egress_registry=$EGRESS_REG"
echo "wg_if=$WG_IF"
echo

[ -r "$USER_REG" ] || err "users registry missing: $USER_REG"
[ -r "$EGRESS_REG" ] || err "egress registry missing: $EGRESS_REG"
ip link show "$WG_IF" >/dev/null 2>&1 || warn "WireGuard interface not visible: $WG_IF"

if [ ! -r "$USER_REG" ]; then
  echo "V7_RECONCILE_RESULT=$result"
  exit 1
fi

echo "===== USERS ====="
while IFS= read -r line || [ -n "$line" ]; do
  [ -n "$line" ] || continue
  case "$line" in \#*) continue ;; esac
  ip="$(v7_kv_get "$line" ip)"
  current="$(v7_kv_get "$line" current)"
  table="$(v7_kv_get "$line" table)"
  enabled="$(v7_kv_get "$line" enabled)"

  if ! v7_safe_ip "$ip"; then
    err "unsafe ip in registry line: $line"
    continue
  fi
  if ! [[ "$table" =~ ^[0-9]+$ ]]; then
    err "unsafe table for $ip: $table"
    continue
  fi

  echo "user=$ip enabled=${enabled:-0} current=$current table=$table"
  if [ "${enabled:-0}" != "1" ]; then
    continue
  fi

  if ! v7_egress_exists "$current"; then
    err "user=$ip current egress missing: $current"
  elif ! v7_egress_enabled "$current"; then
    warn "user=$ip current egress disabled: $current"
  fi

  assign="$STATE_DIR/user-${ip}.assign"
  if [ ! -r "$assign" ]; then
    err "user=$ip assign file missing: $assign"
  else
    assign_egress="$(awk -F= '$1=="egress"{print $2; exit}' "$assign")"
    if [ "$assign_egress" != "$current" ]; then
      warn "user=$ip registry current=$current assign egress=$assign_egress"
    fi
  fi

  if ! wg show "$WG_IF" allowed-ips 2>/dev/null | awk '{print $2}' | grep -qx "$ip/32"; then
    warn "user=$ip not found in live wg allowed-ips"
  fi

  if ! ip -4 rule show 2>/dev/null | grep -q "from $ip lookup $table"; then
    err "user=$ip missing ip rule lookup table $table"
  fi

  dev="$(v7_egress_interface "$current" || true)"
  route="$(ip route get 8.8.8.8 from "$ip" iif "$WG_IF" 2>&1 || true)"
  if [ -n "$dev" ] && ! printf '%s\n' "$route" | grep -q " dev $dev "; then
    warn "user=$ip route_get expected dev=$dev route=$route"
  fi
done < "$USER_REG"

echo
echo "===== RESULT ====="
echo "warnings=$warnings"
echo "errors=$errors"
echo "V7_RECONCILE_RESULT=$result"
[ "$result" != "FAIL" ]
