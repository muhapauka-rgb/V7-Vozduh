#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
USER_REG="${V7_USERS_REGISTRY:-$STATE_DIR/users.registry}"
WG_IF="${V7_WG_IF:-wg0}"
LIB="${V7_EGRESS_LIB:-/usr/local/lib/v7-egress-lib}"
[ -r "$LIB" ] && . "$LIB"
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
  WG_IF="${V7_WG_IF:-$WG_IF}"
fi

result="OK"
actions=0

suggest() {
  actions=$((actions + 1))
  [ "$result" = "OK" ] && result="WARN"
  printf 'SUGGEST: %s\n' "$*"
}

block() {
  actions=$((actions + 1))
  result="FAIL"
  printf 'BLOCKED: %s\n' "$*"
}

echo "===== V7 RECONCILE REPAIR PREVIEW ====="
date -Is
echo "mode=read_only"
echo "users_registry=$USER_REG"
echo "wg_if=$WG_IF"
echo

if [ ! -r "$USER_REG" ]; then
  echo "ERROR: users registry missing: $USER_REG"
  echo "V7_RECONCILE_REPAIR_PREVIEW=FAIL"
  exit 1
fi

while IFS= read -r line || [ -n "$line" ]; do
  [ -n "$line" ] || continue
  case "$line" in \#*) continue ;; esac

  ip="$(v7_kv_get "$line" ip)"
  current="$(v7_kv_get "$line" current)"
  table="$(v7_kv_get "$line" table)"
  enabled="$(v7_kv_get "$line" enabled)"

  if ! v7_safe_ip "$ip"; then
    block "unsafe registry line skipped: $line"
    continue
  fi
  if ! [[ "$table" =~ ^[0-9]+$ ]]; then
    block "unsafe table for user=$ip table=$table"
    continue
  fi
  [ "${enabled:-0}" = "1" ] || continue

  echo "user=$ip current=$current table=$table"

  assign="$STATE_DIR/user-${ip}.assign"
  if [ ! -r "$assign" ]; then
    suggest "create assign file by running: v7-user-reconcile-apply --user $ip --repair assign --apply --confirm REPAIR_USER"
  else
    assign_egress="$(awk -F= '$1=="egress"{print $2; exit}' "$assign")"
    if [ "$assign_egress" != "$current" ]; then
      suggest "align assign with registry by running: v7-user-reconcile-apply --user $ip --repair assign --apply --confirm REPAIR_USER"
    fi
  fi

  if ! ip -4 rule show 2>/dev/null | grep -q "from $ip lookup $table"; then
    suggest "restore policy rule by running: v7-user-reconcile-apply --user $ip --repair routing --apply --confirm REPAIR_USER"
  fi

  dev="$(v7_egress_interface "$current" || true)"
  if [ -z "$dev" ]; then
    block "current egress has no interface in registry: user=$ip current=$current"
  else
    route="$(ip route get 8.8.8.8 from "$ip" iif "$WG_IF" 2>&1 || true)"
    if ! printf '%s\n' "$route" | grep -q " dev $dev "; then
      suggest "restore user table route by running: v7-user-reconcile-apply --user $ip --repair routing --apply --confirm REPAIR_USER"
    fi
  fi

  if ! wg show "$WG_IF" allowed-ips 2>/dev/null | awk '{print $2}' | grep -qx "$ip/32"; then
    suggest "restore live WireGuard peer by running: v7-user-reconcile-apply --user $ip --repair wg-live --apply --confirm REPAIR_USER"
  fi
  echo
done < "$USER_REG"

echo "actions=$actions"
echo "live_changes=NO"
echo "V7_RECONCILE_REPAIR_PREVIEW=$result"
[ "$result" != "FAIL" ]
