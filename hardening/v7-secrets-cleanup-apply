#!/usr/bin/env bash
set -euo pipefail

ROOT="${V7_CLIENT_ROOT:-/root/v7-clients}"
DAYS="${V7_SECRET_CLEANUP_DAYS:-7}"
APPLY=0
CONFIRM=""

usage() {
  cat <<USAGE
Usage: v7-secrets-cleanup-apply [--root PATH] [--days N] [--apply --confirm CLEANUP_SECRETS]

Default mode is dry-run. Apply mode moves old generated exchange artifacts
(.png, .qr, .mobileconfig) into a root-only quarantine folder. It does not
delete private keys or .conf files.
USAGE
}

fail() { echo "ERROR: $*" >&2; exit 1; }

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root) ROOT="${2:-}"; shift 2 ;;
    --days) DAYS="${2:-}"; shift 2 ;;
    --apply) APPLY=1; shift ;;
    --confirm) CONFIRM="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) fail "unknown argument: $1" ;;
  esac
done

case "$DAYS" in (*[!0-9]*|"") fail "invalid --days" ;; esac
[ "$DAYS" -ge 1 ] || fail "--days must be >= 1"

echo "===== V7 SECRETS CLEANUP APPLY ====="
date -Is
echo "mode=$([ "$APPLY" = "1" ] && echo apply || echo dry_run)"
echo "root=$ROOT"
echo "older_than_days=$DAYS"
echo "conf_files=preserved"
echo "private_keys=preserved"

if [ ! -d "$ROOT" ]; then
  echo "WARN: root directory not found"
  echo "V7_SECRETS_CLEANUP_APPLY=WARN"
  exit 0
fi

tmp_files="$(mktemp)"
trap 'rm -f "$tmp_files"' EXIT
find "$ROOT" -type f \( -name '*.png' -o -name '*.qr' -o -name '*.mobileconfig' \) -mtime "+$DAYS" -print 2>/dev/null | sort > "$tmp_files"

echo "candidates=$(wc -l < "$tmp_files" | tr -d ' ')"
while IFS= read -r file || [ -n "$file" ]; do
  [ -n "$file" ] || continue
  echo "candidate=$file"
done < "$tmp_files"

if [ "$APPLY" != "1" ]; then
  echo "live_changes=NO"
  echo "V7_SECRETS_CLEANUP_APPLY=DRY_RUN_OK"
  exit 0
fi

[ "$CONFIRM" = "CLEANUP_SECRETS" ] || fail "apply requires --confirm CLEANUP_SECRETS"
stamp="$(date -u +%Y%m%d-%H%M%S)"
quarantine="/root/v7-secret-cleanup-quarantine/$stamp"
mkdir -p "$quarantine"
chmod 700 "$(dirname "$quarantine")" "$quarantine"

moved=0
while IFS= read -r file || [ -n "$file" ]; do
  [ -n "$file" ] || continue
  rel="${file#$ROOT/}"
  dest="$quarantine/$rel"
  mkdir -p "$(dirname "$dest")"
  mv "$file" "$dest"
  moved=$((moved + 1))
done < "$tmp_files"
chmod -R go-rwx "$quarantine"

if command -v v7-audit-log >/dev/null 2>&1; then
  v7-audit-log "secrets_cleanup_apply" "security" "root=$ROOT days=$DAYS moved=$moved quarantine=$quarantine" >/dev/null 2>&1 || true
fi

echo "moved=$moved"
echo "quarantine=$quarantine"
echo "V7_SECRETS_CLEANUP_APPLY=OK"
