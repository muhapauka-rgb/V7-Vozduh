#!/usr/bin/env bash
set -euo pipefail

ROOT="${1:-/root/v7-clients}"
DAYS="${V7_SECRET_PREVIEW_DAYS:-7}"

echo "===== V7 SECRETS CLEANUP PREVIEW ====="
date -Is
echo "root=$ROOT"
echo "older_than_days=$DAYS"
echo "mode=read_only"

if [ ! -d "$ROOT" ]; then
  echo "WARN: root directory not found"
  echo "V7_SECRETS_CLEANUP_PREVIEW=WARN"
  exit 0
fi

echo
echo "===== OLD GENERATED ARTIFACTS ====="
find "$ROOT" -type f \( -name '*.conf' -o -name '*.png' -o -name '*.qr' -o -name '*.mobileconfig' \) -mtime "+$DAYS" -print 2>/dev/null | sed 's/^/old_artifact=/'

echo
echo "===== PRIVATE MATERIAL ====="
find "$ROOT" -type f \( -name '*.key' -o -name '*private*' -o -name '*preshared*' \) -print 2>/dev/null | sed 's/^/private_material=/'

cat <<NOTE

No files were deleted.
Recommended lifecycle:
1. Generate profile or one-time delivery token.
2. Deliver to user.
3. Expire/revoke delivery token.
4. Keep server-side private material root-only.
5. Remove old QR/config exchange artifacts after operator confirmation.
NOTE

echo "V7_SECRETS_CLEANUP_PREVIEW=OK"
