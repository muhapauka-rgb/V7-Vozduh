#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
DECISION="${V7_TRUSTED_RU_DECISION_STATE:-$STATE_DIR/trusted-ru-decision.state}"
LIMIT="${V7_TRUSTED_RU_MISSING_LIMIT:-2}"

usage() {
  cat <<USAGE
Usage: v7-trusted-ru-refresh-missing [--limit N]

Runs diagnostics only for domains currently marked MISSING_DIAGNOSTIC,
then recalculates the full Sensitive RU decision preview.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --limit)
      LIMIT="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

case "$LIMIT" in
  ''|*[!0-9]*)
    echo "ERROR: --limit must be numeric" >&2
    exit 1
    ;;
esac
[ "$LIMIT" -ge 1 ] || LIMIT=1
[ "$LIMIT" -le 6 ] || LIMIT=6

if [ ! -r "$DECISION" ]; then
  v7-trusted-ru-decision --write-state >/dev/null
fi

mapfile -t missing < <(
  awk -F= '
    /^item_[0-9]+_domain=/ {
      idx=$1
      sub(/^item_/, "", idx)
      sub(/_domain$/, "", idx)
      domain[idx]=$2
    }
    /^item_[0-9]+_decision=MISSING_DIAGNOSTIC$/ {
      idx=$1
      sub(/^item_/, "", idx)
      sub(/_decision$/, "", idx)
      missing[idx]=1
    }
    END {
      for (idx in missing) if (domain[idx] != "") print domain[idx]
    }
  ' "$DECISION" | sort | head -n "$LIMIT"
)

echo "===== V7 TRUSTED RU REFRESH MISSING ====="
date -Is
echo "decision_state=$DECISION"
echo "limit=$LIMIT"
echo "selected_count=${#missing[@]}"

if [ "${#missing[@]}" -eq 0 ]; then
  echo "V7_TRUSTED_RU_REFRESH_MISSING=NOOP"
  v7-trusted-ru-decision --write-state
  exit 0
fi

printf 'selected_domains=%s\n' "${missing[*]}"
v7-trusted-ru-diagnostic "${missing[@]}"
v7-trusted-ru-decision --write-state
command -v v7-state-json-save >/dev/null 2>&1 && v7-state-json-save >/dev/null || true

echo "V7_TRUSTED_RU_REFRESH_MISSING=OK"
