#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/opt/v7/egress/state"
REG="$STATE_DIR/users.registry"
WG_CONF="/etc/wireguard/wg0.conf"
CLIENT_ROOT="/root/v7-clients"
SERVER_ENDPOINT="195.2.79.116:51820"
DEFAULT_EGRESS="awg2"
BASE_PREFIX="10.0.0"
START_HOST=2
END_HOST=254
START_TABLE=100
DRY_RUN=0

usage() {
  cat <<USAGE
Usage: v7-user-create <client-name> [--ip 10.0.0.X] [--table N] [--egress vless|awg2] [--dry-run]

Creates a WireGuard client profile and registers it in V7 routing state.
Outputs paths to .conf and .png QR. Secrets are written to disk, not printed.

Examples:
  v7-user-create ivan-iphone
  v7-user-create maria --ip 10.0.0.20 --table 118 --egress awg2
  v7-user-create test-user --dry-run
USAGE
}

fail() {
  echo "ERROR: $*" >&2
  exit 1
}

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-' | sed -E 's/^-+//; s/-+$//; s/-+/-/g'
}

if [ "$#" -eq 0 ]; then
  usage
  exit 1
fi

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

name=""
client_ip=""
table=""
egress="$DEFAULT_EGRESS"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --ip)
      client_ip="${2:-}"; shift 2 ;;
    --table)
      table="${2:-}"; shift 2 ;;
    --egress)
      egress="${2:-}"; shift 2 ;;
    --dry-run)
      DRY_RUN=1; shift ;;
    --*)
      fail "unknown argument: $1" ;;
    *)
      [ -z "$name" ] || fail "client name already set: $name"
      name="$1"; shift ;;
  esac
done

[ -n "$name" ] || fail "client name is required"
[ "$egress" = "vless" ] || [ "$egress" = "awg2" ] || fail "egress must be vless or awg2"
[ -f "$REG" ] || fail "$REG does not exist"
[ -f "$WG_CONF" ] || fail "$WG_CONF does not exist"
command -v wg >/dev/null || fail "wg not found"
command -v v7-routing-sync >/dev/null || fail "v7-routing-sync not found"
command -v qrencode >/dev/null || fail "qrencode not found"

client_name="$(safe_name "$name")"
[ -n "$client_name" ] || fail "client name became empty after sanitization"
client_dir="$CLIENT_ROOT/$client_name"
[ ! -e "$client_dir" ] || fail "client directory already exists: $client_dir"

ip_in_use() {
  local ip="$1"
  grep -q "^ip=${ip} " "$REG" && return 0
  wg show wg0 allowed-ips 2>/dev/null | awk '{print $2}' | grep -qx "${ip}/32" && return 0
  grep -q "AllowedIPs = ${ip}/32" "$WG_CONF" && return 0
  return 1
}

table_in_use() {
  local t="$1"
  awk -v t="$t" '{for (i=1;i<=NF;i++) if ($i == "table=" t) found=1} END{exit found?0:1}' "$REG"
}

if [ -z "$client_ip" ]; then
  for host in $(seq "$START_HOST" "$END_HOST"); do
    candidate="${BASE_PREFIX}.${host}"
    if ! ip_in_use "$candidate"; then
      client_ip="$candidate"
      break
    fi
  done
fi
[ -n "$client_ip" ] || fail "no free client IP in ${BASE_PREFIX}.0/24"
[[ "$client_ip" =~ ^10\.0\.0\.[0-9]+$ ]] || fail "client IP must be inside current 10.0.0.0/24 range"
! ip_in_use "$client_ip" || fail "client IP already in use: $client_ip"

if [ -z "$table" ]; then
  host="${client_ip##*.}"
  table=$((START_TABLE + host - START_HOST))
  while table_in_use "$table"; do
    table=$((table + 1))
  done
fi
[[ "$table" =~ ^[0-9]+$ ]] || fail "table must be numeric"
! table_in_use "$table" || fail "routing table already in use: $table"

if [ "$DRY_RUN" = "1" ]; then
  cat <<DRY
V7_USER_CREATE_DRY_RUN=OK
name=$client_name
ip=$client_ip
table=$table
egress=$egress
client_dir=$client_dir
DRY
  exit 0
fi

umask 077
mkdir -p "$client_dir"
private_key="$client_dir/private.key"
public_key="$client_dir/public.key"
client_conf="$client_dir/${client_name}.conf"
client_qr="$client_dir/${client_name}.png"

wg genkey | tee "$private_key" | wg pubkey > "$public_key"
client_public="$(cat "$public_key")"
server_public="$(wg show wg0 public-key)"

backup_ts="$(date +%Y%m%d-%H%M%S)"
cp -a "$WG_CONF" "$WG_CONF.backup.v7-user-create.$backup_ts"
cp -a "$REG" "$REG.backup.v7-user-create.$backup_ts"

{
  echo ""
  echo "# $client_name $client_ip"
  echo "[Peer]"
  echo "PublicKey = $client_public"
  echo "AllowedIPs = $client_ip/32"
} >> "$WG_CONF"

echo "ip=$client_ip current=$egress table=$table enabled=1" >> "$REG"

cat > "$STATE_DIR/user-${client_ip}.assign" <<STATE
egress=$egress
last_switch=$(date +%s)
fail_count=0
STATE

cat > "$client_conf" <<CLIENT
[Interface]
PrivateKey = $(cat "$private_key")
Address = $client_ip/32
DNS = 10.0.0.1

[Peer]
PublicKey = $server_public
Endpoint = $SERVER_ENDPOINT
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
CLIENT

qrencode -o "$client_qr" -t PNG < "$client_conf"
chmod 600 "$private_key" "$public_key" "$client_conf" "$client_qr" "$STATE_DIR/user-${client_ip}.assign"

wg set wg0 peer "$client_public" allowed-ips "$client_ip/32"
v7-routing-sync >/tmp/v7-user-create-routing-sync.log

if command -v v7-audit-log >/dev/null 2>&1; then
  v7-audit-log "user_create" "users" "name=$client_name ip=$client_ip table=$table egress=$egress" >/dev/null 2>&1 || true
fi

cat <<RESULT
V7_USER_CREATE=OK
name=$client_name
ip=$client_ip
table=$table
egress=$egress
conf=$client_conf
qr=$client_qr
wg_conf_backup=$WG_CONF.backup.v7-user-create.$backup_ts
registry_backup=$REG.backup.v7-user-create.$backup_ts
RESULT

ip route get 8.8.8.8 from "$client_ip" iif wg0
