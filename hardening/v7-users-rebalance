#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${V7_STATE_DIR:-/opt/v7/egress/state}"
USERS_REG="${STATE_DIR}/users.registry"
EGRESS_REG="${STATE_DIR}/egress.registry"
SUM="${STATE_DIR}/summary.state"
if command -v v7-policy-env >/dev/null 2>&1; then
  eval "$(v7-policy-env)"
fi
QUALITY_MIN_AVG_MBPS="${V7_QUALITY_MIN_AVG_MBPS:-15}"
QUALITY_MIN_FLOOR_MBPS="${V7_QUALITY_MIN_FLOOR_MBPS:-10}"
QUALITY_MIN_STABILITY="${V7_QUALITY_MIN_STABILITY:-0.45}"
MAX_MOVES="${V7_REBALANCE_MAX_MOVES_PER_RUN:-1}"

get() {
  grep "^$1=" "$SUM" 2>/dev/null | tail -n1 | cut -d= -f2 || true
}

egress_ids() {
  awk '
    $0 !~ /^[[:space:]]*($|#)/ {
      id=""; enabled="0"
      for (i=1; i<=NF; i++) {
        if ($i ~ /^id=/) { id=$i; sub(/^id=/, "", id) }
        if ($i ~ /^enabled=/) { enabled=$i; sub(/^enabled=/, "", enabled) }
      }
      if (id != "" && enabled == "1") print id
    }
  ' "$EGRESS_REG"
}

quality_ok() {
  id="$1"
  code="$(get "${id}_code")"
  avg="$(get "${id}_avg_mbps")"
  floor="$(get "${id}_min_mbps")"
  stab="$(get "${id}_stability")"

  [ -z "$code" ] && code="000"
  [ -z "$avg" ] && avg=0
  [ -z "$floor" ] && floor=0
  [ -z "$stab" ] && stab=0

  if [ "$code" = "200" ] && awk "BEGIN {exit !(($avg >= $QUALITY_MIN_AVG_MBPS) && ($floor >= $QUALITY_MIN_FLOOR_MBPS) && ($stab >= $QUALITY_MIN_STABILITY))}"; then
    echo "YES"
  else
    echo "NO"
  fi
}

best_candidate_for() {
  current="$1"
  best=""
  best_users=999999
  while read -r target; do
    [ -z "$target" ] && continue
    [ "$target" = "$current" ] && continue
    target_load="$(get "${target}_load_status")"
    target_users="$(get "${target}_users")"
    target_ok="$(quality_ok "$target")"
    [ -z "$target_users" ] && target_users=0
    [ "$target_ok" = "YES" ] || continue
    [ "$target_load" != "HARD_FULL" ] || continue
    if awk "BEGIN {exit !($target_users < $best_users)}"; then
      best="$target"
      best_users="$target_users"
    fi
  done < <(egress_ids)
  echo "$best"
}

echo "===== V7 USERS REBALANCE ====="
echo "QUALITY_MIN_AVG_MBPS=$QUALITY_MIN_AVG_MBPS"
echo "QUALITY_MIN_FLOOR_MBPS=$QUALITY_MIN_FLOOR_MBPS"
echo "QUALITY_MIN_STABILITY=$QUALITY_MIN_STABILITY"
echo "MAX_MOVES=$MAX_MOVES"

v7-egress-load >/dev/null
v7-state-merge >/dev/null

moved=0

while read -r line; do
  [ -z "$line" ] && continue
  case "$line" in \#*) continue ;; esac
  eval "$line"
  [ "${enabled:-0}" != "1" ] && continue

  other="$(best_candidate_for "$current")"
  current_load="$(get "${current}_load_status")"
  other_load=""
  other_ok="NO"
  if [ -n "$other" ]; then
    other_load="$(get "${other}_load_status")"
    other_ok="$(quality_ok "$other")"
  fi

  echo
  echo "USER=$ip TABLE=$table CURRENT=$current OTHER=${other:-none}"

  if [ -n "$other" ] && [ "$moved" -lt "$MAX_MOVES" ] && [ "$current_load" = "HARD_FULL" ] && [ "$other_load" != "HARD_FULL" ] && [ "$other_ok" = "YES" ]; then
    echo "ACTION=rebalance_to_$other"
    v7-user-switch "$ip" "$other"
    if command -v v7-audit-log >/dev/null 2>&1; then
      v7-audit-log "user_rebalance" "users" "ip=$ip from=$current to=$other table=$table" >/dev/null 2>&1 || true
    fi
    moved=$((moved + 1))
  else
    echo "ACTION=keep"
    echo "REASON=moved=$moved current_load=$current_load other_load=${other_load:-none} other_quality_ok=$other_ok"
  fi

done < "$USERS_REG"

v7-egress-load >/dev/null
v7-state-merge >/dev/null
