#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/opt/v7/egress/state"
USERS_REG="${STATE_DIR}/users.registry"
SUM="${STATE_DIR}/summary.state"
if command -v v7-policy-env >/dev/null 2>&1; then
  eval "$(v7-policy-env)"
fi
QUALITY_MIN_AVG_MBPS="${V7_QUALITY_MIN_AVG_MBPS:-15}"
QUALITY_MIN_FLOOR_MBPS="${V7_QUALITY_MIN_FLOOR_MBPS:-10}"
QUALITY_MIN_STABILITY="${V7_QUALITY_MIN_STABILITY:-0.45}"
MAX_MOVES="${V7_REBALANCE_MAX_MOVES_PER_RUN:-1}"

get() {
  grep "^$1=" "$SUM" 2>/dev/null | tail -n1 | cut -d= -f2 || true
}

quality_ok() {
  id="$1"
  code="$(get "${id}_code")"
  avg="$(get "${id}_avg_mbps")"
  floor="$(get "${id}_min_mbps")"
  stab="$(get "${id}_stability")"

  [ -z "$code" ] && code="000"
  [ -z "$avg" ] && avg=0
  [ -z "$floor" ] && floor=0
  [ -z "$stab" ] && stab=0

  if [ "$code" = "200" ] && awk "BEGIN {exit !(($avg >= $QUALITY_MIN_AVG_MBPS) && ($floor >= $QUALITY_MIN_FLOOR_MBPS) && ($stab >= $QUALITY_MIN_STABILITY))}"; then
    echo "YES"
  else
    echo "NO"
  fi
}

echo "===== V7 USERS REBALANCE DRY RUN ====="
echo "QUALITY_MIN_AVG_MBPS=$QUALITY_MIN_AVG_MBPS"
echo "QUALITY_MIN_FLOOR_MBPS=$QUALITY_MIN_FLOOR_MBPS"
echo "QUALITY_MIN_STABILITY=$QUALITY_MIN_STABILITY"
echo "MAX_MOVES=$MAX_MOVES"

# read-only dry run

for target in vless awg2; do
  echo "$target users=$(get "${target}_users") load=$(get "${target}_load_status") quality_ok=$(quality_ok "$target")"
done

moved=0

echo
echo "===== USER PLAN ====="

while read -r line; do
  [ -z "$line" ] && continue
  eval "$line"
  [ "${enabled:-0}" != "1" ] && continue

  if [ "$current" = "vless" ]; then
    other="awg2"
  else
    other="vless"
  fi

  current_load="$(get "${current}_load_status")"
  other_load="$(get "${other}_load_status")"
  other_ok="$(quality_ok "$other")"

  echo
  echo "USER=$ip TABLE=$table CURRENT=$current OTHER=$other"

  if [ "$moved" -lt "$MAX_MOVES" ] && [ "$current_load" = "HARD_FULL" ] && [ "$other_load" != "HARD_FULL" ] && [ "$other_ok" = "YES" ]; then
    echo "ACTION=would_rebalance_to_$other"
    moved=$((moved + 1))
  else
    echo "ACTION=keep"
    echo "REASON=moved=$moved current_load=$current_load other_load=$other_load other_quality_ok=$other_ok"
  fi

done < "$USERS_REG"
