#!/usr/bin/env bash
set -euo pipefail
DOMAIN="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]//g; s/[.]$//')"
DOMAINS="/etc/v7/direct/domains.conf"
[ -n "$DOMAIN" ] || { echo "Usage: v7-direct-add-domain <domain-or-.tld>" >&2; exit 1; }
case "$DOMAIN" in
  .*) printf '%s' "$DOMAIN" | grep -Eq '^[.][a-z0-9-]{2,63}$' || { echo "ERROR: invalid direct suffix" >&2; exit 2; } ;;
  *) printf '%s' "$DOMAIN" | grep -Eq '^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?([.][a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$' || { echo "ERROR: invalid direct domain" >&2; exit 2; } ;;
esac
touch "$DOMAINS"
if grep -qxF "$DOMAIN" "$DOMAINS"; then
  echo "V7_DIRECT_ADD_DOMAIN=already_present"
else
  cp -a "$DOMAINS" "$DOMAINS.backup.$(date +%Y%m%d-%H%M%S)"
  printf '%s\n' "$DOMAIN" >> "$DOMAINS"
  v7-direct-render-dnsmasq >/dev/null
  systemctl restart dnsmasq
  if command -v v7-audit-log >/dev/null 2>&1; then
    v7-audit-log "direct_domain_add" "direct_ru" "domain=$DOMAIN" >/dev/null 2>&1 || true
  fi
  echo "V7_DIRECT_ADD_DOMAIN=OK"
fi
v7-direct-list | sed -n '1,80p'
