#!/usr/bin/env bash
set -euo pipefail
DOMAINS="/etc/v7/direct/domains.conf"
EXCLUDES="/etc/v7/direct/exclude.conf"
OUT="/etc/dnsmasq.d/v7-direct.conf"
TMP="${OUT}.tmp"
[ -f "$DOMAINS" ] || { echo "ERROR: $DOMAINS missing" >&2; exit 1; }
{
  echo "# Generated by v7-direct-render-dnsmasq"
  echo "interface=wg0"
  echo "listen-address=10.0.0.1"
  echo "bind-dynamic"
  echo "no-resolv"
  echo "strict-order"
  echo "server=77.88.8.8"
  echo "server=77.88.8.1"
  echo "server=1.1.1.1"
  echo "server=8.8.8.8"
  echo "server=/.ru/77.88.8.8"
  echo "server=/.ru/77.88.8.1"
  echo "server=/.xn--p1ai/77.88.8.8"
  echo "server=/.xn--p1ai/77.88.8.1"
  echo "cache-size=10000"
  echo "domain-needed"
  echo "bogus-priv"
  echo "no-hosts"
  echo "log-queries=extra"
  while read -r domain; do
    domain="${domain%%#*}"
    domain="$(printf '%s' "$domain" | xargs)"
    [ -n "$domain" ] || continue
    case "$domain" in
      .*) pattern="$domain" ;;
      *) pattern="$domain" ;;
    esac
    echo "nftset=/$pattern/4#inet#v7_killswitch#v7_direct_dst"
  done < "$DOMAINS"
  if [ -f "$EXCLUDES" ]; then
    while read -r domain; do
      domain="${domain%%#*}"
      domain="$(printf '%s' "$domain" | xargs)"
      [ -n "$domain" ] || continue
      case "$domain" in
        .*) pattern="$domain" ;;
        *) pattern="$domain" ;;
      esac
      echo "nftset=/$pattern/4#inet#v7_killswitch#v7_direct_exclude_dst"
    done < "$EXCLUDES"
  fi
} > "$TMP"
dnsmasq --test --conf-file="$TMP"
mv "$TMP" "$OUT"
echo "V7_DIRECT_RENDER_DNSMASQ=OK"
echo "config=$OUT"
