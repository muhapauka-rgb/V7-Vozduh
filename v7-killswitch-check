#!/usr/bin/env bash
set -euo pipefail

REG="/opt/v7/egress/state/users.registry"
PUBLIC_IF="ens3"
VPN_SUBNET="10.0.0.0/24"
DIRECT_MARK="0x77"
DIRECT_TABLE="70"
DIRECT_RULE_PREF="50"
REBUILD_STATE="${V7_POLICY_REBUILD_STATE:-/opt/v7/egress/state/policy-rebuild.state}"
result="OK"
LIB="/usr/local/lib/v7-egress-lib"
[ -r "$LIB" ] && . "$LIB"
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
  PUBLIC_IF="$V7_PUBLIC_IF"
  VPN_SUBNET="$V7_VPN_SUBNET"
fi

nft_chain_has() {
  local chain="$1"
  local needle="$2"
  local text
  text="$(nft list chain inet v7_killswitch "$chain" 2>/dev/null || true)"
  printf '%s\n' "$text" | grep -Fq "$needle"
}

if [ -r "$REBUILD_STATE" ]; then
  # shellcheck disable=SC1090
  . "$REBUILD_STATE"
  now="$(date +%s)"
  if [ "${active:-0}" = "1" ] && [ "${expires_epoch:-0}" -ge "$now" ] 2>/dev/null; then
    echo "===== V7 KILL SWITCH CHECK ====="
    date -u +"%Y-%m-%dT%H:%M:%SZ"
    echo "vpn_subnet=$VPN_SUBNET"
    echo "public_if=$PUBLIC_IF"
    echo "policy_rebuild=active"
    echo "policy_rebuild_operation=${operation:-unknown}"
    echo "policy_rebuild_updated=${updated:-unknown}"
    echo
    echo "===== RESULT ====="
    echo "V7_KILLSWITCH_CHECK=REBUILDING"
    exit 0
  fi
fi

has_table=0
if nft list table inet v7_killswitch >/dev/null 2>&1; then
  has_table=1
fi

echo "===== V7 KILL SWITCH CHECK ====="
date -u +"%Y-%m-%dT%H:%M:%SZ"
echo "vpn_subnet=$VPN_SUBNET"
echo "public_if=$PUBLIC_IF"

if [ "$has_table" = "1" ]; then
  echo "table=present"
else
  echo "table=missing"
  result="FAIL"
fi

if nft list set inet v7_killswitch v7_client_src >/dev/null 2>&1; then
  echo "client_source_set=present"
else
  echo "client_source_set=missing"
  result="FAIL"
fi

if nft_chain_has forward 'V7 block direct leak to public interface'; then
  echo "direct_leak_drop_rule=present"
else
  echo "direct_leak_drop_rule=missing"
  result="FAIL"
fi

if nft_chain_has forward 'V7 allow explicit direct whitelist'; then
  echo "direct_whitelist_rule=present"
else
  echo "direct_whitelist_rule=missing"
  result="FAIL"
fi

sysctl net.ipv4.ip_forward | sed 's/^/sysctl_/'

if ip -4 rule show pref "$DIRECT_RULE_PREF" 2>/dev/null | grep -q "fwmark $DIRECT_MARK lookup $DIRECT_TABLE"; then
  echo "direct_fwmark_rule=present"
else
  echo "direct_fwmark_rule=missing"
  result="FAIL"
fi

if ip -4 rule show 2>/dev/null | awk '$1 ~ /^[0-9]+:/ {gsub(":", "", $1); if ($1 < 98 && /fwmark 0x77/ && /lookup 70/) found=1} END {exit found ? 0 : 1}'; then
  echo "direct_fwmark_precedes_user_rules=OK"
else
  echo "direct_fwmark_precedes_user_rules=FAIL"
  result="FAIL"
fi

if ip -4 route show table "$DIRECT_TABLE" 2>/dev/null | grep -q "dev $PUBLIC_IF"; then
  echo "direct_route_table=present"
else
  echo "direct_route_table=missing"
  result="FAIL"
fi

if nft_chain_has prerouting 'V7 mark explicit direct whitelist'; then
  echo "direct_mark_rule=present"
else
  echo "direct_mark_rule=missing"
  result="FAIL"
fi

if nft_chain_has dstnat 'V7 capture client UDP DNS'; then
  echo "dns_capture_udp=present"
else
  echo "dns_capture_udp=missing"
  result="FAIL"
fi

if nft_chain_has dstnat 'V7 capture client TCP DNS'; then
  echo "dns_capture_tcp=present"
else
  echo "dns_capture_tcp=missing"
  result="FAIL"
fi


if [ -f "$REG" ]; then
  echo
  echo "===== USER ROUTE CHECK ====="
  while read -r line; do
    [ -z "$line" ] && continue
    case "$line" in \#*) continue ;; esac
    ip="$(v7_kv_get "$line" ip)"
    current="$(v7_kv_get "$line" current)"
    table="$(v7_kv_get "$line" table)"
    enabled="$(v7_kv_get "$line" enabled)"
    [ "${enabled:-0}" = "1" ] || continue
    v7_safe_ip "$ip" || { echo "WARN: unsafe user line skipped"; result="FAIL"; continue; }
    [[ "$table" =~ ^[0-9]+$ ]] || { echo "WARN: unsafe table skipped ip=$ip table=$table"; result="FAIL"; continue; }
    route="$(ip route get 8.8.8.8 from "$ip" iif wg0 2>&1 || true)"
    echo "user=$ip table=$table current=$current route=$route"
    if echo "$route" | grep -q " dev $PUBLIC_IF "; then
      echo "WARN: user=$ip route_get uses public_if=$PUBLIC_IF; kill switch must block direct forward"
    elif echo "$route" | grep -q ' dev '; then
      echo "OK: user=$ip route_get not public"
    else
      echo "WARN: user=$ip route_get inconclusive"
    fi
  done < "$REG"
else
  echo "users_registry=missing"
  result="FAIL"
fi

echo
echo "===== RESULT ====="
echo "V7_KILLSWITCH_CHECK=$result"
[ "$result" = "OK" ]
