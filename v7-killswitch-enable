#!/usr/bin/env bash
set -euo pipefail

VPN_SUBNET="10.0.0.0/24"
PUBLIC_IF="ens3"
PUBLIC_GW="195.2.79.1"
DIRECT_MARK="0x77"
DIRECT_TABLE="70"
EGRESS_IFS=("awg2" "tun0")

command -v nft >/dev/null || { echo "ERROR: nft not found" >&2; exit 1; }
command -v ip >/dev/null || { echo "ERROR: ip not found" >&2; exit 1; }

ip -4 rule del pref 100 2>/dev/null || true
ip -4 route flush table "$DIRECT_TABLE" 2>/dev/null || true
ip -4 route replace default via "$PUBLIC_GW" dev "$PUBLIC_IF" table "$DIRECT_TABLE"
ip -4 rule add pref 100 fwmark "$DIRECT_MARK" lookup "$DIRECT_TABLE"

nft delete table inet v7_killswitch 2>/dev/null || true
nft -f - <<NFT
add table inet v7_killswitch
add set inet v7_killswitch v7_direct_dst { type ipv4_addr; flags interval; timeout 6h; comment "V7 direct whitelist destination IPs"; }
add chain inet v7_killswitch prerouting { type filter hook prerouting priority mangle; policy accept; comment "V7 direct destination marker"; }
add chain inet v7_killswitch dstnat { type nat hook prerouting priority dstnat; policy accept; comment "V7 DNS capture for VPN clients"; }
add chain inet v7_killswitch forward { type filter hook forward priority -50; policy accept; comment "V7 user traffic leak guard"; }
add rule inet v7_killswitch prerouting ip saddr $VPN_SUBNET ip daddr @v7_direct_dst meta mark set $DIRECT_MARK counter comment "V7 mark explicit direct whitelist"
add rule inet v7_killswitch dstnat iifname "wg0" ip saddr $VPN_SUBNET udp dport 53 counter dnat ip to 10.0.0.1 comment "V7 capture client UDP DNS"
add rule inet v7_killswitch dstnat iifname "wg0" ip saddr $VPN_SUBNET tcp dport 53 counter dnat ip to 10.0.0.1 comment "V7 capture client TCP DNS"
add rule inet v7_killswitch forward ip saddr $VPN_SUBNET oifname "${EGRESS_IFS[0]}" counter accept comment "V7 allow users via awg2"
add rule inet v7_killswitch forward ip saddr $VPN_SUBNET oifname "${EGRESS_IFS[1]}" counter accept comment "V7 allow users via tun0"
add rule inet v7_killswitch forward ip saddr $VPN_SUBNET oifname "$PUBLIC_IF" ip daddr @v7_direct_dst counter accept comment "V7 allow explicit direct whitelist"
add rule inet v7_killswitch forward ip saddr $VPN_SUBNET oifname "$PUBLIC_IF" counter drop comment "V7 block direct leak to public interface"
NFT

if command -v v7-audit-log >/dev/null 2>&1; then
  v7-audit-log "killswitch_enable" "killswitch" "public_if=$PUBLIC_IF direct_mark=$DIRECT_MARK direct_table=$DIRECT_TABLE" >/dev/null 2>&1 || true
fi

echo "V7_KILLSWITCH_ENABLE=OK"
echo "direct_mark=$DIRECT_MARK"
echo "direct_table=$DIRECT_TABLE"
ip -4 rule show pref 100
ip -4 route show table "$DIRECT_TABLE"
nft list table inet v7_killswitch
