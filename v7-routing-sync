#!/usr/bin/env bash
set -euo pipefail

if [ "${V7_LOCKED_ROUTING_SYNC:-0}" != "1" ]; then
  export V7_LOCKED_ROUTING_SYNC=1
  exec flock -w "${V7_LOCK_WAIT:-20}" "${V7_ROUTING_LOCK:-/tmp/v7-routing.lock}" "$0" "$@"
fi

REG="${V7_USERS_REGISTRY:-/opt/v7/egress/state/users.registry}"
LIB="/usr/local/lib/v7-egress-lib"
[ -r "$LIB" ] && . "$LIB"
if command -v v7_load_node_env >/dev/null 2>&1; then
  v7_load_node_env
fi

while read -r line; do
  [ -z "$line" ] && continue
  case "$line" in \#*) continue ;; esac

  ip="$(v7_kv_get "$line" ip)"
  current="$(v7_kv_get "$line" current)"
  table="$(v7_kv_get "$line" table)"
  enabled="$(v7_kv_get "$line" enabled)"

  [ "${enabled:-0}" != "1" ] && continue
  v7_safe_ip "$ip" || { echo "skip unsafe ip in registry: $line"; continue; }
  [ -n "$current" ] || { echo "skip empty current egress for $ip"; continue; }
  [[ "$table" =~ ^[0-9]+$ ]] || { echo "skip unsafe table for $ip: $table"; continue; }

  dev=""
  if command -v v7_egress_interface >/dev/null 2>&1; then
    dev="$(v7_egress_interface "$current" || true)"
  fi

  if [ -z "$dev" ]; then
    echo "unknown egress/interface for $ip current=$current"
    continue
  fi

  echo "=== $ip ==="
  pref="$table"
  echo "table=$table pref=$pref dev=$dev"

  ip route replace default dev "$dev" table "$table"

  while ip rule del from "$ip" table "$table" 2>/dev/null; do :; done
  ip rule add pref "$pref" from "$ip" table "$table"

done < "$REG"

echo
echo "=== RULES ==="
ip rule

echo
echo "=== TABLES ==="
awk '{for (i=1;i<=NF;i++) if ($i ~ /^table=/) {sub(/^table=/, "", $i); print $i}}' "$REG" | sort -n -u | while read -r t; do
  echo "--- table $t ---"
  ip route show table "$t"
done
